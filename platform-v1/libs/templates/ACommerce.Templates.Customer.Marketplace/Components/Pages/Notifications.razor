@page "/{slug}/notifications"
@inject ITenantContext Tenant
@inject IDocumentStore Store
@inject AuthSession Auth

@if (!Auth.IsAuthenticated)
{
    <div style="text-align:center;padding:48px 16px;">
        <h2>الإشعارات تَحتاج تَسجيل دُخول</h2>
        <a class="ac-btn ac-btn-primary" href="@($"/{Slug}/login?returnUrl=/{Slug}/notifications")"
           style="display:inline-block;padding:10px 24px;background:var(--ac-primary);color:#fff;border-radius:var(--ac-radius-sm);text-decoration:none;margin-top:12px;">تَسجيل دُخول</a>
    </div>
}
else
{
    <h1>الإشعارات</h1>
    @if (items is null)
    {
        <p class="muted">…</p>
    }
    else if (items.Count == 0)
    {
        <div style="text-align:center;padding:32px 0;color:var(--ac-text-muted);">
            <div style="font-size:48px;">🔔</div>
            <p>لا توجَد إشعارات.</p>
        </div>
    }
    else
    {
        <ul style="list-style:none;padding:0;margin:0;">
            @foreach (var n in items)
            {
                <li style="background:@(n.IsRead ? "var(--ac-surface)" : "color-mix(in srgb, var(--ac-primary) 6%, transparent)");border:1px solid var(--ac-border);border-radius:var(--ac-radius-md);padding:14px;margin-bottom:8px;">
                    <div style="display:flex;justify-content:space-between;align-items:start;gap:8px;">
                        <strong>@n.Title</strong>
                        <span class="ac-muted" style="font-size:11px;">@n.At.ToString("HH:mm")</span>
                    </div>
                    <p style="margin:6px 0 0;color:var(--ac-text-muted);font-size:14px;">@n.Body</p>
                    @if (!string.IsNullOrEmpty(n.RelatedUrl))
                    {
                        <a href="@n.RelatedUrl" style="display:inline-block;margin-top:8px;color:var(--ac-primary);font-size:13px;">فَتح →</a>
                    }
                </li>
            }
        </ul>
    }
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    IReadOnlyList<Notification>? items;

    protected override async Task OnParametersSetAsync()
    {
        if (!Auth.IsAuthenticated) return;
        await using var s = Store.QuerySession(Slug);
        items = await s.Query<Notification>()
            .Where(n => n.UserId == Auth.UserId!.Value)
            .OrderByDescending(n => n.At)
            .Take(50)
            .ToListAsync();
    }
}
