@page "/{slug}/notifications"
@inject IDocumentStore Store
@inject AuthSession Auth

@if (!Auth.IsAuthenticated)
{
    <AcEmptyState Title="الإشعارات تَحتاج تَسجيل دُخول"
                  Icon="bell" />
    <div style="text-align:center;margin-top:12px;">
        <a href="@($"/{Slug}/login?returnUrl=/{Slug}/notifications")"
           style="display:inline-block;padding:10px 24px;background:var(--ac-primary);
                  color:#fff;border-radius:var(--ac-radius-sm);text-decoration:none;">
            تَسجيل دُخول
        </a>
    </div>
}
else
{
    <h1>الإشعارات</h1>

    @if (items is null)        { <AcLoadingState Label="جارٍ التَحميل…" /> }
    else if (items.Count == 0) { <AcEmptyState Title="لا توجَد إشعارات" Icon="bell" /> }
    else
    {
        <div style="display:flex;flex-direction:column;gap:8px;">
            @foreach (var n in items)
            {
                <AcCard Class="@(n.IsRead ? "" : "ac-card-unread")">
                    <ChildContent>
                        <div style="display:flex;justify-content:space-between;align-items:start;gap:8px;">
                            <strong>@n.Title</strong>
                            <span class="ac-muted" style="font-size:11px;">@n.At.ToString("HH:mm")</span>
                        </div>
                        <p style="margin:6px 0 0;color:var(--ac-text-muted);font-size:14px;">@n.Body</p>
                        @if (!string.IsNullOrEmpty(n.RelatedUrl))
                        {
                            <a href="@n.RelatedUrl" style="display:inline-block;margin-top:8px;
                                                           color:var(--ac-primary);font-size:13px;">
                                فَتح →
                            </a>
                        }
                    </ChildContent>
                </AcCard>
            }
        </div>
    }
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    List<Notification>? items;

    protected override async Task OnParametersSetAsync()
    {
        if (!Auth.IsAuthenticated) return;
        await using var s = Store.QuerySession(Slug);
        items = (await s.Query<Notification>()
            .Where(n => n.UserId == Auth.UserId!.Value)
            .OrderByDescending(n => n.At).Take(50).ToListAsync()).ToList();
    }
}
