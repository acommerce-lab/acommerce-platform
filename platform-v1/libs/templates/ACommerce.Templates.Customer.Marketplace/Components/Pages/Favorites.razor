@page "/{slug}/favorites"
@inject IDocumentStore Store
@inject AuthSession Auth

@if (!Auth.IsAuthenticated)
{
    <p class="ac-muted">تَحتاج تَسجيل دُخول.</p>
    <a class="ac-btn ac-btn-primary" href="@($"/{Slug}/login?returnUrl=/{Slug}/favorites")"
       style="display:inline-block;padding:10px 24px;background:var(--ac-primary);
              color:#fff;border-radius:var(--ac-radius-sm);text-decoration:none;">دُخول</a>
}
else
{
    <h1>المُفَضَّلَة</h1>
    @if (items is null) { <p class="ac-muted">جارٍ التَحميل…</p> }
    else if (items.Count == 0) { <p class="empty">لا مُفَضَّلَة بَعد.</p> }
    else
    {
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:12px;">
            @foreach (var l in items)
            {
                <a href="@($"/{Slug}/listings/{l.Id}")"
                   style="background:var(--ac-surface);border:1px solid var(--ac-border);
                          border-radius:var(--ac-radius-md);padding:14px;text-decoration:none;
                          color:var(--ac-text);display:flex;flex-direction:column;gap:6px;">
                    <strong>@l.Title</strong>
                    <span style="color:var(--ac-primary);font-weight:700;">@l.Price.ToString("N0") ريال</span>
                    <span class="ac-muted">@l.City — @l.District</span>
                </a>
            }
        </div>
    }
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    List<Listing>? items;

    protected override async Task OnParametersSetAsync()
    {
        if (!Auth.IsAuthenticated) return;
        await using var s = Store.QuerySession(Slug);
        var favs = await s.Query<Favorite>()
            .Where(f => f.UserId == Auth.UserId!.Value)
            .OrderByDescending(f => f.At).ToListAsync();
        var listingIds = favs.Select(f => f.ListingId).ToList();
        items = (await s.Query<Listing>()
            .Where(l => listingIds.Contains(l.Id) && !l.IsDeleted)
            .ToListAsync()).ToList();
    }
}
