@page "/{slug}/listings/{id:guid}"
@inject IDocumentStore Store
@inject AuthSession Auth

@if (tenant is null)
{
    <p class="ac-muted">المَتجَر غير مَوجود.</p>
}
else if (listing is null)
{
    <p class="ac-muted">جارٍ التَحميل…</p>
}
else if (listing.IsDeleted)
{
    <p>هذا الإعلان مَحذوف.</p>
}
else
{
    <div class="acs-gallery-wrap">
        <AcGallery Images="_noImages"
                   PlaceholderIcon="building" />

        @if (Auth.IsAuthenticated)
        {
            <form method="post" action="@($"/{Slug}/listings/{Id}/favorite")" style="position:absolute;top:8px;inset-inline-end:8px;">
                <input type="hidden" name="return" value="@($"/{Slug}/listings/{Id}")" />
                <button type="submit" class="acs-fav-btn @(IsFav ? "active" : "")"
                        aria-label="@(IsFav ? "أَزِل من المُفَضَّلَة" : "أَضِف للمُفَضَّلَة")">
                    <AcIcon Name="heart" Filled="@IsFav" Size="20" />
                </button>
            </form>
        }
    </div>

    <h1 class="acm-wizard-title">@listing.Title</h1>

    <div style="display:flex;flex-wrap:wrap;gap:12px;align-items:center;margin-bottom:12px;">
        <span style="color:var(--ac-primary);font-weight:700;font-size:20px;">
            @listing.Price.ToString("N0") ريال
        </span>
        <span class="ac-muted" style="display:inline-flex;gap:4px;align-items:center;">
            <AcIcon Name="map-pin" Size="14" /> @listing.City — @listing.District
        </span>
        <AcBadge Variant="info" Text="@CategoryLabel" />
    </div>

    @if (!string.IsNullOrEmpty(listing.Description))
    {
        <AcCard>
            <ChildContent>
                <p style="margin:0;line-height:1.7;">@listing.Description</p>
            </ChildContent>
        </AcCard>
    }

    @if (listing.Attributes is { Count: > 0 })
    {
        <AcCard>
            <ChildContent>
                <h3 style="margin-top:0;">التَفاصيل</h3>
                <AcAttrChipRow Attributes="@AttrSnapshots" IsArabic="true" />
            </ChildContent>
        </AcCard>
    }

    <AcCard>
        <ChildContent>
            <h3 style="margin-top:0;">تَواصُل</h3>
            @if (Auth.IsAuthenticated)
            {
                <form method="post" action="@($"/{Slug}/listings/{Id}/chat")">
                    <AcButton Type="submit" Variant="primary" Size="lg" Class="ac-btn-block"
                              Text="💬 تَواصُل مَع المُعلِن" />
                </form>
            }
            else
            {
                <a href="@($"/{Slug}/login?returnUrl=/{Slug}/listings/{Id}")"
                   class="ac-btn ac-btn-primary ac-btn-lg ac-btn-block"
                   style="display:block;text-align:center;text-decoration:none;background:var(--ac-primary);
                          color:#fff;padding:12px;border-radius:var(--ac-radius-sm);font-weight:600;">
                    دُخول للتَواصُل
                </a>
            }
        </ChildContent>
    </AcCard>

    <p class="ac-muted" style="font-size:12px;margin-top:16px;">
        <AcIcon Name="clock" Size="14" /> نُشِر: @listing.CreatedAt.ToString("yyyy-MM-dd")
        — شوهد: @listing.ViewCount مَرَّة
    </p>
}

@code {
    static readonly string[] _noImages = Array.Empty<string>();
    [Parameter] public string Slug { get; set; } = "";
    [Parameter] public Guid Id { get; set; }
    Listing? listing;
    Tenant? tenant;
    bool IsFav;

    string CategoryLabel => tenant?.Categories.FirstOrDefault(c => c.Slug == listing?.CategorySlug)?.Label ?? "";

    List<ACommerce.Widgets.DynamicAttribute> AttrSnapshots =>
        (listing?.Attributes ?? new()).Select(kv => new ACommerce.Widgets.DynamicAttribute
        {
            Key = kv.Key, Label = kv.Key, LabelAr = kv.Key,
            Type = "text", Value = kv.Value, ShowInCard = true
        }).ToList();

    protected override async Task OnParametersSetAsync()
    {
        await using var g = Store.QuerySession();
        tenant = await g.LoadAsync<Tenant>(Slug);
        if (tenant is null) return;
        await using var t = Store.LightweightSession(Slug);
        listing = await t.Events.AggregateStreamAsync<Listing>(Id);
        if (listing is not null && !listing.IsDeleted)
        {
            t.Events.Append(Id, new ListingViewed(Id, Auth.UserId, DateTime.UtcNow));
            await t.SaveChangesAsync();
            listing.ViewCount++;

            if (Auth.IsAuthenticated)
            {
                var favId = Favorite.MakeId(Auth.UserId!.Value, Id);
                IsFav = (await t.LoadAsync<Favorite>(favId)) is not null;
            }
        }
    }
}
