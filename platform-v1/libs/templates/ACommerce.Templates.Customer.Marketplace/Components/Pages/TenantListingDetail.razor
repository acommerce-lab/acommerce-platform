@page "/{slug}/listings/{id:guid}"
@inject IDocumentStore Store
@inject AuthSession Auth
@inject ACommerce.Templates.Customer.Marketplace.Services.DynamicAttributesService DynAttrs

@*
    صَفحة تَفاصيل الإعلان. بُنية مَنقولَة مِن AcListingDetailsPage
    في القالِب القَديم: AcGallery مَع overlay (Back + Share + Favorite)
    + عُنوان + مَوقِع + meta + قِسم الوَصف + قِسم المُعلِن + قِسم تَواصُل.
    أُضيف قِسم التَبليغ (لم يَكن في القالِب الأَصلي) كَـ <details>
    يَنطَوي افتِراضيّاً ويَفتَح خِيارات السَّبَب.
*@

<div class="acs-page acm-details">
@if (tenant is null)
{
    <AcEmptyState IconName="info" Message="المَتجَر غَير مَوجود." />
}
else if (listing is null)
{
    <AcLoadingState />
}
else if (listing.IsDeleted)
{
    <AcEmptyState IconName="info" Message="هذا الإعلان مَحذوف." />
}
else
{
    @if (Reported == "1")
    {
        <AcAlert Variant="success" Message="شُكراً، تَمّ تَلَقّي بَلاغك وسَيُراجِعه فَريقنا." />
    }

    <div class="acs-gallery-wrap" style="position:relative;">
        <AcGallery Images="_noImages" PlaceholderIcon="building" />

        <div class="acm-details-gallery-actions">
            <a class="acm-details-circle-btn" href="@($"/{Slug}/explore")" aria-label="الرُجوع">
                <AcIcon Name="arrow-right" Size="18" />
            </a>
            <div class="acm-details-gallery-actions-end">
                @if (Auth.IsAuthenticated)
                {
                    <form method="post" action="@($"/{Slug}/listings/{Id}/favorite")" style="margin:0;">
                        <input type="hidden" name="return" value="@($"/{Slug}/listings/{Id}")" />
                        <button type="submit" class="acm-details-circle-btn @(IsFav ? "is-fav" : "")"
                                aria-label="@(IsFav ? "أَزِل مِن المُفَضَّلَة" : "أَضِف لِلمُفَضَّلَة")">
                            <AcIcon Name="heart" Filled="@IsFav" Size="18" />
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>

    <h1 class="acm-details-title">@listing.Title</h1>

    <div class="acm-details-location">
        <AcIcon Name="map-pin" Size="14" />
        <span>@listing.City — @listing.District</span>
    </div>

    <div class="acm-details-meta">
        <span class="acm-details-price">@listing.Price.ToString("N0") ريال</span>
        <AcBadge Variant="info" Text="@CategoryLabel" />
        <span style="color:var(--ac-text-muted);font-size:12px;">
            <AcIcon Name="search" Size="14" /> شوهد @listing.ViewCount مَرَّة
        </span>
    </div>

    @if (!string.IsNullOrEmpty(listing.Description))
    {
        <section class="acm-details-section">
            <h2 class="acm-details-section-title">الوَصف</h2>
            <p class="acm-details-description">@listing.Description</p>
        </section>
    }

    @if (resolvedAttrs is { Count: > 0 })
    {
        <section class="acm-details-section">
            <h2 class="acm-details-section-title">التَفاصيل</h2>
            <dl class="acm-details-attrs">
                @foreach (var a in resolvedAttrs)
                {
                    <div class="acm-details-attr">
                        <dt>@a.Label</dt>
                        <dd>@a.DisplayValue</dd>
                    </div>
                }
            </dl>
        </section>
    }

    <section class="acm-details-section">
        <h2 class="acm-details-section-title">تَواصُل</h2>
        @if (Auth.IsAuthenticated)
        {
            <form method="post" action="@($"/{Slug}/listings/{Id}/chat")" style="margin:0;">
                <button type="submit" class="ac-btn ac-btn-primary ac-btn-lg ac-btn-block">
                    <AcIcon Name="message" Size="18" /> تَواصُل مَع المُعلِن
                </button>
            </form>
        }
        else
        {
            <a href="@($"/{Slug}/login?returnUrl=/{Slug}/listings/{Id}")"
               class="ac-btn ac-btn-primary ac-btn-lg ac-btn-block"
               style="text-decoration:none;text-align:center;">
                دُخول لِلتَواصُل
            </a>
        }
    </section>

    @* قِسم التَبليغ — يَنطَوي بِالـ <details>، يَفتَحه المُتَصَفِّح بِلا JS *@
    <details class="acm-details-report">
        <summary>
            <AcIcon Name="alert-circle" Size="14" />
            <span>تَبليغ عَن هذا الإعلان</span>
        </summary>
        <div class="acm-details-report-body">
            @if (Auth.IsAuthenticated)
            {
                <form method="post" action="@($"/{Slug}/listings/{Id}/report")">
                    <AcField Label="السَّبَب" Required="true">
                        <select name="reason" required class="ac-input">
                            <option value="">— اختَر —</option>
                            <option value="مُكَرَّر">إعلان مُكَرَّر</option>
                            <option value="مُضَلِّل">مَعلومات مُضَلِّلَة</option>
                            <option value="غَير لائِق">مُحتَوى غَير لائِق</option>
                            <option value="نَصَب">اشتِباه نَصَب</option>
                            <option value="آخَر">سَبَب آخَر</option>
                        </select>
                    </AcField>
                    <AcField Label="مَلاحَظَة (اختياريّ)">
                        <textarea name="note" rows="3" maxlength="500" class="ac-input"
                                  style="resize:vertical;" placeholder="تَفاصيل تُساعِد فَريق المُراجَعَة…"></textarea>
                    </AcField>
                    <button type="submit" class="ac-btn ac-btn-danger">
                        <AcIcon Name="send" Size="14" /> إرسال البَلاغ
                    </button>
                </form>
            }
            else
            {
                <p>سَجِّل دُخولك أَوَّلاً لِيَتَمَكَّن فَريقنا مِن مُتابَعَة البَلاغ مَعَك.</p>
                <a class="ac-btn ac-btn-primary" href="@($"/{Slug}/login?returnUrl=/{Slug}/listings/{Id}")">
                    تَسجيل دُخول
                </a>
            }
        </div>
    </details>

    <p class="ac-muted" style="font-size:12px;margin-top:16px;text-align:center;">
        نُشِر: @listing.CreatedAt.ToString("yyyy-MM-dd")
    </p>
}
</div>

@code {
    static readonly string[] _noImages = Array.Empty<string>();
    [Parameter] public string Slug { get; set; } = "";
    [Parameter] public Guid Id { get; set; }
    [SupplyParameterFromQuery(Name = "reported")] public string? Reported { get; set; }
    Listing? listing;
    Tenant? tenant;
    bool IsFav;
    IReadOnlyList<ACommerce.Templates.Customer.Marketplace.Services.ResolvedAttr>? resolvedAttrs;

    string CategoryLabel => tenant?.Categories.FirstOrDefault(c => c.Slug == listing?.CategorySlug)?.Label ?? "";

    protected override async Task OnParametersSetAsync()
    {
        await using var g = Store.QuerySession();
        tenant = await g.LoadAsync<Tenant>(Slug);
        if (tenant is null) return;
        await using var t = Store.LightweightSession(Slug);
        listing = await t.Events.AggregateStreamAsync<Listing>(Id);
        if (listing is not null && !listing.IsDeleted)
        {
            t.Events.Append(Id, new ListingViewed(Id, Auth.UserId, DateTime.UtcNow));
            await t.SaveChangesAsync();
            listing.ViewCount++;

            if (Auth.IsAuthenticated)
            {
                var favId = Favorite.MakeId(Auth.UserId!.Value, Id);
                IsFav = (await t.LoadAsync<Favorite>(favId)) is not null;
            }

            // حُلّ تَسمِيَات السِمات + تَرجَمَة قِيَم SingleSelect/MultiSelect
            // مِن AttributeDefinitions + AttributeValues المُستَورَدَة.
            if (listing.Attributes is { Count: > 0 })
                resolvedAttrs = await DynAttrs.ResolveLabelsAsync(Slug, listing.Attributes);
        }
    }
}
