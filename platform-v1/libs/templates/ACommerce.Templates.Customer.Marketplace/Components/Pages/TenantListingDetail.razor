@page "/{slug}/listings/{id:guid}"
@inject IDocumentStore Store
@inject AuthSession Auth

@*
    لا @rendermode — صَفحَة SSR بَحتَة. زَرّ "تَواصُل" form POST.
    نَستَخدِم Slug من الـ route مُباشَرَةً ولا نَعتَمِد على ITenantContext
    (التي قَد تَفقُد قيمَتها في circuit interactive).
*@

@if (tenant is null)
{
    <p class="ac-muted">المَتجَر غير مَوجود.</p>
}
else if (listing is null)
{
    <p class="ac-muted">جارٍ التَحميل…</p>
}
else if (listing.IsDeleted)
{
    <p>هذا الإعلان مَحذوف.</p>
}
else
{
    <div class="acs-gallery-wrap">
        <div class="acs-gallery-ph" style="font-size:48px;">@CategoryIcon</div>
    </div>

    <h1>@listing.Title</h1>
    <p style="font-size:24px;color:var(--ac-primary);font-weight:700;margin:4px 0;">
        @listing.Price.ToString("N0") ريال
    </p>
    <p class="ac-muted">@listing.City — @listing.District</p>
    <div style="display:inline-block;background:var(--ac-bg-alt);color:var(--ac-text-muted);
                padding:4px 10px;border-radius:999px;font-size:12px;margin:6px 0;">
        @CategoryLabel
    </div>

    @if (!string.IsNullOrEmpty(listing.Description))
    {
        <p style="margin:14px 0;line-height:1.7;">@listing.Description</p>
    }

    @if (listing.Attributes is { Count: > 0 })
    {
        <h3 style="margin-top:20px;">التَفاصيل</h3>
        <ul class="acs-amenity-chips">
            @foreach (var a in listing.Attributes)
            {
                <li class="acs-amenity-chip"><strong>@a.Key:</strong> @a.Value</li>
            }
        </ul>
    }

    <div style="margin:20px 0;padding-top:12px;border-top:1px solid var(--ac-border);">
        @if (Auth.IsAuthenticated)
        {
            <form method="post" action="@($"/{Slug}/listings/{Id}/chat")">
                <button type="submit"
                        style="width:100%;padding:12px;background:var(--ac-primary);
                               color:#fff;border:0;border-radius:var(--ac-radius-sm);
                               cursor:pointer;font-weight:600;font-size:15px;">
                    💬 تَواصُل مَع المُعلِن
                </button>
            </form>
        }
        else
        {
            <a href="@($"/{Slug}/login?returnUrl=/{Slug}/listings/{Id}")"
               style="display:block;text-align:center;padding:12px;
                      background:var(--ac-primary);color:#fff;
                      border-radius:var(--ac-radius-sm);text-decoration:none;font-weight:600;">
                دُخول للتَواصُل
            </a>
        }
    </div>

    <p class="ac-muted" style="font-size:12px;">
        شوهد: @listing.ViewCount مَرَّة — نُشِر: @listing.CreatedAt.ToString("yyyy-MM-dd")
    </p>
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    [Parameter] public Guid Id { get; set; }
    Listing? listing;
    Tenant? tenant;

    string CategoryLabel => tenant?.Categories.FirstOrDefault(c => c.Slug == listing?.CategorySlug)?.Label ?? "";
    string CategoryIcon  => tenant?.Categories.FirstOrDefault(c => c.Slug == listing?.CategorySlug)?.Icon ?? "🏷️";

    protected override async Task OnParametersSetAsync()
    {
        // نَجلب الـ tenant مُباشَرَةً مِن slug — لا نَعتَمِد على ITenantContext
        await using var g = Store.QuerySession();
        tenant = await g.LoadAsync<Tenant>(Slug);
        if (tenant is null) return;

        await using var t = Store.LightweightSession(Slug);
        listing = await t.Events.AggregateStreamAsync<Listing>(Id);
        if (listing is not null && !listing.IsDeleted)
        {
            t.Events.Append(Id, new ListingViewed(Id, Auth.UserId, DateTime.UtcNow));
            await t.SaveChangesAsync();
            listing.ViewCount++;
        }
    }
}
