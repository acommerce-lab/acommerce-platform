@page "/{slug}"
@inject IDocumentStore Store
@inject AuthSession Auth

@if (loaded is null)
{
    <p class="ac-muted">جارٍ التَحميل…</p>
}
else
{
    <section style="background-color: var(--ac-primary);
                    background-image: linear-gradient(135deg, var(--ac-primary), var(--ac-primary-hover));
                    color:#fff;padding:24px 16px;border-radius:var(--ac-radius-lg);margin-bottom:16px;">
        <h1 class="hero-title">@loaded.Name</h1>
        <p style="margin:0;opacity:.92;">@loaded.TagLine</p>
        <p style="margin:4px 0 0;opacity:.85;font-size:13px;">
            <AcIcon Name="map-pin" Size="14" /> @loaded.City
        </p>
    </section>

    <h2 style="margin-top:24px;">الفِئات</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:8px;margin-bottom:24px;">
        @foreach (var c in loaded.Categories)
        {
            <a href="@($"/{Slug}/explore?category={c.Slug}")"
               class="acs-cat-pick" style="text-decoration:none;color:var(--ac-text);">
                <span style="font-size:32px;">@c.Icon</span>
                <strong style="font-size:14px;">@c.Label</strong>
                <span class="ac-muted" style="font-size:12px;">@CountFor(c.Slug) إعلان</span>
            </a>
        }
    </div>

    <h2>أَحدَث الإعلانات</h2>
    @if (latest is { Count: > 0 })
    {
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px;">
            @foreach (var l in latest)
            {
                <a href="/@Slug/listings/@l.Id" style="text-decoration:none;color:inherit;display:block;"><AcSpaceCard Title="@l.Title"
                             ImageUrl="@null"
                             Location="@($"{l.City} — {l.District}")"
                             PriceLabel="@($"{l.Price:N0} ريال")"
                             Ribbon="@(latest.IndexOf(l) == 0 ? "جَديد" : null)"
                             ShowFavorite="@Auth.IsAuthenticated"
                             IsFavorite="@(favIds.Contains(l.Id))"
                             AddFavoriteAriaLabel="أَضِف للمُفَضَّلَة"
                             RemoveFavoriteAriaLabel="أَزِل من المُفَضَّلَة"
                             OnOpen="@(() => Open(l.Id))" /></a>
            }
        </div>
    }
    else
    {
        <p class="empty">لا إعلانات بَعد.</p>
    }
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    [Inject] NavigationManager Nav { get; set; } = default!;

    Tenant? loaded;
    List<Listing>? latest;
    Dictionary<string, int> counts = new();
    HashSet<Guid> favIds = new();

    void Open(Guid id) => Nav.NavigateTo($"/{Slug}/listings/{id}");

    protected override async Task OnParametersSetAsync()
    {
        await using var g = Store.QuerySession();
        loaded = await g.LoadAsync<Tenant>(Slug);
        if (loaded is null) return;

        await using var tq = Store.QuerySession(Slug);
        latest = (await tq.Query<Listing>()
            .Where(x => !x.IsDeleted)
            .OrderByDescending(x => x.CreatedAt)
            .Take(8).ToListAsync()).ToList();

        var all = await tq.Query<Listing>().Where(x => !x.IsDeleted)
            .Select(x => x.CategorySlug).ToListAsync();
        counts = all.GroupBy(s => s).ToDictionary(g => g.Key, g => g.Count());

        if (Auth.IsAuthenticated)
        {
            var favs = await tq.Query<Favorite>()
                .Where(f => f.UserId == Auth.UserId!.Value).ToListAsync();
            favIds = favs.Select(f => f.ListingId).ToHashSet();
        }
    }

    int CountFor(string s) => counts.TryGetValue(s, out var n) ? n : 0;
}
