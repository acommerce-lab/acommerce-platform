@page "/{slug}"
@inject IDocumentStore Store
@inject AuthSession Auth
@inject ITenantContext Tenant
@inject NavigationManager Nav

@*
    صَفحة الـ tenant الرَئيسيّة. تَتَّبع بُنية Home.razor مِن القالَب
    القَديم (AcHeroBanner + AcSearchBox + AcCategoryTile + AcSpaceCard
    + AcCtaCard + AcActionCard) ولكن مُرَكَّبَة يَدَويّاً (دون
    AcMarketplaceHomePage) لأَنّه يَعتَمِد عَلى ITemplateEngine الَّذي لا
    يَعمَل في platform-v1.
*@

<div class="acs-page acm-home">
    @if (loaded is null)
    {
        <AcLoadingState />
    }
    else
    {
        <AcHeroBanner Title="@($"ابحَث في {loaded.Name}")"
                      Subtitle="@loaded.TagLine">
            <LogoContent>
                <div style="display:inline-flex;align-items:center;gap:8px;color:#fff;">
                    <span aria-hidden="true"
                          style="display:inline-flex;width:36px;height:36px;align-items:center;justify-content:center;
                                 background:rgba(255,255,255,.18);border-radius:8px;">
                        <AcIcon Name="home" Size="20" />
                    </span>
                    <span style="font-size:1.1rem;font-weight:700;color:#fff;">@loaded.Name</span>
                </div>
            </LogoContent>
            <ChildContent>
                <form method="get" action="@($"/{Slug}/explore")" role="search" class="ac-search">
                    <span class="ac-search-icon" aria-hidden="true">
                        <AcIcon Name="search" Size="18" />
                    </span>
                    <input type="search" name="q" class="ac-search-input"
                           placeholder="@($"ابحَث في {loaded.Name}…")"
                           autocomplete="off" inputmode="search" />
                    <button type="submit" class="ac-search-submit" aria-label="بَحث">
                        <AcIcon Name="arrow-left" Size="18" />
                    </button>
                </form>
            </ChildContent>
        </AcHeroBanner>

        @if (loaded.Categories is { Count: > 0 })
        {
            <AcSectionHeader Title="الفِئات" />
            <AcHScroll>
                @foreach (var c in loaded.Categories)
                {
                    <AcCategoryTile Label="@c.Label"
                                    Icon="@c.Icon"
                                    OnClick="@(() => Nav.NavigateTo($"/{Slug}/explore?category={Uri.EscapeDataString(c.Slug)}"))" />
                }
            </AcHScroll>
        }

        <AcCtaCard Title="عِندَك ما تَعرِضه؟"
                   Subtitle="أَضِف إعلانك واصِل لِلمُهتَمّين بِسُرعَة"
                   IconName="house-add"
                   Variant="surface"
                   OnClick="@(() => Nav.NavigateTo(Auth.IsAuthenticated ? $"/{Slug}/me/edit" : $"/{Slug}/login"))" />

        @if (featured is { Count: > 0 })
        {
            <AcSectionHeader Title="مُمَيَّز"
                             ActionLabel="عَرض الكلّ"
                             OnAction="@(() => Nav.NavigateTo($"/{Slug}/explore"))" />
            <AcHScroll Class="acm-home-rail">
                @foreach (var l in featured)
                {
                    <div class="acm-home-rail-item">
                        <AcSpaceCard Title="@l.Title"
                                     ImageUrl="@null"
                                     Location="@($"{l.City} — {l.District}")"
                                     PriceLabel="@($"{l.Price:N0} ريال")"
                                     Ribbon="مُمَيَّز"
                                     ShowFavorite="@Auth.IsAuthenticated"
                                     IsFavorite="@favIds.Contains(l.Id)"
                                     AddFavoriteAriaLabel="أَضِف لِلمُفَضَّلَة"
                                     RemoveFavoriteAriaLabel="أَزِل مِن المُفَضَّلَة"
                                     OnOpen="@(() => Open(l.Id))"
                                     OnToggleFavorite="@(on => ToggleFav(l.Id, on))" />
                    </div>
                }
            </AcHScroll>
        }

        @if (latest is { Count: > 0 })
        {
            <AcSectionHeader Title="أُضيفَ حَديثاً"
                             ActionLabel="عَرض الكلّ"
                             OnAction="@(() => Nav.NavigateTo($"/{Slug}/explore"))" />
            <div class="acm-home-grid">
                @foreach (var l in latest)
                {
                    <AcSpaceCard Title="@l.Title"
                                 ImageUrl="@null"
                                 Location="@($"{l.City} — {l.District}")"
                                 PriceLabel="@($"{l.Price:N0} ريال")"
                                 Ribbon="جَديد"
                                 ShowFavorite="@Auth.IsAuthenticated"
                                 IsFavorite="@favIds.Contains(l.Id)"
                                 AddFavoriteAriaLabel="أَضِف لِلمُفَضَّلَة"
                                 RemoveFavoriteAriaLabel="أَزِل مِن المُفَضَّلَة"
                                 OnOpen="@(() => Open(l.Id))"
                                 OnToggleFavorite="@(on => ToggleFav(l.Id, on))" />
                }
            </div>
        }

        <section class="acm-home-actions">
            <AcActionCard Label="استِكشاف"
                          IconName="search-heart"
                          Variant="primary"
                          OnClick="@(() => Nav.NavigateTo($"/{Slug}/explore"))" />
            <AcActionCard Label="@(Auth.IsAuthenticated ? "حِسابي" : "تَسجيل دُخول")"
                          IconName="user"
                          Variant="surface"
                          OnClick="@(() => Nav.NavigateTo(Auth.IsAuthenticated ? $"/{Slug}/me" : $"/{Slug}/login"))" />
        </section>

        @if ((featured is null || featured.Count == 0) && (latest is null || latest.Count == 0))
        {
            <AcEmptyState IconName="building" Message="لا إعلانات بَعد." />
        }
    }
</div>

@code {
    [Parameter] public string Slug { get; set; } = "";

    Tenant? loaded;
    List<Listing>? latest;
    List<Listing>? featured;
    HashSet<Guid> favIds = new();

    void Open(Guid id) => Nav.NavigateTo($"/{Slug}/listings/{id}");

    async Task ToggleFav(Guid listingId, bool on)
    {
        // التَنفيذ الفِعليّ يَجري عَبر form POST في صَفحَة التَفاصيل؛ هُنا
        // نُحَدِّث الـ UI تَفاؤُليّاً ليَنعَكِس التَغيير فَوراً قَبل refresh.
        if (on) favIds.Add(listingId); else favIds.Remove(listingId);
        await Task.CompletedTask;
        StateHasChanged();
    }

    protected override async Task OnParametersSetAsync()
    {
        await using var g = Store.QuerySession();
        loaded = await g.LoadAsync<Tenant>(Slug);
        if (loaded is null) return;

        await using var tq = Store.QuerySession(Slug);

        latest = (await tq.Query<Listing>()
            .Where(x => !x.IsDeleted)
            .OrderByDescending(x => x.CreatedAt)
            .Take(6).ToListAsync()).ToList();

        // "مُمَيَّز" حاليّاً = أَوّل 4 إعلانات حَسَب السِعر الأعلى. سَيُستَبدَل
        // لاحِقاً بِحَقل IsFeatured في Listing.
        featured = (await tq.Query<Listing>()
            .Where(x => !x.IsDeleted)
            .OrderByDescending(x => x.Price)
            .Take(4).ToListAsync()).ToList();

        if (Auth.IsAuthenticated)
        {
            var favs = await tq.Query<Favorite>()
                .Where(f => f.UserId == Auth.UserId!.Value).ToListAsync();
            favIds = favs.Select(f => f.ListingId).ToHashSet();
        }
    }
}
