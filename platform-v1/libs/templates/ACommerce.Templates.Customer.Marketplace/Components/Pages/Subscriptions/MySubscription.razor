@page "/my-subscription"
@attribute [Authorize]
@inject ITemplateEngine Engine
@inject NavigationManager Nav
@inject L L

<PageTitle>@($"{L[TemplateStrings.MeStatsSubscription]} — {L[TemplateStrings.AppName]}")</PageTitle>

<div class="acs-page acs-my-subscription">
    <div style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
        <h1 class="acm-wizard-title" style="margin:0;">@(L[TemplateStrings.MySubActiveHeading])</h1>
        @* اختصار دائم إلى الخطط — كان مدفوناً تحت بطاقات الفواتير، الآن
           ظاهر فوراً سواء وُجد اشتراك أم لا. *@
        <AcButton Variant="outline-primary" Text="@(L[TemplateStrings.PlansBrowseAction])"
                  OnClick="@(() => Nav.NavigateTo("/plans"))" />
    </div>
    @if (_loading) { <AcLoadingState /> }
    else if (_sub is null)
    {
        <AcCard>
            <ChildContent>
                <div style="text-align:center; padding:16px 0;">
                    <AcIcon Name="package" Size="48" />
                    <h3 style="margin:12px 0 4px;">@(L[TemplateStrings.MySubNoneActive])</h3>
                    <p style="color:var(--ac-text-muted); margin:0 0 16px;">
                        @(L[TemplateStrings.MysubSubscribeToPublish])
                    </p>
                    <AcButton Variant="primary" Class="ac-btn-block" Text="@(L[TemplateStrings.MySubPickPlan])"
                              OnClick="@(() => Nav.NavigateTo("/plans"))" />
                </div>
            </ChildContent>
        </AcCard>
    }
    else
    {
        <AcCard>
            <ChildContent>
                <div style="display:flex; justify-content:space-between; align-items:center;">
                    <div>
                        <h2 style="margin:0;">@(string.Format(L[TemplateStrings.MysubPlanLabelFormat], _sub.PlanName))</h2>
                        <small>@(string.Format(L[TemplateStrings.MysubExpiresFormat], _sub.Status, _sub.EndDate.ToString("yyyy-MM-dd")))</small>
                    </div>
                    <AcBadge Variant="@(_sub.DaysRemaining <= 7 ? "warning" : "success")"
                             Text="@(string.Format(L[TemplateStrings.MysubDaysRemainingFormat], _sub.DaysRemaining))" />
                </div>

                @if (_sub.DaysRemaining <= 7)
                {
                    <AcAlert Variant="warning" Message="@(L[TemplateStrings.MySubExpiringSoon])" />
                }

                <div class="acm-checkout-line"><span>@(L[TemplateStrings.MySubStartLabel])</span><strong>@_sub.StartDate.ToString("yyyy-MM-dd")</strong></div>
                <div class="acm-checkout-line"><span>@(L[TemplateStrings.MySubEndLabel])</span><strong>@_sub.EndDate.ToString("yyyy-MM-dd")</strong></div>
            </ChildContent>
        </AcCard>

        <h3 style="margin-top:16px;">@(L[TemplateStrings.MySubUsageHeading])</h3>
        <div class="acm-home-grid">
            <AcCard>
                <ChildContent>
                    <strong>@(L[TemplateStrings.MySubUsageListings])</strong>
                    <div class="acm-checkout-line"><span>@(L[TemplateStrings.CommonUsedLabel])</span><strong>@_sub.ListingsUsed / @_sub.ListingsLimit</strong></div>
                    <div class="acs-progress"><div class="acs-progress-bar" style="width:@(Pct(_sub.ListingsUsed, _sub.ListingsLimit))%"></div></div>
                </ChildContent>
            </AcCard>
            <AcCard>
                <ChildContent>
                    <strong>@(L[TemplateStrings.MySubUsageFeatured])</strong>
                    <div class="acm-checkout-line"><span>@(L[TemplateStrings.CommonUsedLabel])</span><strong>@_sub.FeaturedUsed / @_sub.FeaturedLimit</strong></div>
                    <div class="acs-progress"><div class="acs-progress-bar" style="width:@(Pct(_sub.FeaturedUsed, _sub.FeaturedLimit))%"></div></div>
                </ChildContent>
            </AcCard>
            <AcCard>
                <ChildContent>
                    <strong>@(L[TemplateStrings.MysubImagesPerListing])</strong>
                    <div class="acm-checkout-line"><span>@(L[TemplateStrings.CommonLimitLabel])</span><strong>@_sub.ImagesPerListing</strong></div>
                </ChildContent>
            </AcCard>
        </div>

        <h3 style="margin-top:16px;">@(L[TemplateStrings.MySubPlanFeatures])</h3>
        <AcCard>
            <ChildContent>
                <ul style="list-style:none; padding:0; margin:0;">
                    @foreach (var f in _sub.Features)
                    {
                        <li style="display:flex; gap:8px; padding:6px 0; align-items:center;">
                            <AcIcon Name="check-circle" Size="16" />
                            <span>@f</span>
                        </li>
                    }
                </ul>
            </ChildContent>
        </AcCard>

        <h3 style="margin-top:16px;">@(L[TemplateStrings.MySubInvoices])</h3>
        @if (_invoices.Count == 0) { <AcEmptyState IconName="receipt" Message="@(L[TemplateStrings.MySubNoInvoices])" /> }
        else
        {
            <AcCard>
                <ChildContent>
                    @foreach (var i in _invoices)
                    {
                        <div class="acm-checkout-line">
                            <span>@i.Id — @i.Date.ToString("yyyy-MM-dd")</span>
                            <strong>@i.Amount @(L[TemplateStrings.CommonCurrencyShort])</strong>
                            <AcBadge Variant="@(i.Status == "paid" ? "success" : "warning")" Text="@i.Status" />
                        </div>
                    }
                </ChildContent>
            </AcCard>
        }

        <div style="display:flex; gap:8px; margin-top:12px;">
            <AcButton Variant="primary" Text="@(L[TemplateStrings.MySubRenew])" OnClick="@Renew" />
            <AcButton Variant="outline-primary" Text="@(L[TemplateStrings.MySubChange])" OnClick="@ChangePlan" />
            <AcButton Variant="ghost" Text="@(L[TemplateStrings.MySubCancelSub])" OnClick="@CancelSub" />
        </div>
    }
</div>

@code {
    private SubDto? _sub;
    private List<InvoiceDto> _invoices = new();
    private bool _loading = true;

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (!first) return;
        // OAM-pure: subscription.get_active op (kit-defined) عَبر engine.
        // الشَكل الكامِل لا يَتَّسِع لِـ ISubscriptionsStore.Active (Guid Id فَقَط)
        // فنَستَعمِل DTO مَحَلّيّ يَلتَقِط الـ wire shape كامِلاً.
        var s = await Engine.ExecuteAsync<SubDto>(SubscriptionsOps.GetActive());
        _sub = s.Data;

        var inv = await Engine.ExecuteAsync<List<InvoiceDto>>(SubscriptionsOps.ListInvoices());
        _invoices = inv.Data ?? new();

        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private static int Pct(int used, int limit) => limit > 0 ? Math.Min(100, used * 100 / limit) : 0;

    private void Renew()     => Nav.NavigateTo(
        $"/subscribe?type=plan&id={_sub!.PlanId}&amount={_sub.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)}");
    private void ChangePlan() => Nav.NavigateTo("/plans");
    private void CancelSub() { }

    private sealed record SubDto(string Id, string PlanId, string PlanName, string Status,
        DateTime StartDate, DateTime EndDate, int DaysRemaining,
        int ListingsUsed, int ListingsLimit, int FeaturedUsed, int FeaturedLimit,
        int ImagesPerListing, decimal Price = 0,
        IReadOnlyList<string>? Features = null)
    {
        public IReadOnlyList<string> Features { get; init; } = Features ?? Array.Empty<string>();
    }

    private sealed record InvoiceDto(string Id, string PlanId, decimal Amount, DateTime Date, string Status);
}
