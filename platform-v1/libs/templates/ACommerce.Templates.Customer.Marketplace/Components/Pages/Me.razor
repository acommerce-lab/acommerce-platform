@page "/{slug}/me"
@inject IDocumentStore Store
@inject ITenantContext Tenant
@inject AuthSession Auth
@inject NavigationManager Nav

@*
    صَفحة "حِسابي". تَتَّبع بُنية Me.razor مِن القالَب القَديم
    (avatar card + stats + action grid + sign-out).
*@

<div class="acs-page acs-profile-page">
    <h1 class="acm-wizard-title">حِسابي</h1>

    @if (!Auth.IsAuthenticated)
    {
        <AcEmptyState IconName="user"
                      Title="سَجِّل دُخولك أَوَّلاً"
                      Message="بَعد الدُخول تَستَطيع تَصَفُّح إعلاناتك ومُحادَثاتك."
                      ActionLabel="تَسجيل دُخول"
                      ActionHref="@($"/{Slug}/login")" />
    }
    else
    {
        <AcCard>
            <ChildContent>
                <div class="acm-details-owner">
                    <span class="acm-details-owner-avatar" style="width:56px;height:56px;">
                        <AcIcon Name="user" Size="24" />
                    </span>
                    <div class="acm-details-owner-info" style="flex:1;">
                        <h3 style="margin:0;">@(Auth.UserName ?? "عُضو جَديد")</h3>
                        <span style="color:var(--ac-text-muted);font-size:13px;">
                            مُعَرِّف: @(Auth.UserId?.ToString()![..8] ?? "—")
                        </span>
                    </div>
                    <a class="ac-btn ac-btn-outline-primary" href="@($"/{Slug}/me/edit")">تَعديل</a>
                </div>
            </ChildContent>
        </AcCard>

        <div class="acm-home-grid" style="margin-top:12px;">
            <AcCard><ChildContent>
                <strong style="font-size:1.5rem;">@favoritesCount</strong>
                <div style="color:var(--ac-text-muted);">المُفَضَّلَة</div>
            </ChildContent></AcCard>
            <AcCard><ChildContent>
                <strong style="font-size:1.5rem;">@conversationsCount</strong>
                <div style="color:var(--ac-text-muted);">المُحادَثات</div>
            </ChildContent></AcCard>
            <AcCard><ChildContent>
                <strong style="font-size:1.5rem;">@notificationsCount</strong>
                <div style="color:var(--ac-text-muted);">الإشعارات</div>
            </ChildContent></AcCard>
        </div>

        <div class="acm-home-actions" style="margin-top:12px;">
            <AcActionCard Label="الباقات"      IconName="package"       Variant="primary" Href="@($"/{Slug}/plans")" />
            <AcActionCard Label="المُفَضَّلَة" IconName="heart"         Variant="surface" Href="@($"/{Slug}/favorites")" />
            <AcActionCard Label="المُحادَثات"   IconName="message"       Variant="surface" Href="@($"/{Slug}/chats")" />
            <AcActionCard Label="الإشعارات"     IconName="bell"          Variant="surface" Href="@($"/{Slug}/notifications")" />
            <AcActionCard Label="الشَكاوى والدَّعم" IconName="alert-circle"  Variant="surface" Href="@($"/{Slug}/support")" />
            <AcActionCard Label="إعدادات الحِساب"   IconName="settings"      Variant="surface" Href="@($"/{Slug}/me/edit")" />
        </div>

        <div style="margin-top:16px;">
            <form method="post" action="@($"/{Slug}/auth/logout")" style="margin:0;">
                <button type="submit" class="ac-btn ac-btn-ghost"
                        style="color:var(--ac-danger);width:100%;">
                    <AcIcon Name="log-out" Size="18" /> تَسجيل خُروج
                </button>
            </form>
        </div>

        <div style="margin-top:24px;text-align:center;color:var(--ac-text-muted);font-size:12px;">
            @(loadedTenant?.Name) · platform-v1
        </div>
    }
</div>

@code {
    [Parameter] public string Slug { get; set; } = "";

    Tenant? loadedTenant;
    int favoritesCount;
    int conversationsCount;
    int notificationsCount;

    protected override async Task OnParametersSetAsync()
    {
        await using var g = Store.QuerySession();
        loadedTenant = await g.LoadAsync<Tenant>(Slug);

        if (!Auth.IsAuthenticated || Auth.UserId is null) return;

        await using var s = Store.QuerySession(Slug);
        favoritesCount       = await s.Query<Favorite>().CountAsync(f => f.UserId == Auth.UserId.Value);
        conversationsCount   = await s.Query<Conversation>().CountAsync(c => c.OwnerId == Auth.UserId.Value || c.PartnerId == Auth.UserId.Value);
        notificationsCount   = await s.Query<Notification>().CountAsync(n => n.UserId == Auth.UserId.Value && !n.IsRead);
    }
}
