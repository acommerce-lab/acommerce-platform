@page "/{slug}/explore"
@inject IDocumentStore Store
@inject AuthSession Auth

@*
    صَفحة استِكشاف الإعلانات. بُنية مَنقولَة مِن
    AcListingExplorePage.razor في القالِب القَديم:
      ├─ Filter bar: AcHScroll مِن chips (الكلّ + الفِئات) + زِرّ sliders
      ├─ Sort bar: عَدد النَتائِج + قائِمَة تَرتيب
      ├─ Filter modal (sliders): مَدينَة/حَيّ + سِعر أَدنى/أَعلى
      └─ شَبَكَة بِطاقات AcSpaceCard

    لأنّ الصَفحَة SSR، الـ "modal" مُنَفَّذ كَـ <details> مَفتوح
    بِـ ?filters=open في الـ URL — يَتَوَلّى المُتَصَفِّح فَتح/إغلاق
    العُنصُر بِلا JavaScript.
*@

<div class="acs-page acm-explore">
@if (tenant is null)
{
    <AcLoadingState />
}
else
{
    <h1 class="acm-explore-title">@($"كلّ إعلانات {tenant.Name}")</h1>

    @* Filter bar: شَجَرَة kinds + leaves + sliders button — مُطابِق
       لِبِنية AcTaxonomyChips الأَصلِيَّة. *@
    <div class="acm-explore-filterbar">
        <div class="acm-explore-chips">
            <TaxonomyChips Slug="@Slug"
                           Categories="tenant.Categories"
                           ActiveKind="@Kind"
                           ActiveCategory="@Category" />
        </div>
        <a class="acm-explore-filterbtn" href="@FilterToggleHref" aria-label="الفَلاتِر">
            <AcIcon Name="sliders" Size="18" />
        </a>
    </div>

    @* Sort bar: count + sort dropdown *@
    <div class="acm-explore-sortbar">
        <span class="acm-explore-count">@(items?.Count ?? 0) نَتيجَة</span>
        <div class="acm-explore-sortbar-right">
            <form method="get" action="@($"/{Slug}/explore")" class="acm-sort-form">
                @PreserveHidden(except: "sort")
                <select name="sort" class="ac-input acm-filter-select" aria-label="تَرتيب"
                        onchange="this.form.submit()">
                    <option value="newest"     selected="@(string.IsNullOrEmpty(Sort) || Sort == "newest")">الأَحدَث</option>
                    <option value="price_asc"  selected="@(Sort == "price_asc")">السِعر — تَصاعُديّ</option>
                    <option value="price_desc" selected="@(Sort == "price_desc")">السِعر — تَنازُليّ</option>
                </select>
            </form>
        </div>
    </div>

    @* Filter modal — مُطابِق بِنيَة AcModal الأَصلِيَّة (backdrop +
       ac-modal-header + ac-modal-body + ac-modal-footer). يُفتَح بِـ
       ?filters=open. الـ backdrop رابِط يُغلِق الـ modal. *@
    @if (Filters == "open")
    {
        var closeHref = $"/{Slug}/explore" + Preserve(except: "filters");
        <a class="ac-modal-backdrop" href="@closeHref" aria-label="إغلاق"></a>
        <div class="ac-modal acm-explore-filter-modal" role="dialog" aria-modal="true">
            <div class="ac-modal-header">
                <h3 class="ac-modal-title">الفَلاتِر</h3>
                <div class="ac-modal-header-actions">
                    <a class="ac-modal-close" href="@closeHref" aria-label="إغلاق">
                        <AcIcon Name="x" Size="20" />
                    </a>
                </div>
            </div>
            @* form يَحفَظ السِياق الحاليّ (category/kind/sort) كَ hidden inputs
               حَتّى لا تُفقَد عِنْدَ تَطبيق الفَلتَر. الـ inputs المَرئيَّة
               (district/min/max/q) تَملِك أَسماء فَريدَة فلا تَكرار. *@
            <form method="get" action="@($"/{Slug}/explore")">
                @if (!string.IsNullOrEmpty(Category)) { <input type="hidden" name="category" value="@Category" /> }
                @if (!string.IsNullOrEmpty(Kind))     { <input type="hidden" name="kind"     value="@Kind" /> }
                @if (!string.IsNullOrEmpty(Sort))     { <input type="hidden" name="sort"     value="@Sort" /> }

                <div class="ac-modal-body">
                    <section class="acm-explore-filtersec">
                        <h4 class="acm-explore-filtersec-title">المَوقِع</h4>
                        <select name="district" class="ac-input">
                            <option value="">الكلّ</option>
                            @foreach (var d in districts)
                            {
                                <option value="@d" selected="@(District == d)">@d</option>
                            }
                        </select>
                    </section>

                    <section class="acm-explore-filtersec">
                        <h4 class="acm-explore-filtersec-title">السِعر</h4>
                        <div class="acm-explore-pricerange">
                            <input type="number" name="min" class="ac-input" min="0" step="1"
                                   inputmode="numeric"
                                   value="@(MinPrice?.ToString("0", System.Globalization.CultureInfo.InvariantCulture) ?? "")"
                                   placeholder="مِن" />
                            <span>—</span>
                            <input type="number" name="max" class="ac-input" min="0" step="1"
                                   inputmode="numeric"
                                   value="@(MaxPrice?.ToString("0", System.Globalization.CultureInfo.InvariantCulture) ?? "")"
                                   placeholder="إلى" />
                        </div>
                    </section>

                    <section class="acm-explore-filtersec">
                        <h4 class="acm-explore-filtersec-title">البَحث</h4>
                        <input type="search" name="q" class="ac-input"
                               value="@(Query ?? "")"
                               placeholder="كَلِمَة مِفتاحيّة…" />
                    </section>
                </div>

                <div class="ac-modal-footer">
                    <a class="ac-btn ac-btn-ghost" href="@($"/{Slug}/explore")">إعادَة ضَبط</a>
                    <button type="submit" class="ac-btn ac-btn-primary">تَطبيق</button>
                </div>
            </form>
        </div>
    }

    @if (items is null)
    {
        <AcLoadingState Message="جارٍ التَحميل…" />
    }
    else if (items.Count == 0)
    {
        <AcEmptyState IconName="building"
                      Title="لا إعلانات في هذه الفِئَة"
                      Message="جَرِّب فِئَة أُخرى أو غَيِّر البَحث."
                      ActionLabel="إعادَة ضَبط الفَلاتِر"
                      ActionHref="@($"/{Slug}/explore")" />
    }
    else
    {
        <div class="acm-explore-grid">
            @foreach (var l in items)
            {
                <AcSpaceCard Title="@l.Title"
                             Href="@($"/{Slug}/listings/{l.Id}")"
                             Location="@($"{l.City} — {l.District}")"
                             PriceLabel="@($"{l.Price:N0} ريال")"
                             ShowFavorite="@Auth.IsAuthenticated"
                             IsFavorite="@favIds.Contains(l.Id)"
                             FavoriteFormAction="@($"/{Slug}/listings/{l.Id}/favorite")"
                             FavoriteFormReturn="@($"/{Slug}/explore")"
                             AddFavoriteAriaLabel="أَضِف لِلمُفَضَّلَة"
                             RemoveFavoriteAriaLabel="أَزِل مِن المُفَضَّلَة" />
            }
        </div>
    }
}
</div>

@code {
    [Parameter] public string Slug { get; set; } = "";
    [SupplyParameterFromQuery(Name = "category")] public string? Category { get; set; }
    [SupplyParameterFromQuery(Name = "q")]        public string? Query    { get; set; }
    [SupplyParameterFromQuery(Name = "sort")]     public string? Sort     { get; set; }
    [SupplyParameterFromQuery(Name = "min")]      public decimal? MinPrice { get; set; }
    [SupplyParameterFromQuery(Name = "max")]      public decimal? MaxPrice { get; set; }
    [SupplyParameterFromQuery(Name = "district")] public string? District { get; set; }
    [SupplyParameterFromQuery(Name = "filters")]  public string? Filters  { get; set; }
    [SupplyParameterFromQuery(Name = "kind")]     public string? Kind     { get; set; }

    Tenant? tenant;
    List<Listing>? items;
    List<string> districts = new();
    HashSet<Guid> favIds = new();

    string FilterToggleHref =>
        $"/{Slug}/explore" + Preserve(set: Filters == "open" ? null : ("filters", "open"),
                                       except: "filters");

    /// <summary>يَبني query-string يَحفَظ القِيَم الحاليّة مَع إمكان حَذف
    /// مِفتاح أو إضافَة جَديد. النَّتيجَة تَبدَأ بِـ ? لَو غَير فارِغَة.</summary>
    string Preserve(string? except = null, (string Key, string Value)? set = null, string? prefix = null)
    {
        var pairs = new List<KeyValuePair<string, string?>>
        {
            new("category", Category),
            new("q",        Query),
            new("sort",     Sort),
            new("min",      MinPrice?.ToString()),
            new("max",      MaxPrice?.ToString()),
            new("district", District),
            new("filters",  Filters),
        };
        var parts = new List<string>();
        foreach (var p in pairs)
        {
            if (p.Key == except) continue;
            if (string.IsNullOrEmpty(p.Value)) continue;
            parts.Add($"{p.Key}={Uri.EscapeDataString(p.Value)}");
        }
        if (set is { } s) parts.Add($"{s.Key}={Uri.EscapeDataString(s.Value)}");
        if (parts.Count == 0) return "";
        return (prefix ?? "?") + string.Join("&", parts);
    }

    /// <summary>نَفس Preserve لكن كـ hidden inputs داخِل form.</summary>
    RenderFragment PreserveHidden(string? except = null) => @<text>
        @foreach (var p in new[] {
            ("category", Category),
            ("q",        Query),
            ("sort",     Sort),
            ("min",      MinPrice?.ToString()),
            ("max",      MaxPrice?.ToString()),
            ("district", District),
            ("filters",  Filters)
        })
        {
            if (p.Item1 != except && !string.IsNullOrEmpty(p.Item2))
            {
                <input type="hidden" name="@p.Item1" value="@p.Item2" />
            }
        }
    </text>;

    protected override async Task OnParametersSetAsync()
    {
        await using var g = Store.QuerySession();
        tenant = await g.LoadAsync<Tenant>(Slug);
        if (tenant is null) return;

        await using var t = Store.QuerySession(Slug);
        var q = t.Query<Listing>().Where(x => !x.IsDeleted);
        if (!string.IsNullOrEmpty(Category))   q = q.Where(x => x.CategorySlug == Category);
        else if (!string.IsNullOrEmpty(Kind))
        {
            // فَلتَرَة بِالـ Kind: نَأخُذ كُلّ slugs الَّتي تَنتَمي لِلـ Kind
            // المُختار مِن tenant.Categories. هذا يَسمَح بِفَلتَرَة "كُلّ
            // العَقارات السَكَنيّة" دون اختِيار فِئَة بِعَينها.
            var slugs = tenant.Categories
                .Where(c => c.Kind == Kind)
                .Select(c => c.Slug).ToList();
            q = q.Where(x => slugs.Contains(x.CategorySlug));
        }
        if (!string.IsNullOrEmpty(District))   q = q.Where(x => x.District == District);
        if (MinPrice.HasValue && MinPrice > 0) q = q.Where(x => x.Price >= MinPrice.Value);
        if (MaxPrice.HasValue && MaxPrice > 0) q = q.Where(x => x.Price <= MaxPrice.Value);
        if (!string.IsNullOrEmpty(Query))
        {
            var s = Query;
            q = q.Where(x => x.Title.Contains(s) ||
                             (x.Description != null && x.Description.Contains(s)));
        }
        q = Sort switch
        {
            "price_asc"  => q.OrderBy(x => x.Price),
            "price_desc" => q.OrderByDescending(x => x.Price),
            _            => q.OrderByDescending(x => x.CreatedAt),
        };
        items = (await q.Take(60).ToListAsync()).ToList();

        districts = (await t.Query<Listing>()
            .Where(x => !x.IsDeleted && x.District != null)
            .Select(x => x.District!)
            .ToListAsync())
            .Distinct().OrderBy(s => s).ToList();

        if (Auth.IsAuthenticated && Auth.UserId.HasValue)
        {
            var favs = await t.Query<Favorite>()
                .Where(f => f.UserId == Auth.UserId.Value).ToListAsync();
            favIds = favs.Select(f => f.ListingId).ToHashSet();
        }
    }
}
