@page "/{slug}/explore"
@inject IDocumentStore Store
@inject AuthSession Auth
@inject NavigationManager Nav

@if (tenant is null)
{
    <p class="ac-muted">…</p>
}
else
{
    <h1>كلّ إعلانات @tenant.Name</h1>

    <AcFilterBar SearchValue="@Query"
                 SearchPlaceholder="ابحَث في الإعلانات…"
                 OnSearchChange="@(v => Reload(v, Category, Sort))">
        <LeadingFilters>
            <a class="@(string.IsNullOrEmpty(Category)?"chip active":"chip")"
               href="@($"/{Slug}/explore")">الكلّ</a>
            @foreach (var c in tenant.Categories)
            {
                <a class="@(Category == c.Slug ? "chip active" : "chip")"
                   href="@($"/{Slug}/explore?category={c.Slug}")">
                    @c.Icon @c.Label
                </a>
            }
        </LeadingFilters>
        <TrailingFilters>
            <AcSortMenu Options="_sortOptions" Value="@Sort"
                        ValueChanged="@(v => Reload(Query, Category, v))"
                        Label="ترتيب" />
        </TrailingFilters>
    </AcFilterBar>

    @if (items is null)
    {
        <p class="ac-muted">جارٍ التَحميل…</p>
    }
    else if (items.Count == 0)
    {
        <AcEmptyState Title="لا إعلانات في هذه الفِئَة"
                      Description="جَرِّب فِئَة أُخرى أو غَيِّر البَحث"
                      IconName="search" />
    }
    else
    {
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px;margin-top:12px;">
            @foreach (var l in items)
            {
                <a href="/@Slug/listings/@l.Id" style="text-decoration:none;color:inherit;display:block;"><AcSpaceCard Title="@l.Title"
                             Location="@($"{l.City} — {l.District}")"
                             PriceLabel="@($"{l.Price:N0} ريال")"
                             ShowFavorite="@Auth.IsAuthenticated"
                             IsFavorite="@(favIds.Contains(l.Id))"
                             OnOpen="@(() => Nav.NavigateTo($"/{Slug}/listings/{l.Id}"))" /></a>
            }
        </div>
    }
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    [SupplyParameterFromQuery(Name = "category")] public string? Category { get; set; }
    [SupplyParameterFromQuery(Name = "q")]        public string? Query    { get; set; }
    [SupplyParameterFromQuery(Name = "sort")]     public string? Sort     { get; set; }

    Tenant? tenant;
    List<Listing>? items;
    HashSet<Guid> favIds = new();

    static readonly IReadOnlyDictionary<string, string> _sortOptions = new Dictionary<string, string>
    {
        [""] = "افتراضيّ",
        ["newest"]     = "الأَحدَث",
        ["price_asc"]  = "السِعر تَصاعُديّ",
        ["price_desc"] = "السِعر تَنازُليّ",
    };

    void Reload(string? q, string? cat, string? sort)
    {
        var url = $"/{Slug}/explore?";
        if (!string.IsNullOrEmpty(cat))  url += $"category={cat}&";
        if (!string.IsNullOrEmpty(q))    url += $"q={Uri.EscapeDataString(q)}&";
        if (!string.IsNullOrEmpty(sort)) url += $"sort={sort}";
        Nav.NavigateTo(url.TrimEnd('&', '?'));
    }

    protected override async Task OnParametersSetAsync()
    {
        await using var g = Store.QuerySession();
        tenant = await g.LoadAsync<Tenant>(Slug);
        if (tenant is null) return;

        await using var t = Store.QuerySession(Slug);
        var q = t.Query<Listing>().Where(x => !x.IsDeleted);
        if (!string.IsNullOrEmpty(Category)) q = q.Where(x => x.CategorySlug == Category);
        if (!string.IsNullOrEmpty(Query))
        {
            var s = Query;
            q = q.Where(x => x.Title.Contains(s) ||
                             (x.Description != null && x.Description.Contains(s)));
        }
        q = Sort switch
        {
            "newest"     => q.OrderByDescending(x => x.CreatedAt),
            "price_asc"  => q.OrderBy(x => x.Price),
            "price_desc" => q.OrderByDescending(x => x.Price),
            _            => q.OrderByDescending(x => x.CreatedAt),
        };
        items = (await q.Take(60).ToListAsync()).ToList();

        if (Auth.IsAuthenticated)
        {
            var favs = await t.Query<Favorite>()
                .Where(f => f.UserId == Auth.UserId!.Value).ToListAsync();
            favIds = favs.Select(f => f.ListingId).ToHashSet();
        }
    }
}
