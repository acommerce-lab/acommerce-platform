@page "/admin/agent"
@inject ACommerce.Templates.Customer.Marketplace.Services.AgentService Agent

@*
    وَكيل إداري — مُحادَثَة مَع نَموذَج Claude. كُلّ tool_use يُعرَض كَ
    بِطاقَة بِزِرَّي "تَطبيق" و "رَفض"، بِدون تَنفيذ تِلقائي. كَامِل
    حالَة المُحادَثَة في AgentSession واحِد (لا multi-user حاليّاً).
*@

<div class="acs-page acm-admin">
    <div class="acm-admin-head">
        <div style="display:flex;align-items:center;gap:12px;">
            <a class="ac-btn ac-btn-ghost ac-btn-sm" href="/admin" aria-label="الرُجوع">
                <AcIcon Name="arrow-right" Size="16" />
            </a>
            <h1 class="acm-wizard-title" style="margin:0;">🤖 وَكيل إداري</h1>
        </div>
        <form method="post" action="/admin/agent/reset" style="margin:0;">
            <button type="submit" class="ac-btn ac-btn-ghost ac-btn-sm">
                <AcIcon Name="x" Size="14" /> مَسح المُحادَثَة
            </button>
        </form>
    </div>

    @if (!Agent.IsConfigured)
    {
        <AcAlert Variant="warning"
                 Message="لا يوجَد مِفتاح Anthropic مَضبوط. أَضِف Anthropic:ApiKey في appsettings.Local.json أَو مُتَغَيِّر بيئَة ANTHROPIC_API_KEY ثُمّ أَعِد التَّشغيل." />
    }

    @if (Err is not null) { <AcAlert Variant="danger" Message="@FormatError(Err)" /> }

    <div class="acm-agent-help">
        <p style="margin:0;color:var(--ac-text-muted);font-size:13px;line-height:1.7;">
            اِسأَل الوَكيل بِلُغَتِكَ الطَّبيعيَّة:
            "أَنشِئ مَتجَر «sukna» لِلسَكَن المُشتَرَك"،
            "أَضِف مَدينَتَي الرِياض وجِدَّة إلى ejar"،
            "عَرِّف حُقول إعلانات roommate_has". كُلّ كِتابَة تُعرَض لِلمُراجَعَة قَبل التَّطبيق.
        </p>
    </div>

    <div class="acm-agent-thread">
        @if (session.Turns.Count == 0)
        {
            <div class="acm-agent-empty">
                <span style="font-size:48px;">💬</span>
                <p>ابدَأ بِسُؤال أَو طَلَب</p>
            </div>
        }
        else
        {
            foreach (var turn in session.Turns)
            {
                <div class="acm-agent-turn @(turn.Role == "user" ? "is-user" : "is-assistant")">
                    <div class="acm-agent-avatar">
                        @(turn.Role == "user" ? "👤" : "🤖")
                    </div>
                    <div class="acm-agent-body">
                        @if (!string.IsNullOrEmpty(turn.Text))
                        {
                            <div class="acm-agent-text">@turn.Text</div>
                        }
                        @if (turn.Tool is not null)
                        {
                            <div class="acm-agent-tool @StatusClass(turn.Tool.Status)">
                                <div class="acm-agent-tool-head">
                                    <strong>@ToolLabel(turn.Tool.Name)</strong>
                                    <span class="ac-chip ac-chip-sm">@StatusLabel(turn.Tool.Status)</span>
                                </div>
                                <details class="acm-agent-tool-input">
                                    <summary>عَرض المُعامِلات (JSON)</summary>
                                    <pre>@FormatJson(turn.Tool.InputJson)</pre>
                                </details>
                                @if (!string.IsNullOrEmpty(turn.Tool.Result))
                                {
                                    <div class="acm-agent-tool-result">@turn.Tool.Result</div>
                                }
                                @if (turn.Tool.Status == "pending")
                                {
                                    <div class="acm-agent-tool-actions">
                                        <form method="post" action="@($"/admin/agent/tool/{turn.Tool.Id}/apply")" style="margin:0;">
                                            <button type="submit" class="ac-btn ac-btn-primary ac-btn-sm">
                                                <AcIcon Name="check" Size="14" /> تَطبيق
                                            </button>
                                        </form>
                                        <form method="post" action="@($"/admin/agent/tool/{turn.Tool.Id}/reject")" style="margin:0;">
                                            <button type="submit" class="ac-btn ac-btn-ghost ac-btn-sm">
                                                <AcIcon Name="x" Size="14" /> رَفض
                                            </button>
                                        </form>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>

    <form method="post" action="/admin/agent/ask" class="acm-agent-composer">
        <textarea name="message" rows="3" required
                  class="ac-input"
                  placeholder="اُكتُب طَلَبَك… مَثَلاً: أَنشِئ مَتجَر «sukna» لِلسَكَن المُشتَرَك بِلَون أَخضَر زيتوني"></textarea>
        <button type="submit" class="ac-btn ac-btn-primary" disabled="@(!Agent.IsConfigured)">
            <AcIcon Name="send" Size="16" /> إرسال
        </button>
    </form>
</div>

<style>
.acm-agent-help { padding:12px 16px; background:var(--ac-surface-2,#fafafa);
    border-radius:8px; margin-bottom:16px; }
.acm-agent-thread { display:flex; flex-direction:column; gap:16px;
    margin-bottom:16px; min-height:200px; }
.acm-agent-empty { text-align:center; padding:48px 16px; color:var(--ac-text-muted); }
.acm-agent-turn { display:flex; gap:12px; align-items:flex-start; }
.acm-agent-turn.is-user { flex-direction:row-reverse; }
.acm-agent-avatar { font-size:24px; width:40px; height:40px;
    display:flex; align-items:center; justify-content:center;
    background:var(--ac-surface-2,#f4f4f5); border-radius:50%; flex-shrink:0; }
.acm-agent-body { flex:1; max-width:80%; }
.acm-agent-turn.is-user .acm-agent-body { text-align:start; }
.acm-agent-text { padding:12px 16px; background:#fff;
    border:1px solid var(--ac-border,#e5e7eb); border-radius:12px;
    white-space:pre-wrap; line-height:1.7; }
.acm-agent-turn.is-user .acm-agent-text { background:var(--ac-primary-soft,#eef2ff); }
.acm-agent-tool { margin-top:8px; padding:12px; border-radius:12px;
    background:#fffbeb; border:1px solid #fef3c7; }
.acm-agent-tool.is-applied { background:#f0fdf4; border-color:#bbf7d0; }
.acm-agent-tool.is-rejected { background:#fef2f2; border-color:#fecaca; opacity:0.7; }
.acm-agent-tool.is-error { background:#fef2f2; border-color:#fecaca; }
.acm-agent-tool-head { display:flex; justify-content:space-between;
    align-items:center; margin-bottom:8px; }
.acm-agent-tool-input { font-size:12px; }
.acm-agent-tool-input summary { cursor:pointer; color:var(--ac-text-muted); }
.acm-agent-tool-input pre { background:#fff; padding:8px; border-radius:6px;
    direction:ltr; font-family:monospace; font-size:11px;
    overflow-x:auto; margin-top:4px; max-height:240px; }
.acm-agent-tool-result { margin-top:8px; padding:8px 10px;
    background:#fff; border-radius:6px; font-size:13px; }
.acm-agent-tool-actions { display:flex; gap:8px; margin-top:10px; }
.acm-agent-composer { display:flex; gap:8px; align-items:flex-end;
    padding:12px; background:#fff; border:1px solid var(--ac-border,#e5e7eb);
    border-radius:12px; position:sticky; bottom:8px; }
.acm-agent-composer textarea { flex:1; resize:vertical; }
</style>

@code {
    [SupplyParameterFromQuery(Name = "err")] public string? Err { get; set; }

    ACommerce.Templates.Customer.Marketplace.Services.AgentSession session = new();

    protected override async Task OnParametersSetAsync()
    {
        session = await Agent.LoadSessionAsync();
    }

    static string ToolLabel(string name) => name switch
    {
        "create_tenant"  => "🆕 إنشاء مَتجَر",
        "set_categories" => "🏷️ تَحديث الفِئات",
        "set_branding"   => "🎨 تَحديث الهُويَّة",
        "set_regions"    => "📍 تَحديث المُدُن",
        "set_attributes" => "⚙️ تَحديث الخَصائِص",
        _ => name
    };

    static string StatusLabel(string status) => status switch
    {
        "applied"  => "تَمّ",
        "rejected" => "مَرفوض",
        "error"    => "خَطَأ",
        _          => "قَيد المُراجَعَة"
    };

    static string StatusClass(string status) => status switch
    {
        "applied"  => "is-applied",
        "rejected" => "is-rejected",
        "error"    => "is-error",
        _ => ""
    };

    static string FormatJson(string raw)
    {
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(raw);
            return System.Text.Json.JsonSerializer.Serialize(
                doc.RootElement,
                new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        }
        catch { return raw; }
    }

    static string FormatError(string err) => err switch
    {
        "empty"       => "اِكتُب رِسالَة قَبل الإرسال.",
        "tool_missing" => "لَم يَعُد هذا الإجراء مَوجوداً.",
        _ => err
    };
}
