@page "/{slug}/chats/{conversationId:guid}"
@inject IDocumentStore Store
@inject AuthSession Auth

<div class="acs-page">
@if (!Auth.IsAuthenticated)
{
    <AcEmptyState IconName="message"
                  Title="تَحتاج تَسجيل دُخول"
                  ActionLabel="تَسجيل دُخول"
                  ActionHref="@($"/{Slug}/login")" />
}
else if (conv is null)
{
    <AcLoadingState Message="جارٍ التَحميل…" />
}
else
{
    var iAmOwner = conv.OwnerId == Auth.UserId;
    var partnerName = iAmOwner ? conv.PartnerName : conv.OwnerName;

    <div style="display:flex;align-items:center;gap:12px;padding-bottom:12px;
                border-bottom:1px solid var(--ac-border);margin-bottom:12px;">
        <a href="@($"/{Slug}/chats")"
           style="display:inline-flex;text-decoration:none;color:var(--ac-text);">
            <AcIcon Name="arrow-right" Size="24" />
        </a>
        <AcAvatar Name="@partnerName" Size="40" />
        <strong>@partnerName</strong>
    </div>

    <div style="min-height:400px;display:flex;flex-direction:column;gap:8px;padding-bottom:16px;">
        @if (messages.Count == 0)
        {
            <p class="ac-muted" style="text-align:center;padding:32px 0;">
                ابدأ المُحادَثَة — لا توجَد رَسائل بَعد.
            </p>
        }
        else
        {
            DateTime? lastDay = null;
            foreach (var m in messages)
            {
                var local = m.SentAt.Kind == DateTimeKind.Utc ? m.SentAt.ToLocalTime() : m.SentAt;
                if (lastDay is null || lastDay.Value.Date != local.Date)
                {
                    lastDay = local;
                    <div style="text-align:center;margin:12px 0 8px;">
                        <span style="background:var(--ac-bg-alt);color:var(--ac-text-muted);
                                     padding:3px 12px;border-radius:999px;font-size:11px;">
                            @FormatDay(local)
                        </span>
                    </div>
                }
                var mine = m.SenderId == Auth.UserId;
                <div style="display:flex;justify-content:@(mine ? "flex-end" : "flex-start");">
                    <div style="max-width:75%;padding:10px 14px;
                                border-radius:var(--ac-radius-md);
                                background:@(mine ? "var(--ac-primary)" : "var(--ac-bg-alt)");
                                color:@(mine ? "#fff" : "var(--ac-text)");">
                        <div style="white-space:pre-wrap;word-break:break-word;">@m.Body</div>
                        <div style="font-size:10px;opacity:.7;margin-top:4px;text-align:end;">
                            @local.ToString("HH:mm")
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <form method="post" action="@($"/{Slug}/chats/{ConversationId}/send")" class="acs-chat-composer">
        <input type="text" name="body" class="ac-input"
               style="flex:1;padding:10px;border:1px solid var(--ac-border);border-radius:var(--ac-radius-sm);"
               placeholder="اِكتُب رسالَة…" required autofocus />
        <button type="submit"
                style="padding:10px 18px;background:var(--ac-primary);color:#fff;border:0;
                       border-radius:var(--ac-radius-sm);cursor:pointer;font-weight:600;
                       display:inline-flex;align-items:center;gap:6px;">
            <AcIcon Name="send" Size="16" />
            <span>إرسال</span>
        </button>
    </form>
}
</div>

@code {
    [Parameter] public string Slug { get; set; } = "";
    [Parameter] public Guid ConversationId { get; set; }
    Conversation? conv;
    List<Message> messages = new();

    static string FormatDay(DateTime localAt)
    {
        var today = DateTime.Now.Date;
        if (localAt.Date == today)               return "اليَوم";
        if (localAt.Date == today.AddDays(-1))   return "أَمس";
        if ((today - localAt.Date).TotalDays < 7) return localAt.ToString("dddd", new System.Globalization.CultureInfo("ar"));
        return localAt.ToString("yyyy/MM/dd");
    }


    protected override async Task OnParametersSetAsync()
    {
        if (!Auth.IsAuthenticated) return;
        await using var s = Store.LightweightSession(Slug);
        conv = await s.LoadAsync<Conversation>(ConversationId);
        if (conv is null) return;
        if (conv.OwnerId != Auth.UserId && conv.PartnerId != Auth.UserId) { conv = null; return; }

        messages = (await s.Query<Message>()
            .Where(m => m.ConversationId == ConversationId)
            .OrderBy(m => m.SentAt).Take(200).ToListAsync()).ToList();

        var changed = false;
        if (conv.OwnerId == Auth.UserId && conv.OwnerUnread > 0)     { conv.OwnerUnread = 0; changed = true; }
        if (conv.PartnerId == Auth.UserId && conv.PartnerUnread > 0) { conv.PartnerUnread = 0; changed = true; }
        if (changed) { s.Store(conv); await s.SaveChangesAsync(); }
    }
}
