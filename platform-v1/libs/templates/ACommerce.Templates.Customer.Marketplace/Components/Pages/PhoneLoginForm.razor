@*
    Phone OTP — مَرحَلَتان عَبر forms مُنفَصِلَة.
    Stage = null أو "request" → اُكتُب الهاتف + إرسال
    Stage = "verify"          → اُكتُب الكود + تَأكُّد
*@

@if (Stage != "verify")
{
    <form method="post" action="@($"/{Slug}/auth/phone/login")">
        <label style="display:block;font-size:13px;margin-bottom:6px;">
            رَقم الهاتف <span style="color:var(--ac-danger)">*</span>
        </label>
        <input type="tel" name="phone" value="@Phone"
               required pattern="[0-9]{9,15}"
               style="width:100%;padding:10px;border-radius:var(--ac-radius-sm);border:1px solid var(--ac-border);font-size:16px;direction:ltr;"
               placeholder="7XXXXXXXX" />

        @if (ErrorMessage is not null)
        {
            <div style="background:color-mix(in srgb,var(--ac-danger) 12%,transparent);
                        color:var(--ac-danger);padding:8px;border-radius:6px;
                        margin-top:10px;font-size:13px;">@ErrorMessage</div>
        }

        <button type="submit"
                style="width:100%;padding:12px;margin-top:12px;
                       background:var(--ac-primary);color:#fff;border:0;
                       border-radius:var(--ac-radius-sm);font-size:15px;
                       font-weight:600;cursor:pointer;">
            إرسال الكود
        </button>
    </form>
}
else
{
    <form method="post" action="@($"/{Slug}/auth/phone/verify")">
        <input type="hidden" name="phone" value="@Phone" />

        <p class="acs-nafath-instruction">أَدخِل الكود المُرسَل إلى <strong>@Phone</strong></p>

        <label style="display:block;font-size:13px;margin-bottom:6px;">
            الكود <span style="color:var(--ac-danger)">*</span>
        </label>
        <input type="text" name="code" required minlength="4" maxlength="6"
               pattern="[0-9]{4,6}" autofocus
               style="width:100%;padding:10px;border-radius:var(--ac-radius-sm);
                      border:1px solid var(--ac-border);font-size:18px;
                      letter-spacing:.4em;text-align:center;direction:ltr;"
               placeholder="123456" />

        <div class="acs-nafath-state acs-nafath-state--ok" style="margin-top:10px;">
            <span>ℹ️</span><span>وَضع التَطوير — الكود: <strong>123456</strong></span>
        </div>

        @if (ErrorMessage is not null)
        {
            <div style="background:color-mix(in srgb,var(--ac-danger) 12%,transparent);
                        color:var(--ac-danger);padding:8px;border-radius:6px;
                        margin-top:10px;font-size:13px;">@ErrorMessage</div>
        }

        <button type="submit"
                style="width:100%;padding:12px;margin-top:12px;
                       background:var(--ac-primary);color:#fff;border:0;
                       border-radius:var(--ac-radius-sm);font-size:15px;
                       font-weight:600;cursor:pointer;">
            تَحَقُّق ودُخول
        </button>

        <a href="@($"/{Slug}/login")"
           style="display:block;text-align:center;margin-top:10px;
                  color:var(--ac-text-muted);font-size:13px;text-decoration:none;">
            تَغيير الرَقم
        </a>
    </form>
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    [Parameter] public string? Stage { get; set; }
    [Parameter] public string? Phone { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
}
