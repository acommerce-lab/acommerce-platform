@inherits LayoutComponentBase
@inject ITenantContext Tenant
@inject NavigationManager Nav
@inject IHttpContextAccessor HttpCtx
@inject AuthSession Auth

@{
    var slug = Tenant.Slug;
    var brand = Tenant.BrandColor;
    var path = new Uri(Nav.Uri).AbsolutePath;
    var isLogin = path.Contains("/login", StringComparison.OrdinalIgnoreCase);
    var topItems = new List<AcTopNav.TopNavItem>
    {
        new($"/{slug}",               "الرَئيسيّة", "home",    null, true),
        new($"/{slug}/explore",       "استِكشاف",   "search"),
        new($"/{slug}/chats",         "رَسائل",     "message"),
        new($"/{slug}/notifications", "إشعارات",    "bell"),
        new($"/{slug}/me",            Auth.IsAuthenticated ? Auth.UserName ?? "حِسابي" : "حِسابي", "user")
    };
    var bottomItems = new List<ACommerce.Templates.Shared.Models.BottomNavItemDto>
    {
        new() { Href = $"/{slug}",               Label = "الرَئيسيّة", IconName = "home",    Exact = true },
        new() { Href = $"/{slug}/explore",       Label = "استِكشاف",   IconName = "search" },
        new() { Href = $"/{slug}/chats",         Label = "رَسائل",     IconName = "message" },
        new() { Href = $"/{slug}/notifications", Label = "إشعارات",    IconName = "bell" },
        new() { Href = $"/{slug}/me",            Label = Auth.IsAuthenticated ? "حِسابي" : "دُخول", IconName = "user" },
    };
}

@if (Tenant.IsResolved)
{
    <div class="acs-page" style="--ac-primary:@brand; --ac-primary-dark:@brand; --ac-primary-light:@brand; --ac-primary-hover:@brand;">
        @if (!isLogin)
        {
            <nav class="acm-mobile-nav">
                <div class="acm-mobile-nav-inner">
                    <div class="acm-mobile-nav-brand">
                        <span class="acm-mobile-nav-brand-name">@Tenant.Name</span>
                    </div>
                    <div class="acm-mobile-nav-actions">
                        <a class="acm-mobile-nav-btn" href="@($"/{slug}/notifications")" aria-label="الإشعارات">
                            <AcIcon Name="bell" Size="24" />
                        </a>
                    </div>
                </div>
            </nav>

            <div class="acm-v2-topnav-wrap">
                <AcTopNav Items="topItems">
                    <BrandContent>
                        <div class="acm-brand">
                            <span class="acm-brand-text">@Tenant.Name</span>
                        </div>
                    </BrandContent>
                </AcTopNav>
            </div>
        }

        <main>
            @Body

            @if (!isLogin)
            {
                <div class="acm-v2-bottom-nav-wrap">
                    <AcBottomNav Items="bottomItems" ExtraClass="acm-v2-bottomnav" />
                </div>
            }
        </main>
    </div>
}
else
{
    <div class="acs-page" style="--ac-primary:#1D4ED8;">
        <main>@Body</main>
    </div>
}

@code {
    protected override void OnInitialized()
    {
        if (Tenant.IsResolved && HttpCtx.HttpContext is { } ctx)
        {
            Auth.SetTenant(Tenant.Slug);
            Auth.Load(ctx, Tenant.Slug);
        }
    }
}
