@namespace ACommerce.Widgets

@*
    AcSpaceCard — بِطاقَة عَرض لِلسوق.
    تَحت SSR لا يَستَطيع <a> أَن يَحتَوي <form>/<button> (HTML5 invalid).
    لِذلك نُرَكِّب البِطاقَة كَـ <article> يَحوي:
      ├─ <a class="ac-space-link"> يُغَطّي مُعظَم البِطاقَة (يُفتَح الإعلان)
      └─ <form class="ac-space-fav-form"> صَغير في الرُكن العُلويّ
         يَحوي زِرّ القَلب (POST لِإضافَة/إزالَة المُفَضَّلَة)

    لِلتَوافُق الخَلفيّ مَع المُستَهلِكين الَّذين يُمَرِّرون OnOpen/OnToggleFavorite
    (تَفاعُليّ)، نَدعَم الـ legacy path أَيضاً عِندَما لا يُمَرَّر Href.

    CSS_CLASSES: ac-space, ac-space-link, ac-space-fav-form, ac-space-media,
                 ac-space-ribbon, ac-space-fav, ac-space-body, ac-space-title,
                 ac-space-meta, ac-space-price, ac-space-placeholder
*@

@{
    var hasHref = !string.IsNullOrEmpty(Href);

    RenderFragment linkInner = @<text>
        <div class="ac-space-media">
            @if (!string.IsNullOrWhiteSpace(ImageUrl))
            {
                <img src="@ImageUrl" alt="@Title" loading="lazy" />
            }
            else
            {
                <div class="ac-space-placeholder" aria-hidden="true">
                    <AcIcon Name="package" Size="32" />
                </div>
            }
            @if (!string.IsNullOrEmpty(Ribbon))
            {
                <span class="ac-space-ribbon">@Ribbon</span>
            }
        </div>
        <div class="ac-space-body">
            <h3 class="ac-space-title">@Title</h3>
            @if (!string.IsNullOrEmpty(Location))
            {
                <div class="ac-space-meta">
                    <AcIcon Name="map-pin" Size="14" />
                    <span>@Location</span>
                </div>
            }
            <div class="ac-space-meta">
                @if (Capacity.HasValue)
                {
                    <span><AcIcon Name="user" Size="14" /> @Capacity.Value</span>
                }
                @if (Rating.HasValue)
                {
                    <span><AcIcon Name="star" Filled="true" Size="14" /> @Rating.Value.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)</span>
                }
            </div>
            @if (Attributes is not null && Attributes.Count > 0)
            {
                <AcAttrChipRow Attributes="@Attributes" IsArabic="@IsArabic" Max="@MaxAttributeChips" />
            }
            @if (!string.IsNullOrEmpty(PriceLabel))
            {
                <div class="ac-space-price">@PriceLabel</div>
            }
        </div>
    </text>;
}

@if (hasHref)
{
    <article class="ac-space @(Class ?? "")">
        <a class="ac-space-link" href="@Href">@linkInner</a>
        @if (ShowFavorite && !string.IsNullOrEmpty(FavoriteFormAction))
        {
            <form method="post" action="@FavoriteFormAction" class="ac-space-fav-form">
                @if (!string.IsNullOrEmpty(FavoriteFormReturn))
                {
                    <input type="hidden" name="return" value="@FavoriteFormReturn" />
                }
                <button type="submit"
                        class="ac-space-fav @(IsFavorite ? "is-fav" : "")"
                        aria-label="@(IsFavorite ? RemoveFavoriteAriaLabel : AddFavoriteAriaLabel)"
                        aria-pressed="@(IsFavorite ? "true" : "false")">
                    <AcIcon Name="heart" Filled="@IsFavorite" Size="18" />
                </button>
            </form>
        }
    </article>
}
else
{
    <article class="ac-space @(Class ?? "")" @onclick="OnOpenInternal">
        @linkInner
        @if (ShowFavorite)
        {
            <button type="button"
                    class="ac-space-fav @(IsFavorite ? "is-fav" : "")"
                    aria-label="@(IsFavorite ? RemoveFavoriteAriaLabel : AddFavoriteAriaLabel)"
                    aria-pressed="@(IsFavorite ? "true" : "false")"
                    @onclick="ToggleFavoriteInternal"
                    @onclick:stopPropagation="true"
                    style="position:absolute;top:8px;inset-inline-end:8px;">
                <AcIcon Name="heart" Filled="@IsFavorite" Size="18" />
            </button>
        }
    </article>
}

@code {
    [Parameter] public string? Href { get; set; }
    [Parameter, EditorRequired] public string Title { get; set; } = "";
    [Parameter] public string? ImageUrl { get; set; }
    [Parameter] public string? Location { get; set; }
    [Parameter] public int? Capacity { get; set; }
    [Parameter] public decimal? Rating { get; set; }
    [Parameter] public string? PriceLabel { get; set; }
    [Parameter] public string? Ribbon { get; set; }
    [Parameter] public bool ShowFavorite { get; set; } = true;
    [Parameter] public bool IsFavorite { get; set; }
    [Parameter] public EventCallback OnOpen { get; set; }
    [Parameter] public EventCallback<bool> OnToggleFavorite { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string AddFavoriteAriaLabel    { get; set; } = "Add to favorites";
    [Parameter] public string RemoveFavoriteAriaLabel { get; set; } = "Remove from favorites";

    /// <summary>عُنوان form لِزِرّ المُفَضَّلَة تَحت SSR (POST). لَو فارِغ
    /// والـ Href مَوجود، يَختَفي زِرّ القَلب.</summary>
    [Parameter] public string? FavoriteFormAction { get; set; }
    /// <summary>قِيمَة hidden "return" لِإعادَة التَوجيه بَعد الـ POST.</summary>
    [Parameter] public string? FavoriteFormReturn { get; set; }

    [Parameter] public List<DynamicAttribute>? Attributes { get; set; }
    [Parameter] public bool IsArabic { get; set; } = true;
    [Parameter] public int MaxAttributeChips { get; set; } = 4;

    private Task OnOpenInternal() => OnOpen.InvokeAsync();
    private Task ToggleFavoriteInternal() => OnToggleFavorite.InvokeAsync(!IsFavorite);
}
