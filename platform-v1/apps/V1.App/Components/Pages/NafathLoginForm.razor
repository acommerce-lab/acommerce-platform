@*
    Nafath flow:
    Stage = null أو "request" → اُكتُب الهُويَّة + بَدء
    Stage = "verify"          → اُعرِض الرَقم الكَبير + زَرّ "تَأكَّد الآن"
*@

@if (Stage != "verify")
{
    <form method="post" action="@($"/{Slug}/auth/nafath/login")">
        <label style="display:block;font-size:13px;margin-bottom:6px;">
            رَقم الهُويَّة الوَطَنِيَّة <span style="color:var(--ac-danger)">*</span>
        </label>
        <input type="tel" name="nid" value="@NationalId"
               required pattern="[0-9]{10}" maxlength="10"
               style="width:100%;padding:10px;border-radius:var(--ac-radius-sm);
                      border:1px solid var(--ac-border);font-size:18px;
                      text-align:center;letter-spacing:.2em;direction:ltr;"
               placeholder="1XXXXXXXXX" />

        @if (ErrorMessage is not null)
        {
            <div style="background:color-mix(in srgb,var(--ac-danger) 12%,transparent);
                        color:var(--ac-danger);padding:8px;border-radius:6px;
                        margin-top:10px;font-size:13px;">@ErrorMessage</div>
        }

        <button type="submit"
                style="width:100%;padding:12px;margin-top:12px;
                       background:var(--ac-primary);color:#fff;border:0;
                       border-radius:var(--ac-radius-sm);font-size:15px;
                       font-weight:600;cursor:pointer;">
            بَدء التَحَقُّق عَبر نَفاذ
        </button>
    </form>
}
else
{
    <form method="post" action="@($"/{Slug}/auth/nafath/verify")">
        <input type="hidden" name="nid"     value="@NationalId" />
        <input type="hidden" name="attempt" value="@AttemptId" />

        <p class="acs-nafath-instruction" style="text-align:center;">
            اِفتَح تَطبيق <strong>نَفاذ</strong> في جَوّالك واختَر الرَقم المَوضَح:
        </p>

        <div class="acs-nafath-code-wrap">
            <div class="acs-nafath-code-circle">
                <div class="acs-nafath-code-num">@DisplayCode</div>
            </div>
        </div>

        <div class="acs-nafath-state acs-nafath-state--waiting" style="margin-top:10px;text-align:center;">
            <span>⏱</span>
            <span>وَضع التَطوير: يُعتَبَر مُؤَكَّداً تلقائيّاً بَعد 5 ثَوانٍ</span>
        </div>

        @if (ErrorMessage is not null)
        {
            <div style="background:color-mix(in srgb,var(--ac-danger) 12%,transparent);
                        color:var(--ac-danger);padding:8px;border-radius:6px;
                        margin-top:10px;font-size:13px;">@ErrorMessage</div>
        }

        <button type="submit"
                style="width:100%;padding:12px;margin-top:12px;
                       background:var(--ac-primary);color:#fff;border:0;
                       border-radius:var(--ac-radius-sm);font-size:15px;
                       font-weight:600;cursor:pointer;">
            تَأكَّدت في تَطبيق نَفاذ — أَكمِل الدُخول
        </button>

        <a href="@($"/{Slug}/login")"
           style="display:block;text-align:center;margin-top:10px;
                  color:var(--ac-text-muted);font-size:13px;text-decoration:none;">
            تَغيير الرَقم
        </a>
    </form>
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    [Parameter] public string? Stage { get; set; }
    [Parameter] public string? NationalId { get; set; }
    [Parameter] public string? AttemptId { get; set; }
    [Parameter] public string? DisplayCode { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
}
