@page "/{slug}/listings"
@inject ITenantContext Tenant
@inject IDocumentStore Store
@inject NavigationManager Nav

@if (!Tenant.IsResolved || tenant is null)
{
    <h1>غير مَوجود</h1>
    <p><a href="/">العَودَة</a></p>
}
else
{
    <h1>كلّ إعلانات @Tenant.Name</h1>

    <div class="filters">
        <a class="@(SelectedCategory is null ? "active" : "")" href="/@Slug/listings">الكلّ</a>
        @foreach (var c in tenant.Categories)
        {
            <a class="@(SelectedCategory == c.Slug ? "active" : "")"
               href="/@Slug/listings?category=@c.Slug">
                @c.Icon @c.Label
            </a>
        }
    </div>

    @if (items is null)
    {
        <p>تَحميل...</p>
    }
    else if (items.Count == 0)
    {
        <p class="empty">لا إعلانات في هذه الفِئَة.</p>
    }
    else
    {
        <ul class="listing-grid">
            @foreach (var l in items)
            {
                <li class="listing-card">
                    <a href="/@Slug/listings/@l.Id">
                        <strong>@l.Title</strong>
                        <span class="price">@l.Price.ToString("N0") ريال</span>
                        <span class="muted">@l.City — @l.District</span>
                        <span class="cat">@CategoryLabel(l.CategorySlug)</span>
                    </a>
                </li>
            }
        </ul>
    }
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    [SupplyParameterFromQuery] public string? Category { get; set; }

    Tenant? tenant;
    IReadOnlyList<Listing>? items;
    string? SelectedCategory => Category;

    protected override async Task OnParametersSetAsync()
    {
        await using var g = Store.QuerySession();
        tenant = await g.LoadAsync<Tenant>(Slug);
        if (tenant is null) return;

        await using var t = Store.QuerySession(Slug);
        var q = t.Query<Listing>().Where(x => !x.IsDeleted);
        if (!string.IsNullOrEmpty(Category))
            q = q.Where(x => x.CategorySlug == Category);
        items = await q.OrderByDescending(x => x.CreatedAt).Take(60).ToListAsync();
    }

    string CategoryLabel(string slug) =>
        tenant?.Categories.FirstOrDefault(c => c.Slug == slug)?.Label ?? slug;
}
