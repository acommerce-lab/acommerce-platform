{
  "_comment": "إعدادات الإنتاج - عشير على Alibaba Cloud (Saudi Arabia). كل القيم ${VAR} تُملأ من متغيرات البيئة.",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/ashare-api2-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Database": {
    "Provider": "SqlServer",
    "ConnectionString": "${ASHARE_DB_CONNECTION}"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://ashare.app",
      "https://www.ashare.app",
      "https://ashare-web-130415035604.me-central2.run.app"
    ]
  },
  "Files": {
    "Storage": {
      "Provider": "AliyunOSS",
      "AliyunOSS": {
        "AccessKeyId": "${ALIYUN_ACCESS_KEY_ID}",
        "AccessKeySecret": "${ALIYUN_ACCESS_KEY_SECRET}",
        "Endpoint": "oss-me-central-1.aliyuncs.com",
        "Region": "me-central-1",
        "BucketName": "ashare-media",
        "UseHttps": true,
        "UseV4Signature": true,
        "UseDirectoryStructure": true,
        "DirectoryFormat": "yyyy/MM/dd"
      },
      "GoogleCloud": {
        "BucketName": "ashare-images-dammam",
        "UseDirectoryStructure": true,
        "DirectoryFormat": "yyyy/MM/dd",
        "ServiceAccountKeyJson": "${GCS_SERVICE_ACCOUNT_KEY}"
      }
    }
  },
  "Authentication": {
    "TwoFactor": {
      "Nafath": {
        "Mode": "Production",
        "BaseUrl": "https://api.authentica.sa/api/v2",
        "ClientId": "${NAFATH_CLIENT_ID}",
        "ClientSecret": "${NAFATH_CLIENT_SECRET}",
        "ApplicationName": "Ashare",
        "ApiKey": "${NAFATH_API_KEY}",
        "WebhookSecret": "${NAFATH_WEBHOOK_SECRET}"
      }
    }
  },
  "Payments": {
    "Noon": {
      "BusinessIdentifier": "ashier",
      "ApplicationIdentifier": "newAshier",
      "ApiKey": "${NOON_API_KEY}",
      "Mode": "Live",
      "DefaultCurrency": "SAR",
      "Channel": "Web",
      "WebhookSecret": "${NOON_WEBHOOK_SECRET}"
    }
  },
  "Notifications": {
    "Firebase": {
      "ProjectId": "ashir-f4bfd",
      "CredentialsJson": "${FIREBASE_CREDENTIALS_JSON}",
      "CredentialsFilePath": "${FIREBASE_CREDENTIALS_FILE}",
      "DefaultSound": "default"
    }
  }
}
