@inherits LayoutComponentBase
@inject AppStore Store
@inject AuthStateService AuthService
@inject IJSRuntime JS
@inject L L
@implements IDisposable

<div class="vnd-shell">
    @* Desktop-only top navbar — hidden by CSS when data-ac-mode="mobile" *@
    <nav class="vnd-top-nav">
        <div class="vnd-top-nav-inner">
            <NavLink class="vnd-top-nav-brand" href="/" Match="NavLinkMatch.All">🏪 @(L["nav.brand"])</NavLink>
            <div class="vnd-top-nav-links">
                <NavLink class="vnd-top-nav-link" href="/" Match="NavLinkMatch.All">@(L["nav.home"])</NavLink>
                <NavLink class="vnd-top-nav-link" href="/orders">@(L["nav.orders"])</NavLink>
                <NavLink class="vnd-top-nav-link" href="/offers">@(L["nav.offers"])</NavLink>
                <NavLink class="vnd-top-nav-link" href="/messages">@(L["nav.messages"])</NavLink>
            </div>
            <div class="vnd-top-nav-actions">
                <NavLink class="vnd-top-nav-link" href="@(Store.Auth.IsAuthenticated ? "/profile" : "/login")">
                    @(Store.Auth.IsAuthenticated ? L["nav.profile"] : L["nav.signin"])
                </NavLink>
            </div>
        </div>
    </nav>

    <main class="vnd-main">
        @Body
    </main>

    @* Mobile-only bottom navbar — hidden by CSS when data-ac-mode="desktop" *@
    <nav class="vnd-bottom-nav">
        <NavLink href="/" Match="NavLinkMatch.All" class="vnd-nav-item">
            <AcIcon Name="home" Size="20" />
            <span>@(L["nav.home"])</span>
        </NavLink>
        <NavLink href="/orders" class="vnd-nav-item">
            <AcIcon Name="receipt" Size="20" />
            <span>@(L["nav.orders"])</span>
        </NavLink>
        <NavLink href="/offers" class="vnd-nav-item">
            <AcIcon Name="tag" Size="20" />
            <span>@(L["nav.offers"])</span>
        </NavLink>
        <NavLink href="/messages" class="vnd-nav-item">
            <AcIcon Name="message" Size="20" />
            <span>@(L["nav.messages"])</span>
        </NavLink>
        <NavLink href="@(Store.Auth.IsAuthenticated ? "/profile" : "/login")" class="vnd-nav-item">
            <AcIcon Name="user" Size="20" />
            <span>@(Store.Auth.IsAuthenticated ? L["nav.profile"] : L["nav.signin"])</span>
        </NavLink>
    </nav>
</div>

@code {
    private string _lastTheme = "";
    private string _lastLang  = "";
    private Guid? _lastPersistedUserId;

    protected override void OnInitialized()
    {
        Store.OnChanged += OnChange;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Restore auth from ProtectedLocalStorage → AppStore
            await AuthService.EnsureRestoredAsync();
            if (AuthService.IsAuthenticated)
            {
                Store.Auth.UserId = AuthService.UserId;
                Store.Auth.PhoneNumber = AuthService.PhoneNumber;
                Store.Auth.FullName = AuthService.FullName;
                Store.Auth.AccessToken = AuthService.AccessToken;
                _lastPersistedUserId = AuthService.UserId;
                Store.NotifyChanged();
            }

            _lastTheme = Store.Ui.Theme;
            _lastLang  = Store.Ui.Language;
        }

        // Persist auth state when it changes
        await SyncAuthToStorageAsync();

        if (_lastTheme != Store.Ui.Theme) { _lastTheme = Store.Ui.Theme; try { await JS.InvokeVoidAsync("acTheme.set", Store.Ui.Theme); } catch { } }
        if (_lastLang != Store.Ui.Language) { _lastLang = Store.Ui.Language; try { await JS.InvokeVoidAsync("acLang.set", Store.Ui.Language); } catch { } }
    }

    private async Task SyncAuthToStorageAsync()
    {
        if (Store.Auth.IsAuthenticated && Store.Auth.UserId != _lastPersistedUserId)
        {
            _lastPersistedUserId = Store.Auth.UserId;
            try
            {
                await AuthService.SignInAsync(
                    Store.Auth.UserId!.Value,
                    Store.Auth.PhoneNumber,
                    Store.Auth.FullName,
                    Store.Auth.AccessToken!);
            }
            catch { }
        }
        else if (!Store.Auth.IsAuthenticated && _lastPersistedUserId.HasValue)
        {
            _lastPersistedUserId = null;
            try { await AuthService.SignOutAsync(); } catch { }
        }
    }

    private void OnChange() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Store.OnChanged -= OnChange;
    }
}
