@page "/chat/{Id:guid}"
@inject AppStore Store
@inject OrderApiClient OrderApi
@inject ApiReader Reader

<PageTitle>@(Store.Ui.IsArabic ? "محادثة" : "Chat")</PageTitle>

@if (!Store.Auth.IsAuthenticated)
{
    <AcEmptyState IconName="log-in"
                  Title="@(Store.Ui.IsArabic ? "سجّل دخولك" : "Sign in")"
                  ActionHref="/login"
                  ActionLabel="@(Store.Ui.IsArabic ? "دخول" : "Sign in")" />
}
else
{
    <AcChatPage Mode="TemplateOperationMode.Callback"
                OnSendMessage="HandleSend"
                Messages="@Mapped"
                MySenderId="@(Store.Auth.UserId?.ToString() ?? "")"
                Loading="@Loading"
                Title="@(Store.Ui.IsArabic ? "محادثة" : "Chat")"
                EmptyMessage="@(Store.Ui.IsArabic ? "لا رسائل بعد" : "No messages yet")"
                SendLabel="@(Store.Ui.IsArabic ? "إرسال" : "Send")" />
}

@code {
    [Parameter] public Guid Id { get; set; }
    private List<MsgApi> _messages = new();
    private bool Loading = true;

    private IReadOnlyList<ChatMessageDto> Mapped =>
        _messages.Select(m => new ChatMessageDto
        {
            Id = m.Id.ToString(),
            Content = m.Content,
            SenderId = m.SenderId.ToString(),
            CreatedAt = m.CreatedAt
        }).ToList();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Reload();
        StateHasChanged();
    }

    private async Task Reload()
    {
        Loading = true;
        var env = await Reader.GetAsync<List<MsgApi>>($"/api/messages/conversations/{Id}/messages");
        _messages = env.Data ?? new();
        Loading = false;
    }

    private async Task HandleSend(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return;
        var result = await OrderApi.PostAsync<MsgApi>("/api/messages", new
        {
            conversationId = Id,
            senderId = Store.Auth.UserId,
            content = text,
        });
        if (result.Data != null)
        {
            _messages.Add(result.Data);
        }
        else
        {
            _messages.Add(new MsgApi
            {
                Id = Guid.NewGuid(),
                SenderId = Store.Auth.UserId ?? Guid.Empty,
                Content = text,
                CreatedAt = DateTime.UtcNow,
            });
        }
        StateHasChanged();
    }

    public class MsgApi
    {
        public Guid Id { get; set; }
        public Guid SenderId { get; set; }
        public string Content { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }
}
