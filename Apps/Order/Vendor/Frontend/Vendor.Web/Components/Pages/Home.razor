@page "/"
@inject ApiReader Reader
@inject AppStore Store
@inject AppStateApplier Applier
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>@(Store.Ui.IsArabic ? "لوحة التاجر" : "Dashboard")</PageTitle>

@if (!Store.Auth.IsAuthenticated)
{
    <AcEmptyState IconName="log-in"
                  Title="@(Store.Ui.IsArabic ? "سجّل دخولك" : "Sign in")"
                  ActionLabel="@(Store.Ui.IsArabic ? "دخول" : "Sign in")"
                  ActionHref="/login" />
}
else
{
    <AcVendorDashboard
        Stats="@Stats"
        RecentOrders="@RecentOrders"
        LoadingOrders="@Loading"
        OrdersTitle="@(Store.Ui.IsArabic ? "أحدث الطلبات" : "Recent orders")"
        EmptyOrdersMessage="@(Store.Ui.IsArabic ? "لا توجد طلبات بعد" : "No orders yet")"
        OnOrderClick="@OnOrderClick">
        <AboveStats>
            <h1 class="acs-page-title">
                @(Store.Ui.IsArabic
                    ? $"مرحباً {Store.Auth.FullName ?? ""}"
                    : $"Hello {Store.Auth.FullName ?? ""}")
            </h1>
        </AboveStats>
    </AcVendorDashboard>
}

@code {
    private List<MerchantStatDto> Stats = new();
    private List<MerchantOrderRowDto> RecentOrders = new();
    private bool Loading = true;

    private List<OrderRow> _allOrders = new();
    private Guid? _vendorId;

    protected override void OnInitialized() { Store.OnChanged += OnChange; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (Store.Auth.IsAuthenticated) await LoadDashboard();
        Loading = false;
        StateHasChanged();
    }

    private async Task LoadDashboard()
    {
        // Look up the vendor by OwnerId (Store.Auth.UserId = VendorUser.Id = Vendor.OwnerId)
        var vEnv = await Reader.GetAsync<List<VendorRow>>("/api/vendors");
        var myVendor = vEnv.Data?.FirstOrDefault(v => v.OwnerId == Store.Auth.UserId);
        if (myVendor == null) return;
        _vendorId = myVendor.Id;

        var env = await Reader.GetAsync<List<OrderRow>>(
            $"/api/orders/by-vendor/{_vendorId}");
        _allOrders = env.Data ?? new();

        var today = DateTime.UtcNow.Date;
        var pending   = _allOrders.Count(o => o.Status == 0);
        var todayCount = _allOrders.Count(o => o.CreatedAt.Date == today);
        var delivered  = _allOrders.Count(o => o.Status == 3);

        Stats = new List<MerchantStatDto>
        {
            new() { Label = Store.Ui.IsArabic ? "طلبات معلقة"  : "Pending",    Value = pending.ToString(),   IconName = "clock"    },
            new() { Label = Store.Ui.IsArabic ? "طلبات اليوم"  : "Today",      Value = todayCount.ToString(), IconName = "calendar" },
            new() { Label = Store.Ui.IsArabic ? "تم التسليم"   : "Delivered",  Value = delivered.ToString(),  IconName = "check-circle" },
        };

        RecentOrders = _allOrders
            .OrderByDescending(o => o.CreatedAt)
            .Take(5)
            .Select(ToDto)
            .ToList();
    }

    private Task OnOrderClick(MerchantOrderRowDto o)
    {
        Nav.NavigateTo($"/orders/{o.Id}");
        return Task.CompletedTask;
    }

    private static MerchantOrderRowDto ToDto(OrderRow o) => new()
    {
        Id           = o.Id.ToString(),
        CustomerName = o.CustomerName,
        Total        = o.Total,
        Currency     = o.Currency,
        Status       = StatusHelpers.OrderStatusKey(o.Status),
        CreatedAt    = o.CreatedAt,
    };

    private void OnChange() => InvokeAsync(StateHasChanged);
    public void Dispose() { Store.OnChanged -= OnChange; }

    public class VendorRow
    {
        public Guid Id { get; set; }
        public Guid OwnerId { get; set; }
    }

    public class OrderRow
    {
        public Guid Id { get; set; }
        public string OrderNumber { get; set; } = "";
        public decimal Total { get; set; }
        public string Currency { get; set; } = "SAR";
        public int Status { get; set; }
        public DateTime CreatedAt { get; set; }
        public string CustomerName { get; set; } = "";
    }
}
