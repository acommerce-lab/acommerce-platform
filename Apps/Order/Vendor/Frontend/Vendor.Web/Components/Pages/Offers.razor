@page "/offers"
@inject ApiReader Reader
@inject AppStore Store
@inject NavigationManager Nav

<PageTitle>@(Store.Ui.IsArabic ? "عروضي" : "My Offers")</PageTitle>

<AcAuthGuard IsAuthenticated="@Store.Auth.IsAuthenticated" IsArabic="@Store.Ui.IsArabic" LoginHref="/login">
    <div class="acs-page" style="padding:16px;">
        <AcPageHeader Title="@(Store.Ui.IsArabic ? "عروضي" : "My Offers")">
            <Actions>
                <AcButton Variant="primary" Size="sm" Text="@(Store.Ui.IsArabic ? "+ عرض جديد" : "+ New offer")"
                          OnClick="@(() => Nav.NavigateTo("/offers/new"))" />
            </Actions>
        </AcPageHeader>

        @if (Loading)
        {
            <AcLoadingState Message="@(Store.Ui.IsArabic ? "جاري التحميل..." : "Loading…")" />
        }
        else if (MyOffers.Count == 0)
        {
            <AcEmptyState IconName="tag"
                          Title="@(Store.Ui.IsArabic ? "لا عروض بعد" : "No offers yet")"
                          Message="@(Store.Ui.IsArabic ? "أنشئ عرضك الأول لبدء البيع" : "Create your first offer")"
                          ActionLabel="@(Store.Ui.IsArabic ? "إنشاء عرض" : "Create offer")"
                          ActionHref="/offers/new" />
        }
        else
        {
            @foreach (var o in MyOffers)
            {
                <div @onclick="@(() => Nav.NavigateTo($"/offers/edit/{o.Id}"))"
                     style="cursor:pointer;display:flex;gap:12px;align-items:center;padding:14px;margin-bottom:10px;background:var(--ac-surface);border:1px solid var(--ac-border);border-radius:var(--ac-radius-md);transition:box-shadow 150ms,border-color 150ms;"
                     @onmouseover="@(e => {})" class="vnd-offer-card">
                    <div style="font-size:1.8rem;width:44px;text-align:center;flex-shrink:0;">@(o.Emoji ?? "🍽️")</div>
                    <div style="flex:1;min-width:0;">
                        <div style="font-weight:600;">@o.Title</div>
                        <div class="ac-text-muted" style="font-size:0.85rem;">
                            @o.Price.ToString("0.##") @o.Currency
                            @if (o.OriginalPrice is > 0 && o.OriginalPrice > o.Price)
                            {
                                <span style="text-decoration:line-through;margin-inline-start:6px;opacity:0.5;">@o.OriginalPrice.Value.ToString("0.##")</span>
                            }
                        </div>
                    </div>
                    <AcIcon Name="chevron-left" Size="18" />
                </div>
            }
        }
    </div>
</AcAuthGuard>

@code {
    private List<OfferRow> MyOffers = new();
    private bool Loading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (Store.Auth.IsAuthenticated)
        {
            var vEnv = await Reader.GetAsync<List<VendorRow>>("/api/vendors");
            var myV = vEnv.Data?.FirstOrDefault(v => v.OwnerId == Store.Auth.UserId);
            if (myV != null)
            {
                var env = await Reader.GetAsync<List<OfferRow>>($"/api/offers?vendorId={myV.Id}");
                MyOffers = env.Data ?? new();
            }
        }
        Loading = false;
        StateHasChanged();
    }

    public class VendorRow { public Guid Id { get; set; } public Guid OwnerId { get; set; } }
    public class OfferRow
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = "";
        public decimal Price { get; set; }
        public decimal? OriginalPrice { get; set; }
        public string Currency { get; set; } = "SAR";
        public string? Emoji { get; set; }
    }
}
