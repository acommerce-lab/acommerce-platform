@page "/offers"
@inject VendorApiClient Api
@inject AppStore Store
@inject NavigationManager Nav

<PageTitle>@(Store.Ui.IsArabic ? "عروضي" : "My Offers")</PageTitle>

@if (!Store.Auth.IsAuthenticated)
{
    <AcEmptyState IconName="log-in" Title="@(Store.Ui.IsArabic ? "سجّل دخولك" : "Sign in")" ActionHref="/login" ActionLabel="@(Store.Ui.IsArabic ? "دخول" : "Sign in")" />
}
else
{
    <div class="acs-page">
        <AcPageHeader Title="@(Store.Ui.IsArabic ? "عروضي" : "My Offers")">
            <Actions>
                <a class="btn btn-primary btn-sm" href="/offers/new">
                    <AcIcon Name="plus" Size="16" /> @(Store.Ui.IsArabic ? "عرض جديد" : "New offer")
                </a>
            </Actions>
        </AcPageHeader>

        @if (Loading)
        {
            <AcLoadingState Message="@(Store.Ui.IsArabic ? "جاري التحميل..." : "Loading…")" />
        }
        else if (MyOffers.Count == 0)
        {
            <AcEmptyState IconName="tag"
                          Title="@(Store.Ui.IsArabic ? "لا عروض بعد" : "No offers yet")"
                          Message="@(Store.Ui.IsArabic ? "أنشئ عرضك الأول لبدء البيع" : "Create your first offer")"
                          ActionLabel="@(Store.Ui.IsArabic ? "إنشاء عرض" : "Create offer")"
                          ActionHref="/offers/new" />
        }
        else
        {
            @foreach (var o in MyOffers)
            {
                <AcCard Hover Class="acm-offer-row">
                    <ChildContent>
                        <div class="acm-offer-emoji">@(o.Emoji ?? "🍽️")</div>
                        <div class="acm-offer-body">
                            <div class="acm-offer-title">@o.Title</div>
                            <div class="acm-offer-price">
                                @o.Price.ToString("0.##") @o.Currency
                                @if (o.OriginalPrice is > 0 && o.OriginalPrice > o.Price)
                                {
                                    <span class="acm-offer-original-price">@o.OriginalPrice.Value.ToString("0.##")</span>
                                }
                            </div>
                        </div>
                        <div class="acm-offer-actions">
                            <a class="btn btn-ghost btn-sm" href="/offers/edit/@o.Id">
                                <AcIcon Name="settings" Size="14" />
                            </a>
                        </div>
                    </ChildContent>
                </AcCard>
            }
        }
    </div>
}

@code {
    private List<OfferRow> MyOffers = new();
    private bool Loading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (Store.Auth.IsAuthenticated)
        {
            var vEnv = await Api.GetAsync<List<VendorRow>>("/api/vendors");
            var myV = vEnv.Data?.FirstOrDefault(v => v.OwnerId == Store.Auth.UserId);
            if (myV != null)
            {
                var env = await Api.GetAsync<List<OfferRow>>($"/api/offers?vendorId={myV.Id}");
                MyOffers = env.Data ?? new();
            }
        }
        Loading = false;
        StateHasChanged();
    }

    public class VendorRow { public Guid Id { get; set; } public Guid OwnerId { get; set; } }
    public class OfferRow
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = "";
        public decimal Price { get; set; }
        public decimal? OriginalPrice { get; set; }
        public string Currency { get; set; } = "SAR";
        public string? Emoji { get; set; }
    }
}
