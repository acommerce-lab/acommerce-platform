@page "/orders"
@inject ApiReader Reader
@inject ClientOpEngine Engine
@inject AppStore Store

<PageTitle>@(Store.Ui.IsArabic ? "الطلبات" : "Orders")</PageTitle>

@if (!Store.Auth.IsAuthenticated)
{
    <AcEmptyState IconName="log-in"
                  Title="@(Store.Ui.IsArabic ? "سجّل دخولك" : "Sign in")"
                  ActionHref="/login"
                  ActionLabel="@(Store.Ui.IsArabic ? "دخول" : "Sign in")" />
}
else
{
    <div class="acs-page">
        <h1 class="acs-page-title">@(Store.Ui.IsArabic ? "الطلبات" : "Orders")</h1>

        <AcSegmentControl
            Items="@Segments"
            ActiveKey="@Filter"
            OnSelect="@(k => { Filter = k; StateHasChanged(); })" />

        @if (Loading)
        {
            <AcLoadingState Message="@(Store.Ui.IsArabic ? "جاري التحميل..." : "Loading…")" />
        }
        else if (Visible.Count == 0)
        {
            <AcEmptyState IconName="inbox"
                          Title="@(Store.Ui.IsArabic ? "لا طلبات" : "No orders")" />
        }
        else
        {
            @foreach (var o in Visible)
            {
                <AcVendorOrderCard
                    Order="@o"
                    Mode="TemplateOperationMode.Callback"
                    ConfirmLabel="@(Store.Ui.IsArabic ? "قبول الطلب"     : "Accept order")"
                    ReadyLabel="@(Store.Ui.IsArabic   ? "الطلب جاهز"    : "Mark ready")"
                    CancelLabel="@(Store.Ui.IsArabic  ? "رفض / إلغاء"   : "Reject / Cancel")"
                    TotalLabel="@(Store.Ui.IsArabic   ? "الإجمالي"       : "Total")"
                    NotesLabel="@(Store.Ui.IsArabic   ? "ملاحظات"        : "Notes")"
                    OnConfirm="HandleConfirm"
                    OnReady="HandleReady"
                    OnCancel="HandleCancel" />
            }
        }
    </div>
}

@code {
    private List<MerchantOrderRowDto> AllOrders = new();
    private bool Loading = true;
    private string Filter = "all";

    private IReadOnlyList<AcSegmentControl.SegmentItem> Segments => new[]
    {
        new AcSegmentControl.SegmentItem("all",       Store.Ui.IsArabic ? "الكل"    : "All"),
        new AcSegmentControl.SegmentItem("pending",   Store.Ui.IsArabic ? "معلقة"  : "Pending"),
        new AcSegmentControl.SegmentItem("confirmed", Store.Ui.IsArabic ? "مقبولة" : "Accepted"),
        new AcSegmentControl.SegmentItem("ready",     Store.Ui.IsArabic ? "جاهزة"  : "Ready"),
    };

    private List<MerchantOrderRowDto> Visible => Filter switch
    {
        "pending"   => AllOrders.Where(o => o.Status == "pending").ToList(),
        "confirmed" => AllOrders.Where(o => o.Status == "confirmed").ToList(),
        "ready"     => AllOrders.Where(o => o.Status == "ready").ToList(),
        _           => AllOrders
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (Store.Auth.IsAuthenticated)
        {
            var env = await Reader.GetAsync<List<OrderRow>>(
                $"/api/vendor-orders/by-vendor/{Store.Auth.UserId}");
            AllOrders = (env.Data ?? new()).Select(ToDto).ToList();
        }
        Loading = false;
        StateHasChanged();
    }

    private async Task HandleConfirm(MerchantOrderRowDto o)
    {
        if (!Guid.TryParse(o.Id, out var id)) return;
        await Engine.ExecuteAsync<object>(ClientOps.AcceptOrder(id), new {});
        UpdateStatus(o.Id, "confirmed");
    }

    private async Task HandleReady(MerchantOrderRowDto o)
    {
        if (!Guid.TryParse(o.Id, out var id)) return;
        await Engine.ExecuteAsync<object>(ClientOps.ReadyOrder(id), new {});
        UpdateStatus(o.Id, "ready");
    }

    private async Task HandleCancel(MerchantOrderRowDto o)
    {
        if (!Guid.TryParse(o.Id, out var id)) return;
        await Engine.ExecuteAsync<object>(ClientOps.RejectOrder(id), new {});
        UpdateStatus(o.Id, "cancelled");
    }

    private void UpdateStatus(string id, string newStatus)
    {
        var idx = AllOrders.FindIndex(o => o.Id == id);
        if (idx >= 0)
            AllOrders[idx] = AllOrders[idx] with { Status = newStatus };
        StateHasChanged();
    }

    private static MerchantOrderRowDto ToDto(OrderRow o) => new()
    {
        Id           = o.Id.ToString(),
        CustomerName = o.CustomerName,
        CustomerPhone = o.CustomerPhone,
        Total        = o.Total,
        Currency     = o.Currency,
        Status       = IntToCardStatus(o.Status),
        CreatedAt    = o.CreatedAt,
        Notes        = o.CustomerNotes,
    };

    // AcVendorOrderCard checks: "pending" | "confirmed" | "ready" | "delivered" | "cancelled"
    private static string IntToCardStatus(int s) => s switch
    {
        0 => "pending",
        1 => "confirmed",
        2 => "ready",
        3 => "delivered",
        4 => "cancelled",
        _ => "pending"
    };

    public class OrderRow
    {
        public Guid Id { get; set; }
        public string OrderNumber { get; set; } = "";
        public decimal Total { get; set; }
        public string Currency { get; set; } = "SAR";
        public int Status { get; set; }
        public DateTime CreatedAt { get; set; }
        public string CustomerName { get; set; } = "";
        public string? CustomerPhone { get; set; }
        public string? CustomerNotes { get; set; }
    }
}
