@page "/store-settings"
@inject AppStore Store
@inject VendorApiClient VendorApi
@inject ApiReader Reader

<PageTitle>@(Store.Ui.IsArabic ? "إعدادات المتجر" : "Store Settings")</PageTitle>

<AcAuthGuard IsAuthenticated="@Store.Auth.IsAuthenticated" IsArabic="@Store.Ui.IsArabic" LoginHref="/login">
    <div class="acs-page">
        <AcPageHeader Title="@(Store.Ui.IsArabic ? "إعدادات المتجر" : "Store Settings")"
                      Subtitle="@(Store.Ui.IsArabic ? "إعدادات قبول الطلبات" : "Order acceptance settings")" />

        @if (_loading)
        {
            <AcLoadingState Message="@(Store.Ui.IsArabic ? "جاري التحميل..." : "Loading…")" />
        }
        else if (_vendorId == null)
        {
            <AcEmptyState IconName="alert-circle"
                          Title="@(Store.Ui.IsArabic ? "لم يتم العثور على متجر مرتبط بحسابك" : "No store linked to your account")" />
        }
        else
        {
            <AcCard Class="ac-mb-lg">
                <Header>
                    <strong>@(Store.Ui.IsArabic ? "بيانات المتجر" : "Store Info")</strong>
                </Header>
                <ChildContent>
                    <div class="ac-mb-sm">
                        <span class="ac-text-muted" style="font-size:0.85rem;">
                            @(Store.Ui.IsArabic ? "اسم المتجر:" : "Store Name:")
                        </span>
                        <div style="font-weight:600;">@_storeName</div>
                    </div>
                    <div class="ac-mb-sm">
                        <span class="ac-text-muted" style="font-size:0.85rem;">
                            @(Store.Ui.IsArabic ? "رقم التواصل:" : "Phone:")
                        </span>
                        <div dir="ltr">@_storePhone</div>
                    </div>
                    @if (!string.IsNullOrEmpty(_storeDescription))
                    {
                        <div>
                            <span class="ac-text-muted" style="font-size:0.85rem;">
                                @(Store.Ui.IsArabic ? "الوصف:" : "Description:")
                            </span>
                            <div>@_storeDescription</div>
                        </div>
                    }
                </ChildContent>
            </AcCard>

            <AcCard Class="ac-mb-lg">
                <Header>
                    <strong>@(Store.Ui.IsArabic ? "إعدادات الطلبات" : "Order Settings")</strong>
                </Header>
                <ChildContent>
                    <AcField Label="@(Store.Ui.IsArabic ? "قبول الطلبات" : "Accepting Orders")" Class="ac-mb-md">
                        <div style="display:flex;align-items:center;gap:8px;">
                            <input type="checkbox" checked="@_acceptingOrders"
                                   @onchange="@(e => _acceptingOrders = (bool)(e.Value ?? false))" />
                            <span>
                                @(Store.Ui.IsArabic
                                    ? (_acceptingOrders ? "مفعّل" : "معطّل")
                                    : (_acceptingOrders ? "Enabled" : "Disabled"))
                            </span>
                        </div>
                    </AcField>
                    <AcField Label="@(Store.Ui.IsArabic ? "الحد الأقصى للطلبات المعلقة" : "Max Concurrent Pending")" Class="ac-mb-md">
                        <AcInput Type="number" Value="@_maxConcurrentPending.ToString()"
                                 ValueChanged="@(v => _maxConcurrentPending = int.TryParse(v, out var n) ? n : _maxConcurrentPending)" />
                    </AcField>
                    <AcField Label="@(Store.Ui.IsArabic ? "مهلة الطلب (دقائق)" : "Order Timeout (minutes)")" Class="ac-mb-md">
                        <AcInput Type="number" Value="@_orderTimeoutMinutes.ToString()"
                                 ValueChanged="@(v => _orderTimeoutMinutes = int.TryParse(v, out var n) ? Math.Max(1,n) : _orderTimeoutMinutes)" />
                    </AcField>

                    <AcButton Variant="primary" Block="true"
                              Text="@(_saving ? (Store.Ui.IsArabic ? "جاري الحفظ..." : "Saving...") : (Store.Ui.IsArabic ? "حفظ الإعدادات" : "Save Settings"))"
                              Disabled="@_saving" Loading="@_saving"
                              OnClick="HandleSave" />
                </ChildContent>
            </AcCard>

            @if (!string.IsNullOrEmpty(_successMessage))
            {
                <AcAlert Variant="success" Message="@_successMessage" />
            }
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <AcAlert Variant="danger" Message="@_errorMessage" />
            }
        }
    </div>
</AcAuthGuard>

@code {
    private Guid? _vendorId;
    private bool _loading = true;
    private bool _saving;

    private string _storeName = "";
    private string _storePhone = "";
    private string _storeDescription = "";
    private bool _acceptingOrders = true;
    private int _maxConcurrentPending = 5;
    private int _orderTimeoutMinutes = 10;

    private string? _successMessage;
    private string? _errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!Store.Auth.IsAuthenticated) { _loading = false; StateHasChanged(); return; }

        try
        {
            // Find vendor in Order.Api by OwnerId
            var vEnv = await Reader.GetAsync<List<VendorRow>>("/api/vendors");
            var myVendor = vEnv.Data?.FirstOrDefault(v => v.OwnerId == Store.Auth.UserId);
            if (myVendor != null)
            {
                _vendorId = myVendor.Id;
                _storeName = myVendor.Name ?? "";
                _storePhone = myVendor.Phone ?? "";
                _storeDescription = myVendor.Description ?? "";

                // Load operational settings from Vendor.Api
                var sEnv = await VendorApi.GetAsync<SettingsDto>(
                    $"/api/vendor-settings/{_vendorId}");
                if (sEnv.Data != null)
                {
                    _acceptingOrders = sEnv.Data.AcceptingOrders;
                    _maxConcurrentPending = sEnv.Data.MaxConcurrentPending;
                    _orderTimeoutMinutes = sEnv.Data.OrderTimeoutMinutes;
                }
            }
        }
        catch { /* prevent circuit crash */ }

        _loading = false;
        StateHasChanged();
    }

    private async Task HandleSave()
    {
        _successMessage = null;
        _errorMessage = null;
        if (!_vendorId.HasValue) return;

        _saving = true;
        try
        {
            var payload = new
            {
                AcceptingOrders = _acceptingOrders,
                MaxConcurrentPending = _maxConcurrentPending,
                OrderTimeoutMinutes = _orderTimeoutMinutes
            };

            var result = await VendorApi.PutAsync<object>(
                $"/api/vendor-settings/{_vendorId}", payload);

            if (result.Error == null)
                _successMessage = Store.Ui.IsArabic ? "تم حفظ الإعدادات بنجاح" : "Settings saved successfully";
            else
                _errorMessage = Store.Ui.IsArabic ? "حدث خطأ أثناء الحفظ" : "An error occurred while saving";
        }
        catch
        {
            _errorMessage = Store.Ui.IsArabic ? "حدث خطأ أثناء الحفظ" : "An error occurred while saving";
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    public class VendorRow
    {
        public Guid Id { get; set; }
        public Guid OwnerId { get; set; }
        public string? Name { get; set; }
        public string? Phone { get; set; }
        public string? Description { get; set; }
    }

    public class SettingsDto
    {
        public bool AcceptingOrders { get; set; } = true;
        public int MaxConcurrentPending { get; set; } = 5;
        public int OrderTimeoutMinutes { get; set; } = 10;
    }
}
