@page "/offers/new"
@inject OrderApiClient OrderApi
@inject ApiReader Reader
@inject AppStore Store
@inject NavigationManager Nav

<PageTitle>@(Store.Ui.IsArabic ? "عرض جديد" : "New Offer")</PageTitle>

@if (!Store.Auth.IsAuthenticated)
{
    <AcEmptyState IconName="log-in"
                  Title="@(Store.Ui.IsArabic ? "سجّل دخولك" : "Sign in")"
                  ActionHref="/login"
                  ActionLabel="@(Store.Ui.IsArabic ? "دخول" : "Sign in")" />
}
else if (_loadingVendor)
{
    <AcLoadingState Message="@(Store.Ui.IsArabic ? "جاري التحميل..." : "Loading…")" />
}
else
{
    <AcVendorOfferForm
        Mode="TemplateOperationMode.Callback"
        Form="@_form"
        Title="@(Store.Ui.IsArabic ? "عرض جديد" : "New Offer")"
        TitleLabel="@(Store.Ui.IsArabic ? "اسم العرض" : "Offer title")"
        TitlePlaceholder="@(Store.Ui.IsArabic ? "أدخل اسم العرض" : "Enter offer title")"
        DescriptionLabel="@(Store.Ui.IsArabic ? "الوصف" : "Description")"
        DescriptionPlaceholder="@(Store.Ui.IsArabic ? "وصف مختصر للعرض..." : "Brief description…")"
        PriceLabel="@(Store.Ui.IsArabic ? "السعر" : "Price")"
        EmojiLabel="@(Store.Ui.IsArabic ? "الإيموجي" : "Emoji")"
        CategoryLabel="@(Store.Ui.IsArabic ? "الفئة" : "Category")"
        CategoryPlaceholder="@(Store.Ui.IsArabic ? "مثال: مشروبات" : "e.g. Drinks")"
        AvailableLabel="@(Store.Ui.IsArabic ? "متاح للطلب" : "Available")"
        SubmitLabel="@(Store.Ui.IsArabic ? "حفظ" : "Save")"
        OnSubmit="HandleSubmit" />
}

@code {
    private OfferFormModel _form = new();
    private Guid? _vendorId;
    private bool _loadingVendor = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (Store.Auth.IsAuthenticated)
        {
            var vEnv = await Reader.GetAsync<List<VendorRow>>("/api/vendors");
            var myV = vEnv.Data?.FirstOrDefault(v => v.OwnerId == Store.Auth.UserId);
            _vendorId = myV?.Id;
        }
        _loadingVendor = false;
        StateHasChanged();
    }

    private async Task HandleSubmit(OfferFormModel form)
    {
        if (!_vendorId.HasValue) return;
        var result = await OrderApi.PostAsync<object>("/api/offers", new
        {
            VendorId = _vendorId.Value,
            form.Title,
            form.Description,
            form.Price,
            form.Emoji,
            form.Category,
            form.IsAvailable,
        });
        if (result.Error == null) Nav.NavigateTo("/offers");
    }

    public class VendorRow { public Guid Id { get; set; } public Guid OwnerId { get; set; } }
}
