@page "/offers/edit/{Id:guid}"
@inject OrderApiClient OrderApi
@inject ApiReader Reader
@inject AppStore Store
@inject NavigationManager Nav

<PageTitle>@(Store.Ui.IsArabic ? "تعديل العرض" : "Edit Offer")</PageTitle>

@if (!Store.Auth.IsAuthenticated)
{
    <AcEmptyState IconName="log-in"
                  Title="@(Store.Ui.IsArabic ? "سجّل دخولك" : "Sign in")"
                  ActionHref="/login"
                  ActionLabel="@(Store.Ui.IsArabic ? "دخول" : "Sign in")" />
}
else if (_loading)
{
    <AcLoadingState Message="@(Store.Ui.IsArabic ? "جاري التحميل..." : "Loading…")" />
}
else
{
    <AcVendorOfferForm
        Mode="TemplateOperationMode.Callback"
        Form="@_form"
        Title="@(Store.Ui.IsArabic ? "تعديل العرض" : "Edit Offer")"
        TitleLabel="@(Store.Ui.IsArabic ? "اسم العرض" : "Offer title")"
        TitlePlaceholder="@(Store.Ui.IsArabic ? "أدخل اسم العرض" : "Enter offer title")"
        DescriptionLabel="@(Store.Ui.IsArabic ? "الوصف" : "Description")"
        DescriptionPlaceholder="@(Store.Ui.IsArabic ? "وصف مختصر للعرض..." : "Brief description…")"
        PriceLabel="@(Store.Ui.IsArabic ? "السعر" : "Price")"
        EmojiLabel="@(Store.Ui.IsArabic ? "الإيموجي" : "Emoji")"
        CategoryLabel="@(Store.Ui.IsArabic ? "الفئة" : "Category")"
        CategoryPlaceholder="@(Store.Ui.IsArabic ? "مثال: مشروبات" : "e.g. Drinks")"
        AvailableLabel="@(Store.Ui.IsArabic ? "متاح للطلب" : "Available")"
        SubmitLabel="@(Store.Ui.IsArabic ? "حفظ التعديلات" : "Save changes")"
        OnSubmit="HandleSubmit" />
}

@code {
    [Parameter] public Guid Id { get; set; }

    private OfferFormModel _form = new();
    private bool _loading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (Store.Auth.IsAuthenticated)
        {
            var env = await Reader.GetAsync<OfferDetail>($"/api/offers/{Id}");
            if (env.Data != null)
            {
                var d = env.Data;
                _form = new OfferFormModel
                {
                    Title       = d.Title,
                    Description = d.Description,
                    Price       = d.Price,
                    Emoji       = d.Emoji,
                    Category    = d.Category,
                    IsAvailable = d.IsAvailable,
                };
            }
        }
        _loading = false;
        StateHasChanged();
    }

    private async Task HandleSubmit(OfferFormModel form)
    {
        var result = await OrderApi.PutAsync<object>($"/api/offers/{Id}", new
        {
            form.Title,
            form.Description,
            form.Price,
            form.Emoji,
            form.Category,
            form.IsAvailable,
        });
        if (result.Error == null) Nav.NavigateTo("/offers");
    }

    public class OfferDetail
    {
        public string Title { get; set; } = "";
        public string? Description { get; set; }
        public decimal Price { get; set; }
        public string? Emoji { get; set; }
        public string? Category { get; set; }
        public bool IsAvailable { get; set; } = true;
    }
}
