@inherits LayoutComponentBase
@inject AppStore Store
@inject AuthStateService AuthService
@inject IJSRuntime JS
@implements IDisposable

<div class="ord-shell">
    <main class="ord-main">
        @Body
    </main>

    <nav class="ord-bottom-nav">
        <NavLink href="/" Match="NavLinkMatch.All" class="ord-nav-item">
            <AcIcon Name="home" Size="20" />
            <span>@(Store.Ui.IsArabic ? "الرئيسية" : "Home")</span>
        </NavLink>
        <NavLink href="/search" class="ord-nav-item">
            <AcIcon Name="search" Size="20" />
            <span>@(Store.Ui.IsArabic ? "بحث" : "Search")</span>
        </NavLink>
        <NavLink href="/cart" class="ord-nav-item ord-nav-cart">
            <div class="ord-nav-cart-btn">
                <AcIcon Name="bag" Size="20" />
                @if (Store.Cart.Count > 0)
                {
                    <span class="ord-cart-badge">@Store.Cart.Count</span>
                }
            </div>
            <span>@(Store.Ui.IsArabic ? "السلة" : "Cart")</span>
        </NavLink>
        <NavLink href="/orders" class="ord-nav-item">
            <AcIcon Name="receipt" Size="20" />
            <span>@(Store.Ui.IsArabic ? "طلباتي" : "Orders")</span>
        </NavLink>
        <NavLink href="@(Store.Auth.IsAuthenticated ? "/profile" : "/login")" class="ord-nav-item">
            <AcIcon Name="user" Size="20" />
            <span>@(Store.Ui.IsArabic ? "حسابي" : "Profile")</span>
        </NavLink>
    </nav>
</div>

@code {
    protected override void OnInitialized()
    {
        Store.OnChanged += OnChange;
    }

    private string _lastAppliedTheme = "";
    private string _lastAppliedLang  = "";
    private Guid? _lastPersistedUserId;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Restore auth from ProtectedLocalStorage → AppStore
            await AuthService.EnsureRestoredAsync();
            if (AuthService.IsAuthenticated)
            {
                Store.Auth.UserId = AuthService.UserId;
                Store.Auth.PhoneNumber = AuthService.PhoneNumber;
                Store.Auth.FullName = AuthService.FullName;
                Store.Auth.AccessToken = AuthService.AccessToken;
                _lastPersistedUserId = AuthService.UserId;
                Store.NotifyChanged();
            }

            _lastAppliedTheme = Store.Ui.Theme;
            _lastAppliedLang  = Store.Ui.Language;
        }

        // Persist auth state when it changes
        await SyncAuthToStorageAsync();

        // Push theme/lang to <html> attributes via JS interop
        if (_lastAppliedTheme != Store.Ui.Theme)
        {
            _lastAppliedTheme = Store.Ui.Theme;
            try { await JS.InvokeVoidAsync("acTheme.set", Store.Ui.Theme); } catch { }
        }
        if (_lastAppliedLang != Store.Ui.Language)
        {
            _lastAppliedLang = Store.Ui.Language;
            try { await JS.InvokeVoidAsync("acLang.set", Store.Ui.Language); } catch { }
        }
    }

    private async Task SyncAuthToStorageAsync()
    {
        if (Store.Auth.IsAuthenticated && Store.Auth.UserId != _lastPersistedUserId)
        {
            _lastPersistedUserId = Store.Auth.UserId;
            try
            {
                await AuthService.SignInAsync(
                    Store.Auth.UserId!.Value,
                    Store.Auth.PhoneNumber,
                    Store.Auth.FullName,
                    Store.Auth.AccessToken!);
            }
            catch { }
        }
        else if (!Store.Auth.IsAuthenticated && _lastPersistedUserId.HasValue)
        {
            _lastPersistedUserId = null;
            try { await AuthService.SignOutAsync(); } catch { }
        }
    }

    private void OnChange() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Store.OnChanged -= OnChange;
    }
}
