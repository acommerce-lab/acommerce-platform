@page "/messages"
@inject AppStore Store
@inject ApiReader Api
@inject NavigationManager Nav
@inject LocalizationService Localization

<PageTitle>@(Localization["messages_page_title"]) - @(Localization["app_name"])</PageTitle>

@if (!Store.Auth.IsAuthenticated)
{
    <AcEmptyState IconName="message"
                  Title="@(Localization["messages_signin_title"])"
                  ActionLabel="@(Localization["common_signin"])"
                  ActionHref="/login" />
}
else
{
    <AcMessagesListPage Conversations="@Mapped"
                        Loading="@Loading"
                        Title="@(Localization["messages_title"])"
                        LoadingMessage="@(Localization["common_loading_dots"])"
                        EmptyTitle="@(Localization["messages_empty_title"])"
                        EmptyMessage="@(Localization["messages_empty_message"])"
                        OnSelectConversation="@SelectConversation" />
}

@code {
    private List<ConvApi> Conversations = new();
    private bool Loading = true;

    private IReadOnlyList<ConversationRowDto> Mapped =>
        Conversations
            .Where(c => c.LastMessageAt.HasValue)
            .Select(c => new ConversationRowDto
            {
                Id = c.Id.ToString(),
                Title = c.Title,
                Emoji = c.Emoji,
                LastMessageSnippet = c.LastMessageSnippet,
                LastMessageAt = c.LastMessageAt,
                Unread = c.Unread
            }).ToList();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (Store.Auth.IsAuthenticated)
        {
            var env = await Api.GetAsync<List<ConvApi>>($"/api/messages/conversations/by-user/{Store.Auth.UserId}");
            Conversations = env.Data ?? new();
        }
        Loading = false;
        StateHasChanged();
    }

    private void SelectConversation(ConversationRowDto c)
    {
        Nav.NavigateTo($"/chat/{c.Id}");
    }

    public class ConvApi
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = "";
        public string Emoji { get; set; } = "💬";
        public string? LastMessageSnippet { get; set; }
        public DateTime? LastMessageAt { get; set; }
        public int Unread { get; set; }
    }
}
