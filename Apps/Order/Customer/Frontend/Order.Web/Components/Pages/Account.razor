@page "/account"
@inject AppStore Store
@inject ApiReader Reader
@inject ClientOpEngine Engine
@inject NavigationManager Nav
@inject LocalizationService Localization

<PageTitle>@(Localization["account_page_title"]) - @(Localization["app_name"])</PageTitle>

<AcAuthGuard IsAuthenticated="@Store.Auth.IsAuthenticated" IsArabic="@Store.Ui.IsArabic" LoginHref="/login">
    @if (Loading)
    {
        <AcLoadingState Message="@(Localization["common_loading_dots"])" />
    }
    else
    {
        <div class="acs-page" style="padding: 16px">
            <AcPageHeader Title="@(Localization["account_title"])"
                          Subtitle="@(Localization["account_subtitle"])" />

            <AcCard Class="ac-mb-lg">
                <Header>
                    <strong>@(Localization["account_personal_info"])</strong>
                </Header>
                <ChildContent>
                    <AcField Label="@(Localization["account_full_name"])" Class="ac-mb-md">
                        <AcInput Value="@FullName"
                                 Placeholder="@(Localization["account_full_name_placeholder"])"
                                 ValueChanged="@(v => FullName = v ?? "")" />
                    </AcField>

                    <AcField Label="@(Localization["account_email"])">
                        <AcInput Value="@Email"
                                 Type="email"
                                 Placeholder="@(Localization["account_email_placeholder"])"
                                 ValueChanged="@(v => Email = v ?? "")" />
                    </AcField>
                </ChildContent>
            </AcCard>

            <AcCard Class="ac-mb-lg">
                <Header>
                    <div style="display:flex;align-items:center;gap:0.5rem">
                        <AcIcon Name="car" Size="16" />
                        <strong>@(Localization["account_car_details"])</strong>
                    </div>
                </Header>
                <ChildContent>
                    <p class="ac-text-muted ac-text-sm ac-mb-md">
                        @(Localization["account_car_hint"])
                    </p>

                    <AcField Label="@(Localization["account_car_model"])" Class="ac-mb-md">
                        <AcInput Value="@CarModel"
                                 Placeholder="@(Localization["account_car_model_placeholder"])"
                                 ValueChanged="@(v => CarModel = v ?? "")" />
                    </AcField>

                    <AcField Label="@(Localization["account_car_color"])" Class="ac-mb-md">
                        <AcInput Value="@CarColor"
                                 Placeholder="@(Localization["account_car_color_placeholder"])"
                                 ValueChanged="@(v => CarColor = v ?? "")" />
                    </AcField>

                    <AcField Label="@(Localization["account_car_plate"])">
                        <AcInput Value="@CarPlate"
                                 Placeholder="@(Localization["account_car_plate_placeholder"])"
                                 ValueChanged="@(v => CarPlate = v ?? "")" />
                    </AcField>
                </ChildContent>
            </AcCard>

            @if (!string.IsNullOrEmpty(Message))
            {
                <AcAlert Variant="@MessageVariant" Message="@Message" Class="ac-mb-md" />
            }

            <AcButton Variant="primary"
                      Block="true"
                      Text="@(Saving ? Localization["account_saving"] : Localization["account_save"])"
                      Loading="@Saving"
                      Disabled="@Saving"
                      OnClick="Save" />
        </div>
    }
</AcAuthGuard>

@code {
    private bool Loading = true;
    private bool Saving;
    private string? Message;
    private string MessageVariant = "info";

    private string FullName = "";
    private string Email = "";
    private string CarModel = "";
    private string CarColor = "";
    private string CarPlate = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!Store.Auth.IsAuthenticated || !Store.Auth.UserId.HasValue)
        {
            Loading = false;
            StateHasChanged();
            return;
        }

        try
        {
            var env = await Reader.GetAsync<UserProfile>($"/api/users/{Store.Auth.UserId}");
            if (env.Data != null)
            {
                FullName = env.Data.FullName ?? "";
                Email = env.Data.Email ?? "";
                CarModel = env.Data.CarModel ?? "";
                CarColor = env.Data.CarColor ?? "";
                CarPlate = env.Data.CarPlate ?? "";
            }
        }
        catch { }

        Loading = false;
        StateHasChanged();
    }

    private async Task Save()
    {
        Message = null;
        if (string.IsNullOrWhiteSpace(FullName))
        {
            Message = Localization["account_name_required"];
            MessageVariant = "warning";
            return;
        }

        Saving = true;
        try
        {
            var payload = new
            {
                fullName = FullName.Trim(),
                email = Email.Trim(),
                carModel = CarModel.Trim(),
                carColor = CarColor.Trim(),
                carPlate = CarPlate.Trim()
            };

            var result = await Engine.ExecuteAsync<object>(
                ClientOps.UpdateProfile(Store.Auth.UserId!.Value), payload);

            if (result.Operation.Status == "Success")
            {
                Message = Localization["account_saved"];
                MessageVariant = "success";
            }
            else
            {
                Message = result.Operation.ErrorMessage
                          ?? result.Error?.Message
                          ?? Localization["account_save_failed"];
                MessageVariant = "danger";
            }
        }
        catch (Exception ex)
        {
            Message = ex.Message;
            MessageVariant = "danger";
        }
        finally
        {
            Saving = false;
            StateHasChanged();
        }
    }

    public class UserProfile
    {
        public Guid Id { get; set; }
        public string? FullName { get; set; }
        public string? Email { get; set; }
        public string? Theme { get; set; }
        public string? Language { get; set; }
        public string? CarModel { get; set; }
        public string? CarColor { get; set; }
        public string? CarPlate { get; set; }
    }
}
