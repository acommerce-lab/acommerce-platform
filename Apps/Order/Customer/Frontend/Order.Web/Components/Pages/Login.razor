@page "/login"
@inject AppStore Store
@inject ClientOpEngine Engine
@inject NavigationManager Nav
@inject LocalizationService Localization

<PageTitle>@(Localization["login_page_title"]) - @(Localization["app_name"])</PageTitle>

<AcLoginPage Mode="TemplateOperationMode.Operation"
             Engine="Engine"
             BuildRequestOtpOp="@(phone => ClientOps.RequestOtp(phone))"
             BuildVerifyOtpOp="@((uid, cid, code) => ClientOps.VerifyOtp(uid, cid, code))"
             PhonePayload="@(phone => new { phoneNumber = phone })"
             VerifyPayload="@((uid, cid, code) => new { userId = uid, challengeId = cid, code })"
             RedirectUrl="@(string.IsNullOrEmpty(ReturnUrl) ? "/" : ReturnUrl)"
             BrandName="@(Localization["login_brand_name"])"
             BrandTagline="@(Localization["login_brand_tagline"])"
             PhoneStepTitle="@(Localization["login_phone_title"])"
             PhoneStepSubtitle="@(Localization["login_phone_subtitle"])"
             PhoneLabel="@(Localization["login_phone_label"])"
             RequestOtpLabel="@(Localization["login_request_otp"])"
             SendingLabel="@(Localization["login_sending"])"
             OtpStepTitle="@(Localization["login_otp_title"])"
             OtpStepSubtitle="@(Localization["login_otp_subtitle"])"
             OtpLabel="@(Localization["login_otp_label"])"
             VerifyOtpLabel="@(Localization["login_verify_otp"])"
             VerifyingLabel="@(Localization["login_verifying"])"
             BackLabel="@(Localization["login_back"])">
    <HintSlot>
        <strong>@(Localization["login_demo_mode"])</strong>
        @(Localization["login_demo_hint"])
        <br />
        <span style="font-size:0.875rem">@(Localization["login_demo_accounts"])</span>
        <code dir="ltr">+966500000001</code>
    </HintSlot>
</AcLoginPage>

@code {
    [SupplyParameterFromQuery(Name = "return")] public string? ReturnUrl { get; set; }
}
