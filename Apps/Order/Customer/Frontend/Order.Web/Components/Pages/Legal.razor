@page "/legal"
@inject AppStore Store
@inject LocalizationService Localization

<PageTitle>@(Localization["legal_page_title"]) - @(Localization["app_name"])</PageTitle>

<div class="acs-page">
    <AcPageHeader Title="@(Localization["legal_title"])"
                  Subtitle="@(Localization["legal_subtitle"])" />

    <AcCard Class="ac-mb-lg">
        <Header>
            <strong>@(Localization["legal_terms_of_use"])</strong>
        </Header>
        <ChildContent>
            <p class="ac-mb-sm">@(Localization["legal_terms_intro"])</p>
            <ul style="padding-inline-start:1.2rem">
                <li class="ac-mb-sm">@(Localization["legal_terms_age"])</li>
                <li class="ac-mb-sm">@(Localization["legal_terms_accuracy"])</li>
                <li class="ac-mb-sm">@(Localization["legal_terms_illegal"])</li>
                <li class="ac-mb-sm">@(Localization["legal_terms_suspend"])</li>
                <li>@(Localization["legal_terms_prices"])</li>
            </ul>
        </ChildContent>
    </AcCard>

    <AcCard Class="ac-mb-lg">
        <Header>
            <strong>@(Localization["legal_privacy_title"])</strong>
        </Header>
        <ChildContent>
            <p class="ac-mb-sm">@(Localization["legal_privacy_intro"])</p>
            <ul style="padding-inline-start:1.2rem">
                <li class="ac-mb-sm">@(Localization["legal_privacy_data"])</li>
                <li class="ac-mb-sm">@(Localization["legal_privacy_share"])</li>
                <li class="ac-mb-sm">@(Localization["legal_privacy_car"])</li>
                <li>@(Localization["legal_privacy_delete"])</li>
            </ul>
        </ChildContent>
    </AcCard>

    <AcCard Class="ac-mb-lg">
        <Header>
            <strong>@(Localization["legal_refund_title"])</strong>
        </Header>
        <ChildContent>
            <p class="ac-mb-sm">@(Localization["legal_refund_intro"])</p>
            <ul style="padding-inline-start:1.2rem">
                <li class="ac-mb-sm">@(Localization["legal_refund_cancel"])</li>
                <li class="ac-mb-sm">@(Localization["legal_refund_after"])</li>
                <li class="ac-mb-sm">@(Localization["legal_refund_issue"])</li>
                <li>@(Localization["legal_refund_money"])</li>
            </ul>
        </ChildContent>
    </AcCard>
</div>
