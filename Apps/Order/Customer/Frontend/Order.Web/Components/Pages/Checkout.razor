@page "/checkout"
@inject AppStore Store
@inject ClientOpEngine Engine
@inject AppStateApplier Applier
@inject NavigationManager Nav
@inject LocalizationService Localization

<PageTitle>@(Localization["checkout_page_title"]) - @(Localization["app_name"])</PageTitle>

@if (!Store.Auth.IsAuthenticated)
{
    <AcEmptyState IconName="log-in"
                  Title="@(Localization["checkout_signin_first"])"
                  ActionLabel="@(Localization["common_signin"])"
                  ActionHref="/login?return=/checkout" />
}
else if (Store.Cart.Items.Count == 0)
{
    <AcEmptyState IconName="cart"
                  Title="@(Localization["checkout_cart_empty"])"
                  ActionLabel="@(Localization["checkout_browse_offers"])"
                  ActionHref="/" />
}
else
{
    <AcCheckoutPage Cart="@Snapshot"
                    Draft="@Draft"
                    OnFieldChange="HandleFieldChange"
                    OnSubmit="Submit"
                    Submitting="@Submitting"
                    Error="@Error"
                    Title="@(Localization["checkout_title"])"
                    SummaryLabel="@(Localization["checkout_summary"])"
                    TotalLabel="@(Localization["checkout_total"])"
                    PickupLabel="@(Localization["checkout_pickup"])"
                    InStoreLabel="@(Localization["checkout_instore"])"
                    CurbsideLabel="@(Localization["checkout_curbside"])"
                    CarDetailsLabel="@(Localization["checkout_car_details"])"
                    CarModelLabel="@(Localization["checkout_car_model"])"
                    CarColorLabel="@(Localization["checkout_car_color"])"
                    CarPlateLabel="@(Localization["checkout_car_plate"])"
                    PaymentLabel="@(Localization["checkout_payment"])"
                    PaymentHint="@(Localization["checkout_payment_hint"])"
                    CashLabel="@(Localization["checkout_cash"])"
                    CardLabel="@(Localization["checkout_card"])"
                    CashTenderedLabel="@(Localization["checkout_cash_tendered"])"
                    ChangeLabel="@(Localization["checkout_change"])"
                    NotEnoughLabel="@(Localization["checkout_not_enough"])"
                    NotesLabel="@(Localization["checkout_notes"])"
                    SubmitLabel="@(Localization["checkout_submit"])"
                    SubmittingLabel="@(Localization["checkout_submitting"])"
                    BackToCartHref="/cart"
                    BackToCartLabel="@(Localization["checkout_back_to_cart"])" />
}

@code {
    private CheckoutDraft Draft { get; set; } = new();
    private string Error = "";
    private bool Submitting;

    private CartSnapshot Snapshot => new()
    {
        Items = Store.Cart.Items.Select(i => new CartLineDto
        {
            OfferId = i.OfferId.ToString(),
            Title = i.Title,
            Emoji = i.Emoji,
            UnitPrice = i.UnitPrice,
            Quantity = i.Quantity
        }).ToList(),
        Vendor = Store.Cart.VendorId.HasValue ? new VendorMiniDto
        {
            Id = Store.Cart.VendorId.Value.ToString(),
            Name = Store.Cart.VendorName ?? "",
            LogoEmoji = Store.Cart.VendorEmoji
        } : null,
        Subtotal = Store.Cart.Subtotal,
        Currency = "SAR"
    };

    protected override void OnInitialized()
    {
        if (Store.Cart.Subtotal > 0)
        {
            Draft.CashTendered = Math.Ceiling(Store.Cart.Subtotal / 10) * 10;
        }
    }

    private Task HandleFieldChange((string Field, object? Value) args)
    {
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task Submit()
    {
        Error = "";
        if (!Store.Auth.IsAuthenticated || Store.Cart.Items.Count == 0) return;
        if (Draft.PickupType == "Curbside" && string.IsNullOrWhiteSpace(Draft.CarModel))
        {
            Error = Localization["checkout_err_car_details"];
            return;
        }
        if (Draft.PaymentMethod == "Cash" && Draft.CashTendered.HasValue && Draft.CashTendered.Value < Store.Cart.Subtotal)
        {
            Error = Localization["checkout_err_cash_cover"];
            return;
        }
        Submitting = true;
        try
        {
            var payload = new
            {
                customerId = Store.Auth.UserId,
                items = Store.Cart.Items.Select(i => new { offerId = i.OfferId, quantity = i.Quantity }),
                pickupType = Draft.PickupType == "Curbside" ? 1 : 0,
                preferredPayment = Draft.PaymentMethod == "Card" ? 1 : 0,
                cashTendered = Draft.PaymentMethod == "Cash" ? Draft.CashTendered : null,
                carModel = Draft.PickupType == "Curbside" ? Draft.CarModel : null,
                carColor = Draft.PickupType == "Curbside" ? Draft.CarColor : null,
                carPlate = Draft.PickupType == "Curbside" ? Draft.CarPlate : null,
                customerNotes = string.IsNullOrWhiteSpace(Draft.Notes) ? null : Draft.Notes
            };
            var result = await Engine.ExecuteAsync<CreatedOrderDto>(ClientOps.CreateOrder(Store.Auth.UserId), payload);
            if (result.Operation.Status != "Success" || result.Data == null)
            {
                Error = result.Operation.ErrorMessage ?? result.Error?.Message ?? Localization["checkout_err_create"];
                return;
            }
            var orderId = result.Data.Id;
            await Applier.ApplyLocalAsync(ClientOps.CartClear());
            Nav.NavigateTo($"/order/{orderId}?just=1");
        }
        finally { Submitting = false; }
    }

    public class CreatedOrderDto
    {
        public Guid Id { get; set; }
        public string OrderNumber { get; set; } = "";
    }
}
