@page "/profile"
@inject AppStore Store
@inject AppStateApplier Applier
@inject NavigationManager Nav
@inject LocalizationService Localization

<PageTitle>@(Localization["profile_page_title"]) - @(Localization["app_name"])</PageTitle>

@if (!Store.Auth.IsAuthenticated)
{
    <AcEmptyState IconName="user"
                  Title="@(Localization["profile_not_signed_in"])"
                  ActionLabel="@(Localization["common_signin"])"
                  ActionHref="/login" />
}
else
{
    <AcProfilePage User="@UserDto"
                   Stats="@StatsList"
                   MenuSections="@MenuSectionsList"
                   SignOutLabel="@(Localization["common_signout"])"
                   OnSignOut="SignOut" />
}

@code {
    private ProfileUserDto UserDto => new()
    {
        Id = Store.Auth.UserId?.ToString() ?? "",
        FullName = Store.Auth.FullName ?? Localization["profile_default_name"],
        PhoneNumber = Store.Auth.PhoneNumber,
        Initial = !string.IsNullOrEmpty(Store.Auth.FullName) && Store.Auth.FullName.Length > 0 ? Store.Auth.FullName[..1] : "👤"
    };

    private IReadOnlyList<ProfileStatDto> StatsList => new[]
    {
        new ProfileStatDto(Localization["profile_stat_orders"], "0"),
        new ProfileStatDto(Localization["profile_stat_favorites"], "0"),
        new ProfileStatDto(Localization["profile_stat_points"], "0"),
    };

    private IReadOnlyList<MenuSectionDto> MenuSectionsList => new[]
    {
        new MenuSectionDto
        {
            Title = Localization["profile_section_account"],
            Items = new[]
            {
                new MenuItemDto { Label = Localization["profile_menu_orders"],        IconName = "package",  Href = "/orders" },
                new MenuItemDto { Label = Localization["profile_menu_favorites"],     IconName = "heart",    Href = "/favorites" },
                new MenuItemDto { Label = Localization["profile_menu_messages"],      IconName = "message",  Href = "/messages" },
                new MenuItemDto { Label = Localization["profile_menu_notifications"], IconName = "bell",     Href = "/notifications" },
                new MenuItemDto { Label = Localization["profile_menu_account"],       IconName = "user",     Href = "/account" },
            }
        },
        new MenuSectionDto
        {
            Title = Localization["profile_section_app"],
            Items = new[]
            {
                new MenuItemDto { Label = Localization["profile_menu_settings"], IconName = "settings", Href = "/settings" },
            }
        }
    };

    private async Task SignOut()
    {
        await Applier.ApplyLocalAsync(ClientOps.SignOut());
        Nav.NavigateTo("/", forceLoad: false);
    }
}
