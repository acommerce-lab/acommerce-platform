@inject AppStore Store

<!DOCTYPE html>
<html lang="@(Store.Ui.IsArabic ? "ar" : "en")"
      dir="@(Store.Ui.IsArabic ? "rtl" : "ltr")"
      data-theme="@Store.Ui.Theme">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>اوردر — Order</title>

    @* Google Fonts — Tajawal for Arabic, Inter for Latin *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Tajawal:wght@400;500;700;800&display=swap" />

    @* 1. widgets defaults — variables + atomic styles + Bootstrap-compat layer *@
    <link rel="stylesheet" href="_content/ACommerce.Widgets/widgets.css" />

    @* 2. commerce templates (AcShell, AcProductCard, AcAuthPanel, …) *@
    <link rel="stylesheet" href="_content/ACommerce.Templates.Commerce/templates.css" />

    @* 3. shared page templates (auth, chat, notifications, profile, settings) *@
    <link rel="stylesheet" href="_content/ACommerce.Templates.Shared/templates-shared.css" />

    @* 4. customer commerce templates (catalog, cart, checkout, orders) *@
    <link rel="stylesheet" href="_content/ACommerce.Templates.Customer.Commerce/templates-commerce.css" />

    @* 3. Order brand identity — overrides --ac-* and adds Order shell *@
    <link rel="stylesheet" href="app.css" />

    @* 4. Bootstrap Icons (self-hosted, sandbox blocks the CDN) *@
    <link rel="stylesheet" href="lib/bootstrap-icons/bootstrap-icons.min.css" />

    <HeadOutlet />
</head>

<body>
    <Routes @rendermode="@RenderMode.InteractiveServer" />
    <script src="js/theme.js"></script>
    <script src="_framework/blazor.web.js"></script>
</body>

</html>
