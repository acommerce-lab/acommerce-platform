@page "/settings"
@rendermode InteractiveServer
@inject AppStore Store
@inject AppStateApplier Applier
@implements IDisposable

<PageTitle>@Store.Ui.Tr("الإعدادات - إدارة الطلبات", "Settings - Order Admin")</PageTitle>

<AcSettingsPage Snapshot="@(new SettingsSnapshot { Theme = Store.Ui.Theme, Language = Store.Ui.Language })"
                Title="@Store.Ui.Tr("الإعدادات", "Settings")"
                ThemeLabel="@Store.Ui.Tr("المظهر", "Theme")"
                LanguageLabel="@Store.Ui.Tr("اللغة", "Language")"
                LightLabel="@Store.Ui.Tr("فاتح", "Light")"
                DarkLabel="@Store.Ui.Tr("داكن", "Dark")"
                OnThemeChange="@(t => Applier.ApplyLocalAsync(ClientOps.SetTheme(t)))"
                OnLanguageChange="@(l => Applier.ApplyLocalAsync(ClientOps.SetLanguage(l)))">
    <ExtraSections>
        @if (Store.Auth.IsAuthenticated)
        {
            <div class="s-card">
                <div class="acs-settings-row-label">@Store.Ui.Tr("الحساب", "Account")</div>
                <div class="ac-text-muted ac-text-sm" style="padding: 4px 0">@Store.Auth.PhoneNumber</div>
                <div class="ac-text-muted ac-text-sm" style="padding: 4px 0">@Store.Auth.DisplayName</div>
            </div>
        }
    </ExtraSections>
</AcSettingsPage>

@code {
    protected override void OnInitialized() => Store.OnChanged += OnChanged;
    private void OnChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Store.OnChanged -= OnChanged;
}
