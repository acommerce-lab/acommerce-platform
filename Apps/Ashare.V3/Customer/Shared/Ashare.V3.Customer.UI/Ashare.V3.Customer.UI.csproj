<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Ashare.V3.Customer.UI</RootNamespace>
    <AssemblyName>Ashare.V3.Customer.UI</AssemblyName>
    <PackageId>Ashare.V3.Customer.UI</PackageId>
    <Version>1.0.0</Version>
    <Description>
      Ashare V3 thin overlay على قالَب Ejar V1 (Customer.Marketplace).
      يَكشِف AddAshareV3Customer() الذي يَستَدعي AddEjarCustomer() ثُمّ
      AddAshareV3Translations() — فَوقَها (أَعلى أَولَويّة) — لِيَستَبدِل
      app.name + بَعض النُصوص الخاصّة بِعشير. اللَون يأتي مِن branding.css
      في طَبَقَة الـ host (Ashare.V3.Web).
    </Description>
    <RazorLangVersion>latest</RazorLangVersion>
    <!-- L10n SG (G7-style) — يُوَلِّد AshareV3Strings constants -->
    <L10nClassName>AshareV3Strings</L10nClassName>
    <L10nNamespace>Ashare.V3.Customer.UI.Resources</L10nNamespace>
  </PropertyGroup>

  <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>

  <ItemGroup>
    <CompilerVisibleProperty Include="L10nClassName" />
    <CompilerVisibleProperty Include="L10nNamespace" />
    <CompilerVisibleProperty Include="RootNamespace" />
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="Resources\Strings.resx" />
    <EmbeddedResource Update="Resources\Strings.resx" />
    <EmbeddedResource Update="Resources\Strings.ar.resx" />
  </ItemGroup>

  <ItemGroup>
    <!-- نَستَهلِك Ejar V1 overlay (يَجلِب قالَب Customer.Marketplace + AddEjarCustomerUI). -->
    <ProjectReference Include="..\..\..\..\Ejar\Customer\Shared\Ejar.Customer.UI\Ejar.Customer.UI.csproj" />

    <!-- L10n SG لِتَوليد AshareV3Strings مِن Resources/Strings.resx -->
    <ProjectReference Include="..\..\..\..\..\libs\kits\L10n\ACommerce.L10n.SourceGenerator\ACommerce.L10n.SourceGenerator.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />

    <!-- L10n.Resx composition — AddTranslationLayer extension -->
    <ProjectReference Include="..\..\..\..\..\libs\compositions\Customer.L10n.Resx\ACommerce.Compositions.Customer.L10n.Resx\ACommerce.Compositions.Customer.L10n.Resx.csproj" />

    <!-- DynamicAttributes kit Frontend — IAttributesStore + widgets للسِمات الديناميكِيَّة -->
    <ProjectReference Include="..\..\..\..\..\libs\kits\DynamicAttributes\Frontend\Customer\ACommerce.Kits.DynamicAttributes.Frontend.Customer\ACommerce.Kits.DynamicAttributes.Frontend.Customer.csproj" />

    <!-- Taxonomy kit Frontend — ITaxonomyStore + AcTaxonomyTreeSelect (لِـ CreateListing) -->
    <ProjectReference Include="..\..\..\..\..\libs\kits\Taxonomy\Frontend\Customer\ACommerce.Kits.Taxonomy.Frontend.Customer\ACommerce.Kits.Taxonomy.Frontend.Customer.csproj" />

    <!-- Culture — لِتَسجيل AshareV3CultureContext الَّذي يُعطي Asia/Riyadh + SAR
         فَوق Asia/Aden + YER الافتِراضيَّتَين في قالَب Customer.Marketplace. -->
    <ProjectReference Include="..\..\..\..\..\libs\kits\Culture\ACommerce.Culture.Abstractions\ACommerce.Culture.Abstractions.csproj" />
    <ProjectReference Include="..\..\..\..\..\libs\kits\Culture\ACommerce.Culture.Defaults\ACommerce.Culture.Defaults.csproj" />
  </ItemGroup>
</Project>
