@page "/login"
@rendermode InteractiveServer
@inject AshareApiClient Api
@inject AuthStateService Auth
@inject NavigationManager Nav

<PageTitle>دخول - عشير</PageTitle>

<AcAuthPanel Title="دخول بالهاتف" Subtitle="سنرسل لك رمز تحقق عبر SMS">
    <ChildContent>
        @if (step == 1)
        {
            <AcField Label="رقم الهاتف">
                <AcInput @bind-Value="phoneNumber" Placeholder="+966500000000" />
            </AcField>
            <AcButton Text="@(loading ? "جاري الإرسال..." : "إرسال رمز التحقق")"
                      Loading="@loading" Block="true" OnClick="RequestOtp" />
        }
        else if (step == 2)
        {
            <AcAlert Variant="info" Title="وضع تجريبي"
                     Message="الكود أُرسل للـ logs. راجع طرفية Ashare.Api2." />
            <AcField Label="رمز التحقق (6 أرقام)">
                <AcInput @bind-Value="code" Placeholder="123456" />
            </AcField>
            <AcButton Text="@(loading ? "جاري التحقق..." : "تحقق ودخول")"
                      Variant="success" Loading="@loading" Block="true" OnClick="VerifyOtp" />
            <div class="ac-mt-sm" style="text-align:center;">
                <AcButton Text="رجوع" Variant="ghost" Size="sm" OnClick="() => step = 1" />
            </div>
        }

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="ac-mt-md">
                <AcAlert Variant="danger" Message="@error" />
            </div>
        }
    </ChildContent>
    <Footer>
        <small class="ac-text-muted">
            حسابات تجريبية:<br />
            المالك: <code>+966500000001</code><br />
            العميلة: <code>+966500000002</code>
        </small>
    </Footer>
</AcAuthPanel>

@code {
    private int step = 1;
    private string? phoneNumber = "+966500000001";
    private string? code = "";
    private string challengeId = "";
    private Guid userId;
    private bool loading;
    private string error = "";

    private async Task RequestOtp()
    {
        error = "";
        loading = true;
        try
        {
            var resp = await Api.PostAsync<OtpRequestResult>("/api/auth/sms/request", new { phoneNumber });
            if (resp.Operation.Status != "Success" || resp.Data == null)
            {
                error = resp.Error?.Message ?? "فشل طلب الرمز";
                return;
            }
            challengeId = resp.Data.ChallengeId;
            userId = resp.Data.UserId;
            step = 2;
        }
        finally { loading = false; }
    }

    private async Task VerifyOtp()
    {
        error = "";
        loading = true;
        try
        {
            var resp = await Api.PostAsync<VerifyResult>("/api/auth/sms/verify", new
            {
                userId,
                challengeId,
                code
            });

            if (resp.Operation.Status != "Success" || resp.Data == null)
            {
                error = resp.Error?.Message ?? "كود غير صحيح";
                return;
            }

            Auth.SignIn(
                resp.Data.UserId,
                resp.Data.PhoneNumber,
                resp.Data.AccessToken,
                resp.Data.RefreshToken,
                resp.Data.ExpiresAt);

            Nav.NavigateTo("/");
        }
        finally { loading = false; }
    }

    public class OtpRequestResult
    {
        public string ChallengeId { get; set; } = "";
        public Guid UserId { get; set; }
        public string PhoneNumber { get; set; } = "";
    }

    public class VerifyResult
    {
        public Guid UserId { get; set; }
        public string PhoneNumber { get; set; } = "";
        public string AccessToken { get; set; } = "";
        public string RefreshToken { get; set; } = "";
        public DateTimeOffset ExpiresAt { get; set; }
    }
}
