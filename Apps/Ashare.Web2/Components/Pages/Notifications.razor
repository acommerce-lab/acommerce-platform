@page "/notifications"
@rendermode InteractiveServer
@inject AshareApiClient Api
@inject AuthStateService Auth

<PageTitle>الإشعارات</PageTitle>

<div class="d-flex justify-content-between align-items-center">
    <h1>الإشعارات</h1>
    @if (notifications?.Count > 0)
    {
        <button class="btn btn-outline-primary" @onclick="MarkAllRead">تعليم الكل كمقروء</button>
    }
</div>

@if (notifications == null)
{
    <div class="spinner-border"></div>
}
else if (notifications.Count == 0)
{
    <div class="alert alert-info">لا إشعارات</div>
}
else
{
    <div class="list-group">
        @foreach (var n in notifications)
        {
            <div class="list-group-item @(n.IsRead ? "" : "list-group-item-primary")">
                <div class="d-flex justify-content-between">
                    <strong>@n.Title</strong>
                    <small class="text-muted">@n.CreatedAt.ToString("HH:mm")</small>
                </div>
                <p class="mb-1">@n.Body</p>
                <small class="text-muted">@n.Type • @n.Priority</small>
            </div>
        }
    </div>

    <div class="mt-4 card">
        <div class="card-body">
            <h5>إرسال إشعار تجريبي لنفسي</h5>
            <div class="row g-2">
                <div class="col-md-5"><input class="form-control" placeholder="العنوان" @bind="title" /></div>
                <div class="col-md-5"><input class="form-control" placeholder="المحتوى" @bind="body" /></div>
                <div class="col-md-2"><button class="btn btn-primary w-100" @onclick="Send">إرسال</button></div>
            </div>
        </div>
    </div>
}

@code {
    private List<NotificationDto>? notifications;
    private string title = "تجربة";
    private string body = "إشعار تجريبي من Blazor";

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        if (!Auth.UserId.HasValue) { notifications = new(); return; }
        var resp = await Api.GetAsync<List<NotificationDto>>($"/api/notifications/user/{Auth.UserId}");
        notifications = resp.Data ?? new();
    }

    private async Task MarkAllRead()
    {
        await Api.PostAsync<object>($"/api/notifications/user/{Auth.UserId}/mark-all-read", new { });
        await Load();
    }

    private async Task Send()
    {
        if (!Auth.UserId.HasValue) return;
        await Api.PostAsync<object>("/api/notifications/send", new
        {
            userId = Auth.UserId.Value,
            title,
            body,
            channel = "inapp",
            type = "info",
            priority = "normal"
        });
        await Load();
    }

    public class NotificationDto
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = "";
        public string Body { get; set; } = "";
        public string Type { get; set; } = "";
        public string Priority { get; set; } = "";
        public bool IsRead { get; set; }
        public DateTime CreatedAt { get; set; }
    }
}
