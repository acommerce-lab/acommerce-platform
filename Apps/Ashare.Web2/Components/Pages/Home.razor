@page "/"
@rendermode InteractiveServer
@inject AshareApiClient Api
@inject NavigationManager Nav

<PageTitle>العروض - عشير</PageTitle>

<AcPageHeader Title="عروض عشير" Subtitle="استعراض كل العروض المتاحة" />

<div class="ac-row ac-mb-lg">
    <div style="flex:1;">
        <AcField Label="الفئة">
            <select class="ac-select" @bind="selectedCategory" @bind:after="LoadAsync">
                <option value="">كل الفئات</option>
                @foreach (var cat in categories)
                {
                    <option value="@cat.Id">@cat.NameAr</option>
                }
            </select>
        </AcField>
    </div>
    <div style="flex:1;">
        <AcField Label="المدينة">
            <AcInput @bind-Value="city" Placeholder="اكتب المدينة" />
        </AcField>
    </div>
    <div style="display:flex;align-items:end;">
        <AcButton Text="بحث" OnClick="LoadAsync" Loading="@loading" />
    </div>
</div>

@if (loading)
{
    <div style="text-align:center;padding:3rem;">
        <AcSpinner Large="true" />
        <p class="ac-text-muted ac-mt-md">جاري التحميل...</p>
    </div>
}
else if (listings.Count == 0)
{
    <AcEmpty Icon="🔍" Title="لا توجد عروض مطابقة" Message="جرّب تغيير الفلتر أو البحث بمدينة أخرى" />
}
else
{
    <div class="ac-grid ac-grid-cols-3">
        @foreach (var listing in listings)
        {
            <AcProductCard Title="@listing.Title"
                           Meta="@($"{listing.City}{(string.IsNullOrEmpty(listing.District) ? "" : " • " + listing.District)}")"
                           Description="@listing.Description"
                           Price="@($"{listing.Price:N0} {listing.Currency} / {listing.TimeUnit}")"
                           IconFallback="🏠">
                <Actions>
                    <a href="/listing/@listing.Id" style="flex:1;">
                        <AcButton Text="تفاصيل" Variant="outline-primary" Block="true" />
                    </a>
                </Actions>
            </AcProductCard>
        }
    </div>
}

@code {
    private List<ListingDto> listings = new();
    private List<CategoryDto> categories = new();
    private bool loading = true;
    private string selectedCategory = string.Empty;
    private string? city = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var catResp = await Api.GetAsync<List<CategoryDto>>("/api/categories");
        categories = catResp.Data ?? new();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        loading = true;
        var qs = new List<string>();
        if (!string.IsNullOrEmpty(selectedCategory)) qs.Add($"categoryId={selectedCategory}");
        if (!string.IsNullOrEmpty(city)) qs.Add($"city={Uri.EscapeDataString(city)}");
        var query = qs.Count > 0 ? "?" + string.Join("&", qs) : "";

        var resp = await Api.GetAsync<PagedResult>("/api/listings" + query);
        listings = resp.Data?.Items ?? new();
        loading = false;
    }

    public class ListingDto
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Price { get; set; }
        public string Currency { get; set; } = "";
        public string City { get; set; } = "";
        public string? District { get; set; }
        public string TimeUnit { get; set; } = "";
        public Guid CategoryId { get; set; }
    }

    public class CategoryDto
    {
        public Guid Id { get; set; }
        public string Slug { get; set; } = "";
        public string NameAr { get; set; } = "";
    }

    public class PagedResult
    {
        public List<ListingDto> Items { get; set; } = new();
        public int TotalCount { get; set; }
    }
}
