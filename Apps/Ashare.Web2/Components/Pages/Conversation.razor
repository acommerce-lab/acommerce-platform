@page "/conversation/{id:guid}"
@rendermode InteractiveServer
@inject AshareApiClient Api
@inject AuthStateService Auth

<PageTitle>محادثة - عشير</PageTitle>

<h1>محادثة</h1>

<div class="card" style="max-height: 500px; overflow-y: auto;">
    <div class="card-body">
        @if (messages == null)
        {
            <div class="spinner-border"></div>
        }
        else if (messages.Count == 0)
        {
            <p class="text-muted text-center">لا رسائل بعد</p>
        }
        else
        {
            @foreach (var m in messages)
            {
                <div class="mb-2 @(m.SenderId == Auth.UserId ? "text-end" : "")">
                    <div class="d-inline-block p-2 rounded @(m.SenderId == Auth.UserId ? "bg-primary text-white" : "bg-light")">
                        @m.Content
                    </div>
                    <div><small class="text-muted">@m.CreatedAt.ToString("HH:mm")</small></div>
                </div>
            }
        }
    </div>
</div>

<div class="mt-3">
    <div class="input-group">
        <input class="form-control" placeholder="اكتب رسالة..." @bind="newMessage" @bind:event="oninput" @onkeyup="OnKey" />
        <button class="btn btn-primary" @onclick="Send" disabled="@sending">إرسال</button>
    </div>
</div>

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger mt-2">@error</div>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private List<MessageDto>? messages;
    private string newMessage = "";
    private bool sending;
    private string error = "";

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        var resp = await Api.GetAsync<List<MessageDto>>($"/api/messages/conversations/{Id}/messages");
        messages = resp.Data ?? new();
    }

    private async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrEmpty(newMessage))
            await Send();
    }

    private async Task Send()
    {
        if (string.IsNullOrEmpty(newMessage) || !Auth.UserId.HasValue) return;
        sending = true;
        error = "";
        try
        {
            var resp = await Api.PostAsync<object>("/api/messages", new
            {
                conversationId = Id,
                senderId = Auth.UserId.Value,
                content = newMessage,
                messageType = "text"
            });

            if (resp.Operation.Status != "Success")
            {
                error = resp.Operation.ErrorMessage ?? "فشل الإرسال";
                return;
            }

            newMessage = "";
            await Load();
        }
        finally { sending = false; }
    }

    public class MessageDto
    {
        public Guid Id { get; set; }
        public Guid SenderId { get; set; }
        public string Content { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }
}
