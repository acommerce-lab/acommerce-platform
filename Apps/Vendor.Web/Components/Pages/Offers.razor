@page "/offers"
@inject VendorApiClient Api
@inject AuthStateService Auth
@inject UiPreferences Ui
@inject NavigationManager Nav

<PageTitle>@(Ui.IsArabic ? "عروضي" : "My Offers")</PageTitle>

@if (!Auth.IsAuthenticated)
{
    <AcEmptyState IconName="log-in" Title="@(Ui.IsArabic ? "سجّل دخولك" : "Sign in")" ActionHref="/login" ActionLabel="@(Ui.IsArabic ? "دخول" : "Sign in")" />
}
else
{
    <div style="padding:16px;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
            <h1 class="acs-page-title" style="margin:0;">@(Ui.IsArabic ? "عروضي" : "My Offers")</h1>
            <a class="btn btn-primary btn-sm" href="/offers/new">
                <AcIcon Name="plus" Size="16" /> @(Ui.IsArabic ? "عرض جديد" : "New offer")
            </a>
        </div>

        @if (Loading)
        {
            <AcLoadingState Message="@(Ui.IsArabic ? "جاري التحميل..." : "Loading…")" />
        }
        else if (MyOffers.Count == 0)
        {
            <AcEmptyState IconName="tag"
                          Title="@(Ui.IsArabic ? "لا عروض بعد" : "No offers yet")"
                          Message="@(Ui.IsArabic ? "أنشئ عرضك الأول لبدء البيع" : "Create your first offer")"
                          ActionLabel="@(Ui.IsArabic ? "إنشاء عرض" : "Create offer")"
                          ActionHref="/offers/new" />
        }
        else
        {
            @foreach (var o in MyOffers)
            {
                <div class="vnd-offer-card">
                    <div class="vnd-offer-emoji">@(o.Emoji ?? "🍽️")</div>
                    <div class="vnd-offer-body">
                        <div class="vnd-offer-title">@o.Title</div>
                        <div class="vnd-offer-price">
                            @o.Price.ToString("0.##") @o.Currency
                            @if (o.OriginalPrice is > 0 && o.OriginalPrice > o.Price)
                            {
                                <span style="text-decoration:line-through;margin-inline-start:6px;">@o.OriginalPrice.Value.ToString("0.##")</span>
                            }
                        </div>
                    </div>
                    <div class="vnd-offer-actions">
                        <a class="btn btn-ghost btn-sm" href="/offers/edit/@o.Id">
                            <AcIcon Name="settings" Size="14" />
                        </a>
                    </div>
                </div>
            }
        }
    </div>
}

@code {
    private List<OfferRow> MyOffers = new();
    private bool Loading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Auth.EnsureRestoredAsync();
        if (Auth.IsAuthenticated)
        {
            var vEnv = await Api.GetAsync<List<VendorRow>>("/api/vendors");
            var myV = vEnv.Data?.FirstOrDefault(v => v.OwnerId == Auth.UserId);
            if (myV != null)
            {
                var env = await Api.GetAsync<List<OfferRow>>($"/api/offers?vendorId={myV.Id}");
                MyOffers = env.Data ?? new();
            }
        }
        Loading = false;
        StateHasChanged();
    }

    public class VendorRow { public Guid Id { get; set; } public Guid OwnerId { get; set; } }
    public class OfferRow
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = "";
        public decimal Price { get; set; }
        public decimal? OriginalPrice { get; set; }
        public string Currency { get; set; } = "SAR";
        public string? Emoji { get; set; }
    }
}
