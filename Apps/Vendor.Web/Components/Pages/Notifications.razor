@page "/notifications"
@inject VendorApiClient Api
@inject AuthStateService Auth
@inject UiPreferences Ui

<PageTitle>@(Ui.IsArabic ? "الإشعارات" : "Notifications")</PageTitle>

@if (!Auth.IsAuthenticated)
{
    <AcEmptyState IconName="bell" Title="@(Ui.IsArabic ? "سجّل دخولك" : "Sign in")" ActionHref="/login" ActionLabel="@(Ui.IsArabic ? "دخول" : "Sign in")" />
}
else
{
    <AcNotificationsPage Notifications="@(Array.Empty<NotificationRowDto>())"
                         Loading="false"
                         Title="@(Ui.IsArabic ? "الإشعارات" : "Notifications")"
                         EmptyTitle="@(Ui.IsArabic ? "لا إشعارات" : "No notifications")"
                         EmptyMessage="@(Ui.IsArabic ? "ستظهر هنا إشعارات الطلبات الجديدة" : "New order notifications will appear here")" />
}
