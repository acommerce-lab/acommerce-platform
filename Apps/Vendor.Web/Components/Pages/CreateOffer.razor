@page "/offers/new"
@page "/offers/edit/{Id:guid}"
@inject VendorApiClient Api
@inject AuthStateService Auth
@inject UiPreferences Ui
@inject NavigationManager Nav

<PageTitle>@(IsEdit ? (Ui.IsArabic ? "تعديل العرض" : "Edit Offer") : (Ui.IsArabic ? "عرض جديد" : "New Offer"))</PageTitle>

<div style="padding:16px;">
    <h1 class="acs-page-title" style="margin:0 0 14px;">
        @(IsEdit ? (Ui.IsArabic ? "تعديل العرض" : "Edit Offer") : (Ui.IsArabic ? "عرض جديد" : "New Offer"))
    </h1>

    <div class="s-card">
        <label class="form-label">@(Ui.IsArabic ? "اسم العرض" : "Offer title")</label>
        <input class="form-input" value="@Title" @oninput="@(e => Title = e.Value?.ToString() ?? "")" />

        <label class="form-label" style="margin-top:12px;">@(Ui.IsArabic ? "الوصف" : "Description")</label>
        <textarea class="form-input" rows="3" @oninput="@(e => Description = e.Value?.ToString() ?? "")">@Description</textarea>

        <div style="display:flex;gap:10px;margin-top:12px;">
            <div style="flex:1;">
                <label class="form-label">@(Ui.IsArabic ? "السعر" : "Price")</label>
                <input class="form-input" type="number" value="@Price" @oninput="@(e => { if (decimal.TryParse(e.Value?.ToString(), out var d)) Price = d; })" />
            </div>
            <div style="flex:1;">
                <label class="form-label">@(Ui.IsArabic ? "السعر الأصلي" : "Original price")</label>
                <input class="form-input" type="number" placeholder="@(Ui.IsArabic ? "اختياري" : "Optional")"
                       value="@OriginalPrice" @oninput="@(e => OriginalPrice = decimal.TryParse(e.Value?.ToString(), out var d) ? d : null)" />
            </div>
        </div>

        <label class="form-label" style="margin-top:12px;">@(Ui.IsArabic ? "الإيموجي" : "Emoji")</label>
        <input class="form-input" value="@Emoji" @oninput="@(e => Emoji = e.Value?.ToString() ?? "🍽️")" style="max-width:100px;" />

        <label class="form-label" style="margin-top:12px;">@(Ui.IsArabic ? "الفئة" : "Category")</label>
        <select class="form-input" value="@SelectedCategoryId" @onchange="@(e => SelectedCategoryId = e.Value?.ToString() ?? "")">
            @foreach (var c in Categories)
            {
                <option value="@c.Id">@c.Icon @(Ui.IsArabic ? c.NameAr : c.NameEn)</option>
            }
        </select>
    </div>

    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="alert alert-danger" style="margin-top:12px;">@Error</div>
    }

    <button class="btn btn-primary btn-block" style="margin-top:14px;" @onclick="Save" disabled="@Saving">
        @(Saving
            ? (Ui.IsArabic ? "جاري الحفظ..." : "Saving…")
            : (Ui.IsArabic ? "حفظ" : "Save"))
    </button>
    <a class="btn btn-ghost btn-block" href="/offers" style="margin-top:8px;">@(Ui.IsArabic ? "إلغاء" : "Cancel")</a>
</div>

@code {
    [Parameter] public Guid? Id { get; set; }
    private bool IsEdit => Id.HasValue;

    private string Title = "";
    private string Description = "";
    private decimal Price;
    private decimal? OriginalPrice;
    private string Emoji = "🍽️";
    private string SelectedCategoryId = "";
    private Guid? VendorId;
    private string? Error;
    private bool Saving;
    private List<CatRow> Categories = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Auth.EnsureRestoredAsync();

        var catEnv = await Api.GetAsync<List<CatRow>>("/api/categories");
        Categories = catEnv.Data ?? new();
        if (Categories.Count > 0 && string.IsNullOrEmpty(SelectedCategoryId))
            SelectedCategoryId = Categories[0].Id.ToString();

        var vEnv = await Api.GetAsync<List<VendorRow>>("/api/vendors");
        var myV = vEnv.Data?.FirstOrDefault(v => v.OwnerId == Auth.UserId);
        VendorId = myV?.Id;

        if (IsEdit)
        {
            var env = await Api.GetAsync<OfferDetail>($"/api/offers/{Id}");
            if (env.Data != null)
            {
                Title = env.Data.Title;
                Description = env.Data.Description;
                Price = env.Data.Price;
                OriginalPrice = env.Data.OriginalPrice;
                Emoji = env.Data.Emoji;
                SelectedCategoryId = env.Data.CategoryId.ToString();
            }
        }
        StateHasChanged();
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(Title)) { Error = Ui.IsArabic ? "أدخل اسم العرض" : "Enter title"; return; }
        if (Price <= 0) { Error = Ui.IsArabic ? "السعر يجب أن يكون أكبر من صفر" : "Price must be > 0"; return; }
        Saving = true; Error = null;

        if (IsEdit)
        {
            await Api.PutAsync<object>($"/api/offers/{Id}", new { Title, Description, Price, OriginalPrice, Emoji });
        }
        else
        {
            if (!VendorId.HasValue) { Error = Ui.IsArabic ? "لم يُعثر على متجرك" : "Vendor not found"; Saving = false; return; }
            await Api.PostAsync<object>("/api/offers", new
            {
                VendorId = VendorId.Value,
                CategoryId = Guid.TryParse(SelectedCategoryId, out var cid) ? cid : Categories.First().Id,
                Title, Description, Price, OriginalPrice, Emoji
            });
        }
        Saving = false;
        Nav.NavigateTo("/offers");
    }

    public class VendorRow { public Guid Id { get; set; } public Guid OwnerId { get; set; } }
    public class CatRow { public Guid Id { get; set; } public string NameAr { get; set; } = ""; public string NameEn { get; set; } = ""; public string Icon { get; set; } = ""; }
    public class OfferDetail
    {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Price { get; set; }
        public decimal? OriginalPrice { get; set; }
        public string Emoji { get; set; } = "🍽️";
        public Guid CategoryId { get; set; }
    }
}
