@page "/orders"
@inject VendorApiClient Api
@inject AppStore Store

<PageTitle>@(Store.Ui.IsArabic ? "الطلبات" : "Orders")</PageTitle>

@if (!Store.Auth.IsAuthenticated)
{
    <AcEmptyState IconName="log-in" Title="@(Store.Ui.IsArabic ? "سجّل دخولك" : "Sign in")" ActionHref="/login" ActionLabel="@(Store.Ui.IsArabic ? "دخول" : "Sign in")" />
}
else
{
    <div style="padding:16px;">
        <h1 class="acs-page-title" style="margin:0 0 10px;">@(Store.Ui.IsArabic ? "الطلبات" : "Orders")</h1>

        <div class="acs-seg" style="margin-bottom:12px;">
            @foreach (var f in new[] { ("all", Store.Ui.IsArabic ? "الكل" : "All"), ("pending", Store.Ui.IsArabic ? "معلقة" : "Pending"), ("accepted", Store.Ui.IsArabic ? "مقبولة" : "Accepted"), ("ready", Store.Ui.IsArabic ? "جاهزة" : "Ready") })
            {
                <button type="button" class="acs-seg-btn @(Filter == f.Item1 ? "active" : "")" @onclick="@(() => Filter = f.Item1)">@f.Item2</button>
            }
        </div>

        @if (Loading)
        {
            <AcLoadingState Message="@(Store.Ui.IsArabic ? "جاري التحميل..." : "Loading…")" />
        }
        else if (Filtered.Count == 0)
        {
            <AcEmptyState IconName="inbox" Title="@(Store.Ui.IsArabic ? "لا طلبات" : "No orders")" />
        }
        else
        {
            @foreach (var o in Filtered)
            {
                <a class="s-card" href="/order/@o.Id" style="display:flex;justify-content:space-between;align-items:center;text-decoration:none;color:inherit;margin-bottom:10px;">
                    <div>
                        <div style="font-weight:700;">#@o.OrderNumber</div>
                        <div style="font-size:0.78rem;color:var(--ac-text-muted);">@o.CustomerName • @o.Total.ToString("0.##") SAR</div>
                    </div>
                    <span class="vnd-status vnd-status-@StatusKey(o.Status)">@o.StatusAr</span>
                </a>
            }
        }
    </div>
}

@code {
    private List<OrderRow> AllOrders = new();
    private bool Loading = true;
    private string Filter = "all";
    private Guid? VendorId;

    private List<OrderRow> Filtered => Filter switch
    {
        "pending"  => AllOrders.Where(o => o.Status == 0).ToList(),
        "accepted" => AllOrders.Where(o => o.Status == 1).ToList(),
        "ready"    => AllOrders.Where(o => o.Status == 2).ToList(),
        _ => AllOrders
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (Store.Auth.IsAuthenticated)
        {
            var vEnv = await Api.GetAsync<List<VendorRow>>("/api/vendors");
            var myV = vEnv.Data?.FirstOrDefault(v => v.OwnerId == Store.Auth.UserId);
            if (myV != null)
            {
                VendorId = myV.Id;
                var env = await Api.GetAsync<List<OrderRow>>($"/api/orders/by-vendor/{myV.Id}");
                AllOrders = env.Data ?? new();
            }
        }
        Loading = false;
        StateHasChanged();
    }

    private static string StatusKey(int s) => s switch { 0=>"pending", 1=>"accepted", 2=>"ready", 3=>"delivered", 4=>"cancelled", _=>"pending" };

    public class VendorRow { public Guid Id { get; set; } public Guid OwnerId { get; set; } }
    public class OrderRow
    {
        public Guid Id { get; set; }
        public string OrderNumber { get; set; } = "";
        public decimal Total { get; set; }
        public int Status { get; set; }
        public string StatusAr { get; set; } = "";
        public string CustomerName { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }
}
