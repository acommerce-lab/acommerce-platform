@page "/login"
@inject VendorApiClient Api
@inject AuthStateService Auth
@inject UiPreferences Ui
@inject NavigationManager Nav

<PageTitle>@(Ui.IsArabic ? "دخول التاجر" : "Vendor Login")</PageTitle>

<AcLoginPage Step="@Step"
             Phone="@Phone"
             PhoneChanged="@(v => Phone = v)"
             Code="@Code"
             CodeChanged="@(v => Code = v)"
             Error="@Error"
             Busy="@Busy"
             BrandName="@(Ui.IsArabic ? "لوحة التاجر" : "Vendor Dashboard")"
             BrandTagline="@(Ui.IsArabic ? "أدر طلباتك وعروضك" : "Manage orders & offers")"
             PhoneStepTitle="@(Ui.IsArabic ? "تسجيل الدخول" : "Sign in")"
             PhoneStepSubtitle="@(Ui.IsArabic ? "أدخل رقم جوال التاجر" : "Enter your vendor phone")"
             PhoneLabel="@(Ui.IsArabic ? "رقم الجوال" : "Phone number")"
             PhonePlaceholder="+966501111111"
             RequestOtpLabel="@(Ui.IsArabic ? "إرسال رمز التحقق" : "Send OTP")"
             SendingLabel="@(Ui.IsArabic ? "جاري الإرسال..." : "Sending...")"
             OtpStepTitle="@(Ui.IsArabic ? "رمز التحقق" : "Verification code")"
             OtpStepSubtitle="@(Ui.IsArabic ? "أدخل الرمز المرسل إلى" : "Enter the code sent to")"
             OtpLabel="@(Ui.IsArabic ? "الرمز (6 أرقام)" : "Code (6 digits)")"
             VerifyOtpLabel="@(Ui.IsArabic ? "دخول" : "Sign in")"
             VerifyingLabel="@(Ui.IsArabic ? "جاري التحقق..." : "Verifying...")"
             BackLabel="@(Ui.IsArabic ? "تغيير الرقم" : "Change number")"
             OnRequestOtp="RequestOtp"
             OnVerifyOtp="VerifyOtp"
             OnBack="GoBack">
    <HintSlot>
        <strong>@(Ui.IsArabic ? "حسابات التجار التجريبية:" : "Demo vendor accounts:")</strong><br/>
        <code dir="ltr">+966501111111</code> @(Ui.IsArabic ? "(أحمد — كافيه السعادة)" : "(Ahmed — Happiness Café)")<br/>
        <code dir="ltr">+966502222222</code> @(Ui.IsArabic ? "(فاطمة — مطعم الأصيل)" : "(Fatimah — Al-Aseel)")
    </HintSlot>
</AcLoginPage>

@code {
    private int Step = 1;
    private string Phone = "+966501111111";
    private string Code = "";
    private string Error = "";
    private bool Busy;
    private Guid? UserId;
    private string? ChallengeId;

    private async Task RequestOtp()
    {
        Error = "";
        if (string.IsNullOrWhiteSpace(Phone)) { Error = Ui.IsArabic ? "أدخل رقم الجوال" : "Enter phone"; return; }
        Busy = true;
        try
        {
            var env = await Api.PostAsync<OtpRequestDto>("/api/auth/sms/request", new { phoneNumber = Phone });
            if (env.Operation.Status != "Success" || env.Data == null)
            {
                Error = env.Operation.ErrorMessage ?? env.Error?.Message ?? (Ui.IsArabic ? "فشل الإرسال" : "Send failed");
                return;
            }
            UserId = env.Data.UserId;
            ChallengeId = env.Data.ChallengeId;
            Step = 2;
        }
        catch (Exception ex) { Error = ex.Message; }
        finally { Busy = false; }
    }

    private async Task VerifyOtp()
    {
        Error = "";
        if (string.IsNullOrWhiteSpace(Code) || !UserId.HasValue) return;
        Busy = true;
        try
        {
            var env = await Api.PostAsync<VerifyDto>("/api/auth/sms/verify", new
            {
                userId = UserId.Value,
                challengeId = ChallengeId,
                code = Code
            });
            if (env.Operation.Status != "Success" || env.Data == null || string.IsNullOrEmpty(env.Data.AccessToken))
            {
                Error = env.Operation.ErrorMessage ?? env.Error?.Message ?? (Ui.IsArabic ? "كود غير صحيح" : "Wrong code");
                return;
            }
            await Auth.SignInAsync(env.Data.UserId, env.Data.PhoneNumber, env.Data.FullName, env.Data.AccessToken);
            Nav.NavigateTo("/", forceLoad: false);
        }
        catch (Exception ex) { Error = ex.Message; }
        finally { Busy = false; }
    }

    private void GoBack() { Step = 1; Code = ""; Error = ""; }

    public class OtpRequestDto
    {
        public string ChallengeId { get; set; } = "";
        public Guid UserId { get; set; }
        public string PhoneNumber { get; set; } = "";
    }
    public class VerifyDto
    {
        public Guid UserId { get; set; }
        public string? PhoneNumber { get; set; }
        public string? FullName { get; set; }
        public string AccessToken { get; set; } = "";
    }
}
