@page "/subscribe"
@attribute [Authorize]
@inject AppStore Store
@inject ApiReader Api
@inject NavigationManager Nav
@inject L L

<PageTitle>الدفع — @(L["app.name"])</PageTitle>

<div class="acs-page acs-subscribe-page">
    <h1 class="acm-wizard-title">إتمام الدفع</h1>

    @if (_loading) { <AcLoadingState /> }
    else
    {
        @if (Type == "plan")
        {
            <AcCard>
                <ChildContent>
                    <h3 style="margin-top:0;">خطّة @(_plan?.Name)</h3>
                    <p>@(_plan?.Description)</p>

                    <AcField Label="دورة الفوترة">
                        <div style="display:flex; gap:8px; flex-wrap:wrap;">
                            <AcFilterChip Label="شهريّ"               Active="@(_cycle == "month")"   OnClick="@(() => SetCycle("month"))" />
                            <AcFilterChip Label="ربع سنويّ (خصم 5%)" Active="@(_cycle == "quarter")" OnClick="@(() => SetCycle("quarter"))" />
                            <AcFilterChip Label="سنويّ (خصم 20%)"    Active="@(_cycle == "year")"    OnClick="@(() => SetCycle("year"))" />
                        </div>
                    </AcField>
                </ChildContent>
            </AcCard>
        }

        <AcCard>
            <ChildContent>
                <h3 style="margin-top:0;">ملخّص الطلب</h3>
                <div class="acm-checkout-line"><span>البند:</span><strong>@_itemText</strong></div>
                <div class="acm-checkout-line"><span>السعر الأساسيّ:</span><strong>@BaseAmount ر.ي</strong></div>
                @if (CycleDiscount > 0)
                {
                    <div class="acm-checkout-line"><span>خصم الدورة:</span><strong>−@CycleDiscount ر.ي</strong></div>
                }
                @if (PromoDiscount > 0)
                {
                    <div class="acm-checkout-line"><span>خصم البرومو (@_promoApplied):</span><strong>−@PromoDiscount ر.ي</strong></div>
                }
                <div class="acm-checkout-line"><span>المجموع الفرعيّ:</span><strong>@Subtotal ر.ي</strong></div>
                <hr />
                <div class="acm-checkout-line"><span><strong>المجموع:</strong></span><strong>@Total ر.ي</strong></div>
            </ChildContent>
        </AcCard>

        <AcCard>
            <ChildContent>
                <AcField Label="رمز خصم (اختياريّ)">
                    <div style="display:flex; gap:8px;">
                        <AcInput Value="@_promo" ValueChanged="@(v => _promo = (v ?? string.Empty).Trim().ToUpperInvariant())"
                                 Placeholder="EJAR10" />
                        <AcButton Variant="outline-primary" Text="تطبيق" OnClick="@ApplyPromo" />
                    </div>
                </AcField>
                @if (!string.IsNullOrEmpty(_promoAlert))
                {
                    <AcAlert Variant="@_promoAlertVariant" Message="@_promoAlert" />
                }
            </ChildContent>
        </AcCard>

        <AcCard>
            <ChildContent>
                <h3 style="margin-top:0;">بيانات الدفع</h3>
                <AcPaymentForm SubmitLabel="@($"ادفع {Total} ر.ي")"
                              OnSubmit="OnPay" />
                @if (!string.IsNullOrEmpty(_alert))
                {
                    <AcAlert Variant="@_alertVariant" Message="@_alert" />
                }
            </ChildContent>
        </AcCard>
    }
</div>

@code {
    [SupplyParameterFromQuery] public string? Type { get; set; }
    [SupplyParameterFromQuery] public string? Id { get; set; }
    [SupplyParameterFromQuery] public decimal Amount { get; set; }

    private PlanDto? _plan;
    private string _itemText = "";
    private decimal _baseAmount;
    private string _cycle = "month";
    private string _promo = "";
    private string? _promoApplied;
    private decimal _promoPct;
    private string? _promoAlert;
    private string _promoAlertVariant = "success";
    private string? _alert;
    private string _alertVariant = "success";
    private bool _loading = true;

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (!first) return;
        if (Type == "plan" && !string.IsNullOrEmpty(Id))
        {
            var env = await Api.GetAsync<List<PlanDto>>("/plans");
            _plan = env.Data?.FirstOrDefault(p => p.Id == Id);
            _baseAmount = _plan?.Price ?? Amount;
            _itemText = _plan is null ? $"خطّة {Id}" : $"اشتراك خطّة {_plan.Name}";
        }
        else
        {
            _baseAmount = Amount > 0 ? Amount : 99m;
            _itemText = $"إعلان #{Id ?? "—"}";
        }
        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private decimal BaseAmount => _cycle switch
    {
        "quarter" => _baseAmount * 3,
        "year"    => _baseAmount * 12,
        _         => _baseAmount
    };

    private decimal CycleDiscount => _cycle switch
    {
        "quarter" => Math.Round(BaseAmount * 0.05m, 2),
        "year"    => Math.Round(BaseAmount * 0.20m, 2),
        _         => 0m
    };

    private decimal PromoDiscount => Math.Round((BaseAmount - CycleDiscount) * _promoPct, 2);
    private decimal Subtotal => BaseAmount - CycleDiscount - PromoDiscount;
    private decimal Total => Subtotal;

    private void SetCycle(string c) => _cycle = c;

    private void ApplyPromo()
    {
        switch (_promo)
        {
            case "EJAR10": _promoApplied = _promo; _promoPct = 0.10m;
                _promoAlert = "تمّ تطبيق خصم 10%"; _promoAlertVariant = "success"; break;
            case "WELCOME20": _promoApplied = _promo; _promoPct = 0.20m;
                _promoAlert = "تمّ تطبيق خصم 20%"; _promoAlertVariant = "success"; break;
            default: _promoPct = 0; _promoApplied = null;
                _promoAlert = "الرمز غير صالح"; _promoAlertVariant = "danger"; break;
        }
    }

    private void OnPay(AcPaymentForm.PaymentFormValues dto)
    {
        var lastDigit = dto.CardNumber.LastOrDefault(char.IsDigit);
        if (char.IsDigit(lastDigit) && (lastDigit - '0') % 2 == 0)
        {
            Nav.NavigateTo(
                $"/payment/callback?status=success&type={Type ?? "plan"}&id={Id}" +
                $"&amount={Total.ToString(System.Globalization.CultureInfo.InvariantCulture)}");
        }
        else
        {
            _alert = "فشلت عمليّة الدفع — حاول ببطاقة أخرى";
            _alertVariant = "danger";
        }
    }

    private sealed record PlanDto(string Id, string Name, string Description,
        decimal Price, string Unit, int ListingQuota, int FeaturedQuota,
        int ImagesPerListing, bool Popular, List<string> Features);
}
