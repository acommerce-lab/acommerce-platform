@page "/payment/callback"
@attribute [Authorize]
@inject NavigationManager Nav
@inject L L

<PageTitle>نتيجة الدفع — @(L["app.name"])</PageTitle>

<div class="acs-page acs-payment-callback" style="text-align:center; padding:32px 16px;">
    @if (Status == "success")
    {
        <div style="color:var(--ac-success);"><AcIcon Name="check-circle" Filled="true" Size="48" /></div>
        <h1 class="acm-wizard-title">تمّ الدفع بنجاح</h1>
        <p>شكراً لك — تمّت معالجة طلبك.</p>

        <AcCard>
            <ChildContent>
                <div class="acm-checkout-line"><span>رقم المعاملة:</span><strong>@_txnId</strong></div>
                @if (!string.IsNullOrEmpty(Id))
                {
                    <div class="acm-checkout-line"><span>@(Type == "booking" ? "رقم الحجز" : "رقم الخطّة")</span><strong>@Id</strong></div>
                }
                @if (Amount > 0)
                {
                    <div class="acm-checkout-line"><span>المبلغ:</span><strong>@Amount ر.ي</strong></div>
                }
                <div class="acm-checkout-line"><span>التاريخ:</span><strong>@DateTime.Now.ToString("yyyy-MM-dd HH:mm")</strong></div>
            </ChildContent>
        </AcCard>

        <div style="display:flex; gap:8px; margin-top:16px; justify-content:center;">
            <AcButton Variant="primary" Text="اشتراكي" OnClick="@GoMySub" />
            <AcButton Variant="ghost"   Text="الرئيسيّة" OnClick="@GoHome" />
        </div>
    }
    else
    {
        <div style="color:var(--ac-danger);"><AcIcon Name="x-circle" Filled="true" Size="48" /></div>
        <h1 class="acm-wizard-title">فشل الدفع</h1>
        <p>لم تكتمل عمليّة الدفع. حاول مرّة أخرى أو استخدم بطاقة مختلفة.</p>
        <div style="display:flex; gap:8px; margin-top:16px; justify-content:center;">
            <AcButton Variant="primary" Text="المحاولة مجدّداً" OnClick="@Retry" />
            <AcButton Variant="ghost"   Text="الرئيسيّة" OnClick="@GoHome" />
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery] public string? Status { get; set; }
    [SupplyParameterFromQuery] public string? Type { get; set; }
    [SupplyParameterFromQuery] public string? Id { get; set; }
    [SupplyParameterFromQuery] public decimal Amount { get; set; }

    private string _txnId = "";

    protected override void OnInitialized()
    {
        _txnId = $"TXN-{Random.Shared.Next(100000, 999999)}";
    }

    private void GoMySub() => Nav.NavigateTo("/my-subscription");
    private void GoHome()  => Nav.NavigateTo("/");
    private void Retry()   => Nav.NavigateTo("/plans");
}
