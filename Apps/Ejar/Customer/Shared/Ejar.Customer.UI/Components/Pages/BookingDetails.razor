@page "/booking/{Id}"
@inject ApiReader Api
@inject NavigationManager Nav
@inject L L

<PageTitle>تفاصيل الحجز — @(L["app.name"])</PageTitle>

<div class="acs-page">
    @if (_b is null) { <AcLoadingState /> }
    else
    {
        <h1 class="acm-wizard-title">حجز: @_b.ListingTitle</h1>
        <AcCard>
            <ChildContent>
                <div class="acm-checkout-line"><span>الحالة:</span><AcBadge Variant="@BadgeVariant(_b.Status)" Text="@StatusLabel(_b.Status)" /></div>
                <div class="acm-checkout-line"><span>التاريخ:</span><strong>@_b.StartDate.ToString("yyyy-MM-dd")</strong></div>
                <div class="acm-checkout-line"><span>عدد الليالي:</span><strong>@_b.Nights</strong></div>
                <div class="acm-checkout-line"><span>عدد الأشخاص:</span><strong>@_b.Guests</strong></div>
                <div class="acm-checkout-line"><span>المجموع:</span><strong>@_b.Total ر.ي</strong></div>
            </ChildContent>
        </AcCard>
        <div style="display:flex; gap:8px; margin-top:12px;">
            <AcButton Variant="ghost" Text="رجوع" OnClick="@GoBack" />
            @if (CanCancel(_b.Status))
            {
                <AcButton Variant="danger" Text="إلغاء الحجز" OnClick="@CancelBooking" />
            }
        </div>
        @if (_cancelled)
        {
            <AcAlert Variant="warning" Text="تمّ إرسال طلب الإلغاء — بانتظار موافقة المالك" />
        }
    }
</div>

@code {
    [Parameter] public string Id { get; set; } = "";
    private Payload? _b;
    private bool _cancelled;

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (first) { var env = await Api.GetAsync<Payload>($"/bookings/{Id}"); _b = env.Data; await InvokeAsync(StateHasChanged); }
    }

    private void GoBack() => Nav.NavigateTo("/bookings");
    private void CancelBooking() => _cancelled = true;

    private static bool CanCancel(string status) => status is "pending" or "confirmed";

    private static string StatusLabel(string s) => s switch
    {
        "pending"   => "قيد المراجعة",
        "confirmed" => "مؤكَّد",
        "completed" => "منتهٍ",
        "cancelled" => "ملغى",
        _           => s
    };

    private static string BadgeVariant(string s) => s switch
    {
        "confirmed" => "success",
        "pending"   => "warning",
        "cancelled" => "danger",
        "completed" => "secondary",
        _           => "secondary"
    };

    private sealed record Payload(string Id, string ListingId, string ListingTitle,
        decimal Total, DateTime StartDate, int Nights, int Guests, string Status);
}
