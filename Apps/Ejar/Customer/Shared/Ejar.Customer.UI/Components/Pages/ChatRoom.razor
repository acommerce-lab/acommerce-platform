@page "/chat/{Id}"
@attribute [Authorize]
@using ACommerce.Chat.Client.Blazor
@using ACommerce.Chat.Operations
@inject ApiReader Api
@inject NavigationManager Nav
@inject IChatClient Chat
@inject L L
@implements IAsyncDisposable

<PageTitle>@(L["chat.title"]) — @(L["app.name"])</PageTitle>

<div class="acs-page acs-chat-page">
    @if (_loading) { <AcLoadingState /> }
    else if (_loadError is not null)
    {
        @* لا تُبقي المؤشّر يدور للأبد لو فشل /conversations/{id} (500/404). كان
           الكود السابق يضع AcLoadingState متى كان _conv == null، فعند فشل
           الجلب يبقى المستخدم محدّقاً في عجلة لا تتوقّف. الآن نعرض الخطأ
           وزرّ رجوع. *@
        <AcEmptyState IconName="alert-circle" Message="@_loadError" />
        <AcButton Variant="ghost" Class="ac-btn-block" Text="رجوع للمحادثات"
                  OnClick="@(() => Nav.NavigateTo("/chats"))" />
    }
    else if (_conv is null)
    {
        <AcEmptyState IconName="info" Message="المحادثة غير متوفّرة." />
        <AcButton Variant="ghost" Class="ac-btn-block" Text="رجوع للمحادثات"
                  OnClick="@(() => Nav.NavigateTo("/chats"))" />
    }
    else
    {
        <div style="display:flex; justify-content:space-between; align-items:center;">
            <div>
                <h1 class="acm-wizard-title" style="margin-bottom:4px;">@_conv.PartnerName</h1>
                <small style="color:var(--ac-text-muted);">@_conv.Subject</small>
            </div>
            <AcButton Variant="ghost" Text="رجوع" OnClick="@GoBack" />
        </div>

        <div class="acs-chat-messages">
            @foreach (var m in _messages)
            {
                var mine = m.SenderPartyId == "me";
                <div class="acs-bubble @(mine ? "acs-bubble-mine" : "acs-bubble-other")">
                    @if (!string.IsNullOrEmpty(m.Body))
                    {
                        <div>@m.Body</div>
                    }
                    <small style="display:block; opacity:.6;">@m.SentAt.ToLocalTime().ToString("HH:mm")</small>
                </div>
            }
        </div>

        <div class="acs-chat-composer">
            <AcInput Value="@_draft" ValueChanged="@(v => _draft = v ?? string.Empty)"
                     Placeholder="@(L["chat.new_message"])" />
            <AcButton Variant="primary" Text="@(L["chat.send"])" OnClick="@Send"
                      Disabled="@(_sending || string.IsNullOrWhiteSpace(_draft))" />
        </div>
    }
</div>

@code {
    [Parameter] public string Id { get; set; } = "";
    private Payload? _conv;
    private bool _loading = true;
    private string? _loadError;
    private readonly List<IChatMessage> _messages = new();
    private string _draft = "";
    private bool _sending;

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (!first) return;

        // 1) Load message history from the DB. لو فشل (500/404) نعرض خطأ بدل
        //    إبقاء المؤشّر يدور.
        var env = await Api.GetAsync<Payload>($"/conversations/{Id}", localize: true);
        _conv = env.Data;
        if (_conv is null)
        {
            var code = env.Error?.Code ?? env.Operation?.FailedAnalyzer;
            var msg  = env.Error?.Message ?? env.Operation?.ErrorMessage;
            _loadError = (code, msg) switch
            {
                ("conversation_not_found", _) => "المحادثة غير موجودة أو ليست لك.",
                ("network_error", var m) when m is not null => $"تعذّر الاتصال: {m}",
                (_, var m) when !string.IsNullOrWhiteSpace(m) => m!,
                (var c, _) when !string.IsNullOrWhiteSpace(c) => $"تعذّر تحميل المحادثة ({c}).",
                _ => "تعذّر تحميل المحادثة. حاول لاحقاً."
            };
        }
        else
        {
            _messages.AddRange(_conv.Messages.Select(m => (IChatMessage)
                new ChatMessage(m.Id, Id, m.From, m.Text, m.SentAt)));

            // 2) Open the chat channel for this conversation.
            Chat.MessageReceived += OnRealtimeMessage;
            try { await Chat.EnterAsync(Id); }
            catch { /* فشل realtime ليس حرجاً — الرسائل تستمرّ عبر HTTP polling إن لزم */ }
        }

        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private void OnRealtimeMessage(IChatMessage msg)
    {
        // Skip our own echo (already added optimistically below) and de-dup by id.
        if (_messages.Any(m => m.Id == msg.Id)) return;
        _messages.Add(msg);
        InvokeAsync(StateHasChanged);
    }

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(_draft)) return;
        _sending = true;
        try
        {
            await Chat.SendAsync(_draft);
            // Optimistic local echo — the broadcast-back through chat:conv:X will
            // arrive shortly; OnRealtimeMessage de-dups by id when it lands.
            _messages.Add(new ChatMessage(
                Id: $"local-{DateTime.UtcNow.Ticks}",
                ConversationId: Id,
                SenderPartyId: "me",
                Body: _draft,
                SentAt: DateTime.UtcNow));
            _draft = "";
        }
        finally { _sending = false; await InvokeAsync(StateHasChanged); }
    }

    private void GoBack() => Nav.NavigateTo("/chats");

    public async ValueTask DisposeAsync()
    {
        Chat.MessageReceived -= OnRealtimeMessage;
        // Closing the chat channel re-opens the notif channel for this
        // conversation, so future messages reach the user as notifications.
        await Chat.LeaveAsync();
    }

    private sealed record Payload(string Id, string PartnerName, string Subject,
        string? PartnerId, string? ListingId, List<MessageDto> Messages);
    private sealed record MessageDto(string Id, string From, string Text, DateTime SentAt,
        string? Attachment = null);
}
