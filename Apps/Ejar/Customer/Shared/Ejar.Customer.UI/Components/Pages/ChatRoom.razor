@page "/chat/{Id}"
@attribute [Authorize]
@using ACommerce.Chat.Client.Blazor
@using ACommerce.Chat.Operations
@using Ejar.Customer.UI.Store
@inject AppStore Store
@inject ApiReader Api
@inject NavigationManager Nav
@inject IChatClient Chat
@inject IJSRuntime JS
@inject L L
@implements IAsyncDisposable

<PageTitle>@(L["chat.title"]) — @(L["app.name"])</PageTitle>

<div class="acs-page acs-chat-page">
    @if (_loading) { <AcLoadingState /> }
    else if (_loadError is not null)
    {
        @* لا تُبقي المؤشّر يدور للأبد لو فشل /conversations/{id} (500/404). كان
           الكود السابق يضع AcLoadingState متى كان _conv == null، فعند فشل
           الجلب يبقى المستخدم محدّقاً في عجلة لا تتوقّف. الآن نعرض الخطأ
           وزرّ رجوع. *@
        <AcEmptyState IconName="alert-circle" Message="@_loadError" />
        <AcButton Variant="ghost" Class="ac-btn-block" Text="رجوع للمحادثات"
                  OnClick="@(() => Nav.NavigateTo("/chats"))" />
    }
    else if (_conv is null)
    {
        <AcEmptyState IconName="info" Message="المحادثة غير متوفّرة." />
        <AcButton Variant="ghost" Class="ac-btn-block" Text="رجوع للمحادثات"
                  OnClick="@(() => Nav.NavigateTo("/chats"))" />
    }
    else
    {
        <div class="acs-chat-header" style="display:flex; justify-content:space-between; align-items:center;">
            <div>
                <h1 class="acm-wizard-title" style="margin-bottom:4px;">@OtherName</h1>
                <small style="color:var(--ac-text-muted);">
                    @(_conv.Subject ?? "")
                    @* مؤشّر حالة realtime — يساعد على تشخيص متى التسليم حيّ
                       ومتى يعتمد على الـ polling الاحتياطيّ. *@
                    <span style="margin-inline-start:8px; font-size:11px;">
                        <span style="display:inline-block; width:8px; height:8px; border-radius:50%; vertical-align:middle;
                                     background:@(_realtimeAlive ? "#16a34a" : "#f59e0b");"></span>
                        @(_realtimeAlive ? "حيّ" : "تحقّق دوريّ")
                    </span>
                </small>
            </div>
            <AcButton Variant="ghost" Text="رجوع" OnClick="@GoBack" />
        </div>

        <div class="acs-chat-messages" id="acs-chat-msgs">
            @foreach (var m in _messages)
            {
                var mine = IsMine(m);
                <div class="acs-bubble @(mine ? "acs-bubble-mine" : "acs-bubble-other")">
                    @if (!string.IsNullOrEmpty(m.Body))
                    {
                        <div>@m.Body</div>
                    }
                    <small style="display:block; opacity:.6;">@m.SentAt.ToLocalTime().ToString("HH:mm")</small>
                </div>
            }
        </div>

        @if (!string.IsNullOrEmpty(_sendError))
        {
            <AcAlert Variant="danger" Message="@_sendError" />
        }
        <div class="acs-chat-composer" @onkeydown="OnComposerKey">
            <AcInput Value="@_draft" id="chat-composer"
                     ValueChanged="@(v => _draft = v ?? string.Empty)"
                     Placeholder="@(L["chat.new_message"])" />
            <AcButton Variant="primary" Text="@(L["chat.send"])" OnClick="@Send"
                      Disabled="@(_sending || string.IsNullOrWhiteSpace(_draft))" />
        </div>
    }
</div>

@code {
    [Parameter] public string Id { get; set; } = "";
    private ConvDto? _conv;
    private bool _loading = true;
    private string? _loadError;
    private readonly List<IChatMessage> _messages = new();
    private string _draft = "";
    private bool _sending;

    private int _lastSeenCount;

    // Polling state. الـ realtime عبر SignalR قد يتعطّل على الجوّال (الـ tab
    // في الخلفيّة، الشاشة مقفولة، شبكة الجوّال متقطّعة). نُشغّل polling
    // كلّ ٥ ثوانٍ على /conversations/{id}/messages?since=ISO يجلب فقط ما
    // وصل بعد آخر رسالة رأيناها. الـ dedup عبر Id يضمن عدم التكرار. الـ
    // realtime يبقى الأسرع، الـ polling يضمن الوصول.
    private System.Threading.Timer? _pollTimer;
    private DateTime _lastSeenAt = DateTime.MinValue;
    private bool _realtimeAlive;
    private DateTime _lastRealtimeAt = DateTime.MinValue;

    protected override async Task OnAfterRenderAsync(bool first)
    {
        // أنزل التمرير إلى الأسفل عند أوّل render بعد تحميل الرسائل، وعند
        // كلّ زيادة في عدد الرسائل (إرسال أو استلام). لا نُمرّر في كلّ render
        // لأنّ ذلك يقفز التمرير على كلّ keystroke في خانة النصّ.
        if (_conv is not null && _messages.Count != _lastSeenCount)
        {
            _lastSeenCount = _messages.Count;
            try { await JS.InvokeVoidAsync("ejarChatUi.scrollToBottom", "#acs-chat-msgs"); }
            catch { /* JSInterop غير جاهز قبل أوّل render */ }
        }

        if (!first) return;

        // GET /conversations/{id} يردّه ChatController في Chat Kit الآن
        // (بعد إزالة التضارب من CatalogController). الشكل:
        //   { conversation: { id, ownerId, ownerName, partnerId, partnerName,
        //                     subject, listingId, lastAt, unreadCount, ... },
        //     messages: [ { id, conversationId, senderPartyId (User:GUID),
        //                   body, sentAt, readAt } ] }
        var env = await Api.GetAsync<Payload>($"/conversations/{Id}", localize: true);
        _conv = env.Data?.Conversation;
        if (env.Data?.Messages is { } msgs)
        {
            _messages.AddRange(msgs.Select(m => (IChatMessage)m));
        }
        if (_conv is null)
        {
            var code = env.Error?.Code ?? env.Operation?.FailedAnalyzer;
            var msg  = env.Error?.Message ?? env.Operation?.ErrorMessage;
            _loadError = (code, msg) switch
            {
                ("conversation_not_found", _) => "المحادثة غير موجودة أو ليست لك.",
                ("not_a_participant",      _) => "لست مشاركاً في هذه المحادثة.",
                ("network_error", var m) when m is not null => $"تعذّر الاتصال: {m}",
                (_, var m) when !string.IsNullOrWhiteSpace(m) => m!,
                (var c, _) when !string.IsNullOrWhiteSpace(c) => $"تعذّر تحميل المحادثة ({c}).",
                _ => "تعذّر تحميل المحادثة. حاول لاحقاً."
            };
        }
        else
        {
            // ابدأ من timestamp آخر رسالة محمَّلة، ليبدأ polling من النقطة
            // الصحيحة (وإلّا يجلب كلّ الرسائل في كلّ tick).
            if (_messages.Count > 0)
                _lastSeenAt = _messages[^1].SentAt;

            // Open the chat channel for this conversation. لو فشل realtime،
            // polling سيعمل وحده.
            Chat.MessageReceived += OnRealtimeMessage;
            try { await Chat.EnterAsync(Id); }
            catch { /* ignore */ }

            // ركّز على خانة الرسالة بعد ما يُرسَم الـ DOM.
            try { await JS.InvokeVoidAsync("ejarChatUi.focus", "#chat-composer"); } catch { }

            // فلتر polling: كلّ ٥s يفحص رسائل جديدة. خفيف الباندويث (delta only).
            _pollTimer = new System.Threading.Timer(
                _ => _ = PollOnceAsync(),
                state: null,
                dueTime:  TimeSpan.FromSeconds(5),
                period:   TimeSpan.FromSeconds(5));
        }

        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private string MyPartyId => Store.Auth.UserId is { } g ? $"User:{g}" : "User:?";
    private bool IsMine(IChatMessage m) =>
        string.Equals(m.SenderPartyId, MyPartyId, StringComparison.OrdinalIgnoreCase);

    /// <summary>
    /// اسم "الطرف الآخر" حسب من يعرض المحادثة. لو أنا الـ Owner أعرض اسم
    /// Partner، والعكس. الـ backend يرسل الاسمَين معاً، الواجهة تختار.
    /// </summary>
    private string OtherName
    {
        get
        {
            if (_conv is null) return "";
            var myId = Store.Auth.UserId?.ToString();
            return string.Equals(_conv.OwnerId, myId, StringComparison.OrdinalIgnoreCase)
                ? _conv.PartnerName ?? "—"
                : _conv.OwnerName ?? "—";
        }
    }

    private void OnRealtimeMessage(IChatMessage msg)
    {
        // أيّ رسالة من realtime = الاتّصال حيّ. نُحدّث المؤشّر للعرض.
        _lastRealtimeAt = DateTime.UtcNow;
        _realtimeAlive = true;

        // De-dup by id (server echo of remote message) — لا نُضيف نفس المعرّف مرّتَين.
        if (_messages.Any(m => m.Id == msg.Id)) return;

        // عند أرسال "أنا"، أضفنا echo محلّيّ بمعرّف "local-{ticks}". الـ server
        // echo يأتي بمعرّف Guid حقيقيّ من نفس body+sender خلال ثوانٍ. لو وجدنا
        // محلّيّ بنفس body من نفس sender خلال ٥ ثوانٍ، استبدله بدل التكرار.
        if (msg.SenderPartyId == MyPartyId)
        {
            for (int i = 0; i < _messages.Count; i++)
            {
                var existing = _messages[i];
                if (!existing.Id.StartsWith("local-")) continue;
                if (existing.Body != msg.Body) continue;
                if ((msg.SentAt - existing.SentAt).Duration() > TimeSpan.FromSeconds(10)) continue;
                _messages[i] = msg; // نُبدّل local بالحقيقيّ
                InvokeAsync(StateHasChanged);
                return;
            }
        }

        _messages.Add(msg);
        InvokeAsync(StateHasChanged);
    }

    private string? _sendError;

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(_draft)) return;
        _sending = true; _sendError = null;
        var pending = _draft;
        try
        {
            // Optimistic local echo بمعرف pending قبل الإرسال — لو نجح،
            // الـ broadcast سيصل بنفس النصّ من معرّف الخادم؛ لو فشل نُزيل
            // الـ echo ونعرض خطأ.
            var localId = $"local-{DateTime.UtcNow.Ticks}";
            _messages.Add(new ChatMessage(
                Id: localId,
                ConversationId: Id,
                SenderPartyId: MyPartyId,
                Body: pending,
                SentAt: DateTime.UtcNow));
            _draft = "";
            await InvokeAsync(StateHasChanged);

            await Chat.SendAsync(pending);
        }
        catch (Exception ex)
        {
            _messages.RemoveAll(m => m.Body == pending && m.Id.StartsWith("local-"));
            _sendError = $"تعذّر إرسال الرسالة: {ex.Message}";
            _draft = pending;
        }
        finally { _sending = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task OnComposerKey(KeyboardEventArgs e)
    {
        // Enter يُرسل، Shift+Enter يُدخل سطراً جديداً (سلوك معتاد في الدردشة).
        if (e.Key == "Enter" && !e.ShiftKey && !_sending && !string.IsNullOrWhiteSpace(_draft))
            await Send();
    }

    /// <summary>
    /// يجلب الرسائل التي وصلت بعد <see cref="_lastSeenAt"/> ويُضيف الجديد.
    /// يُستدعى دورياً (٥s) من الـ Timer. realtime يُعتبر "حيّ" لو وصلت رسالة
    /// عبره خلال آخر ١٢ ثانية؛ بعدها نعتمد على polling فقط.
    /// </summary>
    private async Task PollOnceAsync()
    {
        try
        {
            var sinceIso = _lastSeenAt == DateTime.MinValue
                ? "0001-01-01T00:00:00Z"
                : _lastSeenAt.ToUniversalTime().ToString("o");
            var path = $"/conversations/{Uri.EscapeDataString(Id)}/messages" +
                       $"?since={Uri.EscapeDataString(sinceIso)}";
            var env = await Api.GetAsync<List<MessageDto>>(path);
            if (env.Operation.Status != "Success" || env.Data is null) return;

            var added = false;
            foreach (var dto in env.Data)
            {
                if (_messages.Any(m => m.Id == dto.Id)) continue;

                // استبدل local-* بـ id الحقيقيّ لو body+sender متطابقَين خلال
                // ١٠s — يطابق ما يفعله OnRealtimeMessage فلا نكرّر رسالة المُرسِل.
                if (dto.SenderPartyId == MyPartyId)
                {
                    var local = _messages.FirstOrDefault(m =>
                        m.Id.StartsWith("local-") && m.Body == dto.Body
                        && (dto.SentAt - m.SentAt).Duration() <= TimeSpan.FromSeconds(10));
                    if (local is not null)
                    {
                        var idx = _messages.IndexOf(local);
                        _messages[idx] = dto;
                        if (dto.SentAt > _lastSeenAt) _lastSeenAt = dto.SentAt;
                        added = true;
                        continue;
                    }
                }

                _messages.Add(dto);
                if (dto.SentAt > _lastSeenAt) _lastSeenAt = dto.SentAt;
                added = true;
            }

            // realtime يُعتبر حيّاً لو سُمع آخر ١٢ ثانية؛ غير ذلك نُظهر "تحقّق دوريّ".
            var alive = (DateTime.UtcNow - _lastRealtimeAt) < TimeSpan.FromSeconds(12);
            if (alive != _realtimeAlive) { _realtimeAlive = alive; added = true; }

            if (added) await InvokeAsync(StateHasChanged);
        }
        catch { /* تجاهل خطأ شبكيّ — المحاولة التالية بعد ٥s */ }
    }

    private void GoBack() => Nav.NavigateTo("/chats");

    public async ValueTask DisposeAsync()
    {
        _pollTimer?.Dispose();
        _pollTimer = null;
        Chat.MessageReceived -= OnRealtimeMessage;
        // Closing the chat channel re-opens the notif channel for this
        // conversation, so future messages reach the user as notifications.
        await Chat.LeaveAsync();
    }

    // Chat Kit shape: { conversation: ConvDto, messages: MessageDto[] }
    // ConvDto حقول إضافيّة فوق IChatConversation (OwnerId/PartnerId/Subject/...)
    // يضيفها EjarCustomerChatStore.ConversationView.
    private sealed record Payload(ConvDto? Conversation, List<MessageDto>? Messages);
    private sealed record ConvDto(
        string Id,
        string? OwnerId, string? OwnerName,
        string? PartnerId, string? PartnerName,
        string? Subject, string? ListingId,
        DateTime LastAt, int UnreadCount,
        string? LastMessage);

    private sealed record MessageDto(
        string Id, string ConversationId, string SenderPartyId,
        string Body, DateTime SentAt, DateTime? ReadAt) : IChatMessage;
}
