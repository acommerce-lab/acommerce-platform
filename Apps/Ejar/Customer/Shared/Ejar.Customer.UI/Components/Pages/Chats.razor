@page "/chats"
@attribute [Authorize]
@using Ejar.Customer.UI.Store
@inject AppStore Store
@inject ApiReader Api
@inject NavigationManager Nav
@inject ITimezoneProvider Tz
@inject L L

<PageTitle>@(L["chat.title"]) — @(L["app.name"])</PageTitle>

<div class="acs-page acs-chats-page">
    <h1 class="acm-wizard-title">@(L["chat.title"])</h1>

    <AcSearchBox Value="@_search" ValueChanged="@(v => _search = v ?? string.Empty)"
                 Placeholder="ابحث في المحادثات…" />

    @if (_loading) { <AcLoadingState /> }
    else
    {
        var list = _items.Where(c =>
            string.IsNullOrWhiteSpace(_search) ||
            (OtherName(c).Contains(_search, StringComparison.OrdinalIgnoreCase)) ||
            (c.Subject?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (c.LastMessage?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false)).ToList();

        @if (list.Count == 0) { <AcEmptyState IconName="message" Message="لا توجد محادثات" /> }
        else
        {
            <div style="display:flex; flex-direction:column; gap:8px; margin-top:12px;">
                @foreach (var c in list)
                {
                    var cid = c.Id;
                    <AcCard Hover="true">
                        <ChildContent>
                            <button type="button" class="acm-complaint-btn" @onclick="@(() => Open(cid))">
                                <div style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                                    <strong>@OtherName(c)</strong>
                                    <div style="display:flex; gap:6px; align-items:center;">
                                        <small>@Tz.FormatRelative(c.LastAt)</small>
                                        @if (c.UnreadCount > 0) { <AcBadge Variant="primary" Text="@c.UnreadCount.ToString()" /> }
                                    </div>
                                </div>
                                <div class="acm-complaint-body">@c.LastMessage</div>
                                <small>@c.Subject</small>
                            </button>
                        </ChildContent>
                    </AcCard>
                }
            </div>
        }
    }
</div>

@code {
    private List<ConvDto> _items = new();
    private bool _loading = true;
    private string _search = "";

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (!first) return;
        await Tz.InitAsync();
        var env  = await Api.GetAsync<List<ConvDto>>("/conversations", localize: true);
        _items   = env.Data ?? new();
        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private void Open(string id) => Nav.NavigateTo($"/chat/{id}");

    /// <summary>
    /// "الطرف الآخر" حسب من يعرض inbox. الـ backend يُرسل OwnerName و
    /// PartnerName معاً، الواجهة تختار حسب userId الحاليّ.
    /// </summary>
    private string OtherName(ConvDto c)
    {
        var myId = Store.Auth.UserId?.ToString();
        return string.Equals(c.OwnerId, myId, StringComparison.OrdinalIgnoreCase)
            ? c.PartnerName ?? "—"
            : c.OwnerName ?? "—";
    }

    // الشكل الذي يُصدّره EjarCustomerChatStore.ConversationView (حقول إضافيّة
    // فوق IChatConversation). Subject/LastMessage/UnreadCount يأتون كحقول.
    private sealed record ConvDto(string Id,
        string? OwnerId, string? OwnerName,
        string? PartnerId, string? PartnerName,
        string? Subject, string? ListingId,
        DateTime LastAt, int UnreadCount, string? LastMessage);
}
