@page "/listings/{Id}"
@using ACommerce.Client.Operations
@using Ejar.Customer.UI.Operations
@using Ejar.Customer.UI.Services
@using Ejar.Customer.UI.Interceptors
@using System.Net.Http.Json
@inject AppStore Store
@inject AppStateApplier Applier
@inject ApiReader Api
@inject NavigationManager Nav
@inject ClientOpEngine Engine
@inject FavoritesSync Favorites
@inject EjarCircuitHttp Http
@inject L L
@implements IDisposable

<PageTitle>@(_listing?.Title ?? L["app.name"])</PageTitle>

<div class="acs-page acs-space-details">
    @if (_loading) { <AcLoadingState /> }
    else if (_listing is null) { <AcEmptyState IconName="info" Message="الإعلان غير موجود" /> }
    else
    {
        <div class="acs-gallery-wrap">
            @if (_listing.Images is not null && _listing.Images.Count > 0)
            {
                <AcGallery Images="@(_listing.Images.ToList())" />
            }
            else
            {
                <div class="acs-gallery-ph"><AcIcon Name="image" Size="48" /></div>
            }
            <button type="button" class="acs-fav-btn @(_isFav ? "active" : "")" @onclick="ToggleFavorite">
                <AcIcon Name="heart" Filled="@_isFav" Size="20" />
            </button>
        </div>

        <h1 class="acm-wizard-title">@_listing.Title</h1>
        <div style="display:flex; flex-wrap:wrap; gap:8px; align-items:center; margin-bottom:8px;">
            @if (!string.IsNullOrEmpty(_listing.District))
            {
                <span><AcIcon Name="map-pin" Size="14" /> @_listing.District — @_listing.City</span>
            }
            @if (_listing.BedroomCount > 0)
            {
                <span><AcIcon Name="home" Size="14" /> @_listing.BedroomCount @(L["listing.bedrooms"])</span>
            }
            @if (_listing.IsVerified)
            {
                <AcBadge Variant="success" Text="@(L["listing.verified"])" />
            }
        </div>

        <div class="acm-checkout-line">
            <strong style="font-size:20px;">@_listing.Price.ToString("N0") ر.ي</strong>
            <span>/ @_listing.TimeUnitLabel</span>
        </div>

        @if (!string.IsNullOrEmpty(_listing.Description))
        {
            <AcCard>
                <ChildContent>
                    <h3 style="margin-top:0;">@(L["listing.description"])</h3>
                    <p>@_listing.Description</p>
                </ChildContent>
            </AcCard>
        }

        @if (_listing.Amenities is not null && _listing.Amenities.Count > 0)
        {
            <AcCard>
                <ChildContent>
                    <h3 style="margin-top:0;">@(L["listing.amenities"])</h3>
                    <div class="acs-amenity-chips">
                        @foreach (var a in _listing.Amenities)
                        {
                            <span class="acs-amenity-chip"><AcIcon Name="check" Size="14" /> @a.Label</span>
                        }
                    </div>
                </ChildContent>
            </AcCard>
        }

        <AcCard>
            <ChildContent>
                <h3 style="margin-top:0;">الموقع</h3>
                <AcMapSim Pins="@MapPins" />
            </ChildContent>
        </AcCard>

        @if (_listing.Owner is not null && !IsMine)
        {
            <AcCard>
                <ChildContent>
                    <h3 style="margin-top:0;">المؤجّر</h3>
                    <div class="acm-details-owner">
                        <span class="acm-details-owner-avatar"><AcIcon Name="user" Size="20" /></span>
                        <div class="acm-details-owner-info">
                            <strong>@_listing.Owner.Name</strong>
                            @if (!string.IsNullOrEmpty(_listing.Owner.MemberSince))
                            {
                                <span>عضو منذ @_listing.Owner.MemberSince</span>
                            }
                        </div>
                        @* زرّ المراسلة الموحَّد موجود في AcStickyActionBar أسفل
                           الصفحة — لا حاجة لتكراره داخل بطاقة المالك. *@
                    </div>
                </ChildContent>
            </AcCard>
        }

        @if (!string.IsNullOrEmpty(_chatError))
        {
            <AcAlert Variant="danger" Message="@_chatError" />
        }
        @if (!string.IsNullOrEmpty(Favorites.LastError))
        {
            <AcAlert Variant="danger" Message="@Favorites.LastError" />
        }

        @if (IsMine)
        {
            @* لا زرّ تعديل الآن — التحرير غير مدعوم في الـ backend بعد. نُظهر
               فقط ملصقاً يبيّن للمستخدم أنّ الإعلان له حتى لا يظنّ أنّ الزرّ
               مفقود. زرّ "إدارة" يصل إلى /my-listings للتحكّم العامّ. *@
            <AcCard>
                <ChildContent>
                    <div style="display:flex; align-items:center; gap:8px;">
                        <AcIcon Name="check-circle" Size="20" />
                        <strong>هذا إعلانك</strong>
                    </div>
                </ChildContent>
            </AcCard>
        }
        @* زرّ "إبلاغ عن الإعلان" — يستخدم AcButton widget بدل raw button،
           فيرث styling مفروض من contract (Layer 5) وأيقونة flag معيار. *@
        @if (!IsMine && Store.Auth.IsAuthenticated && _listing is not null)
        {
            <div class="acs-report-link-wrap">
                <AcButton Variant="ghost" Size="sm" Icon="flag"
                          Text="إبلاغ عن هذا الإعلان" OnClick="@OpenReport" />
            </div>
        }

        @if (_showReport)
        {
            <AcCard>
                <ChildContent>
                    <h3 style="margin-top:0;">إبلاغ عن إعلان</h3>
                    <AcField Label="السبب" Required="true">
                        <select class="ac-input" @bind="_reportReason">
                            <option value="">— اختر سبباً —</option>
                            <option value="spam">إعلان مزعج / spam</option>
                            <option value="scam">احتيال</option>
                            <option value="inappropriate_images">صور غير لائقة</option>
                            <option value="wrong_info">معلومات خاطئة</option>
                            <option value="duplicate">إعلان مكرَّر</option>
                            <option value="offensive">محتوى مسيء</option>
                            <option value="other">سبب آخر</option>
                        </select>
                    </AcField>
                    <AcField Label="تفاصيل (اختياريّ)">
                        <textarea class="ac-input" rows="3" @bind="_reportBody"
                                  @bind:event="oninput" placeholder="أضف تفاصيل…"></textarea>
                    </AcField>
                    @if (!string.IsNullOrEmpty(_reportAlert))
                    {
                        <AcAlert Variant="@_reportAlertVariant" Message="@_reportAlert" />
                    }
                    <div style="display:flex; gap:8px;">
                        <AcButton Variant="primary" Text="إرسال البلاغ" OnClick="@SubmitReport"
                                  Disabled="@(string.IsNullOrEmpty(_reportReason) || _reportSending)" />
                        <AcButton Variant="ghost" Text="إلغاء" OnClick="@(() => _showReport = false)" />
                    </div>
                </ChildContent>
            </AcCard>
        }

        <AcStickyActionBar>
            <AcButton Variant="ghost" Text="رجوع" OnClick="@GoBack" />
            @if (IsMine)
            {
                <AcButton Variant="outline-primary" Class="ac-btn-block" Text="إدارة إعلاناتي"
                          OnClick="@(() => Nav.NavigateTo("/my-listings"))" />
            }
            else if (Store.Auth.IsAuthenticated)
            {
                <AcButton Variant="primary" Class="ac-btn-block" Text="@(L["listing.contact"])"
                          OnClick="@StartChat" Disabled="@_startingChat" />
            }
            else
            {
                <AcButton Variant="primary" Class="ac-btn-block" Text="سجّل دخولك للتواصل"
                          OnClick="@(() => Nav.NavigateTo("/login"))" />
            }
        </AcStickyActionBar>
    }
</div>

@code {
    [Parameter] public string Id { get; set; } = "";

    private ListingDetailDto? _listing;
    private bool _loading = true;
    private bool _startingChat;
    private string? _chatError;

    // Report state
    private bool   _showReport;
    private string _reportReason = "";
    private string _reportBody = "";
    private bool   _reportSending;
    private string? _reportAlert;
    private string  _reportAlertVariant = "success";

    private void OpenReport()
    {
        _showReport = true;
        _reportReason = "";
        _reportBody = "";
        _reportAlert = null;
    }

    private async Task SubmitReport()
    {
        if (string.IsNullOrEmpty(_reportReason) || _listing is null) return;
        _reportSending = true;
        _reportAlert = null;
        try
        {
            var resp = await Http.Client.PostAsJsonAsync("/reports", new
            {
                EntityType = "listing",
                EntityId   = _listing.Id,
                Reason     = _reportReason,
                Body       = string.IsNullOrWhiteSpace(_reportBody) ? null : _reportBody,
            });
            if (resp.IsSuccessStatusCode)
            {
                _reportAlert = "تمّ إرسال البلاغ. شكراً لمساعدتك في المحافظة على المنصّة.";
                _reportAlertVariant = "success";
                _reportReason = "";
                _reportBody = "";
                // أغلق النموذج بعد ٣ ثوانٍ.
                _ = Task.Delay(3000).ContinueWith(_ => InvokeAsync(() => { _showReport = false; StateHasChanged(); }));
            }
            else
            {
                _reportAlert = $"فشل إرسال البلاغ ({(int)resp.StatusCode}).";
                _reportAlertVariant = "danger";
            }
        }
        catch (Exception ex)
        {
            _reportAlert = "خطأ شبكيّ: " + ex.Message;
            _reportAlertVariant = "danger";
        }
        finally { _reportSending = false; }
    }
    private bool _isFav => _listing is not null && Store.FavoriteListingIds.Contains(_listing.Id);
    private bool IsMine => _listing is not null && Store.Auth.IsAuthenticated
                           && _listing.OwnerId == Store.Auth.UserId?.ToString();

    private void EditListing() => Nav.NavigateTo($"/create-listing?edit={_listing?.Id}");

    private IReadOnlyList<AcMapSim.MapPin> MapPins =>
        _listing is null ? Array.Empty<AcMapSim.MapPin>()
                         : new[] { new AcMapSim.MapPin("loc", _listing.Title, _listing.Lat, _listing.Lng) };

    protected override void OnInitialized()
    {
        Store.OnChanged += OnChange;
        Favorites.Changed += OnChange;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var env  = await Api.GetAsync<ListingDetailDto>($"/listings/{Id}");
        _listing = env.Data;
        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ToggleFavorite()
    {
        if (_listing is null) return;
        if (!Store.Auth.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
        // FavoritesSync يُحدّث المحلّيّ تفاؤليّاً ثمّ يُزامن مع الخادم.
        // بدونه كانت المفضّلات تبقى في localStorage فقط ولا تظهر على أجهزة أخرى.
        await Favorites.ToggleAsync(_listing.Id);
    }

    private async Task StartChat()
    {
        if (_listing is null) return;
        if (!Store.Auth.IsAuthenticated) { Nav.NavigateTo("/login?returnUrl=" + Uri.EscapeDataString($"/listings/{_listing.Id}")); return; }
        _startingChat = true; _chatError = null;
        try
        {
            // استدعاء مباشر بدل الذهاب عبر OpEngine — أبسط، ويضمن أنّ env.Data
            // يحوي {Id, Created} الذي يُرجعه /conversations/start فعلاً.
            var text = $"مرحباً، أنا مهتمّ بـ \"{_listing.Title}\".";
            var env = await Api.PostAsync<StartChatData>(
                "/conversations/start",
                new { ListingId = _listing.Id, Text = text });

            if (env?.Data is not null && !string.IsNullOrEmpty(env.Data.Id))
            {
                Nav.NavigateTo($"/chat/{env.Data.Id}");
                return;
            }

            // فشل /conversations/start — لا تنقل المستخدم بصمت إلى /chats، اعرض
            // السبب الحقيقيّ من الـ envelope (cannot_chat_with_self / listing_not_found
            // / network_error / 500…). السابق كان يخفي الخطأ والمستخدم يحتار.
            var code = env?.Error?.Code ?? env?.Operation?.FailedAnalyzer;
            var msg  = env?.Error?.Message ?? env?.Operation?.ErrorMessage;
            _chatError = (code, msg) switch
            {
                ("cannot_chat_with_self",          _) => "لا يمكنك بدء محادثة مع نفسك.",
                ("listing_not_found",              _) => "الإعلان لم يعد متوفّراً.",
                ("missing_or_invalid_listing_id",  _) => "بيانات الإعلان غير صالحة.",
                ("network_error",                  var m) when m is not null => $"تعذّر الاتصال بالخادم: {m}",
                (_, var m) when !string.IsNullOrWhiteSpace(m) => m!,
                (var c, _) when !string.IsNullOrWhiteSpace(c) => $"تعذّر بدء المحادثة ({c}).",
                _                                              => "تعذّر بدء المحادثة — حاول لاحقاً."
            };
        }
        finally { _startingChat = false; }
    }

    private void GoBack() => Nav.NavigateTo("/search");

    private void OnChange() => InvokeAsync(StateHasChanged);
    public void Dispose()
    {
        Store.OnChanged -= OnChange;
        Favorites.Changed -= OnChange;
    }

    private sealed record AmenityDto(string Key, string Label);
    private sealed record OwnerDto(string Name, string? MemberSince);
    private sealed record ListingDetailDto(
        string Id, string Title, string Description, decimal Price,
        string TimeUnit, string TimeUnitLabel, string PropertyType, string PropertyTypeLabel,
        string City, string District, double Lat, double Lng,
        List<AmenityDto> Amenities, string OwnerId, OwnerDto? Owner,
        int BedroomCount, int BathroomCount,
        double AreaSqm, bool IsVerified, int ViewsCount, int Status, bool IsFavorite,
        List<string>? Images);
    private sealed record StartChatData(string Id, bool Created);
}
