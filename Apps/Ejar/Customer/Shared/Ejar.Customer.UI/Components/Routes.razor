@*
  Router shared across hosts (Server / WebAssembly / MAUI). Default
  AppAssembly = هذه المكتبة (تحتوي كل صفحات @page)؛ يمكن للمضيف تمرير
  تجميعه الخاص لو أضاف صفحات إضافية.
*@
<Router AppAssembly="@(AppAssembly ?? typeof(Routes).Assembly)"
        AdditionalAssemblies="@AdditionalAssemblies">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>

@code {
    [Parameter] public System.Reflection.Assembly? AppAssembly { get; set; }
    [Parameter] public IEnumerable<System.Reflection.Assembly>? AdditionalAssemblies { get; set; }
}
