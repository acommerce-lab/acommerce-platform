@*
    Routes — قائمة @page صَريحَة لِكلّ مَسار. نَفس بَنيَة V2 تَماماً.
    HostedApp يَستَعمِل NavigationManager.LocationChanged + KitPageRegistry
    لِلتَوجيه. /properties بَدَل /listings (إيجار V1).
*@

@page "/"
@page "/login"
@page "/me"
@page "/dashboard"

@page "/properties"
@page "/properties/{Id}"
@page "/my-listings"
@page "/my-listings/new"

@page "/chat"
@page "/chat/{Id}"

@page "/notifications"
@page "/plans"
@page "/support"
@page "/favorites"

@using ACommerce.ClientHost
@using Ejar.Customer.UI.Components.Layout

<HostedApp DefaultLayout="@typeof(MainLayout)"
           LoginRoute="/login"
           LoadingMessage="جاري التحميل…"
           NotFoundTitle="الصفحة غير موجودة"
           NotFoundMessage="عُد إلى" />

@code {
    [Parameter] public string? Id { get; set; }
}
