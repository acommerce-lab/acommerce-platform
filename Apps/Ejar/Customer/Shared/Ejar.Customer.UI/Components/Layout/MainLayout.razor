@namespace Ejar.Customer.UI.Components.Layout
@using ACommerce.Kits.Versions.Templates
@using Ejar.Customer.UI.Operations
@using Ejar.Customer.UI.Services
@using Ejar.Customer.UI.Store
@inherits LayoutComponentBase
@inject AppStore Store
@inject AppStorePersistence Persistence
@inject AppStateApplier Applier
@inject ApiReader Api
@inject L L
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject EjarRealtimeService Realtime
@inject FavoritesSync Favorites
@inject VersionPoll VersionPoll
@inject IConfiguration Config
@implements IAsyncDisposable

<div class="acs-page @(Store.Ui.HideChrome ? "acm-chrome-hidden" : "")">
@if (VersionPoll.UpdateAvailable)
{
    @* بانر التحديث — يظهر فوق كلّ شيء عندما يُكتشف إصدار جديد على الخادم.
       الزرّ "تحديث الآن" يُنظّف SW + caches ثمّ يُعيد التحميل. الـ
       version-check.js الأوّليّ ما زال يعمل عند بدء التحميل، لكن هذا
       الـ banner يُعالج الحالة "مستخدم يفتح التطبيق ساعات بينما نشرنا
       إصدارين". *@
    <div role="alert" style="position:sticky; top:0; z-index:1000;
                             background:#1d4ed8; color:#fff; padding:10px 14px;
                             display:flex; gap:12px; align-items:center;
                             justify-content:center; flex-wrap:wrap;
                             font-family:Cairo,sans-serif;">
        <span>إصدار جديد متاح (@VersionPoll.AvailableVersion). أعد التحميل لتثبيته.</span>
        <button type="button"
                style="background:#fff; color:#1d4ed8; border:0; padding:6px 14px;
                       border-radius:6px; font-weight:700; cursor:pointer;"
                @onclick="ApplyAppUpdate">
            تحديث الآن
        </button>
    </div>
}
<AcAppVersionGate>
    <ChildContent>
        <nav class="acm-mobile-nav">
            <div class="acm-mobile-nav-inner">
                <div class="acm-mobile-nav-brand">
                    <span class="acm-brand-text" style="font-size:1.3rem;font-weight:700;color:var(--ac-primary);">إيجار</span>
                </div>
                <div class="acm-mobile-nav-actions">
                    <button class="acm-mobile-nav-btn" @onclick="@(() => Nav.NavigateTo("/search"))" aria-label="بحث">
                        <AcIcon Name="search" Size="28" />
                    </button>
                    <button class="acm-mobile-nav-btn" @onclick="@(() => Nav.NavigateTo("/notifications"))" aria-label="إشعارات">
                        <AcIcon Name="bell" Size="28" />
                    </button>
                </div>
            </div>
        </nav>

        <div class="acm-v2-topnav-wrap">
            <AcTopNav Items="_topItems">
                <BrandContent>
                    <div class="acm-brand">
                        <span style="font-size:1.4rem;font-weight:700;color:var(--ac-primary);">إيجار</span>
                    </div>
                </BrandContent>
                <RightActions>
                    <AcThemeToggle IsDark="@Store.Ui.IsDark"
                                   IsDarkChanged="@(async v => await Applier.ApplyLocalAsync(EjarOps.SetTheme(v ? "dark" : "light")))" />
                    <AcLanguageToggle IsArabic="@Store.Ui.IsArabic"
                                      IsArabicChanged="@(async v => await Applier.ApplyLocalAsync(EjarOps.SetLanguage(v ? "ar" : "en")))" />
                </RightActions>
            </AcTopNav>
        </div>

        <main class="@(Store.Ui.IsDark ? "ac-dark-wrap" : "")">
            @Body
            <div class="acm-v2-bottom-nav-wrap">
                <AcBottomNav Items="_bottomItems" ExtraClass="acm-v2-bottomnav" />
            </div>
        </main>

        <CookieConsentBanner />
    </ChildContent>
</AcAppVersionGate>
</div>

@code {
    // ملاحظة: حالة الإصدار يتولّاها AcAppVersionGate + VersionState تلقائياً.
    // لم نعد نستدعي /version/check يدوياً.
    private bool _favoritesLoaded;

    private static readonly IReadOnlyList<BottomNavItemDto> _bottomItems = new[]
    {
        new BottomNavItemDto { Href = "/",              Label = "الرئيسية", IconName = "home",    Exact = true },
        new BottomNavItemDto { Href = "/explore",       Label = "استكشاف",  IconName = "compass" },
        new BottomNavItemDto { Href = "/favorites",     Label = "المفضلة",  IconName = "heart" },
        new BottomNavItemDto { Href = "/chats",         Label = "الرسائل",  IconName = "message" },
        new BottomNavItemDto { Href = "/me",            Label = "حسابي",    IconName = "user" }
    };

    private static readonly IReadOnlyList<AcTopNav.TopNavItem> _topItems = new[]
    {
        new AcTopNav.TopNavItem("/",              "الرئيسية",  "home",    null, true),
        new AcTopNav.TopNavItem("/explore",       "استكشاف",   "compass"),
        new AcTopNav.TopNavItem("/favorites",     "المفضلة",   "heart"),
        new AcTopNav.TopNavItem("/chats",         "الرسائل",   "message"),
        new AcTopNav.TopNavItem("/notifications", "الإشعارات", "bell"),
        new AcTopNav.TopNavItem("/me",            "حسابي",     "user")
    };

    private string? _appliedTheme;
    private string? _appliedLang;

    protected override void OnInitialized()
    {
        Store.OnChanged += OnChange;
        Nav.LocationChanged += OnLocationChanged;
        VersionPoll.Changed += OnVersionPollChanged;
        _ = VersionPoll.StartAsync();
        UpdateChrome(Nav.Uri);
    }

    private void OnVersionPollChanged() => InvokeAsync(StateHasChanged);
    private async Task ApplyAppUpdate() => await VersionPoll.ApplyUpdateAsync();

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        UpdateChrome(e.Location);
        InvokeAsync(StateHasChanged);
    }

    private void UpdateChrome(string uri)
    {
        var path = new Uri(uri).AbsolutePath;
        Store.Ui.HideChrome = path.StartsWith("/login", StringComparison.OrdinalIgnoreCase);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // استعادة حالة المستخدم من localStorage قبل أيّ شيء آخر — يُعيد JWT
            // والمفضّلات والمسوّدة بعد إعادة تحميل الصفحة. لا يفعل شيئاً لو
            // قد استُعيد سابقاً.
            await Persistence.RestoreAsync();

            // Connect to realtime hub if already authenticated (page reload case).
            if (Store.Auth.IsAuthenticated)
                await ConnectRealtimeAsync();
        }

        // Connect after login (OnAfterRenderAsync fires after Store.NotifyChanged)
        if (Store.Auth.IsAuthenticated && !Realtime.IsConnected)
            await ConnectRealtimeAsync();

        // حمِّل المفضّلات من الخادم بعد المصادقة لتظهر على كلّ الأجهزة. مرّة
        // واحدة لكلّ جلسة — Login.razor يتولّى التحميل بعد تسجيل الدخول الجديد.
        if (Store.Auth.IsAuthenticated && !_favoritesLoaded)
        {
            _favoritesLoaded = true;
            await Favorites.LoadFromServerAsync();
        }

        if (_appliedTheme != Store.Ui.Theme || _appliedLang != Store.Ui.Language)
        {
            _appliedTheme = Store.Ui.Theme;
            _appliedLang = Store.Ui.Language;
            var dir = Store.Ui.IsRtl ? "rtl" : "ltr";
            try { await JS.InvokeVoidAsync("ejarUi.apply", Store.Ui.Theme, Store.Ui.Language, dir); }
            catch (InvalidOperationException) { }
        }
    }

    private async Task ConnectRealtimeAsync()
    {
        var apiBase = Config["EjarApi:BaseUrl"]?.TrimEnd('/') ?? "http://localhost:5300";
        // الـ hub في الباك مُركَّب على /realtime (راجع Program.cs MapHub).
        // كان هنا "/hubs/ejar" خطأً — مسار غير موجود فيفشل negotiation
        // ولا تصل أيّ رسالة حيّة. هذا سبب أنّ الإشعارات والدردشة الحيّة لم
        // تعملا أبداً رغم أنّ كلّ القنوات والأكواد سليمة.
        await Realtime.ConnectAsync($"{apiBase}/realtime");

        // اشترك مرّة واحدة في إشعارات realtime لإظهار toast OS-level. لا
        // نحتاج Firebase لهذا — Notification API الأصليّ يعمل ما دام التبويب
        // مفتوحاً (حتى لو غير مرئيّ). لإشعارات يصل مع تبويب مغلق نحتاج Web
        // Push (راجع notifications.js للخطوات).
        if (!_notifWired)
        {
            _notifWired = true;
            Realtime.NotificationReceived += OnRemoteNotification;
            try { await JS.InvokeVoidAsync("ejarNotify.requestPermission"); } catch { }
        }
    }

    private bool _notifWired;
    private void OnRemoteNotification(string json)
    {
        // payload شكل عامّ: { title, body, url? }. لو لم يُرسله الخادم بهذا
        // الشكل نُحاول استخراج الحقول المعتادة.
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            var root = doc.RootElement;
            string title = TryGet(root, "title") ?? "إيجار";
            string body  = TryGet(root, "body")  ?? TryGet(root, "text") ?? "";
            string? url  = TryGet(root, "url");
            _ = JS.InvokeVoidAsync("ejarNotify.show", title, body, new { url });
        }
        catch { /* ignore — لا نُريد أن يكسر إشعار غير متوقّع layout */ }

        static string? TryGet(System.Text.Json.JsonElement el, string name)
            => el.TryGetProperty(name, out var p) && p.ValueKind == System.Text.Json.JsonValueKind.String
               ? p.GetString() : null;
    }

    private void OnChange()
    {
        InvokeAsync(async () =>
        {
            StateHasChanged();
            if (Store.Auth.IsAuthenticated && !Realtime.IsConnected)
                await ConnectRealtimeAsync();
        });
    }

    public async ValueTask DisposeAsync()
    {
        Store.OnChanged -= OnChange;
        Nav.LocationChanged -= OnLocationChanged;
        VersionPoll.Changed -= OnVersionPollChanged;
        await VersionPoll.DisposeAsync();
        await Realtime.DisposeAsync();
    }
}
