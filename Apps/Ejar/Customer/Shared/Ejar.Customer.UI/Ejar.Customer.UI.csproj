<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Ejar.Customer.UI</RootNamespace>
    <AssemblyName>Ejar.Customer.UI</AssemblyName>
    <PackageId>Ejar.Customer.UI</PackageId>
    <Version>1.0.0</Version>
    <Description>
      تَطبيق إيجار V1 — بَعد التَّوحيد (F54) يَستَهلِك قالَب
      Customer.Marketplace كَنُقطة دَخول وَحيدة. نَفس شَكل V2 تَماماً —
      القالَب المُختَلِف + branding.css هُما الفَرق الوَحيد. لا app
      services، لا app stores، لا app pages مُكَرَّرة لِما يَعرِضه القالَب.
    </Description>
    <RazorLangVersion>latest</RazorLangVersion>
  </PropertyGroup>
  <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>
  <ItemGroup>
    <!-- قالَب Customer.Marketplace — مَصدر كلّ pages + bindings + api clients (يَرِث Customer.Ledger) -->
    <ProjectReference Include="..\..\..\..\..\libs\templates\Customer.Marketplace\ACommerce.Templates.Customer.Marketplace\ACommerce.Templates.Customer.Marketplace.csproj" />

    <!-- Versions Templates يَكشف AppVersionInfo + AppVersionHeadersHandler -->
    <ProjectReference Include="..\..\..\..\..\libs\kits\Versions\ACommerce.Kits.Versions.Templates\ACommerce.Kits.Versions.Templates.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.Authorization" Version="10.0.7" />
    <PackageReference Include="Microsoft.AspNetCore.Authorization" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="10.0.7" />
  </ItemGroup>
</Project>
