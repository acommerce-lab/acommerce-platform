<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Ejar.Customer.UI</RootNamespace>
    <AssemblyName>Ejar.Customer.UI</AssemblyName>
    <PackageId>Ejar.Customer.UI</PackageId>
    <Version>1.0.0</Version>
    <Description>
      مكتبة V1 الخاصّة بـ إيجار: صفحات @page (Login, Favorites, Explore...),
      MainLayout V1، ClientHost wiring لـ V1. كلّ الخَدَمات المُشتَرَكة في
      Ejar.Customer.Shared (مُستقلّة، يَستوردها V2 أيضاً).
    </Description>
  </PropertyGroup>

  <ItemGroup>
    <!-- المكتبة المُشتَرَكة — كلّ AppStore/Bindings/Services/Interceptors هناك -->
    <ProjectReference Include="..\Ejar.Customer.Shared\Ejar.Customer.Shared.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.Authorization" Version="10.0.7" />
    <PackageReference Include="Microsoft.AspNetCore.Authorization" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.7" />
  </ItemGroup>
</Project>
