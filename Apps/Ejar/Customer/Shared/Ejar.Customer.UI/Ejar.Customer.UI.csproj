<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Ejar.Customer.UI</RootNamespace>
    <AssemblyName>Ejar.Customer.UI</AssemblyName>
    <PackageId>Ejar.Customer.UI</PackageId>
    <Version>1.0.0</Version>
    <Description>
      المكتبة المشتركة لعميل إيجار. تحتوي كل صفحات الـ Razor، AppStore،
      عمليات الـ OAM، الـ Interpreters، خدمات HTTP/Realtime/Chat. لا
      تعتمد على بيئة استضافة معيّنة — تشغّلها قشرة Blazor Server (Ejar.Web)،
      Blazor WebAssembly (Ejar.WebAssembly)، أو MAUI Hybrid (Ejar.Maui).
    </Description>
  </PropertyGroup>

  <ItemGroup>
    <!-- Domain (entities + seed contracts) -->
    <ProjectReference Include="..\..\..\Domain\Ejar.Domain.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- OperationEngine core + Wire -->
    <ProjectReference Include="..\..\..\..\..\libs\kits\Core\OperationEngine\ACommerce.OperationEngine\ACommerce.OperationEngine.csproj" />
    <ProjectReference Include="..\..\..\..\..\libs\kits\Core\OperationEngine\ACommerce.OperationEngine.Wire\ACommerce.OperationEngine.Wire.csproj" />

    <!-- Client libraries: dispatcher + state bridge + interceptors -->
    <ProjectReference Include="..\..\..\..\..\clients\ACommerce.Client.Operations\ACommerce.Client.Operations.csproj" />
    <ProjectReference Include="..\..\..\..\..\clients\ACommerce.Client.Http\ACommerce.Client.Http.csproj" />
    <ProjectReference Include="..\..\..\..\..\clients\ACommerce.Client.StateBridge\ACommerce.Client.StateBridge.csproj" />

    <!-- Culture: numeral + phone normalization -->
    <ProjectReference Include="..\..\..\..\..\libs\kits\Culture\ACommerce.Culture.Abstractions\ACommerce.Culture.Abstractions.csproj" />
    <ProjectReference Include="..\..\..\..\..\libs\kits\Culture\ACommerce.Culture.Defaults\ACommerce.Culture.Defaults.csproj" />

    <!-- Widgets + Marketplace templates -->
    <ProjectReference Include="..\..\..\..\..\libs\kits\Widgets\ACommerce.Widgets\ACommerce.Widgets.csproj" />
    <ProjectReference Include="..\..\..\..\..\libs\kits\Templates\Shared\ACommerce.Templates.Shared\ACommerce.Templates.Shared.csproj" />
    <ProjectReference Include="..\..\..\..\..\libs\kits\Templates\Marketplace\ACommerce.Templates.Marketplace\ACommerce.Templates.Marketplace.csproj" />

    <!-- Chat client -->
    <ProjectReference Include="..\..\..\..\..\libs\kits\Chat\ACommerce.Chat.Client.Blazor\ACommerce.Chat.Client.Blazor.csproj" />

    <!-- Versions Kit — atomic refs (Operations + Templates; no server Backend).
         Avoid the .Client meta indirection because preview SDKs occasionally
         skip transitive flow through empty meta projects. -->
    <ProjectReference Include="..\..\..\..\..\libs\kits\Versions\ACommerce.Kits.Versions.Operations\ACommerce.Kits.Versions.Operations.csproj" />
    <ProjectReference Include="..\..\..\..\..\libs\kits\Versions\ACommerce.Kits.Versions.Templates\ACommerce.Kits.Versions.Templates.csproj" />

    <!-- Auth Kit — atomic refs (Operations + Templates; no server Backend) -->
    <ProjectReference Include="..\..\..\..\..\libs\kits\Auth\ACommerce.Kits.Auth.Operations\ACommerce.Kits.Auth.Operations.csproj" />
    <ProjectReference Include="..\..\..\..\..\libs\kits\Auth\ACommerce.Kits.Auth.Templates\ACommerce.Kits.Auth.Templates.csproj" />

    <!-- Subscriptions Templates (AcSubscriptionGate + SubscriptionState).
         Subscriptions has no separate Backend project yet; Operations is browser-safe
         (no HttpContext deps), Templates pulls Operations transitively. -->
    <ProjectReference Include="..\..\..\..\..\libs\kits\Subscriptions\ACommerce.Subscriptions.Templates\ACommerce.Subscriptions.Templates.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Authorization metadata (AuthorizeAttribute used by @attribute [Authorize]
         on Razor pages) + Components.Authorization for AuthorizeView/AuthorizationStateProvider.
         Both are WASM-safe (netstandard / browser-supported). -->
    <PackageReference Include="Microsoft.AspNetCore.Authorization" Version="10.0.7" />
    <PackageReference Include="Microsoft.AspNetCore.Components.Authorization" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.Options" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="10.0.7" />
  </ItemGroup>
</Project>
