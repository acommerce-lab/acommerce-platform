@*
    EjarDashboardWidget — صفحة composition بكامل OAM design fingerprint:
      - OamTAccount: حساب المستخدِم (مُلَخَّص ledger-style)
      - OamReceipt:  آخر عمليّة مُنفَّذة كإيصال
      - OamLedger:   اليوميّة — قائمة عمليّات أخيرة
      - شارات kit + composition

    البيانات هنا توضيحيّة (sample). pass لاحق يُغذّيها من Stores.
*@
@inject L L

<section class="ejar-page-intro">
    <h1>@(L[EjarV2Strings.DashboardTitle])</h1>
    <p>@(L[EjarV2Strings.DashboardSubtitle])</p>
</section>

<header class="ejar-section-head">
    <h2 class="ejar-section-title">@(L[EjarV2Strings.DashboardAccountSection])</h2>
    <span class="ejar-section-meta oam-mono">/ T-account</span>
</header>

<OamTAccount Title="@(L[EjarV2Strings.DashboardTaccountTitle])"
             Subtitle="user:current"
             LeftHeader="@(L[EjarV2Strings.DashboardTaccountLeft])"
             RightHeader="@(L[EjarV2Strings.DashboardTaccountRight])"
             Left="@DebitsList"
             Right="@CreditsList"
             Balanced="true" />

<header class="ejar-section-head">
    <h2 class="ejar-section-title">@(L[EjarV2Strings.DashboardLastOp])</h2>
    <span class="ejar-section-meta oam-mono">/ receipt</span>
</header>

<OamReceipt OperationType="listing.create"
            From="user:current"
            To="listing:apt-zhour"
            Time="@_lastOpTime"
            State="OamState.Executed"
            Tags="@LastOpTags" />

<header class="ejar-section-head">
    <h2 class="ejar-section-title">@(L[EjarV2Strings.DashboardLedger])</h2>
    <span class="ejar-section-meta oam-mono">@(L[EjarV2Strings.DashboardLedgerMeta])</span>
</header>

<OamLedger Rows="@_ledger" />

<header class="ejar-section-head">
    <h2 class="ejar-section-title">@(L[EjarV2Strings.DashboardBadges])</h2>
    <span class="ejar-section-meta oam-mono">/ kit composition</span>
</header>

<a href="/chat" class="ejar-card">
    <div>
        <div class="ejar-card-title">@(L[EjarV2Strings.LayoutChats])</div>
        <div class="ejar-card-meta">@(L[EjarV2Strings.DashboardCardChatsMeta])</div>
    </div>
    <AcChatUnreadBadgeWidget AriaLabel="@(L[EjarV2Strings.DashboardChatUnreadAria])" />
</a>

<a href="/notifications" class="ejar-card">
    <div>
        <div class="ejar-card-title">@(L[EjarV2Strings.LayoutNotifications])</div>
        <div class="ejar-card-meta">@(L[EjarV2Strings.DashboardCardNotificationsMeta])</div>
    </div>
    <AcNotificationsUnreadBadgeWidget AriaLabel="@(L[EjarV2Strings.DashboardNotifUnreadAria])" />
</a>

@code {
    // ‹L› مَحقون كَـ instance — لا يَجوز static readonly initializer.
    // العَناصر تُحسَب على كلّ render (رَخيصَة).
    private OamTAccountLine[] DebitsList =>
    [
        new(L[EjarV2Strings.DashboardDemoListingsPublished], "3"),
        new(L[EjarV2Strings.DashboardDemoMessagesSent],     "142"),
        new(L[EjarV2Strings.DashboardDemoFavoritesAdded],   "12"),
    ];

    private OamTAccountLine[] CreditsList =>
    [
        new(L[EjarV2Strings.DashboardDemoPropertiesViewed], "47"),
        new(L[EjarV2Strings.DashboardDemoNotificationsRead], "23"),
        new(L[EjarV2Strings.DashboardDemoSubscriptions],     "1"),
    ];

    private static readonly DateTime _lastOpTime = DateTime.UtcNow.AddMinutes(-12);

    private OamTag[] LastOpTags =>
    [
        new("title", L[EjarV2Strings.DashboardDemoListingTitle]),
        new("price", "1500"),
        new("city",  L[EjarV2Strings.DashboardDemoListingCity]),
    ];

    private static readonly OamLedgerEntry[] _ledger =
    {
        new("11:42", "listing.create",    "user:current", "listing:X",   "+1"),
        new("11:48", "favorite.toggle",   "user:current", "listing:X",   "±1"),
        new("11:55", "chat.send",         "user:current", "conv:Y",      "+1msg"),
        new("12:01", "notification.read", "system",       "user:current","-1"),
    };
}
