@using ACommerce.ClientHost
@using Ejar.Customer.UI.V2.Components.Layout

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>إيجار</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" />
    <link rel="stylesheet" href="_content/ACommerce.Templates.OAM/oam-fingerprint.css" />
    <link rel="stylesheet" href="_content/Ejar.Customer.UI.V2/app-v2.css" />
    <HeadOutlet />
</head>
<body>
    <RoutableHostedApp DefaultLayout="@typeof(MainLayout)"
                       LoginRoute="/login"
                       @rendermode="@(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode())">
        <AuthorizingSlot>
            <div class="ejar-loading" role="status" aria-busy="true">جاري التحميل…</div>
        </AuthorizingSlot>
        <NotFoundSlot>
            <div class="ejar-notfound">
                <h1>الصفحة غير موجودة</h1>
                <p>عُد إلى <a href="/">الرئيسيّة</a>.</p>
            </div>
        </NotFoundSlot>
    </RoutableHostedApp>
    <script src="_framework/blazor.web.js"></script>
</body>
</html>
