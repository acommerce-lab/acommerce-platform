@using ACommerce.ClientHost
@using Ejar.Customer.UI.V2.Components.Layout

@*
    App.razor — root component لـ Ejar.Web.V2. يَلفّ HostedApp مع MainLayout.
    لا Routes.razor، لا @page wrappers — كلّ المسارات في AddAppPages.
*@
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>إيجار V2</title>
    <link rel="stylesheet" href="_content/Ejar.Customer.UI.V2/app-v2.css" />
    <HeadOutlet />
</head>
<body>
    <HostedApp DefaultLayout="@typeof(MainLayout)"
               LoginRoute="/login"
               @rendermode="@(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode())">
        <AuthorizingSlot>
            <div class="ejar-v2-loading" role="status" aria-busy="true">جاري التحميل…</div>
        </AuthorizingSlot>
        <NotFoundSlot>
            <div class="ejar-v2-notfound">
                <h1>الصفحة غير موجودة</h1>
                <p>عُد إلى <a href="/">الرئيسيّة</a>.</p>
            </div>
        </NotFoundSlot>
    </HostedApp>
    <script src="_framework/blazor.web.js"></script>
</body>
</html>
