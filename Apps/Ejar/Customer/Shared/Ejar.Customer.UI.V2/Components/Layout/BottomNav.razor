@inject NavigationManager Nav
@inject L L
@implements IDisposable

<nav class="ejar-bottomnav" aria-label="@(L[EjarV2Strings.BottomnavAria])">
    <a href="/" class="@Active("/")">
        <span class="ejar-bn-icon" aria-hidden="true">⌂</span>
        <span class="ejar-bn-label">@(L[EjarV2Strings.BottomnavHome])</span>
    </a>
    <a href="/properties" class="@Active("/properties")">
        <span class="ejar-bn-icon" aria-hidden="true">▤</span>
        <span class="ejar-bn-label">@(L[EjarV2Strings.BottomnavProperties])</span>
    </a>
    <a href="/favorites" class="@Active("/favorites")">
        <span class="ejar-bn-icon" aria-hidden="true">♥</span>
        <span class="ejar-bn-label">@(L[EjarV2Strings.BottomnavFavorites])</span>
    </a>
    <a href="/chat" class="@Active("/chat")">
        <span class="ejar-bn-icon" aria-hidden="true">✉</span>
        <span class="ejar-bn-label">@(L[EjarV2Strings.BottomnavChats])</span>
        <AcChatUnreadBadgeWidget />
    </a>
    <a href="/me" class="@Active("/me")">
        <span class="ejar-bn-icon" aria-hidden="true">◉</span>
        <span class="ejar-bn-label">@(L[EjarV2Strings.BottomnavAccount])</span>
    </a>
</nav>

@code {
    protected override void OnInitialized() => Nav.LocationChanged += OnLoc;
    private void OnLoc(object? s, LocationChangedEventArgs e) => InvokeAsync(StateHasChanged);
    public void Dispose() => Nav.LocationChanged -= OnLoc;

    private string Active(string path)
    {
        var rel = Nav.ToBaseRelativePath(Nav.Uri);
        if (string.IsNullOrEmpty(rel)) rel = "/";
        else if (!rel.StartsWith("/")) rel = "/" + rel;
        var match = path == "/" ? rel == "/" : rel.StartsWith(path);
        return match ? "active" : "";
    }
}
