@*
    App.razor — root SSR component، LOCAL في Ejar.Web (نَفس بَنيَة V2's App.razor).
    Razor SDK يَحتاج رؤية Razor components داخل host project لِيُسَجِّل
    _framework/blazor.web.js في static asset manifest.
*@
@using Ejar.Customer.UI.Components

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>إيجار</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" />
    <link rel="stylesheet" href="_content/ACommerce.Widgets/widgets.css" />
    <link rel="stylesheet" href="_content/ACommerce.Templates.Shared/templates-shared.css" />
    <link rel="stylesheet" href="_content/ACommerce.Templates.OAM/oam-fingerprint.css" />
    <!-- branding.css آخر CSS ⇒ override كَلاسات Marketplace + Ledger
         بِلَوحة V1. هذا هو الفَرق الوَحيد البَصَريّ بَين V1 و V2. -->
    <link rel="stylesheet" href="branding.css" />
    <HeadOutlet />
</head>
<body>
    <Routes @rendermode="InteractiveServer" />
    <script src="_framework/blazor.web.js"></script>
</body>
</html>
