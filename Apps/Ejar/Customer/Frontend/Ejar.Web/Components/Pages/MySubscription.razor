@page "/my-subscription"
@inject ApiReader Api
@inject NavigationManager Nav
@inject L L

<PageTitle>اشتراكي — @(L["app.name"])</PageTitle>

<div class="acs-page acs-my-subscription">
    <h1 class="acm-wizard-title">اشتراكي النشط</h1>
    @if (_loading) { <AcLoadingState /> }
    else if (_sub is null) { <AcEmptyState IconName="package" Message="لا يوجد اشتراك نشط" /> }
    else
    {
        <AcCard>
            <ChildContent>
                <div style="display:flex; justify-content:space-between; align-items:center;">
                    <div>
                        <h2 style="margin:0;">خطة @_sub.PlanName</h2>
                        <small>@_sub.Status — ينتهي في @_sub.EndDate.ToString("yyyy-MM-dd")</small>
                    </div>
                    <AcBadge Variant="@(_sub.DaysRemaining <= 7 ? "warning" : "success")"
                             Text="@($"{_sub.DaysRemaining} يوم متبقّي")" />
                </div>

                @if (_sub.DaysRemaining <= 7)
                {
                    <AcAlert Variant="warning" Text="اشتراكك ينتهي قريباً — جدّد قبل الانتهاء لتفادي تعطّل الإعلانات." />
                }

                <div class="acm-checkout-line"><span>تاريخ البدء:</span><strong>@_sub.StartDate.ToString("yyyy-MM-dd")</strong></div>
                <div class="acm-checkout-line"><span>تاريخ الانتهاء:</span><strong>@_sub.EndDate.ToString("yyyy-MM-dd")</strong></div>
            </ChildContent>
        </AcCard>

        <h3 style="margin-top:16px;">استهلاك الكوتا</h3>
        <div class="acm-home-grid">
            <AcCard>
                <ChildContent>
                    <strong>الإعلانات</strong>
                    <div class="acm-checkout-line"><span>مستخدَم:</span><strong>@_sub.ListingsUsed / @_sub.ListingsLimit</strong></div>
                    <div class="acs-progress"><div class="acs-progress-bar" style="width:@(Pct(_sub.ListingsUsed, _sub.ListingsLimit))%"></div></div>
                </ChildContent>
            </AcCard>
            <AcCard>
                <ChildContent>
                    <strong>التمييز</strong>
                    <div class="acm-checkout-line"><span>مستخدَم:</span><strong>@_sub.FeaturedUsed / @_sub.FeaturedLimit</strong></div>
                    <div class="acs-progress"><div class="acs-progress-bar" style="width:@(Pct(_sub.FeaturedUsed, _sub.FeaturedLimit))%"></div></div>
                </ChildContent>
            </AcCard>
            <AcCard>
                <ChildContent>
                    <strong>الصور لكلّ إعلان</strong>
                    <div class="acm-checkout-line"><span>الحد:</span><strong>@_sub.ImagesPerListing</strong></div>
                </ChildContent>
            </AcCard>
        </div>

        <h3 style="margin-top:16px;">مزايا الخطّة</h3>
        <AcCard>
            <ChildContent>
                <ul style="list-style:none; padding:0; margin:0;">
                    @foreach (var f in _sub.Features)
                    {
                        <li style="display:flex; gap:8px; padding:6px 0; align-items:center;">
                            <AcIcon Name="check-circle" Size="16" />
                            <span>@f</span>
                        </li>
                    }
                </ul>
            </ChildContent>
        </AcCard>

        <h3 style="margin-top:16px;">الفواتير</h3>
        @if (_invoices.Count == 0) { <AcEmptyState IconName="receipt" Message="لا توجد فواتير" /> }
        else
        {
            <AcCard>
                <ChildContent>
                    @foreach (var i in _invoices)
                    {
                        <div class="acm-checkout-line">
                            <span>@i.Id — @i.Date.ToString("yyyy-MM-dd")</span>
                            <strong>@i.Amount SAR</strong>
                            <AcBadge Variant="@(i.Status == "paid" ? "success" : "warning")" Text="@i.Status" />
                        </div>
                    }
                </ChildContent>
            </AcCard>
        }

        <div style="display:flex; gap:8px; margin-top:12px;">
            <AcButton Variant="primary" Text="تجديد الاشتراك" OnClick="@Renew" />
            <AcButton Variant="outline-primary" Text="تغيير الخطّة" OnClick="@ChangePlan" />
            <AcButton Variant="ghost" Text="إلغاء الاشتراك" OnClick="@CancelSub" />
        </div>
    }
</div>

@code {
    private SubDto? _sub;
    private List<InvoiceDto> _invoices = new();
    private bool _loading = true;

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (!first) return;
        var s = await Api.GetAsync<SubDto>("/me/subscription");
        _sub = s.Data;
        var inv = await Api.GetAsync<List<InvoiceDto>>("/me/invoices");
        _invoices = inv.Data ?? new();
        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private static int Pct(int used, int limit) => limit > 0 ? Math.Min(100, used * 100 / limit) : 0;

    private void Renew()     => Nav.NavigateTo($"/subscribe?type=plan&id={_sub!.PlanId}&amount={_sub.Price}");
    private void ChangePlan() => Nav.NavigateTo("/plans");
    private void CancelSub() { }

    private sealed record SubDto(string Id, string PlanId, string PlanName, string Status,
        DateTime StartDate, DateTime EndDate, int DaysRemaining,
        int ListingsUsed, int ListingsLimit, int FeaturedUsed, int FeaturedLimit,
        int ImagesPerListing, decimal Price = 0,
        IReadOnlyList<string>? Features = null)
    {
        public IReadOnlyList<string> Features { get; init; } = Features ?? Array.Empty<string>();
    }

    private sealed record InvoiceDto(string Id, string PlanId, decimal Amount, DateTime Date, string Status);
}
