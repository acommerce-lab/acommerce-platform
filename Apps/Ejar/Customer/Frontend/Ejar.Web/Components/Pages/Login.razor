@page "/login"
@inject AppStore Store
@inject ApiReader Api
@inject NavigationManager Nav
@inject L L
@implements IDisposable

<PageTitle>@(L["auth.login.title"]) — @(L["app.name"])</PageTitle>

<div class="ejar-auth-wrap">
    <div class="ejar-auth-card">
        <div style="text-align:center;margin-bottom:24px;">
            <span style="font-size:2.5rem;font-weight:700;color:var(--ac-primary);">إيجار</span>
        </div>

        @if (!_otpSent)
        {
            <h2>@(L["auth.login.title"])</h2>
            <p>@(L["auth.phone.hint"])</p>
            <div class="mb-2">
                <label class="ac-label">@(L["auth.phone"])</label>
                <input type="tel" class="ac-input w-100" placeholder="05xxxxxxxx" @bind="_phone" disabled="@_busy" />
            </div>
            @if (_error is not null)
            {
                <div class="ac-alert ac-alert-danger mt-2">@_error</div>
            }
            <button class="ac-btn ac-btn-primary w-100 mt-3" disabled="@_busy" @onclick="RequestOtp">
                @if (_busy) { <span class="acm-spinner-sm"></span> }
                @(L["auth.send_otp"])
            </button>
        }
        else
        {
            <h2>رمز التحقق</h2>
            <p>@(L["auth.otp.hint"])</p>
            <div class="mb-2">
                <label class="ac-label">@(L["auth.otp"])</label>
                <input type="tel" class="ac-input w-100" placeholder="123456" maxlength="6" @bind="_code" disabled="@_busy" />
            </div>
            <div class="ejar-otp-hint">@(L["auth.otp.demo"])</div>
            @if (_error is not null)
            {
                <div class="ac-alert ac-alert-danger mt-2">@_error</div>
            }
            <button class="ac-btn ac-btn-primary w-100 mt-3" disabled="@(_busy || _code.Length < 6)" @onclick="VerifyOtp">
                @if (_busy) { <span class="acm-spinner-sm"></span> }
                @(L["auth.verify"])
            </button>
            <button class="ac-btn ac-btn-outline-secondary w-100 mt-2" @onclick="Reset">تغيير رقم الجوّال</button>
        }
    </div>
</div>

@code {
    private string _phone = "";
    private string _code = "";
    private bool _otpSent;
    private bool _busy;
    private string? _error;

    protected override void OnInitialized()
    {
        Store.OnChanged += OnChange;
        Store.Ui.HideChrome = true;
        if (Store.Auth.IsAuthenticated) Nav.NavigateTo("/me");
    }

    private async Task RequestOtp()
    {
        _error = null;
        _busy = true;
        await InvokeAsync(StateHasChanged);
        var env = await Api.PostAsync<object>("/auth/otp/request", new { phone = _phone });
        _busy = false;
        if (env.Operation.Status == "Success") { _otpSent = true; }
        else { _error = env.Operation.ErrorMessage ?? "فشل الإرسال"; }
        await InvokeAsync(StateHasChanged);
    }

    private async Task VerifyOtp()
    {
        _error = null;
        _busy = true;
        await InvokeAsync(StateHasChanged);
        var env = await Api.PostAsync<AuthDto>("/auth/otp/verify", new { phone = _phone, code = _code });
        _busy = false;
        if (env.Operation.Status == "Success" && env.Data is not null)
        {
            Store.Auth.AccessToken = env.Data.Token;
            Store.Auth.FullName = env.Data.Name;
            Store.Auth.Phone = env.Data.Phone;
            if (Guid.TryParse(env.Data.UserId, out var uid)) Store.Auth.UserId = uid;
            Store.NotifyChanged();
            Store.Ui.HideChrome = false;
            Nav.NavigateTo("/me");
        }
        else { _error = env.Operation.ErrorMessage ?? "رمز التحقق غير صحيح"; }
        await InvokeAsync(StateHasChanged);
    }

    private void Reset() { _otpSent = false; _code = ""; _error = null; }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender) Store.Ui.HideChrome = true;
    }

    private void OnChange() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Store.OnChanged -= OnChange;
        Store.Ui.HideChrome = false;
    }

    private sealed record AuthDto(string Token, string UserId, string Name, string Phone);
}
