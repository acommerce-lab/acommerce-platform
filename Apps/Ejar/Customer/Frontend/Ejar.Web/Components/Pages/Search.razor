@page "/search"
@inject AppStore Store
@inject AppStateApplier Applier
@inject ApiReader Api
@inject NavigationManager Nav
@inject L L
@implements IDisposable

<PageTitle>@(L["common.search"]) — @(L["app.name"])</PageTitle>

<div class="ejar-page">
    @* Search box *@
    <div style="padding:12px 16px;background:var(--ac-surface);border-bottom:1px solid var(--ac-border);">
        <div class="ejar-search-box">
            <input type="search" placeholder="@(L["home.search.placeholder"])"
                   @bind="_q" @bind:event="oninput" @onkeyup="OnSearchKey" />
            <button @onclick="RunSearch">@(L["common.search"])</button>
        </div>
    </div>

    @* Filters *@
    <div style="padding:10px 16px;background:var(--ac-surface);border-bottom:1px solid var(--ac-border);">
        <div class="d-flex gap-2 flex-wrap">
            <select class="ac-input" style="min-width:100px;" @bind="_city">
                <option value="">@(L["filter.city"])</option>
                @foreach (var c in _cities) { <option value="@c">@c</option> }
            </select>
            <select class="ac-input" style="min-width:120px;" @bind="_propertyType">
                <option value="">@(L["filter.type"])</option>
                @foreach (var cat in _categories) { <option value="@cat.Id">@cat.Label</option> }
            </select>
            <select class="ac-input" style="min-width:110px;" @bind="_timeUnit">
                <option value="">@(L["filter.time_unit"])</option>
                <option value="monthly">شهري</option>
                <option value="yearly">سنوي</option>
                <option value="daily">يومي</option>
                <option value="hourly">بالساعة</option>
            </select>
            <select class="ac-input" style="min-width:130px;" @bind="_sort">
                <option value="">@(L["filter.sort"])</option>
                <option value="price_asc">@(L["filter.sort.price_asc"])</option>
                <option value="price_desc">@(L["filter.sort.price_desc"])</option>
                <option value="views">@(L["filter.sort.views"])</option>
            </select>
            <button class="ac-btn ac-btn-sm ac-btn-primary" @onclick="RunSearch">@(L["common.apply"])</button>
            <button class="ac-btn ac-btn-sm ac-btn-outline-secondary" @onclick="Reset">@(L["common.reset"])</button>
        </div>
    </div>

    @* Results *@
    <div class="ejar-content mt-3">
        @if (_loading)
        {
            <div class="ejar-empty"><div class="acm-spinner"></div></div>
        }
        else if (_listings.Count == 0)
        {
            <div class="ejar-empty">
                <div class="ejar-empty-icon">🔍</div>
                <div class="ejar-empty-text">@(L["listing.no_results"])</div>
            </div>
        }
        else
        {
            <p style="font-size:0.83rem;color:var(--ac-text-muted);margin-bottom:12px;">@_total نتيجة</p>
            <div class="row g-3">
                @foreach (var l in _listings)
                {
                    var lid = l.Id;
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="ejar-listing-card p-0" style="cursor:pointer;" @onclick="@(() => Nav.NavigateTo("/listings/" + lid))">
                            @if (l.FirstImage is not null)
                            {
                                <img src="@l.FirstImage" alt="@l.Title" style="width:100%;height:180px;object-fit:cover;" />
                            }
                            else
                            {
                                <div style="height:120px;background:var(--ac-primary-light);display:flex;align-items:center;justify-content:center;font-size:2.5rem;">🏠</div>
                            }
                            <div class="p-3">
                                <div class="d-flex align-items-center gap-1 mb-1">
                                    @if (l.IsVerified) { <span class="ejar-badge-verified">✔ موثَّق</span> }
                                </div>
                                <p style="font-weight:600;font-size:0.93rem;margin:0 0 4px;line-height:1.3;">@l.Title</p>
                                <p style="font-size:0.8rem;color:var(--ac-text-muted);margin:0 0 6px;">📍 @l.District — @l.City</p>
                                <div class="d-flex align-items-center justify-content-between">
                                    <div>
                                        <span class="ejar-price">@l.Price.ToString("N0")</span>
                                        <span class="ejar-time-unit">ر / @l.TimeUnitLabel</span>
                                    </div>
                                    <button class="ac-btn ac-btn-xs @(Store.FavoriteListingIds.Contains(l.Id) ? "ac-btn-primary" : "ac-btn-outline-secondary")"
                                            @onclick:stopPropagation="true"
                                            @onclick="@(async () => await Applier.ApplyLocalAsync(EjarOps.ToggleFavorite(l.Id)))">♥</button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @* Pagination *@
            @if (_total > _pageSize)
            {
                <div class="d-flex justify-content-center gap-2 mt-4">
                    <button class="ac-btn ac-btn-sm ac-btn-outline-primary" disabled="@(_page <= 1)" @onclick="PrevPage">@(L["common.prev"])</button>
                    <span style="padding:6px 12px;font-size:0.85rem;color:var(--ac-text-muted);">@_page</span>
                    <button class="ac-btn ac-btn-sm ac-btn-outline-primary" disabled="@(_page * _pageSize >= _total)" @onclick="NextPage">@(L["common.next"])</button>
                </div>
            }
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? q { get; set; }
    [SupplyParameterFromQuery] public string? propertyType { get; set; }
    [SupplyParameterFromQuery] public string? city { get; set; }

    private string _q = "";
    private string _city = "";
    private string _propertyType = "";
    private string _timeUnit = "";
    private string _sort = "";
    private int _page = 1;
    private int _pageSize = 20;
    private int _total;
    private bool _loading;
    private List<ListingDto> _listings = new();
    private List<string> _cities = new();
    private List<CategoryDto> _categories = new();

    protected override void OnInitialized()
    {
        _q = q ?? "";
        _propertyType = propertyType ?? "";
        _city = city ?? Store.Ui.City;
        Store.OnChanged += OnChange;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var cEnv = await Api.GetAsync<List<string>>("/cities");
        var catEnv = await Api.GetAsync<List<CategoryDto>>("/categories");
        _cities = cEnv.Data ?? new();
        _categories = catEnv.Data ?? new();
        await RunSearch();
    }

    private async Task RunSearch()
    {
        _loading = true;
        await InvokeAsync(StateHasChanged);
        var url = BuildUrl();
        var env = await Api.GetAsync<ListingsResponse>(url);
        _total = env.Data?.Total ?? 0;
        _listings = env.Data?.Items ?? new();
        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private string BuildUrl()
    {
        var p = new List<string> { $"page={_page}", $"pageSize={_pageSize}" };
        if (!string.IsNullOrEmpty(_q))            p.Add($"q={Uri.EscapeDataString(_q)}");
        if (!string.IsNullOrEmpty(_city))         p.Add($"city={Uri.EscapeDataString(_city)}");
        if (!string.IsNullOrEmpty(_propertyType)) p.Add($"propertyType={Uri.EscapeDataString(_propertyType)}");
        if (!string.IsNullOrEmpty(_timeUnit))     p.Add($"timeUnit={Uri.EscapeDataString(_timeUnit)}");
        if (!string.IsNullOrEmpty(_sort))         p.Add($"sort={Uri.EscapeDataString(_sort)}");
        return "/listings?" + string.Join("&", p);
    }

    private void OnSearchKey(KeyboardEventArgs e) { if (e.Key == "Enter") _ = RunSearch(); }

    private async Task Reset()
    {
        _q = ""; _city = ""; _propertyType = ""; _timeUnit = ""; _sort = ""; _page = 1;
        await RunSearch();
    }

    private async Task PrevPage() { if (_page > 1) { _page--; await RunSearch(); } }
    private async Task NextPage() { _page++; await RunSearch(); }

    private void OnChange() => InvokeAsync(StateHasChanged);
    public void Dispose() => Store.OnChanged -= OnChange;

    private sealed record CategoryDto(string Id, string Label, string Emoji, string Kind, List<string> TimeUnits);
    private sealed record ListingsResponse(int Total, int Page, int PageSize, List<ListingDto> Items);
    private sealed record ListingDto(
        string Id, string Title, decimal Price, string TimeUnit, string TimeUnitLabel,
        string PropertyType, string City, string District, bool IsVerified,
        int ViewsCount, bool IsFavorite, List<string> Amenities, string? FirstImage);
}
