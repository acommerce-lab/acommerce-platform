@page "/my-listings"
@inject AppStore Store
@inject ApiReader Api
@inject NavigationManager Nav
@inject L L
@implements IDisposable

<PageTitle>@(L["my_listings.title"]) — @(L["app.name"])</PageTitle>

<div class="ejar-page">
    <div style="padding:16px;border-bottom:1px solid var(--ac-border);display:flex;align-items:center;justify-content:space-between;">
        <h1 style="font-size:1rem;font-weight:700;margin:0;">@(L["my_listings.title"])</h1>
        <button class="ac-btn ac-btn-sm ac-btn-primary" @onclick="@(() => Nav.NavigateTo("/my-listings/create"))">+ @(L["my_listings.add"])</button>
    </div>

    @if (!Store.Auth.IsAuthenticated)
    {
        <div class="ejar-empty mt-5">
            <button class="ac-btn ac-btn-primary" @onclick="@(() => Nav.NavigateTo("/login"))">@(L["auth.login.title"])</button>
        </div>
    }
    else if (_loading)
    {
        <div class="ejar-empty"><div class="acm-spinner"></div></div>
    }
    else if (_listings.Count == 0)
    {
        <div class="ejar-empty">
            <div class="ejar-empty-icon">📋</div>
            <div class="ejar-empty-text">@(L["my_listings.empty"])</div>
            <button class="ac-btn ac-btn-primary mt-2" @onclick="@(() => Nav.NavigateTo("/my-listings/create"))">@(L["my_listings.add"])</button>
        </div>
    }
    else
    {
        @foreach (var l in _listings)
        {
            <div style="padding:14px 16px;border-bottom:1px solid var(--ac-border);">
                <div class="d-flex align-items-start gap-3">
                    <div @onclick="@(() => Nav.NavigateTo($"/listings/{l.Id}"))"
                         style="width:72px;height:72px;border-radius:8px;overflow:hidden;flex-shrink:0;cursor:pointer;background:var(--ac-primary-light);display:flex;align-items:center;justify-content:center;font-size:1.8rem;">
                        @if (l.FirstImage is not null) { <img src="@l.FirstImage" alt="" style="width:100%;height:100%;object-fit:cover;" /> }
                        else { <span>🏠</span> }
                    </div>
                    <div style="flex:1;overflow:hidden;">
                        <div style="font-weight:600;font-size:0.93rem;">@l.Title</div>
                        <div style="font-size:0.8rem;color:var(--ac-text-muted);margin:2px 0;">@l.City — @l.District</div>
                        <div class="d-flex align-items-center gap-2 mt-1">
                            <span style="font-size:0.78rem;padding:2px 8px;border-radius:99px;background:@(l.Status == 1 ? "var(--ac-success)" : "var(--ac-surface-alt)");color:@(l.Status == 1 ? "#fff" : "var(--ac-text-muted)");">
                                @(l.Status == 1 ? L["my_listings.active"] : L["my_listings.paused"])
                            </span>
                            <span class="ejar-price" style="font-size:0.88rem;">@l.Price.ToString("N0") ر</span>
                        </div>
                    </div>
                    <div class="d-flex flex-column gap-1">
                        <button class="ac-btn ac-btn-xs ac-btn-outline-primary" @onclick="@(() => ToggleStatus(l))">
                            @(l.Status == 1 ? "إيقاف" : "تفعيل")
                        </button>
                        <button class="ac-btn ac-btn-xs ac-btn-outline-danger" @onclick="@(() => Delete(l))">حذف</button>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<MyListingDto> _listings = new();
    private bool _loading = true;

    protected override void OnInitialized() => Store.OnChanged += OnChange;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !Store.Auth.IsAuthenticated) return;
        await Load();
    }

    private async Task Load()
    {
        _loading = true;
        var env = await Api.GetAsync<List<MyListingDto>>("/my-listings");
        _listings = env.Data ?? new();
        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ToggleStatus(MyListingDto l)
    {
        await Api.PostAsync<object>($"/my-listings/{l.Id}/toggle");
        var ix = _listings.FindIndex(x => x.Id == l.Id);
        if (ix >= 0) _listings[ix] = l with { Status = l.Status == 1 ? 0 : 1 };
        await InvokeAsync(StateHasChanged);
    }

    private async Task Delete(MyListingDto l)
    {
        await Api.DeleteAsync<object>($"/my-listings/{l.Id}");
        _listings.Remove(l);
        await InvokeAsync(StateHasChanged);
    }

    private void OnChange() => InvokeAsync(StateHasChanged);
    public void Dispose() => Store.OnChanged -= OnChange;

    private sealed record MyListingDto(string Id, string Title, decimal Price, string TimeUnit,
        string TimeUnitLabel, string City, string District, int Status, int ViewsCount, string? FirstImage);
}
