@page "/my-listings"
@using ACommerce.Client.Operations
@inject ApiReader Api
@inject NavigationManager Nav
@inject ClientOpEngine Engine
@inject L L

<PageTitle>@(L["my_listings.title"]) — @(L["app.name"])</PageTitle>

<div class="acs-page acs-my-listings">
    <AcSectionHeader Title="@(L["my_listings.title"])" ActionLabel="@(L["my_listings.add"])" OnAction="@GoCreate" />

    <div class="acs-filter-chips">
        <AcFilterChip Label="الكلّ"    Active="@(_filter == 0)" OnClick="@(() => SetFilter(0))" />
        <AcFilterChip Label="نشطة"     Active="@(_filter == 1)" OnClick="@(() => SetFilter(1))" />
        <AcFilterChip Label="موقوفة"   Active="@(_filter == 2)" OnClick="@(() => SetFilter(2))" />
    </div>

    @if (_loading) { <AcLoadingState /> }
    else
    {
        var list = _filter == 0 ? _items : _items.Where(l => l.Status == _filter).ToList();

        @if (list.Count == 0) { <AcEmptyState IconName="building" Message="لا توجد إعلانات" /> }
        else
        {
            <div class="acm-home-grid" style="margin-top:12px;">
                @foreach (var l in list)
                {
                    var lid    = l.Id;
                    var active = l.Status == 1;
                    <AcCard>
                        <ChildContent>
                            <div style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                                <strong>@l.Title</strong>
                                <AcBadge Variant="@(active ? "success" : "secondary")"
                                         Text="@(active ? L["my_listings.active"] : L["my_listings.paused"])" />
                            </div>
                            <small style="color:var(--ac-text-muted);">@l.City — @l.District</small>
                            <div style="margin-top:8px; display:flex; gap:12px; font-size:13px; color:var(--ac-text-muted);">
                                <span><AcIcon Name="eye" Size="14" /> @l.ViewsCount مشاهدة</span>
                            </div>
                            <div style="margin-top:8px; font-size:16px;">
                                <strong>@l.Price.ToString("N0") ر.ي</strong> / @l.TimeUnitLabel
                            </div>
                            <div style="display:flex; gap:8px; margin-top:12px; flex-wrap:wrap;">
                                <AcButton Variant="outline-primary" Text="عرض" OnClick="@(() => Open(lid))" />
                                <AcButton Variant="ghost" Text="@(active ? "إيقاف" : "نشر")" OnClick="@(() => Toggle(lid))" />
                            </div>
                        </ChildContent>
                    </AcCard>
                }
            </div>
        }
    }
</div>

@code {
    private List<MyListingDto> _items = new();
    private bool _loading = true;
    private int _filter = 0;

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (!first) return;
        var env  = await Api.GetAsync<List<MyListingDto>>("/my-listings");
        _items   = env.Data ?? new();
        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private void SetFilter(int s) { _filter = s; StateHasChanged(); }
    private void GoCreate() => Nav.NavigateTo("/create-listing");
    private void Open(string id) => Nav.NavigateTo($"/listings/{id}");

    private async Task Toggle(string id)
    {
        var env = await Engine.ExecuteAsync<ToggleData>(EjarOps.ToggleListing(id));
        if (env?.Data is null) return;
        var ix = _items.FindIndex(x => x.Id == id);
        if (ix >= 0) _items[ix] = _items[ix] with { Status = env.Data.Status };
        await InvokeAsync(StateHasChanged);
    }

    private sealed record ToggleData(string Id, int Status);
    private sealed record MyListingDto(string Id, string Title, decimal Price, string TimeUnit,
        string TimeUnitLabel, string City, string District, int Status, int ViewsCount, string? FirstImage);
}
