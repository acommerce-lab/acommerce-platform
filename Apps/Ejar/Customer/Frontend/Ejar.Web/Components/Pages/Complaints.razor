@page "/complaints"
@inject AppStore Store
@inject ApiReader Api
@inject NavigationManager Nav
@inject L L
@implements IDisposable

<PageTitle>@(L["complaint.title"]) — @(L["app.name"])</PageTitle>

<div class="ejar-page">
    <div style="padding:16px;border-bottom:1px solid var(--ac-border);display:flex;align-items:center;justify-content:space-between;">
        <h1 style="font-size:1rem;font-weight:700;margin:0;">@(L["complaint.title"])</h1>
        <button class="ac-btn ac-btn-sm ac-btn-primary" @onclick="@(() => _showNew = true)">+ @(L["complaint.new"])</button>
    </div>

    @if (!Store.Auth.IsAuthenticated)
    {
        <div class="ejar-empty mt-5">
            <button class="ac-btn ac-btn-primary" @onclick="@(() => Nav.NavigateTo("/login"))">@(L["auth.login.title"])</button>
        </div>
    }
    else
    {
        @if (_showNew)
        {
            <div class="ejar-content mt-3">
                <div class="mb-2">
                    <label class="ac-label">@(L["complaint.subject"])</label>
                    <input type="text" class="ac-input w-100" @bind="_subject" disabled="@_busy" />
                </div>
                <div class="mt-2">
                    <label style="font-size:0.85rem;font-weight:600;color:var(--ac-text-muted);">@(L["complaint.body"])</label>
                    <textarea class="ac-input w-100 mt-1" rows="4" @bind="_body" disabled="@_busy"></textarea>
                </div>
                @if (_error is not null) { <div class="ac-alert ac-alert-danger mt-2">@_error</div> }
                <div class="d-flex gap-2 mt-3">
                    <button class="ac-btn ac-btn-primary flex-grow-1" disabled="@_busy" @onclick="SubmitComplaint">@(L["complaint.send"])</button>
                    <button class="ac-btn ac-btn-outline-secondary" @onclick="@(() => _showNew = false)">@(L["common.cancel"])</button>
                </div>
            </div>
            <hr />
        }

        @if (_loading)
        {
            <div class="ejar-empty"><div class="acm-spinner"></div></div>
        }
        else if (_complaints.Count == 0)
        {
            <div class="ejar-empty">
                <div class="ejar-empty-icon">🚨</div>
                <div class="ejar-empty-text">لا توجد شكاوى</div>
            </div>
        }
        else
        {
            @foreach (var c in _complaints)
            {
                <div @onclick="@(() => Nav.NavigateTo($"/complaints/{c.Id}"))"
                     style="padding:14px 16px;border-bottom:1px solid var(--ac-border);cursor:pointer;">
                    <div class="d-flex align-items-center justify-content-between mb-1">
                        <span style="font-weight:600;font-size:0.93rem;">@c.Subject</span>
                        <span style="font-size:0.75rem;padding:2px 10px;border-radius:99px;background:var(--ac-primary-light);color:var(--ac-primary-dark);">@c.Status</span>
                    </div>
                    <p style="font-size:0.8rem;color:var(--ac-text-muted);margin:0;">@c.Body.Substring(0, Math.Min(80, c.Body.Length))…</p>
                </div>
            }
        }
    }
</div>

@code {
    private List<ComplaintDto> _complaints = new();
    private bool _loading = true;
    private bool _showNew;
    private bool _busy;
    private string _subject = "";
    private string _body = "";
    private string? _error;

    protected override void OnInitialized() => Store.OnChanged += OnChange;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !Store.Auth.IsAuthenticated) return;
        await Load();
    }

    private async Task Load()
    {
        _loading = true;
        var env = await Api.GetAsync<List<ComplaintDto>>("/complaints");
        _complaints = env.Data ?? new();
        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task SubmitComplaint()
    {
        _error = null; _busy = true;
        var env = await Api.PostAsync<ComplaintDto>("/complaints", new { subject = _subject, body = _body });
        _busy = false;
        if (env.Operation.Status == "Success" && env.Data is not null)
        {
            _complaints.Insert(0, env.Data);
            _showNew = false; _subject = ""; _body = "";
        }
        else { _error = env.Operation.ErrorMessage ?? "فشل الإرسال"; }
        await InvokeAsync(StateHasChanged);
    }

    private void OnChange() => InvokeAsync(StateHasChanged);
    public void Dispose() => Store.OnChanged -= OnChange;

    private sealed record ComplaintDto(string Id, string UserId, string Subject, string Body, string Status, DateTime CreatedAt, int RepliesCount);
}
