@page "/plans"
@inject ApiReader Api
@inject NavigationManager Nav
@inject L L

<PageTitle>@(L["plans.title"]) — @(L["app.name"])</PageTitle>

<div class="acs-page acs-plans-page">
    <h1 class="acm-wizard-title">@(L["plans.title"])</h1>
    <p style="color:var(--ac-text-muted);">اختر الخطّة المناسبة لنشاطك — يمكنك الترقية أو التخفيض في أيّ وقت.</p>

    @if (_loading) { <AcLoadingState /> }
    else
    {
        <div class="acm-home-grid acs-plans-grid">
            @foreach (var p in _plans)
            {
                var plan = p;
                <AcCard Hover="true">
                    <ChildContent>
                        <div style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                            <h3 style="margin:0;">@plan.Name</h3>
                            @if (plan.Popular) { <AcBadge Variant="secondary" Text="الأشهر" /> }
                        </div>
                        <p style="color:var(--ac-text-muted); font-size:13px;">@plan.Description</p>

                        <div style="font-size:24px; font-weight:700; margin:8px 0;">
                            @if (plan.Price == 0) { <span>مجّاني</span> }
                            else { <span>@plan.Price SAR</span><small style="font-size:13px; color:var(--ac-text-muted);"> / @plan.Unit</small> }
                        </div>

                        <ul style="list-style:none; padding:0; margin:8px 0 12px;">
                            @foreach (var f in plan.Features)
                            {
                                <li style="display:flex; gap:8px; padding:4px 0; align-items:center;">
                                    <AcIcon Name="check-circle" Size="14" />
                                    <span>@f</span>
                                </li>
                            }
                        </ul>

                        <AcButton Variant="@(plan.Popular ? "primary" : "outline-primary")"
                                  Class="ac-btn-block"
                                  Text="@(plan.Price == 0 ? "ابدأ مجّاناً" : "اشترك")"
                                  OnClick="@(() => Subscribe(plan))" />
                    </ChildContent>
                </AcCard>
            }
        </div>

        <h3 style="margin-top:16px;">مقارنة الخطط</h3>
        <AcCard>
            <ChildContent>
                <table class="acs-plans-compare">
                    <thead>
                        <tr>
                            <th>الميزة</th>
                            @foreach (var p in _plans) { <th>@p.Name</th> }
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>إعلانات فعّالة</td>
                            @foreach (var p in _plans) { <td>@(p.ListingQuota == 99 ? "∞" : p.ListingQuota.ToString())</td> }
                        </tr>
                        <tr>
                            <td>إعلانات مميّزة</td>
                            @foreach (var p in _plans) { <td>@p.FeaturedQuota</td> }
                        </tr>
                        <tr>
                            <td>صور لكلّ إعلان</td>
                            @foreach (var p in _plans) { <td>@p.ImagesPerListing</td> }
                        </tr>
                        <tr>
                            <td>الدعم</td>
                            @foreach (var p in _plans) { <td>@SupportLevel(p.Id)</td> }
                        </tr>
                    </tbody>
                </table>
            </ChildContent>
        </AcCard>
    }
</div>

@code {
    private List<PlanDto> _plans = new();
    private bool _loading = true;

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (!first) return;
        var env = await Api.GetAsync<List<PlanDto>>("/plans");
        _plans = env.Data ?? new();
        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private void Subscribe(PlanDto p) => Nav.NavigateTo($"/subscribe?type=plan&id={p.Id}&amount={p.Price}");

    private static string SupportLevel(string id) => id switch
    {
        "plan-basic"   => "بريد",
        "plan-pro"     => "أولويّة",
        "plan-premium" => "مدير حساب",
        _              => "—"
    };

    private sealed record PlanDto(string Id, string Name, string Description,
        decimal Price, string Unit, int ListingQuota, int FeaturedQuota,
        int ImagesPerListing, bool Popular, List<string> Features);
}
