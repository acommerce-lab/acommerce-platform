@page "/favorites"
@inject AppStore Store
@inject AppStateApplier Applier
@inject ApiReader Api
@inject NavigationManager Nav
@inject L L
@implements IDisposable

<PageTitle>@(L["nav.favorites"]) — @(L["app.name"])</PageTitle>

<div class="acs-page">
    <h1 class="acm-wizard-title">@(L["nav.favorites"])</h1>
    @if (_loading) { <AcLoadingState /> }
    else if (_listings.Count == 0) { <AcEmptyState IconName="heart" Message="لا توجد مفضلة بعد" /> }
    else
    {
        <div class="acm-home-grid">
            @foreach (var l in _listings)
            {
                var lid = l.Id;
                <AcSpaceCard Title="@l.Title"
                             ImageUrl="@l.FirstImage"
                             Location="@($"{l.District} — {l.City}")"
                             PriceLabel="@($"{l.Price:0} SAR / {l.TimeUnitLabel}")"
                             IsFavorite="true"
                             OnOpen="@(() => Nav.NavigateTo($"/listings/{lid}"))"
                             OnToggleFavorite="@(async on => { await Applier.ApplyLocalAsync(EjarOps.ToggleFavorite(lid)); _listings.RemoveAll(x => x.Id == lid); await InvokeAsync(StateHasChanged); })" />
            }
        </div>
    }
</div>

@code {
    private List<FavDto> _listings = new();
    private bool _loading = true;

    protected override void OnInitialized() => Store.OnChanged += OnChange;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!Store.Auth.IsAuthenticated) { _loading = false; await InvokeAsync(StateHasChanged); return; }
        var env = await Api.GetAsync<List<FavDto>>("/favorites");
        _listings = env.Data ?? new();
        foreach (var l in _listings) Store.FavoriteListingIds.Add(l.Id);
        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private void OnChange() => InvokeAsync(StateHasChanged);
    public void Dispose() => Store.OnChanged -= OnChange;

    private sealed record FavDto(string Id, string Title, decimal Price, string TimeUnit, string TimeUnitLabel,
        string City, string District, bool IsVerified, string? FirstImage);
}
