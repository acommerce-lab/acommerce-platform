@page "/complaints/{Id}"
@using ACommerce.Client.Operations
@inject ApiReader Api
@inject ClientOpEngine Engine
@inject NavigationManager Nav

<PageTitle>تفاصيل الشكوى — إيجار</PageTitle>

<div class="acs-page acs-complaint-thread">
    @if (_loading) { <AcLoadingState /> }
    else if (_c is null) { <AcEmptyState IconName="alert-circle" Message="الشكوى غير موجودة" /> }
    else
    {
        <h1 class="acm-wizard-title">@_c.Subject</h1>
        <AcCard>
            <ChildContent>
                <div class="acm-checkout-line">
                    <span>الحالة:</span>
                    <AcBadge Variant="@StatusVariant(_c.Status)" Text="@StatusLabel(_c.Status)" />
                </div>
                <div class="acm-checkout-line">
                    <span>أُنشئت:</span>
                    <strong>@_c.CreatedAt.ToString("yyyy-MM-dd HH:mm")</strong>
                </div>
            </ChildContent>
        </AcCard>

        <h3 style="margin-top:16px;">المحادثة</h3>
        <div class="acs-chat-messages">
            @foreach (var r in _c.Replies)
            {
                var isMine = r.SenderId != "support";
                <div class="acs-bubble @(isMine ? "acs-bubble-mine" : "acs-bubble-other acs-bubble-staff")">
                    @if (!isMine)
                    {
                        <small style="display:block; font-weight:700; color:var(--ac-primary);">
                            <AcIcon Name="shield" Size="14" /> @r.SenderName
                        </small>
                    }
                    <div>@r.Message</div>
                    <small style="display:block; opacity:.6;">@r.SentAt.ToString("yyyy-MM-dd HH:mm")</small>
                </div>
            }
        </div>

        @if (_c.Status != "closed")
        {
            <div style="display:flex; gap:8px; margin-top:12px;">
                <AcInput Value="@_draft" ValueChanged="@(v => _draft = v ?? string.Empty)"
                         Placeholder="اكتب ردّك…" />
                <AcButton Variant="primary" Text="إرسال" OnClick="@Send"
                          Disabled="@(string.IsNullOrWhiteSpace(_draft) || _sending)" />
            </div>
        }
        else
        {
            <AcAlert Variant="secondary" Text="الشكوى مغلقة — لا يمكن إضافة ردود." />
        }

        <div style="margin-top:12px;">
            <AcButton Variant="ghost" Text="رجوع" OnClick="@GoBack" />
        </div>
    }
</div>

@code {
    [Parameter] public string Id { get; set; } = "";

    private ComplaintDetailDto? _c;
    private bool _loading = true;
    private string _draft = "";
    private bool _sending;

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (!first) return;
        await Reload();
    }

    private async Task Reload()
    {
        var env = await Api.GetAsync<ComplaintDetailDto>($"/complaints/{Id}");
        _c = env.Data;
        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(_draft) || _c is null) return;
        _sending = true;
        try
        {
            var env = await Engine.ExecuteAsync<object>(
                EjarOps.ReplyComplaint(Id, _draft),
                payload: new { Message = _draft });
            if (env?.Operation.Status == "Success")
            {
                _draft = "";
                await Reload();
            }
        }
        finally { _sending = false; }
    }

    private void GoBack() => Nav.NavigateTo("/complaints");

    private static string StatusLabel(string s) => s switch
    {
        "open" => "مفتوحة", "in_progress" => "قيد المعالجة",
        "resolved" => "محلولة", "closed" => "مغلقة",
        _ => s
    };

    private static string StatusVariant(string s) => s switch
    {
        "open" => "warning", "in_progress" => "secondary",
        "resolved" => "success", "closed" => "secondary",
        _ => "secondary"
    };

    private sealed record ReplyDto(string Id, string ComplaintId, string SenderId, string SenderName, string Message, DateTime SentAt);
    private sealed record ComplaintDetailDto(string Id, string Subject, string Body, string Status,
        DateTime CreatedAt, List<ReplyDto> Replies);
}
