@page "/complaints/{Id}"
@inject ApiReader Api
@inject NavigationManager Nav
@using ACommerce.Client.Operations
@using Ejar.Web.Operations
@inject ClientOpEngine Engine
@inject L L

<PageTitle>تفاصيل الشكوى — @(L["app.name"])</PageTitle>

<div class="acs-page acs-complaint-thread">
    @if (_loading) { <AcLoadingState /> }
    else if (_c is null) { <AcEmptyState IconName="alert-circle" Message="الشكوى غير موجودة" /> }
    else
    {
        <h1 class="acm-wizard-title">@_c.Subject</h1>
        <AcCard>
            <ChildContent>
                <div class="acm-checkout-line"><span>الحالة:</span><AcBadge Variant="@StatusVariant(_c.Status)" Text="@StatusLabel(_c.Status)" /></div>
                <div class="acm-checkout-line"><span>الأولويّة:</span><strong>@_c.Priority</strong></div>
                @if (!string.IsNullOrEmpty(_c.RelatedEntity))
                {
                    <div class="acm-checkout-line"><span>مرتبطة بـ:</span><strong>@_c.RelatedEntity</strong></div>
                }
                <div class="acm-checkout-line"><span>أُنشئت:</span><strong>@_c.CreatedAt.ToString("yyyy-MM-dd HH:mm")</strong></div>
            </ChildContent>
        </AcCard>

        <h3 style="margin-top:16px;">المحادثة</h3>
        <div class="acs-chat-messages">
            @foreach (var r in _c.Replies)
            {
                var isStaff = r.From == "staff";
                <div class="acs-bubble @(isStaff ? "acs-bubble-other acs-bubble-staff" : "acs-bubble-mine")">
                    @if (isStaff)
                    {
                        <small style="display:block; font-weight:700; color:var(--ac-primary);">
                            <AcIcon Name="shield" Size="14" /> موظّف دعم
                        </small>
                    }
                    <div>@r.Message</div>
                    <small style="display:block; opacity:.6;">@r.CreatedAt.ToString("yyyy-MM-dd HH:mm")</small>
                </div>
            }
        </div>

        @if (_c.Status is "open" or "in_progress")
        {
            <div style="display:flex; gap:8px; margin-top:12px;">
                <AcInput Value="@_draft" ValueChanged="@(v => _draft = v ?? string.Empty)" Placeholder="اكتب ردّك…" />
                <AcButton Variant="primary" Text="إرسال" OnClick="@Send"
                          Disabled="@(string.IsNullOrWhiteSpace(_draft) || _sending)" />
            </div>
        }
        else
        {
            <AcAlert Variant="secondary" Text="الشكوى مغلقة — لا يمكن إضافة ردود." />
        }

        <div style="margin-top:12px;">
            <AcButton Variant="ghost" Text="رجوع" OnClick="@GoBack" />
        </div>
    }
</div>

@code {
    [Parameter] public string Id { get; set; } = "";

    private ComplaintDto? _c;
    private bool _loading = true;
    private string _draft = "";
    private bool _sending;

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (!first) return;
        await Reload();
    }

    private async Task Reload()
    {
        var env = await Api.GetAsync<ComplaintDto>($"/complaints/{Id}");
        _c = env.Data;
        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(_draft) || _c is null) return;
        _sending = true;
        try
        {
            var env = await Engine.ExecuteAsync<object>(
                EjarOps.ReplyComplaint(Id, _draft),
                payload: new { Message = _draft });
            if (env?.Operation.Status == "Success")
            {
                _draft = "";
                await Reload();
            }
        }
        finally { _sending = false; }
    }

    private void GoBack() => Nav.NavigateTo("/complaints");

    private static string StatusLabel(string s) => s switch
    {
        "open" => "مفتوحة", "in_progress" => "قيد المعالجة",
        "resolved" => "محلولة", "closed" => "مغلقة",
        _ => s
    };

    private static string StatusVariant(string s) => s switch
    {
        "open" => "warning", "in_progress" => "secondary",
        "resolved" => "success", "closed" => "secondary",
        _ => "secondary"
    };

    private sealed record ReplyDto(string Id, string From, string Message, DateTime CreatedAt);
    private sealed record ComplaintDto(string Id, string Subject, string Body, DateTime CreatedAt,
        string Status, string Priority, string? RelatedEntity, List<ReplyDto> Replies);
}
