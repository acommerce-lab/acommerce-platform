@page "/listings/{Id}"
@using ACommerce.Client.Operations
@using Ejar.Web.Operations
@inject AppStore Store
@inject AppStateApplier Applier
@inject ApiReader Api
@inject NavigationManager Nav
@inject ClientOpEngine Engine
@inject L L
@implements IDisposable

<PageTitle>@(_listing?.Title ?? L["app.name"])</PageTitle>

<div class="acs-page acs-space-details">
    @if (_loading) { <AcLoadingState /> }
    else if (_listing is null) { <AcEmptyState IconName="info" Message="الإعلان غير موجود" /> }
    else
    {
        <div class="acs-gallery-wrap">
            @if (_listing.Images is not null && _listing.Images.Count > 0)
            {
                <AcGallery Images="@(_listing.Images.ToList())" />
            }
            else
            {
                <div class="acs-gallery-ph"><AcIcon Name="image" Size="48" /></div>
            }
            <button type="button" class="acs-fav-btn @(_isFav ? "active" : "")" @onclick="ToggleFavorite">
                <AcIcon Name="heart" Filled="@_isFav" Size="20" />
            </button>
        </div>

        <h1 class="acm-wizard-title">@_listing.Title</h1>
        <div style="display:flex; flex-wrap:wrap; gap:8px; align-items:center; margin-bottom:8px;">
            @if (!string.IsNullOrEmpty(_listing.District))
            {
                <span><AcIcon Name="map-pin" Size="14" /> @_listing.District — @_listing.City</span>
            }
            @if (_listing.BedroomCount > 0)
            {
                <span><AcIcon Name="home" Size="14" /> @_listing.BedroomCount @(L["listing.bedrooms"])</span>
            }
            @if (_listing.IsVerified)
            {
                <AcBadge Variant="success" Text="@(L["listing.verified"])" />
            }
        </div>

        <div class="acm-checkout-line">
            <strong style="font-size:20px;">@_listing.Price.ToString("N0") SAR</strong>
            <span>/ @_listing.TimeUnitLabel</span>
        </div>

        @if (!string.IsNullOrEmpty(_listing.Description))
        {
            <AcCard>
                <ChildContent>
                    <h3 style="margin-top:0;">@(L["listing.description"])</h3>
                    <p>@_listing.Description</p>
                </ChildContent>
            </AcCard>
        }

        @if (_listing.Amenities is not null && _listing.Amenities.Count > 0)
        {
            <AcCard>
                <ChildContent>
                    <h3 style="margin-top:0;">@(L["listing.amenities"])</h3>
                    <div class="acs-amenity-chips">
                        @foreach (var a in _listing.Amenities)
                        {
                            <span class="acs-amenity-chip"><AcIcon Name="check" Size="14" /> @a.Label</span>
                        }
                    </div>
                </ChildContent>
            </AcCard>
        }

        <AcCard>
            <ChildContent>
                <h3 style="margin-top:0;">الموقع</h3>
                <AcMapSim Pins="@MapPins" />
            </ChildContent>
        </AcCard>

        @if (_listing.Owner is not null && !IsMine)
        {
            <AcCard>
                <ChildContent>
                    <h3 style="margin-top:0;">المؤجّر</h3>
                    <div class="acm-details-owner">
                        <span class="acm-details-owner-avatar"><AcIcon Name="user" Size="20" /></span>
                        <div class="acm-details-owner-info">
                            <strong>@_listing.Owner.Name</strong>
                            @if (!string.IsNullOrEmpty(_listing.Owner.MemberSince))
                            {
                                <span>عضو منذ @_listing.Owner.MemberSince</span>
                            }
                        </div>
                        @if (Store.Auth.IsAuthenticated)
                        {
                            <AcButton Variant="outline-primary" Text="مراسلة"
                                      OnClick="@StartChat" Disabled="@_startingChat" />
                        }
                    </div>
                </ChildContent>
            </AcCard>
        }

        <AcStickyActionBar>
            <AcButton Variant="ghost" Text="رجوع" OnClick="@GoBack" />
            @if (IsMine)
            {
                <AcButton Variant="outline-primary" Class="ac-btn-block" Text="تعديل الإعلان"
                          OnClick="@EditListing" />
            }
            else if (Store.Auth.IsAuthenticated)
            {
                <AcButton Variant="primary" Class="ac-btn-block" Text="@(L["listing.contact"])"
                          OnClick="@StartChat" Disabled="@_startingChat" />
            }
            else
            {
                <AcButton Variant="primary" Class="ac-btn-block" Text="سجّل دخولك للتواصل"
                          OnClick="@(() => Nav.NavigateTo("/login"))" />
            }
        </AcStickyActionBar>
    }
</div>

@code {
    [Parameter] public string Id { get; set; } = "";

    private ListingDetailDto? _listing;
    private bool _loading = true;
    private bool _startingChat;
    private bool _isFav => _listing is not null && Store.FavoriteListingIds.Contains(_listing.Id);
    private bool IsMine => _listing is not null && Store.Auth.IsAuthenticated
                           && _listing.OwnerId == Store.Auth.UserId?.ToString();

    private void EditListing() => Nav.NavigateTo($"/create-listing?edit={_listing?.Id}");

    private IReadOnlyList<AcMapSim.MapPin> MapPins =>
        _listing is null ? Array.Empty<AcMapSim.MapPin>()
                         : new[] { new AcMapSim.MapPin("loc", _listing.Title, _listing.Lat, _listing.Lng) };

    protected override void OnInitialized() => Store.OnChanged += OnChange;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var env  = await Api.GetAsync<ListingDetailDto>($"/listings/{Id}");
        _listing = env.Data;
        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ToggleFavorite()
    {
        if (_listing is null) return;
        if (!Store.Auth.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
        await Applier.ApplyLocalAsync(EjarOps.ToggleFavorite(_listing.Id));
    }

    private async Task StartChat()
    {
        if (_listing is null) return;
        _startingChat = true;
        try
        {
            var text = $"مرحباً، أنا مهتمّ بـ \"{_listing.Title}\".";
            var env = await Engine.ExecuteAsync<StartChatData>(
                EjarOps.StartConversation(_listing.Id, text),
                payload: new { ListingId = _listing.Id, Text = text });
            if (env?.Data is not null) Nav.NavigateTo($"/chat/{env.Data.Id}");
            else                       Nav.NavigateTo("/chats");
        }
        finally { _startingChat = false; }
    }

    private void GoBack() => Nav.NavigateTo("/search");

    private void OnChange() => InvokeAsync(StateHasChanged);
    public void Dispose() => Store.OnChanged -= OnChange;

    private sealed record AmenityDto(string Key, string Label);
    private sealed record OwnerDto(string Name, string? MemberSince);
    private sealed record ListingDetailDto(
        string Id, string Title, string Description, decimal Price,
        string TimeUnit, string TimeUnitLabel, string PropertyType, string PropertyTypeLabel,
        string City, string District, double Lat, double Lng,
        List<AmenityDto> Amenities, string OwnerId, OwnerDto? Owner,
        int BedroomCount, int BathroomCount,
        double AreaSqm, bool IsVerified, int ViewsCount, int Status, bool IsFavorite,
        List<string>? Images);
    private sealed record StartChatData(string Id, bool Created);
}
