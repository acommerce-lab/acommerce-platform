@page "/chat/{Id}"
@using ACommerce.Client.Operations
@inject AppStore Store
@inject ApiReader Api
@inject ClientOpEngine Engine
@inject NavigationManager Nav
@inject L L

<PageTitle>@(L["chat.title"]) — @(L["app.name"])</PageTitle>

<div class="acs-page acs-chat-page">
    @if (_conv is null) { <AcLoadingState /> }
    else
    {
        <div style="display:flex; justify-content:space-between; align-items:center;">
            <div>
                <h1 class="acm-wizard-title" style="margin-bottom:4px;">@_conv.OtherUserName</h1>
                <small style="color:var(--ac-text-muted);">@_conv.ListingTitle</small>
            </div>
            <AcButton Variant="ghost" Text="رجوع" OnClick="@GoBack" />
        </div>

        <div class="acs-chat-messages">
            @foreach (var m in _conv.Messages)
            {
                var mine = m.SenderId == Store.Auth.UserId?.ToString();
                <div class="acs-bubble @(mine ? "acs-bubble-mine" : "acs-bubble-other")">
                    <div>@m.Text</div>
                    <small style="display:block; opacity:.6;">@m.SentAt.ToString("HH:mm")</small>
                </div>
            }
        </div>

        <div class="acs-chat-composer">
            <AcInput Value="@_draft" ValueChanged="@(v => _draft = v ?? string.Empty)"
                     Placeholder="@(L["chat.new_message"])" />
            <AcButton Variant="primary" Text="@(L["chat.send"])" OnClick="@Send"
                      Disabled="@(_sending || string.IsNullOrWhiteSpace(_draft))" />
        </div>
    }
</div>

@code {
    [Parameter] public string Id { get; set; } = "";

    private ConvDetailDto? _conv;
    private string _draft = "";
    private bool _sending;

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (!first) return;
        await Reload();
    }

    private async Task Reload()
    {
        var env  = await Api.GetAsync<ConvDetailDto>($"/conversations/{Id}");
        _conv    = env.Data;
        await InvokeAsync(StateHasChanged);
    }

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(_draft) || _conv is null) return;
        _sending = true;
        try
        {
            var env = await Engine.ExecuteAsync<object>(
                EjarOps.SendMessage(Id, _draft),
                payload: new { Text = _draft });
            if (env?.Operation.Status == "Success")
            {
                _draft = "";
                await Reload();
            }
        }
        finally { _sending = false; await InvokeAsync(StateHasChanged); }
    }

    private void GoBack() => Nav.NavigateTo("/chats");

    private sealed record ConvDetailDto(string Id, string ListingId, string ListingTitle,
        string OtherUserId, string OtherUserName, List<MsgDto> Messages);
    private sealed record MsgDto(string Id, string ConversationId, string SenderId, string SenderName,
        string Text, DateTime SentAt);
}
