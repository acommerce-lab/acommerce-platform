@page "/chats/{Id}"
@inject AppStore Store
@inject ApiReader Api
@inject NavigationManager Nav
@inject L L
@implements IDisposable

<PageTitle>@(L["chat.title"]) — @(L["app.name"])</PageTitle>

<div style="display:flex;flex-direction:column;height:100dvh;max-height:100dvh;">
    @* Header *@
    <div style="padding:12px 16px;border-bottom:1px solid var(--ac-border);background:var(--ac-surface);display:flex;align-items:center;gap:10px;flex-shrink:0;">
        <button class="ac-btn ac-btn-xs ac-btn-outline-secondary" @onclick="@(() => Nav.NavigateTo("/chats"))">→</button>
        <div>
            <div style="font-weight:600;font-size:0.93rem;">@(_conv?.ListingTitle ?? "محادثة")</div>
            <div style="font-size:0.78rem;color:var(--ac-text-muted);">@(_conv?.OtherUserName)</div>
        </div>
    </div>

    @* Messages *@
    <div style="flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:10px;">
        @foreach (var m in _messages)
        {
            var isMine = m.SenderId == Store.Auth.UserId?.ToString();
            <div style="display:flex;justify-content:@(isMine ? "flex-start" : "flex-end");">
                <div style="max-width:72%;padding:10px 14px;border-radius:@(isMine ? "4px 16px 16px 16px" : "16px 4px 16px 16px");
                             background:@(isMine ? "var(--ac-primary-light)" : "var(--ac-primary)");
                             color:@(isMine ? "var(--ac-text)" : "#fff");
                             font-size:0.9rem;line-height:1.5;">
                    @m.Text
                </div>
            </div>
        }
    </div>

    @* Input *@
    <div style="padding:10px 12px;border-top:1px solid var(--ac-border);background:var(--ac-surface);display:flex;gap:8px;flex-shrink:0;">
        <input type="text" class="ac-input" placeholder="@(L["chat.new_message"])"
               @bind="_draft" @bind:event="oninput" @onkeyup="OnKey"
               style="flex:1;" />
        <button class="ac-btn ac-btn-primary" disabled="@(string.IsNullOrWhiteSpace(_draft) || _busy)" @onclick="Send">
            @(L["chat.send"])
        </button>
    </div>
</div>

@code {
    [Parameter] public string Id { get; set; } = "";

    private ConvDto? _conv;
    private List<MsgDto> _messages = new();
    private string _draft = "";
    private bool _busy;

    protected override void OnInitialized() => Store.OnChanged += OnChange;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var env = await Api.GetAsync<ConvDetailDto>($"/conversations/{Id}");
        if (env.Data is not null)
        {
            _conv = new ConvDto(env.Data.Id, env.Data.ListingId, env.Data.ListingTitle,
                env.Data.OtherUserId, env.Data.OtherUserName, null, 0);
            _messages = env.Data.Messages;
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task Send()
    {
        var text = _draft.Trim();
        if (string.IsNullOrEmpty(text)) return;
        _busy = true; _draft = "";
        var env = await Api.PostAsync<MsgDto>($"/conversations/{Id}/messages", new { text });
        _busy = false;
        if (env.Data is not null) _messages.Add(env.Data);
        await InvokeAsync(StateHasChanged);
    }

    private void OnKey(KeyboardEventArgs e) { if (e.Key == "Enter") _ = Send(); }

    private void OnChange() => InvokeAsync(StateHasChanged);
    public void Dispose() => Store.OnChanged -= OnChange;

    private sealed record ConvDto(string Id, string ListingId, string ListingTitle, string OtherUserId, string OtherUserName, string? LastMessage, int UnreadCount);
    private sealed record ConvDetailDto(string Id, string ListingId, string ListingTitle, string OtherUserId, string OtherUserName, List<MsgDto> Messages);
    private sealed record MsgDto(string Id, string ConversationId, string SenderId, string SenderName, string Text, DateTime SentAt);
}
