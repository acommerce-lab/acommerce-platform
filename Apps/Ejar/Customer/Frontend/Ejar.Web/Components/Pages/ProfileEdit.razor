@page "/me/edit"
@inject AppStore Store
@inject ApiReader Api
@inject NavigationManager Nav
@inject L L
@implements IDisposable

<PageTitle>@(L["profile.edit"]) — @(L["app.name"])</PageTitle>

<div class="ejar-page">
    @if (!Store.Auth.IsAuthenticated)
    {
        Nav.NavigateTo("/login");
        return;
    }

    <div class="ejar-content mt-3">
        <h1 style="font-size:1.1rem;font-weight:700;margin-bottom:20px;">@(L["profile.edit"])</h1>

        @if (_loading) { <div class="ejar-empty"><div class="acm-spinner"></div></div> }
        else
        {
            <div class="mb-3">
                <label class="ac-label">@(L["profile.name"])</label>
                <input type="text" class="ac-input w-100" @bind="_fullName" disabled="@_busy" />
            </div>
            <div class="mb-3">
                <label class="ac-label">@(L["profile.email"])</label>
                <input type="email" class="ac-input w-100" @bind="_email" disabled="@_busy" />
            </div>
            <div class="mb-3">
                <label class="ac-label">@(L["profile.phone"])</label>
                <input type="tel" class="ac-input w-100" @bind="_phone" disabled="true" />
            </div>
            <div class="mb-3">
                <label class="ac-label">@(L["profile.city"])</label>
                <input type="text" class="ac-input w-100" @bind="_city" disabled="@_busy" />
            </div>

            @if (_error is not null)   { <div class="ac-alert ac-alert-danger mt-2">@_error</div>   }
            @if (_success is not null) { <div class="ac-alert ac-alert-success mt-2">@_success</div> }

            <button class="ac-btn ac-btn-primary w-100 mt-4" disabled="@_busy" @onclick="Save">
                @if (_busy) { <span class="acm-spinner-sm"></span> }
                @(L["profile.save"])
            </button>
        }
    </div>
</div>

@code {
    private string _fullName = "";
    private string _email = "";
    private string _phone = "";
    private string _city = "";
    private bool _loading = true;
    private bool _busy;
    private string? _error;
    private string? _success;

    protected override void OnInitialized() => Store.OnChanged += OnChange;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var env = await Api.GetAsync<ProfileDto>("/me/profile");
        if (env.Data is not null)
        {
            _fullName = env.Data.FullName;
            _email    = env.Data.Email ?? "";
            _phone    = env.Data.Phone;
            _city     = env.Data.City ?? "";
        }
        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task Save()
    {
        _error = null; _success = null; _busy = true;
        await InvokeAsync(StateHasChanged);
        var env = await Api.PutAsync<object>("/me/profile",
            new { fullName = _fullName, email = _email, phone = _phone, city = _city });
        _busy = false;
        if (env.Operation.Status == "Success") { _success = "تمّ حفظ التغييرات"; Store.Auth.FullName = _fullName; }
        else { _error = env.Operation.ErrorMessage ?? "فشل الحفظ"; }
        await InvokeAsync(StateHasChanged);
    }

    private void OnChange() => InvokeAsync(StateHasChanged);
    public void Dispose() => Store.OnChanged -= OnChange;

    private sealed record ProfileDto(string UserId, string FullName, string Phone, string? Email, string? City, bool IsVerified,
        int ActiveListingsCount, int TotalViews, int UnreadNotifications);
}
