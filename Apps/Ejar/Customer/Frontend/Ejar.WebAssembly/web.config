<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS web.config مخصّص لـ Blazor WASM المنشور على runasp.net وأمثاله.
  ينسخه target في csproj فوق الذي يولّده SDK ليُضيف:
    - .webmanifest MIME (السبب الفعليّ لرفض Chrome تثبيت PWA — كان 404)
    - .br + .gz MIME (للأصول المضغوطة مسبقاً من Blazor publish)
    - .svg MIME (للأيقونة المتجهة في manifest)
-->
<configuration>
  <system.webServer>
    <staticContent>
      <remove fileExtension=".blat" />
      <remove fileExtension=".dat" />
      <remove fileExtension=".dll" />
      <remove fileExtension=".webcil" />
      <remove fileExtension=".json" />
      <remove fileExtension=".wasm" />
      <remove fileExtension=".woff" />
      <remove fileExtension=".woff2" />
      <remove fileExtension=".webmanifest" />
      <remove fileExtension=".br" />
      <remove fileExtension=".gz" />
      <remove fileExtension=".svg" />
      <remove fileExtension=".pdb" />
      <mimeMap fileExtension=".blat"        mimeType="application/octet-stream" />
      <mimeMap fileExtension=".dll"         mimeType="application/octet-stream" />
      <mimeMap fileExtension=".webcil"      mimeType="application/octet-stream" />
      <mimeMap fileExtension=".dat"         mimeType="application/octet-stream" />
      <mimeMap fileExtension=".json"        mimeType="application/json" />
      <mimeMap fileExtension=".wasm"        mimeType="application/wasm" />
      <mimeMap fileExtension=".woff"        mimeType="application/font-woff" />
      <mimeMap fileExtension=".woff2"       mimeType="application/font-woff" />
      <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
      <mimeMap fileExtension=".br"          mimeType="application/octet-stream" />
      <mimeMap fileExtension=".gz"          mimeType="application/octet-stream" />
      <mimeMap fileExtension=".svg"         mimeType="image/svg+xml" />
      <mimeMap fileExtension=".pdb"         mimeType="application/octet-stream" />
    </staticContent>
    <httpCompression>
      <dynamicTypes>
        <add mimeType="application/octet-stream" enabled="true" />
        <add mimeType="application/wasm" enabled="true" />
        <add mimeType="application/manifest+json" enabled="true" />
      </dynamicTypes>
    </httpCompression>
    <rewrite>
      <rules>
        <!-- runasp/IIS pattern: المحتوى الفعليّ تحت wwwroot/. أعِد توجيه
             كل طلب لذلك المسار، باستثناء الذي يطابق ملفاً موجوداً مباشرة. -->
        <rule name="Serve subdir">
          <match url=".*" />
          <action type="Rewrite" url="wwwroot\{R:0}" />
        </rule>
        <!-- SPA fallback: مسارات Blazor router (/login، /explore، /listings/X)
             ليست ملفات فعلية → خدِم index.html ليتولّى Blazor الموجه. -->
        <rule name="SPA fallback routing" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="wwwroot\" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>

  <!--
    لا تخزّن ملفّات الـ shell التي تتغيّر مع كلّ نشر في HTTP cache.
    أهمّها service-worker.js — لو خُزِّن في cache المتصفّح يبقى المستخدم
    على إصدار قديم حتى انتهاء صلاحيّته (٢٤ ساعة افتراضياً في Chrome).
    إضافة Cache-Control: no-cache تجبر المتصفّح على re-validate كلّ مرّة،
    فيكتشف بايتات الـ SW الجديدة فوراً ويُطلِق دورة install→activate.
  -->
  <location path="service-worker.js">
    <system.webServer>
      <httpProtocol>
        <customHeaders>
          <add name="Cache-Control" value="no-cache, no-store, must-revalidate" />
          <add name="Pragma" value="no-cache" />
          <add name="Expires" value="0" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>

  <location path="service-worker.published.js">
    <system.webServer>
      <httpProtocol>
        <customHeaders>
          <add name="Cache-Control" value="no-cache, no-store, must-revalidate" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>

  <location path="service-worker-assets.js">
    <system.webServer>
      <httpProtocol>
        <customHeaders>
          <add name="Cache-Control" value="no-cache, no-store, must-revalidate" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>

  <location path="index.html">
    <system.webServer>
      <httpProtocol>
        <customHeaders>
          <add name="Cache-Control" value="no-cache, no-store, must-revalidate" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>

  <location path="appsettings.json">
    <system.webServer>
      <httpProtocol>
        <customHeaders>
          <add name="Cache-Control" value="no-cache, no-store, must-revalidate" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>

  <location path="manifest.webmanifest">
    <system.webServer>
      <httpProtocol>
        <customHeaders>
          <add name="Cache-Control" value="no-cache, no-store, must-revalidate" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>
</configuration>
