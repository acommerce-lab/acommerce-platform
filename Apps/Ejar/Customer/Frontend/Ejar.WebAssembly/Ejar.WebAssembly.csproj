<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Ejar.WebAssembly</RootNamespace>
    <AssemblyName>Ejar.WebAssembly</AssemblyName>
    <ServiceWorkerAssetsManifest>service-worker-assets.js</ServiceWorkerAssetsManifest>
    <Description>
      تطبيق إيجار للعميل (Customer) كنسخة Blazor WebAssembly — تطبيق ويب
      تقدّمي (PWA) قابل للتثبيت على الموبايل والديسكتوب. كل الـ UI من
      Ejar.Customer.UI؛ هذا المشروع يضع فقط نقطة الإقلاع (Program.cs)،
      index.html، manifest.json، service worker.
    </Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Shared\Ejar.Customer.UI\Ejar.Customer.UI.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.0" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="10.0.0" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <ServiceWorker Include="wwwroot\service-worker.js" PublishedContent="wwwroot\service-worker.published.js" />
  </ItemGroup>
</Project>
