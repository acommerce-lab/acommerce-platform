@*
    App.razor — root SSR component، LOCAL في Ejar.Web.V2 (وليس في
    المكتبة المُشتَرَكة). الـ Razor SDK يَحتاج رؤية Razor components
    داخل host project لِيُسَجِّل _framework/blazor.web.js في الـ static
    asset manifest. لو App.razor كان في مكتبة فقط، الـ manifest يَفتقد
    الـ framework JS endpoint ⇒ 404.

    Routes.razor يَبقى في المكتبة المُشتَرَكة (يُستورد عبر @using).
*@
@using Ejar.Customer.UI.V2.Components

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>إيجار</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" />
    @* favicon فارِغ — يَكتُم طَلَب /favicon.ico التِلقائيّ مِن المُتَصَفِّح
       حَتّى لا يَظهَر 404 في الـ console. التَّطبيق يَستَطيع وَضع
       favicon.ico حَقيقيّ في wwwroot وحينَها يَفوز عَلى هذا. *@
    <link rel="icon" href="data:," />
    <link rel="stylesheet" href="_content/ACommerce.Widgets/widgets.css" />
    <link rel="stylesheet" href="_content/ACommerce.Templates.OAM/oam-fingerprint.css" />
    <link rel="stylesheet" href="_content/ACommerce.Templates.Customer.Ledger/template.css" />
    @* templates-shared.css + templates-marketplace.css كانَتا مِن قَوالِب V1
       (Templates.Shared / Templates.Marketplace) لا يَستَهلِكها V2 — أُزيلَتا
       بَعد ٤٠٤ في الـ console، الـ assemblies غَير مَرجوعَة فَلا
       _content/... لَهما. *@
    <!-- branding.css آخر CSS يُحمَّل ⇒ override كَلاسات Customer.Ledger
         (LedgerClasses.*) بألوان إيجار. هذا هو نُقطة التَّخصيص الوَحيدة
         التي يَحتاجها التَّطبيق لِتَلوين القالَب. -->
    <link rel="stylesheet" href="branding.css" />
    <HeadOutlet />
</head>
<body>
    <Routes @rendermode="InteractiveServer" />
    <script src="_framework/blazor.web.js"></script>
</body>
</html>
