<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!-- Linux dev: نضمن Android فقط (الـ workload الوحيد المتاح هنا).
         macOS dev يضيف net10.0-ios + net10.0-maccatalyst؛
         Windows dev يضيف net10.0-windows10.0.19041.0. -->
    <TargetFrameworks>net10.0-android</TargetFrameworks>
    <TargetFrameworks Condition="$([MSBuild]::IsOSPlatform('windows'))">$(TargetFrameworks);net10.0-windows10.0.19041.0</TargetFrameworks>
    <TargetFrameworks Condition="$([MSBuild]::IsOSPlatform('osx'))">$(TargetFrameworks);net10.0-ios;net10.0-maccatalyst</TargetFrameworks>

    <!-- صريح: تطبيق MAUI = executable (ليس مكتبة). إستيراد StaticWebAssets
         SDK يمكن أن يطفئ هذا ضمنياً، فنُجبره هنا. -->
    <OutputType>Exe</OutputType>

    <UseMaui>true</UseMaui>
    <SingleProject>true</SingleProject>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <RootNamespace>Ejar.Maui</RootNamespace>
    <AssemblyName>Ejar.Maui</AssemblyName>

    <ApplicationTitle>إيجار</ApplicationTitle>
    <ApplicationId>ye.ejar.customer</ApplicationId>
    <ApplicationIdGuid>3a3a1b1f-1f1f-4f4f-8b8b-1d1d2d2d3d3d</ApplicationIdGuid>
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
    <ApplicationVersion>1</ApplicationVersion>

    <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'">21.0</SupportedOSPlatformVersion>
    <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios'">15.0</SupportedOSPlatformVersion>
    <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'maccatalyst'">15.0</SupportedOSPlatformVersion>
    <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows'">10.0.17763.0</SupportedOSPlatformVersion>
    <TargetPlatformMinVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows'">10.0.17763.0</TargetPlatformMinVersion>

    <!-- Windows: لا نُغلّف كـ MSIX (لا AppxManifest في المشروع). تشغيل
         تطبيق MAUI كـ unpackaged Windows EXE. -->
    <WindowsPackageType Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows'">None</WindowsPackageType>

    <!-- إيقاف بنية StaticWebAssets على هذا المشروع — مشاكلها على MAUI
         في dotnet 10 معروفة (dotnet/maui#22944، #2609 + variants).
         نُغلِّف wwwroot للـ RCLs يدوياً عبر MauiAsset أدناه. -->
    <StaticWebAssetsEnabled>false</StaticWebAssetsEnabled>
  </PropertyGroup>

  <!-- يجبّر MAUI على تخطّي ConvertStaticWebAssetsToMauiAssets الذي يطلب
       manifest غير مولَّد في مشاريع MAUI (يسبّب: «Manifest file at obj\
       …\staticwebassets.build.json not found»). الـ MauiAsset أدناه يبدّل
       الوظيفة بالأسلوب الموثوق على الجوال.

       التعريف الفعليّ في Directory.Build.targets المجاور — لأنّ التارجيتس
       المعرَّفة في csproj يبدّلها استيراد الـ package اللاحق. ملف
       Directory.Build.targets يُستورد آخر شيء بعد الـ package فينتصر. -->
  <!-- (placeholder — see Directory.Build.targets) -->

  <ItemGroup>
    <!-- App icon + splash + assets — placeholders (تُولَّد آلياً عند البناء) -->
    <MauiIcon Include="Resources\AppIcon\appicon.svg" ForegroundFile="Resources\AppIcon\appiconfg.svg" Color="#1d4ed8" />
    <MauiSplashScreen Include="Resources\Splash\splash.svg" Color="#f1f5f9" BaseSize="128,128" />
    <MauiImage Include="Resources\Images\*" />
    <MauiFont Include="Resources\Fonts\*" />
    <MauiAsset Include="Resources\Raw\**" LogicalName="%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

  <!-- بدائل يدويّة لـ ConvertStaticWebAssetsToMauiAssets المعطَّل: نَنسَخ
       wwwroot من RCLs إلى APK كـ MauiAsset بمسار virtual يطابق ما يتوقّعه
       index.html (_content/<PackageId>/<file>). أضِف سطراً جديداً لكل
       RCL إضافي يحتاج أصوله المحلية عند التشغيل في WebView. -->
  <ItemGroup>
    <MauiAsset Include="..\..\Shared\Ejar.Customer.UI\wwwroot\**\*.*"
               LogicalName="_content/Ejar.Customer.UI/%(RecursiveDir)%(Filename)%(Extension)" />
    <MauiAsset Include="..\..\..\..\..\libs\kits\Widgets\ACommerce.Widgets\wwwroot\**\*.*"
               LogicalName="_content/ACommerce.Widgets/%(RecursiveDir)%(Filename)%(Extension)" />
    <MauiAsset Include="..\..\..\..\..\libs\kits\Templates\Shared\ACommerce.Templates.Shared\wwwroot\**\*.*"
               LogicalName="_content/ACommerce.Templates.Shared/%(RecursiveDir)%(Filename)%(Extension)" />
    <MauiAsset Include="..\..\..\..\..\libs\kits\Templates\Marketplace\ACommerce.Templates.Marketplace\wwwroot\**\*.*"
               LogicalName="_content/ACommerce.Templates.Marketplace/%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Maui.Controls" Version="10.0.0" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebView.Maui" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Debug" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="10.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Shared\Ejar.Customer.UI\Ejar.Customer.UI.csproj" />
  </ItemGroup>
</Project>
