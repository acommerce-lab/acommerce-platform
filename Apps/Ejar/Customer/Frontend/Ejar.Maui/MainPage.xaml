<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:b="clr-namespace:Microsoft.AspNetCore.Components.WebView.Maui;assembly=Microsoft.AspNetCore.Components.WebView.Maui"
             xmlns:local="clr-namespace:Ejar.Maui"
             xmlns:ui="clr-namespace:Ejar.Customer.UI.Components;assembly=Ejar.Customer.UI"
             x:Class="Ejar.Maui.MainPage"
             FlowDirection="RightToLeft"
             BackgroundColor="#f1f5f9">

    <ContentPage.Padding>
        <OnPlatform x:TypeArguments="Thickness">
            <On Platform="iOS" Value="0, 44, 0, 0" />
            <On Platform="Android" Value="0, 24, 0, 0" />
        </OnPlatform>
    </ContentPage.Padding>

    <b:BlazorWebView x:Name="blazorWebView" HostPage="wwwroot/index.html">
        <b:BlazorWebView.RootComponents>
            <b:RootComponent Selector="#app" ComponentType="{x:Type ui:Routes}" />
        </b:BlazorWebView.RootComponents>
    </b:BlazorWebView>

</ContentPage>
