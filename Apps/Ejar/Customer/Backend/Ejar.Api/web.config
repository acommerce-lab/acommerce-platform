<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS hosting config لـ runasp.net (Windows IIS shared). الـ ASP.NET Core
  SDK ينشئ web.config افتراضيّ عند publish، لكنّه لا يُفعّل WebSocket ولا
  يُعطّل buffering — وكلاهما لازم لتسليم رسائل SignalR realtime عبر IIS.
  بدون هذا الملف:
    - WebSocket module في IIS غير مُفعّل افتراضياً → الترقية تفشل بصمت.
    - استجابات SSE/LongPolling قد تُبفَّر في طبقة proxy → الأحداث لا تخرج
      إلى العميل حتى ينتهي الطلب.
  Aspect المهمّ هنا: <webSocket enabled="true" /> + responseBufferLimit=0
  على aspNetCore handler لتمرير streaming مباشرة بدون تجميع.
-->
<configuration>
  <system.webServer>
    <!-- تفعيل WebSocket module — لا يكون مُحمَّلاً على بعض IIS shared. -->
    <webSocket enabled="true" />

    <handlers>
      <remove name="aspNetCore" />
      <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
    </handlers>

    <!-- responseBufferLimit="0" يُلغي تجميع الاستجابة، حيويّ لـ SSE/LongPolling.
         requestTimeout: ١٠ دقائق — long polling قد ينتظر طويلاً. -->
    <aspNetCore processPath="dotnet"
                arguments=".\Ejar.Api.dll"
                stdoutLogEnabled="false"
                stdoutLogFile=".\logs\stdout"
                hostingModel="inprocess"
                requestTimeout="00:10:00">
      <handlerSettings>
        <handlerSetting name="responseBufferLimit" value="0" />
      </handlerSettings>
    </aspNetCore>

    <httpProtocol>
      <customHeaders>
        <!-- يمنع أيّ proxy وسيط من تخزين استجابات realtime/auth. -->
        <add name="X-Accel-Buffering" value="no" />
      </customHeaders>
    </httpProtocol>

    <!-- زيادة الحد الأقصى لطلبات POST (الصور/data URLs قد تكون كبيرة). -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="20971520" /> <!-- 20MB -->
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
