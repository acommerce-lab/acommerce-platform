<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RollForward>LatestMajor</RollForward>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Ejar.Api</RootNamespace>
    <AssemblyName>Ejar.Api</AssemblyName>
    <UserSecretsId>ejar-api</UserSecretsId>
    <!-- نُبقي web.config كما كتبناه (تفعيل WebSocket + responseBufferLimit=0).
         بدون هذا الإعداد الـ SDK يُولّد web.config افتراضيّ بدون تلك الإعدادات
         فيعطّل realtime على IIS/runasp.net. -->
    <IsTransformWebConfigDisabled>true</IsTransformWebConfigDisabled>
  </PropertyGroup>

  <ItemGroup>
    <None Update="web.config">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </None>
    <!-- ملف اعتماد Firebase Admin SDK — موجود محلّياً فقط (gitignored لأنّه
         يحوي مفتاحاً خاصّاً). Update يُحدّث metadata لـ item موجود؛ إن لم
         يكن الملف موجوداً في الـ working tree فلا يُنشأ item ولا يفشل البناء.
         راجع Secrets/README.md للنشر. -->
    <None Update="Secrets\firebase-service-account.json" Condition="Exists('Secrets\firebase-service-account.json')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </None>
    <None Update="Secrets\firebase-service-account.example.json">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
      <CopyToPublishDirectory>Never</CopyToPublishDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <!-- Domain (entities + seed state) — single source of truth shared by Customer/Provider/Admin -->
    <ProjectReference Include="..\..\..\..\..\libs\kits\Auth\ACommerce.Kits.Auth.Backend\ACommerce.Kits.Auth.Backend.csproj" />
    <ProjectReference Include="..\..\..\..\..\libs\kits\Versions\ACommerce.Kits.Versions\ACommerce.Kits.Versions.csproj" />
    <ProjectReference Include="..\..\..\Domain\Ejar.Domain.csproj" />

    <!-- SharedKernel EF infra (PlatformDataRoot + SqliteSchemaGuard helpers) -->
    <ProjectReference Include="..\..\..\..\..\libs\kits\Core\SharedKernel\ACommerce.SharedKernel.Infrastructure.EFCores\ACommerce.SharedKernel.Infrastructure.EFCores.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- ─── Core OAM engine ──────────────────────────────────────────── -->
    <ProjectReference Include="..\..\..\..\..\libs\kits\Core\OperationEngine\ACommerce.OperationEngine\ACommerce.OperationEngine.csproj" />
    <ProjectReference Include="..\..\..\..\..\libs\kits\Core\OperationEngine\ACommerce.OperationEngine.Wire\ACommerce.OperationEngine.Wire.csproj" />
    <ProjectReference Include="..\..\..\..\..\libs\kits\Core\OperationEngine\ACommerce.OperationEngine.AspNetCore\ACommerce.OperationEngine.AspNetCore.csproj" />
    <ProjectReference Include="..\..\..\..\..\libs\kits\Core\OperationEngine\ACommerce.OperationEngine.Interceptors\ACommerce.OperationEngine.Interceptors.csproj" />
  </ItemGroup>

  <ItemGroup>
