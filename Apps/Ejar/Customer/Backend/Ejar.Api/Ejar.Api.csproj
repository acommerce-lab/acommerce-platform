    <ProjectReference Include="..\..\..\..\..\libs\kits\Core\SharedKernel\ACommerce.SharedKernel.Mediators\ACommerce.SharedKernel.Mediators.csproj" />
    <ProjectReference Include="..\..\..\..\..\libs\kits\Support\ACommerce.Kits.Support\ACommerce.Kits.Support.csproj" />
    <ProjectReference Include="..\..\..\..\..\libs\kits\Reports\ACommerce.Kits.Reports\ACommerce.Kits.Reports.csproj" />
