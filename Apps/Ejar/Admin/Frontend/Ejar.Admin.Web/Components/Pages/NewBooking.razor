@page "/book/{Id}"
@inject AppStore Store
@inject ApiReader Api
@inject NavigationManager Nav
@inject L L

<PageTitle>حجز — @(L["app.name"])</PageTitle>

<div class="acs-page acs-booking-wizard">
    @if (_loading) { <AcLoadingState /> }
    else if (_listing is null) { <AcEmptyState IconName="info" Message="الإعلان غير موجود" /> }
    else if (IsMine)
    {
        <AcEmptyState IconName="alert-circle" Message="لا يمكن حجز إعلان من إنشائك" />
        <AcButton Variant="ghost" Class="ac-btn-block" Text="العودة إلى الإعلان"
                  OnClick="@(() => Nav.NavigateTo($"/listings/{Id}"))" />
    }
    else
    {
        <h1 class="acm-wizard-title">حجز: @_listing.Title</h1>

        <div class="acs-step-indicator">
            <span class="@(_step >= 1 ? "active" : "")">١ التاريخ</span>
            <span class="@(_step >= 2 ? "active" : "")">٢ الضيوف</span>
            <span class="@(_step >= 3 ? "active" : "")">٣ المراجعة</span>
            <span class="@(_step >= 4 ? "active" : "")">٤ الدفع</span>
        </div>

        @if (_step == 1)
        {
            <AcCard>
                <ChildContent>
                    <h3 style="margin-top:0;">متى تريد السكن؟</h3>
                    <AcField Label="تاريخ البدء" Required="true">
                        <input type="date" class="ac-input"
                               value="@_startDate.ToString("yyyy-MM-dd")"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")"
                               @onchange="@(e => _startDate = DateTime.TryParse(e.Value?.ToString(), out var d) ? d : _startDate)" />
                    </AcField>
                    <AcField Label="عدد الليالي" Required="true">
                        <div style="display:flex; gap:8px; align-items:center;">
                            <AcButton Variant="ghost" Text="−" OnClick="@(() => _nights = Math.Max(1, _nights - 1))" />
                            <strong style="min-width:40px; text-align:center;">@_nights</strong>
                            <AcButton Variant="ghost" Text="+" OnClick="@(() => _nights = Math.Min(365, _nights + 1))" />
                        </div>
                    </AcField>
                    <AcButton Variant="primary" Class="ac-btn-block" Text="التالي"
                              OnClick="@(() => _step = 2)" Disabled="@(_startDate < DateTime.Today)" />
                </ChildContent>
            </AcCard>
        }
        else if (_step == 2)
        {
            <AcCard>
                <ChildContent>
                    <h3 style="margin-top:0;">كم عدد الضيوف؟</h3>
                    <AcField Label="عدد الأشخاص" Required="true">
                        <div style="display:flex; gap:8px; align-items:center;">
                            <AcButton Variant="ghost" Text="−" OnClick="@(() => _guests = Math.Max(1, _guests - 1))" />
                            <strong style="min-width:40px; text-align:center;">@_guests</strong>
                            <AcButton Variant="ghost" Text="+" OnClick="@(() => _guests = Math.Min(20, _guests + 1))" />
                        </div>
                    </AcField>
                    <AcField Label="ملاحظات للمالك (اختياريّ)">
                        <textarea class="ac-input" rows="3" @bind="_notes"
                                  placeholder="أيّ احتياجات أو طلبات خاصّة…"></textarea>
                    </AcField>
                    <div style="display:flex; gap:8px;">
                        <AcButton Variant="ghost" Text="رجوع" OnClick="@(() => _step = 1)" />
                        <AcButton Variant="primary" Class="ac-btn-block" Text="التالي"
                                  OnClick="@(() => _step = 3)" />
                    </div>
                </ChildContent>
            </AcCard>
        }
        else if (_step == 3)
        {
            <AcCard>
                <ChildContent>
                    <h3 style="margin-top:0;">مراجعة الحجز</h3>
                    <div class="acm-checkout-line"><span>الإعلان:</span><strong>@_listing.Title</strong></div>
                    <div class="acm-checkout-line"><span>تاريخ البدء:</span><strong>@_startDate.ToString("yyyy-MM-dd")</strong></div>
                    <div class="acm-checkout-line"><span>عدد الليالي:</span><strong>@_nights</strong></div>
                    <div class="acm-checkout-line"><span>عدد الأشخاص:</span><strong>@_guests</strong></div>
                    <hr />
                    <div class="acm-checkout-line"><span>السعر اليومي:</span><strong>@_listing.Price ر.ي</strong></div>
                    <div class="acm-checkout-line"><span>الإجماليّ الفرعيّ:</span><strong>@Subtotal ر.ي</strong></div>
                    <div class="acm-checkout-line"><span>رسوم الخدمة (5%):</span><strong>@ServiceFee ر.ي</strong></div>
                    <hr />
                    <div class="acm-checkout-line"><span><strong>المجموع:</strong></span><strong>@Total ر.ي</strong></div>

                    <AcField>
                        <label style="display:flex; gap:8px; align-items:center;">
                            <input type="checkbox" @bind="_agreeTerms" />
                            <span>أوافق على <a href="/legal/terms">الشروط والأحكام</a> و<a href="/legal/refund">سياسة الاسترداد</a></span>
                        </label>
                    </AcField>

                    <div style="display:flex; gap:8px;">
                        <AcButton Variant="ghost" Text="رجوع" OnClick="@(() => _step = 2)" />
                        <AcButton Variant="primary" Class="ac-btn-block" Text="انتقل للدفع"
                                  OnClick="@(() => _step = 4)" Disabled="@(!_agreeTerms)" />
                    </div>
                </ChildContent>
            </AcCard>
        }
        else
        {
            <AcCard>
                <ChildContent>
                    <h3 style="margin-top:0;">الدفع</h3>
                    <p>المجموع المستحقّ: <strong>@Total ر.ي</strong></p>
                    <AcPaymentForm SubmitLabel="@($"ادفع {Total} ر.ي")"
                                  OnSubmit="OnPay" />
                    @if (!string.IsNullOrEmpty(_alert))
                    {
                        <AcAlert Variant="@_alertVariant" Text="@_alert" />
                    }
                    <AcButton Variant="ghost" Text="رجوع للمراجعة" OnClick="@(() => _step = 3)" />
                </ChildContent>
            </AcCard>
        }
    }
</div>

@code {
    [Parameter] public string Id { get; set; } = "";

    private ListingDto? _listing;
    private bool _loading = true;
    private int _step = 1;
    private DateTime _startDate = DateTime.Today.AddDays(1);
    private int _nights = 1;
    private int _guests = 1;
    private string _notes = "";
    private bool _agreeTerms;
    private string? _alert;
    private string _alertVariant = "success";

    private bool IsMine => _listing is not null && Store.Auth.IsAuthenticated
                           && _listing.OwnerId == Store.Auth.UserId?.ToString();

    private decimal Subtotal    => _listing is null ? 0 : _listing.Price * _nights;
    private decimal ServiceFee  => Math.Round(Subtotal * 0.05m, 2);
    private decimal Total       => Subtotal + ServiceFee;

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (!first) return;
        var env = await Api.GetAsync<ListingDto>($"/listings/{Id}");
        _listing = env.Data;
        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private void OnPay(AcPaymentForm.PaymentFormValues dto)
    {
        var lastDigit = dto.CardNumber.LastOrDefault(char.IsDigit);
        if (char.IsDigit(lastDigit) && (lastDigit - '0') % 2 == 0)
        {
            var bookingId = $"B-{Random.Shared.Next(100, 999)}";
            Nav.NavigateTo($"/payment/callback?status=success&type=booking&id={bookingId}&amount={Total}");
        }
        else
        {
            _alert = "فشلت عمليّة الدفع — حاول ببطاقة أخرى";
            _alertVariant = "danger";
        }
    }

    private sealed record ListingDto(
        string Id, string Title, decimal Price, string TimeUnit, string TimeUnitLabel,
        string PropertyType, string PropertyTypeLabel, string City, string District,
        double Lat, double Lng, List<object>? Amenities, string OwnerId, object? Owner,
        int BedroomCount, int BathroomCount, double AreaSqm, bool IsVerified,
        int ViewsCount, int Status, bool IsFavorite, List<string>? Images);
}
