@page "/"
@inject AppStore Store
@inject ApiReader Api
@inject NavigationManager Nav
@inject L L

<PageTitle>@(L["app.name"]) — إدارة</PageTitle>

@if (!Store.Auth.IsAuthenticated)
{
    <AcEmptyState IconName="log-in"
                  Title="لوحة الإدارة"
                  Message="سجّل دخولك بحساب مسؤول للوصول"
                  ActionLabel="@(L["auth.login.title"])"
                  ActionHref="/login" />
}
else if (_data is null)
{
    <AcLoadingState />
}
else
{
    <div class="acs-page">
        <h1 class="acm-wizard-title">لوحة إدارة إيجار</h1>
        <p style="color:var(--ac-text-muted);">نظرة عامّة على نشاط المنصّة.</p>

        <div class="acs-stats-grid" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:12px; margin:16px 0;">
            <div class="acs-stat card"><small>الإعلانات</small><div style="font-size:24px; font-weight:600;">@_data.totalListings</div></div>
            <div class="acs-stat card"><small>موثَّقة</small><div style="font-size:24px; font-weight:600;">@_data.verifiedListings</div></div>
            <div class="acs-stat card"><small>نشطة</small><div style="font-size:24px; font-weight:600;">@_data.activeListings</div></div>
            <div class="acs-stat card"><small>المحادثات</small><div style="font-size:24px; font-weight:600;">@_data.totalConversations</div></div>
        </div>

        <div style="display:flex; gap:8px; flex-wrap:wrap;">
            <AcButton Variant="primary"   Text="إدارة الإعلانات" OnClick="@(() => Nav.NavigateTo("/admin/listings"))" />
            <AcButton Variant="secondary" Text="المستخدمون"      OnClick="@(() => Nav.NavigateTo("/admin/users"))" />
        </div>

        <h3 style="margin-top:24px;">آخر الرسائل</h3>
        <ul>
            @foreach (var m in _data.recentMessages)
            {
                <li><strong>@m.From</strong> · @m.SentAt.ToLocalTime().ToString("HH:mm") — محادثة @m.ConversationId</li>
            }
        </ul>
    </div>
}

@code {
    private DashboardDto? _data;

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (!first || !Store.Auth.IsAuthenticated) return;
        try
        {
            var env = await Api.GetAsync<DashboardDto>("/admin/dashboard");
            _data = env.Data;
            await InvokeAsync(StateHasChanged);
        }
        catch { /* tolerate API offline */ }
    }

    private record RecentMsg(string Id, string ConversationId, string From, DateTime SentAt);
    private record DashboardDto(
        int totalListings, int verifiedListings, int activeListings,
        int totalConversations,
        List<RecentMsg> recentMessages);
}
