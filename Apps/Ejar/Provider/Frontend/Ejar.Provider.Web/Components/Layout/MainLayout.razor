@namespace Ejar.Provider.Web.Components.Layout
@using Ejar.Provider.Web.Operations
@inherits LayoutComponentBase
@inject AppStore Store
@inject AppStateApplier Applier
@inject ApiReader Api
@inject L L
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject EjarProviderRealtimeService Realtime
@inject IConfiguration Config
@implements IAsyncDisposable

<div class="@(Store.Ui.HideChrome ? "acm-chrome-hidden" : "")">
<AcVersionGate IsLoading="@(!_checked)"
               IsBlocked="@_versionBlocked"
               RequiredTitle="@(L["version.required"])"
               RequiredBody="@(L["version.required_body"])"
               DownloadLabel="@(L["version.download"])"
               CurrentLabel="@(L["version.current"])"
               LatestLabel="@(L["version.latest"])"
               CurrentVersion="@_current"
               LatestVersion="@_latest"
               SupportEmail="@_support">
    <ChildContent>
        <nav class="acm-mobile-nav">
            <div class="acm-mobile-nav-inner">
                <div class="acm-mobile-nav-brand">
                    <span class="acm-brand-text" style="font-size:1.3rem;font-weight:700;color:var(--ac-primary);">إيجار</span>
                </div>
                <div class="acm-mobile-nav-actions">
                    <button class="acm-mobile-nav-btn" @onclick="@(() => Nav.NavigateTo("/search"))" aria-label="بحث">
                        <AcIcon Name="search" Size="28" />
                    </button>
                    <button class="acm-mobile-nav-btn" @onclick="@(() => Nav.NavigateTo("/notifications"))" aria-label="إشعارات">
                        <AcIcon Name="bell" Size="28" />
                    </button>
                </div>
            </div>
        </nav>

        <div class="acm-v2-topnav-wrap">
            <AcTopNav Items="_topItems">
                <BrandContent>
                    <div class="acm-brand">
                        <span style="font-size:1.4rem;font-weight:700;color:var(--ac-primary);">إيجار</span>
                    </div>
                </BrandContent>
                <RightActions>
                    <AcThemeToggle IsDark="@Store.Ui.IsDark"
                                   IsDarkChanged="@(async v => await Applier.ApplyLocalAsync(EjarOps.SetTheme(v ? "dark" : "light")))" />
                    <AcLanguageToggle IsArabic="@Store.Ui.IsArabic"
                                      IsArabicChanged="@(async v => await Applier.ApplyLocalAsync(EjarOps.SetLanguage(v ? "ar" : "en")))" />
                </RightActions>
            </AcTopNav>
        </div>

        <main class="@(Store.Ui.IsDark ? "ac-dark-wrap" : "")">
            @Body
            <div class="acm-v2-bottom-nav-wrap">
                <AcBottomNav Items="_bottomItems" ExtraClass="acm-v2-bottomnav" />
            </div>
        </main>

        <CookieConsentBanner />
    </ChildContent>
</AcVersionGate>
</div>

@code {
    private bool _checked;
    private bool _versionBlocked;
    private string _current = "1.0.0";
    private string _latest = "1.0.0";
    private string? _support;
    private bool _realtimeConnected;

    private static readonly IReadOnlyList<BottomNavItemDto> _bottomItems = new[]
    {
        new BottomNavItemDto { Href = "/",              Label = "الرئيسية", IconName = "home",    Exact = true },
        new BottomNavItemDto { Href = "/search",        Label = "بحث",      IconName = "search" },
        new BottomNavItemDto { Href = "/favorites",     Label = "المفضلة",  IconName = "heart" },
        new BottomNavItemDto { Href = "/chats",         Label = "الرسائل",  IconName = "message" },
        new BottomNavItemDto { Href = "/me",            Label = "حسابي",    IconName = "user" }
    };

    private static readonly IReadOnlyList<AcTopNav.TopNavItem> _topItems = new[]
    {
        new AcTopNav.TopNavItem("/",              "الرئيسية",  "home",    null, true),
        new AcTopNav.TopNavItem("/search",        "بحث",       "search"),
        new AcTopNav.TopNavItem("/favorites",     "المفضلة",   "heart"),
        new AcTopNav.TopNavItem("/chats",         "الرسائل",   "message"),
        new AcTopNav.TopNavItem("/notifications", "الإشعارات", "bell"),
        new AcTopNav.TopNavItem("/me",            "حسابي",     "user")
    };

    private string? _appliedTheme;
    private string? _appliedLang;

    protected override void OnInitialized()
    {
        Store.OnChanged += OnChange;
        Nav.LocationChanged += OnLocationChanged;
        UpdateChrome(Nav.Uri);
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        UpdateChrome(e.Location);
        InvokeAsync(StateHasChanged);
    }

    private void UpdateChrome(string uri)
    {
        var path = new Uri(uri).AbsolutePath;
        Store.Ui.HideChrome = path.StartsWith("/login", StringComparison.OrdinalIgnoreCase);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var env = await Api.GetAsync<VersionDto>("/version/check");
            if (env.Data is not null)
            {
                _current = env.Data.Current;
                _latest = env.Data.Latest;
                _versionBlocked = env.Data.IsBlocked;
                _support = env.Data.SupportEmail;
            }
            _checked = true;
            await InvokeAsync(StateHasChanged);

            // Connect to realtime hub if already authenticated (page reload case)
            if (Store.Auth.IsAuthenticated)
                await ConnectRealtimeAsync();
        }

        // Connect after login (OnAfterRenderAsync fires after Store.NotifyChanged)
        if (Store.Auth.IsAuthenticated && !_realtimeConnected)
            await ConnectRealtimeAsync();

        if (_appliedTheme != Store.Ui.Theme || _appliedLang != Store.Ui.Language)
        {
            _appliedTheme = Store.Ui.Theme;
            _appliedLang = Store.Ui.Language;
            var dir = Store.Ui.IsRtl ? "rtl" : "ltr";
            try { await JS.InvokeVoidAsync("ejarUi.apply", Store.Ui.Theme, Store.Ui.Language, dir); }
            catch (InvalidOperationException) { }
        }
    }

    private async Task ConnectRealtimeAsync()
    {
        _realtimeConnected = true;
        var apiBase = Config["EjarApi:BaseUrl"]?.TrimEnd('/') ?? "http://localhost:5300";
        await Realtime.ConnectAsync($"{apiBase}/hubs/ejar");
    }

    private void OnChange()
    {
        InvokeAsync(async () =>
        {
            StateHasChanged();
            if (Store.Auth.IsAuthenticated && !_realtimeConnected)
                await ConnectRealtimeAsync();
        });
    }

    public async ValueTask DisposeAsync()
    {
        Store.OnChanged -= OnChange;
        Nav.LocationChanged -= OnLocationChanged;
        await Realtime.DisposeAsync();
    }

    private sealed record VersionDto(string Current, string Latest, bool IsBlocked, string? StoreUrl, string? SupportEmail);
}
