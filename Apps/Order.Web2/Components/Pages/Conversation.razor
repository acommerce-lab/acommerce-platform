@page "/chat/{Id:guid}"
@inject OrderApiClient Api
@inject AuthStateService Auth
@inject UiPreferences Ui
@inject NavigationManager Nav

<PageTitle>محادثة - اوردر</PageTitle>

<h1 class="page-title">@(Ui.IsArabic ? "محادثة" : "Chat")</h1>

@if (!Auth.IsAuthenticated)
{
    <div class="empty-state">
        <div class="ico">🔒</div>
        <h3>@(Ui.IsArabic ? "سجل دخولك" : "Sign in")</h3>
        <a class="btn btn-primary" href="/login">@(Ui.IsArabic ? "دخول" : "Sign in")</a>
    </div>
}
else
{
    <div class="msg-stream s-card" style="max-height:60vh; overflow-y:auto; padding:12px;">
        @if (Loading)
        {
            <div style="text-align:center; padding:40px 0; color:var(--ac-text-muted);">
                <i class="bi bi-arrow-clockwise"></i> @(Ui.IsArabic ? "جاري التحميل..." : "Loading...")
            </div>
        }
        else if (Messages.Count == 0)
        {
            <div style="text-align:center; padding:40px 0; color:var(--ac-text-muted);">
                @(Ui.IsArabic ? "لا رسائل بعد" : "No messages yet")
            </div>
        }
        else
        {
            foreach (var m in Messages)
            {
                var mine = m.SenderId == Auth.UserId;
                <div class="bubble-wrap @(mine ? "mine" : "")">
                    <div class="bubble @(mine ? "bubble-mine" : "bubble-other")">
                        <div>@m.Content</div>
                        <div class="bubble-time">@m.CreatedAt.ToLocalTime().ToString("HH:mm")</div>
                    </div>
                </div>
            }
        }
    </div>

    <div style="padding: 12px 16px 30px;">
        <div class="msg-input">
            <input class="form-input" placeholder="@(Ui.IsArabic ? "اكتب رسالة..." : "Type a message...")"
                   @bind="Draft" @bind:event="oninput" @onkeyup="OnKey" />
            <button class="btn btn-primary" @onclick="Send" disabled="@Sending">
                <i class="bi bi-send"></i>
            </button>
        </div>
    </div>
}

<style>
    .bubble-wrap { display: flex; margin-bottom: 8px; }
    .bubble-wrap.mine { justify-content: flex-end; }
    html[dir="rtl"] .bubble-wrap.mine { justify-content: flex-start; }
    .bubble {
        max-width: 75%;
        padding: 9px 13px;
        border-radius: 16px;
        font-size: 0.92rem;
        line-height: 1.45;
    }
    .bubble-mine {
        background: var(--ord-hero-grad);
        color: #fff;
        border-bottom-right-radius: 4px;
    }
    html[dir="rtl"] .bubble-mine {
        border-bottom-right-radius: 16px;
        border-bottom-left-radius: 4px;
    }
    .bubble-other {
        background: var(--ac-bg-alt);
        color: var(--ac-text);
        border-bottom-left-radius: 4px;
    }
    html[dir="rtl"] .bubble-other {
        border-bottom-left-radius: 16px;
        border-bottom-right-radius: 4px;
    }
    .bubble-time { font-size: 0.65rem; opacity: 0.7; margin-top: 4px; }
    .msg-input {
        display: flex;
        gap: 8px;
        background: var(--ac-surface);
        padding: 8px;
        border-radius: 18px;
        box-shadow: var(--ac-shadow-sm);
    }
    .msg-input .form-input {
        border: 0;
        background: transparent;
        flex: 1;
    }
    .msg-input .form-input:focus { box-shadow: none; }
    .msg-input .btn-primary {
        width: 44px;
        height: 44px;
        padding: 0;
        border-radius: 50%;
        flex-shrink: 0;
    }
</style>

@code {
    [Parameter] public Guid Id { get; set; }
    private List<MsgDto> Messages = new();
    private bool Loading = true;
    private bool Sending;
    private string Draft = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Auth.EnsureRestoredAsync();
        await Reload();
        StateHasChanged();
    }

    private async Task Reload()
    {
        Loading = true;
        var env = await Api.GetAsync<List<MsgDto>>($"/api/messages/conversations/{Id}/messages");
        Messages = env.Data ?? new();
        Loading = false;
    }

    private async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Send();
    }

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(Draft) || Sending) return;
        Sending = true;
        try
        {
            var env = await Api.PostAsync<MsgDto>("/api/messages",
                new { conversationId = Id, senderId = Auth.UserId, content = Draft });
            if (env.Data != null)
            {
                Messages.Add(env.Data);
                Draft = "";
            }
        }
        finally { Sending = false; }
    }

    public class MsgDto
    {
        public Guid Id { get; set; }
        public Guid ConversationId { get; set; }
        public Guid SenderId { get; set; }
        public string Content { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }
}
