@page "/offer/{Id:guid}"
@inject OrderApiClient Api
@inject CartService Cart
@inject AuthStateService Auth
@inject UiPreferences Ui
@inject NavigationManager Nav

<PageTitle>@(Offer?.Title ?? "تفاصيل العرض") - اوردر</PageTitle>

@if (Loading)
{
    <div class="empty-state"><div class="ico">⏳</div><p>جاري التحميل...</p></div>
}
else if (Offer == null)
{
    <div class="empty-state"><div class="ico">⚠️</div><h3>العرض غير موجود</h3>
        <a class="btn btn-primary" href="/">العودة للرئيسية</a></div>
}
else
{
    <div class="offer-hero">
        <button class="back-btn" @onclick="@(() => Nav.NavigateTo("/"))">
            <i class="bi bi-chevron-@(Ui.IsArabic ? "right" : "left")"></i>
        </button>
        <button class="fav-btn @(IsFavorite ? "active" : "")" @onclick="ToggleFavorite">
            <i class="bi bi-heart@(IsFavorite ? "-fill" : "")"></i>
        </button>
        <div class="hero-emoji">@Offer.Emoji</div>
        @if (Offer.DiscountPercent > 0)
        {
            <div class="hero-discount">-@(Offer.DiscountPercent)% @(Ui.IsArabic ? "خصم" : "OFF")</div>
        }
    </div>

    <div style="padding: 18px 16px 0;">
        <h1 style="margin:0 0 4px; font-size:1.4rem; font-weight:800;">@Offer.Title</h1>
        @if (Offer.Vendor != null)
        {
            <div style="display:flex; align-items:center; gap:6px; color:var(--ac-text-muted); font-size:0.9rem;">
                <span style="font-size:1.1rem;">@Offer.Vendor.LogoEmoji</span>
                <span>@Offer.Vendor.Name</span>
                <span>•</span>
                <span><i class="bi bi-star-fill" style="color:#FFB300;"></i> @Offer.Vendor.Rating.ToString("0.0")</span>
            </div>
        }
        <div style="display:flex; align-items:baseline; gap:10px; margin-top:14px;">
            <span style="color:var(--ac-primary); font-weight:800; font-size:2rem;">@Offer.Price.ToString("N0")</span>
            <span style="color:var(--ac-text-muted); font-size:0.95rem;">@Offer.Currency</span>
            @if (Offer.OriginalPrice.HasValue && Offer.OriginalPrice > Offer.Price)
            {
                <span style="color:var(--ac-text-muted); text-decoration:line-through; font-size:0.95rem;">
                    @Offer.OriginalPrice.Value.ToString("N0")
                </span>
            }
        </div>
    </div>

    <div class="s-card" style="margin-top:14px;">
        <h3>@(Ui.IsArabic ? "تفاصيل العرض" : "Details")</h3>
        <p style="margin:6px 0 0; color:var(--ac-text); line-height:1.7; white-space:pre-line;">@Offer.Description</p>
    </div>

    @if (Offer.Vendor != null)
    {
        <div class="s-card">
            <h3>@(Ui.IsArabic ? "معلومات المتجر" : "Store info")</h3>
            <div class="s-card-row">
                <span class="label"><i class="bi bi-geo-alt"></i> @(Ui.IsArabic ? "العنوان" : "Address")</span>
                <span class="value">@Offer.Vendor.City@(string.IsNullOrEmpty(Offer.Vendor.District) ? "" : " - " + Offer.Vendor.District)</span>
            </div>
            <div class="s-card-row">
                <span class="label"><i class="bi bi-clock"></i> @(Ui.IsArabic ? "ساعات العمل" : "Hours")</span>
                <span class="value" dir="ltr">@FormatHours(Offer.Vendor.OpenHours)</span>
            </div>
            <div class="s-card-row">
                <span class="label"><i class="bi bi-telephone"></i> @(Ui.IsArabic ? "الهاتف" : "Phone")</span>
                <span class="value" dir="ltr">@Offer.Vendor.Phone</span>
            </div>
        </div>
    }

    <div style="padding: 4px 16px 30px;">
        <button class="btn btn-primary btn-block" @onclick="AddToCart">
            <i class="bi bi-bag-plus"></i>
            @(Ui.IsArabic ? "أضف إلى السلة" : "Add to cart") • @Offer.Price.ToString("N0") @Offer.Currency
        </button>
        @if (Auth.IsAuthenticated && Offer.Vendor != null)
        {
            <button class="btn btn-outline-primary btn-block" style="margin-top:10px;" @onclick="StartChat">
                <i class="bi bi-chat-dots"></i>
                @(Ui.IsArabic ? "محادثة المتجر" : "Chat with store")
            </button>
        }
    </div>
}

<style>
    .offer-hero {
        position: relative;
        height: 220px;
        background: linear-gradient(135deg, #FFE2CC 0%, #FFC9A6 100%);
        display: flex;
        align-items: center;
        justify-content: center;
    }
    html[data-theme="dark"] .offer-hero { background: linear-gradient(135deg, #3A2818 0%, #4A2A18 100%); }
    .hero-emoji { font-size: 6rem; }
    .hero-discount {
        position: absolute;
        bottom: 14px;
        inset-inline-end: 14px;
        background: var(--ac-danger);
        color: #fff;
        padding: 6px 14px;
        border-radius: 999px;
        font-weight: 800;
        font-size: 0.85rem;
        box-shadow: 0 4px 12px rgba(244,67,54,0.4);
    }
    .back-btn, .fav-btn {
        position: absolute;
        top: 14px;
        background: rgba(255,255,255,0.92);
        color: var(--ac-text);
        border: 0;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        cursor: pointer;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        z-index: 10;
    }
    html[data-theme="dark"] .back-btn, html[data-theme="dark"] .fav-btn {
        background: rgba(40,28,20,0.95);
        color: #fff;
    }
    .back-btn { inset-inline-start: 14px; }
    .fav-btn  { inset-inline-end: 14px; }
    .fav-btn.active { color: var(--ac-danger); }
</style>

@code {
    [Parameter] public Guid Id { get; set; }
    private OfferDto? Offer;
    private bool Loading = true;
    private bool IsFavorite;

    protected override async Task OnInitializedAsync()
    {
        var env = await Api.GetAsync<OfferDto>($"/api/offers/{Id}");
        Offer = env.Data;
        Loading = false;
    }

    private void AddToCart()
    {
        if (Offer == null || Offer.Vendor == null) return;
        Cart.Add(Offer.Id, Offer.Title, Offer.Emoji, Offer.Price,
                 Offer.Vendor.Id, Offer.Vendor.Name, Offer.Vendor.LogoEmoji);
        Nav.NavigateTo("/cart");
    }

    private async Task ToggleFavorite()
    {
        if (!Auth.IsAuthenticated || Offer == null) { Nav.NavigateTo("/login"); return; }
        var env = await Api.PostAsync<FavToggle>("/api/favorites/toggle",
            new { userId = Auth.UserId, offerId = Offer.Id });
        IsFavorite = env.Data?.IsFavorite ?? IsFavorite;
    }

    private async Task StartChat()
    {
        if (Offer?.Vendor == null) return;
        var env = await Api.PostAsync<StartConvDto>("/api/messages/conversations",
            new { customerId = Auth.UserId, vendorId = Offer.Vendor.Id });
        if (env.Data != null) Nav.NavigateTo($"/chat/{env.Data.Id}");
    }

    private static string FormatHours(string h)
    {
        if (string.IsNullOrEmpty(h) || !h.Contains('|')) return h;
        var parts = h.Split('|');
        return $"{parts[0]} – {parts[1]}";
    }

    public class OfferDto
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Price { get; set; }
        public decimal? OriginalPrice { get; set; }
        public string Currency { get; set; } = "SAR";
        public string Emoji { get; set; } = "🍽️";
        public int DiscountPercent { get; set; }
        public VendorDto? Vendor { get; set; }
    }

    public class VendorDto
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public string Phone { get; set; } = "";
        public string City { get; set; } = "";
        public string? District { get; set; }
        public string LogoEmoji { get; set; } = "🏪";
        public string OpenHours { get; set; } = "";
        public double Rating { get; set; }
    }

    public class FavToggle { public bool IsFavorite { get; set; } }
    public class StartConvDto { public Guid Id { get; set; } }
}
