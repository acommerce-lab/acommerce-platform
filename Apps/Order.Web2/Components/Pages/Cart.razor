@page "/cart"
@inject CartService Bag
@inject UiPreferences Ui
@inject NavigationManager Nav
@inject AuthStateService Auth
@implements IDisposable

<PageTitle>السلة - اوردر</PageTitle>

<h1 class="page-title">@(Ui.IsArabic ? "سلة الطلبات" : "Your cart")</h1>

@if (Bag.Items.Count == 0)
{
    <div class="empty-state">
        <div class="ico">🛒</div>
        <h3>@(Ui.IsArabic ? "السلة فارغة" : "Cart is empty")</h3>
        <p>@(Ui.IsArabic ? "تصفّح العروض وأضف أصنافك المفضلة" : "Browse offers and add your favorites")</p>
        <a class="btn btn-primary" href="/" style="margin-top:8px;">
            <i class="bi bi-shop"></i> @(Ui.IsArabic ? "تصفّح العروض" : "Browse offers")
        </a>
    </div>
}
else
{
    <div class="s-card">
        <div class="vendor-row">
            <div class="vendor-emoji">@Bag.VendorEmoji</div>
            <div>
                <div style="font-weight:800;">@Bag.VendorName</div>
                <div style="font-size:0.78rem; color:var(--ac-text-muted);">@(Ui.IsArabic ? "الاستلام من المتجر أو من السيارة" : "In-store or curbside pickup")</div>
            </div>
        </div>
    </div>

    @foreach (var item in Bag.Items)
    {
        <div class="s-card cart-item">
            <div class="ci-emoji">@item.Emoji</div>
            <div class="ci-body">
                <div class="ci-title">@item.Title</div>
                <div class="ci-price">@item.UnitPrice.ToString("N0") ر.س</div>
            </div>
            <div class="ci-qty">
                <button class="qbtn" @onclick="@(() => Bag.SetQuantity(item.OfferId, item.Quantity - 1))">−</button>
                <span class="qval">@item.Quantity</span>
                <button class="qbtn" @onclick="@(() => Bag.SetQuantity(item.OfferId, item.Quantity + 1))">+</button>
            </div>
        </div>
    }

    <div class="s-card">
        <div class="s-card-row">
            <span class="label">@(Ui.IsArabic ? "المجموع الفرعي" : "Subtotal")</span>
            <span class="value">@Bag.Subtotal.ToString("N0") ر.س</span>
        </div>
        <div class="s-card-row" style="border-bottom:0;">
            <span class="label" style="font-weight:800;">@(Ui.IsArabic ? "الإجمالي" : "Total")</span>
            <span class="value" style="color:var(--ac-primary); font-size:1.2rem;">@Bag.Subtotal.ToString("N0") ر.س</span>
        </div>
    </div>

    <div style="padding: 4px 16px 30px;">
        <button class="btn btn-primary btn-block" @onclick="GoCheckout">
            <i class="bi bi-bag-check"></i>
            @(Ui.IsArabic ? "متابعة للطلب" : "Continue to checkout")
        </button>
        <button class="btn btn-ghost btn-block" style="margin-top:8px;" @onclick="@(() => Bag.Clear())">
            <i class="bi bi-trash"></i> @(Ui.IsArabic ? "إفراغ السلة" : "Clear cart")
        </button>
    </div>
}

<style>
    .vendor-row { display:flex; align-items:center; gap:12px; }
    .vendor-emoji {
        width: 48px; height: 48px;
        background: var(--ord-hero-grad);
        color: #fff;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
    }
    .cart-item { display: flex; align-items: center; gap: 12px; }
    .ci-emoji {
        width: 56px; height: 56px;
        background: var(--ac-bg-alt);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.9rem;
        flex-shrink: 0;
    }
    .ci-body { flex: 1; min-width: 0; }
    .ci-title { font-weight: 700; }
    .ci-price { color: var(--ac-primary); font-weight: 800; font-size: 0.9rem; }
    .ci-qty { display: flex; align-items: center; gap: 8px; }
    .qbtn {
        width: 30px; height: 30px;
        border-radius: 8px;
        border: 1px solid var(--ac-border);
        background: var(--ac-surface);
        color: var(--ac-text);
        cursor: pointer;
        font-size: 1.1rem;
        font-weight: 700;
    }
    .qbtn:hover { border-color: var(--ac-primary); color: var(--ac-primary); }
    .qval { min-width: 22px; text-align: center; font-weight: 700; }
</style>

@code {
    protected override void OnInitialized() => Bag.OnChanged += OnChanged;
    private void OnChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Bag.OnChanged -= OnChanged;

    private void GoCheckout()
    {
        if (!Auth.IsAuthenticated)
        {
            Nav.NavigateTo("/login?return=/checkout");
            return;
        }
        Nav.NavigateTo("/checkout");
    }
}
