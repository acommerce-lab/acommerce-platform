@page "/order/{Id:guid}"
@inject OrderApiClient Api
@inject AuthStateService Auth
@inject UiPreferences Ui
@inject NavigationManager Nav

<PageTitle>تفاصيل الطلب - اوردر</PageTitle>

@if (JustCreated)
{
    <div class="page-hero" style="text-align:center; padding-top:30px;">
        <div style="font-size:3rem;">✅</div>
        <h1>@(Ui.IsArabic ? "تم استلام طلبك" : "Order received")</h1>
        <p>@(Ui.IsArabic ? "سيؤكد المتجر طلبك قريباً جداً" : "The store will confirm shortly")</p>
    </div>
}
else
{
    <h1 class="page-title">@(Ui.IsArabic ? "تفاصيل الطلب" : "Order details")</h1>
}

@if (Loading)
{
    <div class="empty-state"><div class="ico">⏳</div><p>@(Ui.IsArabic ? "جاري التحميل..." : "Loading...")</p></div>
}
else if (Order == null)
{
    <div class="empty-state">
        <div class="ico">⚠️</div>
        <h3>@(Ui.IsArabic ? "الطلب غير موجود" : "Order not found")</h3>
        <a class="btn btn-primary" href="/orders">@(Ui.IsArabic ? "كل الطلبات" : "All orders")</a>
    </div>
}
else
{
    <div class="s-card">
        <div class="s-card-row">
            <span class="label">@(Ui.IsArabic ? "رقم الطلب" : "Order #")</span>
            <span class="value" dir="ltr">@Order.OrderNumber</span>
        </div>
        <div class="s-card-row">
            <span class="label">@(Ui.IsArabic ? "المتجر" : "Store")</span>
            <span class="value">@(Order.Vendor?.LogoEmoji ?? "🏪") @(Order.Vendor?.Name ?? "")</span>
        </div>
        <div class="s-card-row">
            <span class="label">@(Ui.IsArabic ? "الحالة" : "Status")</span>
            <span class="@StatusClass(Order.Status)">@Order.StatusAr</span>
        </div>
        <div class="s-card-row" style="border-bottom:0;">
            <span class="label">@(Ui.IsArabic ? "تاريخ الإنشاء" : "Created")</span>
            <span class="value" dir="ltr">@Order.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span>
        </div>
    </div>

    <div class="s-card">
        <h3>@(Ui.IsArabic ? "العناصر" : "Items")</h3>
        @foreach (var i in Order.Items)
        {
            <div class="s-card-row">
                <span><span style="font-size:1.2rem;">@i.Emoji</span> @i.OfferTitle <span style="color:var(--ac-text-muted);">×@i.Quantity</span></span>
                <span class="value">@i.LineTotal.ToString("N0") ر.س</span>
            </div>
        }
        <div class="s-card-row" style="border-bottom:0;">
            <span class="label" style="font-weight:800;">@(Ui.IsArabic ? "الإجمالي" : "Total")</span>
            <span class="value" style="color:var(--ac-primary); font-size:1.2rem;">@Order.Total.ToString("N0") ر.س</span>
        </div>
    </div>

    <div class="s-card">
        <h3>@(Ui.IsArabic ? "الاستلام" : "Pickup")</h3>
        <div class="s-card-row">
            <span class="label">@(Ui.IsArabic ? "النوع" : "Type")</span>
            <span class="value">
                <i class="bi bi-@(Order.PickupType == 1 ? "car-front" : "shop")"></i>
                @(Order.PickupType == 1 ? (Ui.IsArabic ? "من السيارة" : "Curbside") : (Ui.IsArabic ? "من المتجر" : "In-store"))
            </span>
        </div>
        @if (Order.PickupType == 1)
        {
            <div class="s-card-row">
                <span class="label">@(Ui.IsArabic ? "السيارة" : "Car")</span>
                <span class="value">@Order.CarColor @Order.CarModel</span>
            </div>
            @if (!string.IsNullOrEmpty(Order.CarPlate))
            {
                <div class="s-card-row" style="border-bottom:0;">
                    <span class="label">@(Ui.IsArabic ? "اللوحة" : "Plate")</span>
                    <span class="value" dir="ltr">@Order.CarPlate</span>
                </div>
            }
        }
    </div>

    <div class="s-card">
        <h3>@(Ui.IsArabic ? "الدفع (في المتجر)" : "Payment (at pickup)")</h3>
        <div class="s-card-row">
            <span class="label">@(Ui.IsArabic ? "الطريقة" : "Method")</span>
            <span class="value">
                <i class="bi bi-@(Order.PreferredPayment == 1 ? "credit-card" : "cash-coin")"></i>
                @(Order.PreferredPayment == 1 ? (Ui.IsArabic ? "بطاقة" : "Card") : (Ui.IsArabic ? "نقدي" : "Cash"))
            </span>
        </div>
        @if (Order.PreferredPayment == 0 && Order.CashTendered.HasValue)
        {
            <div class="s-card-row">
                <span class="label">@(Ui.IsArabic ? "المبلغ المتوقع" : "Cash tendered")</span>
                <span class="value">@Order.CashTendered.Value.ToString("N0") ر.س</span>
            </div>
            @if (Order.ExpectedChange.HasValue && Order.ExpectedChange > 0)
            {
                <div class="s-card-row" style="border-bottom:0;">
                    <span class="label" style="font-weight:800;">@(Ui.IsArabic ? "الباقي المتوقع" : "Expected change")</span>
                    <span class="value" style="color:var(--ac-success); font-size:1.1rem;">
                        @Order.ExpectedChange.Value.ToString("N2") ر.س
                    </span>
                </div>
            }
        }
    </div>

    @if (!string.IsNullOrEmpty(Order.CustomerNotes))
    {
        <div class="s-card">
            <h3>@(Ui.IsArabic ? "ملاحظاتك" : "Notes")</h3>
            <p style="margin:0; color:var(--ac-text-muted);">@Order.CustomerNotes</p>
        </div>
    }

    <div style="padding: 4px 16px 30px;">
        @if (Order.Status == 0 || Order.Status == 1)
        {
            <button class="btn btn-outline-danger btn-block" @onclick="Cancel">
                <i class="bi bi-x-circle"></i> @(Ui.IsArabic ? "إلغاء الطلب" : "Cancel order")
            </button>
        }
        <a class="btn btn-primary btn-block" href="/orders" style="margin-top:10px;">
            <i class="bi bi-list"></i> @(Ui.IsArabic ? "كل طلباتي" : "All orders")
        </a>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }
    [SupplyParameterFromQuery(Name = "just")] public string? Just { get; set; }
    private OrderDto? Order;
    private bool Loading = true;
    private bool JustCreated => Just == "1";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Auth.EnsureRestoredAsync();
        var env = await Api.GetAsync<OrderDto>($"/api/orders/{Id}");
        Order = env.Data;
        Loading = false;
        StateHasChanged();
    }

    private async Task Cancel()
    {
        var env = await Api.PostAsync<object>($"/api/orders/{Id}/cancel", new { });
        if (env.Operation.Status == "Success")
        {
            var refresh = await Api.GetAsync<OrderDto>($"/api/orders/{Id}");
            Order = refresh.Data;
        }
    }

    private string StatusClass(int s) => s switch
    {
        0 => "st-pending", 1 => "st-accepted", 2 => "st-ready",
        3 => "st-delivered", 4 => "st-cancelled", _ => "st-pending"
    };

    public class OrderDto
    {
        public Guid Id { get; set; }
        public string OrderNumber { get; set; } = "";
        public decimal Total { get; set; }
        public decimal Subtotal { get; set; }
        public string Currency { get; set; } = "SAR";
        public int Status { get; set; }
        public string StatusAr { get; set; } = "";
        public int PickupType { get; set; }
        public int PreferredPayment { get; set; }
        public decimal? CashTendered { get; set; }
        public decimal? ExpectedChange { get; set; }
        public string? CarModel { get; set; }
        public string? CarColor { get; set; }
        public string? CarPlate { get; set; }
        public string? CustomerNotes { get; set; }
        public DateTime CreatedAt { get; set; }
        public VendorDto? Vendor { get; set; }
        public List<ItemDto> Items { get; set; } = new();
    }

    public class VendorDto
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public string Phone { get; set; } = "";
        public string LogoEmoji { get; set; } = "🏪";
    }

    public class ItemDto
    {
        public Guid Id { get; set; }
        public string OfferTitle { get; set; } = "";
        public string Emoji { get; set; } = "🍽️";
        public int Quantity { get; set; }
        public decimal UnitPrice { get; set; }
        public decimal LineTotal { get; set; }
    }
}
