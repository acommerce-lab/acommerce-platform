@page "/checkout"
@inject CartService Cart
@inject AuthStateService Auth
@inject OrderApiClient Api
@inject UiPreferences Ui
@inject NavigationManager Nav

<PageTitle>إكمال الطلب - اوردر</PageTitle>

<h1 class="page-title">@(Ui.IsArabic ? "إكمال الطلب" : "Place order")</h1>

@if (!Auth.IsAuthenticated)
{
    <div class="empty-state">
        <div class="ico">🔒</div>
        <h3>@(Ui.IsArabic ? "يجب تسجيل الدخول أولاً" : "Sign in first")</h3>
        <a class="btn btn-primary" href="/login?return=/checkout">@(Ui.IsArabic ? "تسجيل الدخول" : "Sign in")</a>
    </div>
}
else if (Cart.Items.Count == 0)
{
    <div class="empty-state">
        <div class="ico">🛒</div>
        <h3>@(Ui.IsArabic ? "السلة فارغة" : "Cart is empty")</h3>
        <a class="btn btn-primary" href="/">@(Ui.IsArabic ? "تصفّح العروض" : "Browse offers")</a>
    </div>
}
else
{
    <div class="s-card">
        <h3>@(Ui.IsArabic ? "ملخص الطلب" : "Order summary")</h3>
        @foreach (var item in Cart.Items)
        {
            <div class="s-card-row">
                <span><span style="font-size:1.2rem;">@item.Emoji</span> @item.Title <span style="color:var(--ac-text-muted);">×@item.Quantity</span></span>
                <span class="value">@item.LineTotal.ToString("N0") ر.س</span>
            </div>
        }
        <div class="s-card-row" style="border-bottom:0;">
            <span class="label" style="font-weight:800;">@(Ui.IsArabic ? "الإجمالي" : "Total")</span>
            <span class="value" style="color:var(--ac-primary); font-size:1.2rem;">@Cart.Subtotal.ToString("N0") ر.س</span>
        </div>
    </div>

    <div class="s-card">
        <h3>@(Ui.IsArabic ? "طريقة الاستلام" : "Pickup method")</h3>
        <div class="seg">
            <button class="seg-btn @(PickupType == "InStore" ? "active" : "")" @onclick="@(() => PickupType = "InStore")">
                <i class="bi bi-shop"></i>
                <span>@(Ui.IsArabic ? "من المتجر" : "In-store")</span>
            </button>
            <button class="seg-btn @(PickupType == "Curbside" ? "active" : "")" @onclick="@(() => PickupType = "Curbside")">
                <i class="bi bi-car-front"></i>
                <span>@(Ui.IsArabic ? "من السيارة" : "Curbside")</span>
            </button>
        </div>
    </div>

    @if (PickupType == "Curbside")
    {
        <div class="s-card">
            <h3>@(Ui.IsArabic ? "بيانات السيارة" : "Car details")</h3>
            <div class="form-group">
                <label class="form-label">@(Ui.IsArabic ? "نوع السيارة" : "Model")</label>
                <input class="form-input" placeholder="@(Ui.IsArabic ? "مثال: تويوتا كامري" : "e.g. Toyota Camry")" @bind="CarModel" />
            </div>
            <div class="form-group">
                <label class="form-label">@(Ui.IsArabic ? "اللون" : "Color")</label>
                <input class="form-input" placeholder="@(Ui.IsArabic ? "أبيض" : "White")" @bind="CarColor" />
            </div>
            <div class="form-group">
                <label class="form-label">@(Ui.IsArabic ? "رقم اللوحة (اختياري)" : "Plate number (optional)")</label>
                <input class="form-input" placeholder="أ ب ج 1234" @bind="CarPlate" />
            </div>
        </div>
    }

    <div class="s-card">
        <h3>@(Ui.IsArabic ? "طريقة الدفع المفضلة" : "Preferred payment")</h3>
        <p style="margin:0 0 10px; font-size:0.78rem; color:var(--ac-text-muted);">
            @(Ui.IsArabic ? "الدفع يتم عند الاستلام في المتجر — لا دفع إلكتروني." : "Payment happens at pickup — no online payment.")
        </p>
        <div class="seg">
            <button class="seg-btn @(Payment == "Cash" ? "active" : "")" @onclick="@(() => Payment = "Cash")">
                <i class="bi bi-cash-coin"></i>
                <span>@(Ui.IsArabic ? "نقدي" : "Cash")</span>
            </button>
            <button class="seg-btn @(Payment == "Card" ? "active" : "")" @onclick="@(() => Payment = "Card")">
                <i class="bi bi-credit-card"></i>
                <span>@(Ui.IsArabic ? "بطاقة" : "Card")</span>
            </button>
        </div>
    </div>

    @if (Payment == "Cash")
    {
        <div class="s-card">
            <h3>@(Ui.IsArabic ? "المبلغ المتوقع تقديمه" : "Expected cash tendered")</h3>
            <p style="margin:0 0 10px; font-size:0.78rem; color:var(--ac-text-muted);">
                @(Ui.IsArabic ? "نحسب لك الباقي مسبقاً ليكون معك جاهزاً." : "We pre-compute your change so the cashier is ready.")
            </p>
            <div class="form-group">
                <label class="form-label">@(Ui.IsArabic ? "المبلغ بالريال" : "Amount (SAR)")</label>
                <input class="form-input" type="number" min="0" step="1" @bind="CashTendered" placeholder="50" />
            </div>
            @if (CashTendered.HasValue && CashTendered.Value >= Cart.Subtotal)
            {
                <div class="change-box">
                    <span>@(Ui.IsArabic ? "الباقي المتوقع" : "Expected change")</span>
                    <strong>@((CashTendered.Value - Cart.Subtotal).ToString("N2")) ر.س</strong>
                </div>
            }
            else if (CashTendered.HasValue)
            {
                <div class="change-box warn">
                    <span>@(Ui.IsArabic ? "المبلغ غير كافٍ — يجب أن يساوي أو يتجاوز الإجمالي" : "Amount must cover the total")</span>
                </div>
            }
        </div>
    }

    <div class="s-card">
        <h3>@(Ui.IsArabic ? "ملاحظات للتاجر (اختياري)" : "Notes (optional)")</h3>
        <textarea class="form-input" rows="3" @bind="Notes"
                  placeholder="@(Ui.IsArabic ? "بدون سكر، إضافة كريمة..." : "No sugar, extra cream...")"></textarea>
    </div>

    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="alert alert-danger" style="margin: 0 16px 12px;">@Error</div>
    }

    <div style="padding: 4px 16px 30px;">
        <button class="btn btn-primary btn-block" @onclick="Submit" disabled="@Submitting">
            @if (Submitting)
            {
                <i class="bi bi-arrow-clockwise"></i><span>@(Ui.IsArabic ? "جاري الإرسال..." : "Sending...")</span>
            }
            else
            {
                <i class="bi bi-check-circle"></i><span>@(Ui.IsArabic ? "تأكيد الطلب" : "Confirm order")</span>
            }
        </button>
    </div>
}

<style>
    .seg {
        display: flex;
        background: var(--ac-bg-alt);
        border-radius: 12px;
        padding: 4px;
        gap: 4px;
    }
    .seg-btn {
        flex: 1;
        padding: 12px;
        border: 0;
        background: transparent;
        color: var(--ac-text-muted);
        font-weight: 700;
        font-size: 0.9rem;
        border-radius: 9px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        transition: all 150ms;
    }
    .seg-btn i { font-size: 1.1rem; }
    .seg-btn.active {
        background: var(--ac-surface);
        color: var(--ac-primary);
        box-shadow: 0 2px 6px rgba(0,0,0,0.06);
    }
    .change-box {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
        color: #1B5E20;
        padding: 12px 14px;
        border-radius: 12px;
        font-weight: 700;
    }
    .change-box.warn {
        background: linear-gradient(135deg, #FFEBEE, #FFCDD2);
        color: #B71C1C;
    }
    html[data-theme="dark"] .change-box {
        background: #1B3A22;
        color: #A5D6A7;
    }
    html[data-theme="dark"] .change-box.warn {
        background: #4A1418;
        color: #EF9A9A;
    }
</style>

@code {
    private string PickupType = "InStore";
    private string Payment = "Cash";
    private string CarModel = "";
    private string CarColor = "";
    private string CarPlate = "";
    private decimal? CashTendered;
    private string Notes = "";
    private string Error = "";
    private bool Submitting;

    protected override void OnInitialized()
    {
        if (Cart.Subtotal > 0)
        {
            // Pre-fill a sensible cash amount (next 10s)
            CashTendered = Math.Ceiling(Cart.Subtotal / 10) * 10;
        }
    }

    private async Task Submit()
    {
        Error = "";
        if (!Auth.IsAuthenticated || Cart.Items.Count == 0) return;
        if (PickupType == "Curbside" && string.IsNullOrWhiteSpace(CarModel))
        {
            Error = Ui.IsArabic ? "أدخل بيانات السيارة" : "Please enter car details";
            return;
        }
        if (Payment == "Cash" && CashTendered.HasValue && CashTendered.Value < Cart.Subtotal)
        {
            Error = Ui.IsArabic ? "المبلغ المقدّم يجب أن يغطي الإجمالي" : "Cash amount must cover the total";
            return;
        }
        Submitting = true;
        try
        {
            var payload = new
            {
                customerId = Auth.UserId,
                items = Cart.Items.Select(i => new { offerId = i.OfferId, quantity = i.Quantity }),
                pickupType = PickupType == "Curbside" ? 1 : 0,
                preferredPayment = Payment == "Card" ? 1 : 0,
                cashTendered = Payment == "Cash" ? CashTendered : null,
                carModel = PickupType == "Curbside" ? CarModel : null,
                carColor = PickupType == "Curbside" ? CarColor : null,
                carPlate = PickupType == "Curbside" ? CarPlate : null,
                customerNotes = string.IsNullOrWhiteSpace(Notes) ? null : Notes
            };
            var env = await Api.PostAsync<CreatedOrderDto>("/api/orders", payload);
            if (env.Operation.Status != "Success" || env.Data == null)
            {
                Error = env.Operation.ErrorMessage ?? env.Error?.Message ?? (Ui.IsArabic ? "تعذّر إنشاء الطلب" : "Could not create order");
                return;
            }
            var orderId = env.Data.Id;
            Cart.Clear();
            Nav.NavigateTo($"/order/{orderId}?just=1");
        }
        finally { Submitting = false; }
    }

    public class CreatedOrderDto
    {
        public Guid Id { get; set; }
        public string OrderNumber { get; set; } = "";
    }
}
