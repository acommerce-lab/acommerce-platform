@page "/bookings"
@inject ApiReader Api
@inject NavigationManager Nav
@inject L L

<PageTitle>@(L["nav.bookings"]) - @(L["app.name"])</PageTitle>

<div class="acs-page acs-bookings-page">
    <h1 class="acm-wizard-title">@(L["nav.bookings"])</h1>

    <div class="acs-filter-chips">
        <AcFilterChip Label="الكلّ" Active="@(_filter == "")" OnClick="@(() => SetFilter(""))" />
        <AcFilterChip Label="قيد المراجعة" Active="@(_filter == "pending")" OnClick="@(() => SetFilter("pending"))" />
        <AcFilterChip Label="مؤكَّدة" Active="@(_filter == "confirmed")" OnClick="@(() => SetFilter("confirmed"))" />
        <AcFilterChip Label="منتهية" Active="@(_filter == "completed")" OnClick="@(() => SetFilter("completed"))" />
        <AcFilterChip Label="ملغاة" Active="@(_filter == "cancelled")" OnClick="@(() => SetFilter("cancelled"))" />
    </div>

    @if (_loading) { <AcLoadingState /> }
    else
    {
        var list = string.IsNullOrEmpty(_filter) ? _items : _items.Where(b => b.Status == _filter).ToList();
        @if (list.Count == 0) { <AcEmptyState IconName="receipt" Message="لا توجد حجوزات" /> }
        else
        {
            <div class="acm-home-grid" style="margin-top:12px;">
                @foreach (var b in list)
                {
                    var bid = b.Id;
                    <AcCard Hover="true">
                        <ChildContent>
                            <button type="button" class="acm-complaint-btn" @onclick="@(() => Open(bid))">
                                <strong>@b.ListingTitle</strong>
                                <div class="acm-complaint-body">من @b.StartDate.ToString("yyyy-MM-dd") — @b.Nights ليلة — @b.Guests أشخاص</div>
                                <div style="display:flex; gap:8px; align-items:center; justify-content:space-between;">
                                    <AcBadge Variant="@BadgeVariant(b.Status)" Text="@StatusLabel(b.Status)" />
                                    <strong>@b.Total SAR</strong>
                                </div>
                            </button>
                        </ChildContent>
                    </AcCard>
                }
            </div>
        }
    }
</div>

@code {
    private List<BookingDto> _items = new();
    private bool _loading = true;
    private string _filter = "";

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (!first) return;
        var env = await Api.GetAsync<List<BookingDto>>("/bookings");
        _items = env.Data ?? new();
        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private void SetFilter(string s) { _filter = s; StateHasChanged(); }
    private void Open(string id) => Nav.NavigateTo($"/booking/{id}");

    private static string StatusLabel(string s) => s switch
    {
        "pending"   => "قيد المراجعة",
        "confirmed" => "مؤكَّد",
        "completed" => "منتهٍ",
        "cancelled" => "ملغى",
        _           => s
    };

    private static string BadgeVariant(string s) => s switch
    {
        "confirmed" => "success",
        "pending"   => "warning",
        "cancelled" => "danger",
        "completed" => "secondary",
        _           => "secondary"
    };

    private sealed record BookingDto(string Id, string ListingId, string ListingTitle,
        decimal Total, DateTime StartDate, int Nights, int Guests, string Status);
}
