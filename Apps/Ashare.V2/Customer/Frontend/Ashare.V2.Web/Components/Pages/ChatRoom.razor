@page "/chat/{Id}"
@inject ApiReader Api
@inject NavigationManager Nav
@inject ITimezoneProvider Tz
@inject IHttpClientFactory Http

<PageTitle>محادثة - عشير</PageTitle>

<div class="acs-page acs-chat-page">
    @if (_conv is null) { <AcLoadingState /> }
    else
    {
        <div style="display:flex; justify-content:space-between; align-items:center;">
            <div>
                <h1 class="acm-wizard-title" style="margin-bottom:4px;">@_conv.PartnerName</h1>
                <small style="color:var(--ac-text-muted);">@_conv.Subject</small>
            </div>
            <AcButton Variant="ghost" Text="رجوع" OnClick="@GoBack" />
        </div>

        <div class="acs-chat-messages">
            @foreach (var m in _conv.Messages)
            {
                var mine = m.From == "me";
                <div class="acs-bubble @(mine ? "acs-bubble-mine" : "acs-bubble-other")">
                    @if (m.Attachment is not null)
                    {
                        <div class="acs-chat-attach">
                            <AcIcon Name="file" Size="14" />
                            <span>@m.Attachment</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(m.Text))
                    {
                        <div>@m.Text</div>
                    }
                    <small style="display:block; opacity:.6;">@Tz.FormatTime(m.SentAt)</small>
                </div>
            }
            @if (_partnerTyping)
            {
                <div class="acs-bubble acs-bubble-other acs-typing">
                    <span></span><span></span><span></span>
                </div>
            }
        </div>

        <div class="acs-chat-composer">
            <label class="acs-chat-attach-btn" title="إرفاق ملفّ">
                <AcIcon Name="paperclip" Size="16" />
                <InputFile OnChange="OnAttach" style="display:none;" />
            </label>
            @if (!string.IsNullOrEmpty(_pendingAttach))
            {
                <span class="acs-chat-attach-preview">@_pendingAttach <button @onclick="@(() => _pendingAttach = null)">×</button></span>
            }
            <AcInput Value="@_draft" ValueChanged="@(v => _draft = v ?? string.Empty)"
                     Placeholder="اكتب رسالة…" />
            <AcButton Variant="primary" Text="إرسال" OnClick="@Send"
                      Disabled="@(_sending || (string.IsNullOrWhiteSpace(_draft) && string.IsNullOrEmpty(_pendingAttach)))" />
        </div>
    }
</div>

@code {
    [Parameter] public string Id { get; set; } = "";
    private Payload? _conv;
    private string _draft = "";
    private string? _pendingAttach;
    private bool _partnerTyping;
    private bool _sending;

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (!first) return;
        await Tz.InitAsync();
        await Reload();
    }

    private async Task Reload()
    {
        var env = await Api.GetAsync<Payload>($"/conversations/{Id}");
        _conv = env.Data;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnAttach(InputFileChangeEventArgs e)
    {
        if (e.File is null) return;
        _pendingAttach = e.File.Name;
        await InvokeAsync(StateHasChanged);
    }

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(_draft) && string.IsNullOrEmpty(_pendingAttach)) return;
        if (_conv is null) return;
        _sending = true;
        try
        {
            var client = Http.CreateClient("api");
            var resp = await client.PostAsJsonAsync($"/conversations/{Id}/messages", new {
                Text = _draft,
                Attachment = _pendingAttach
            });
            if (resp.IsSuccessStatusCode)
            {
                _draft = "";
                _pendingAttach = null;
                await Reload();
                _ = SimulatePartnerReply();   // اختياريّ: محاكاة ردّ تلقائيّ
            }
        }
        finally { _sending = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task SimulatePartnerReply()
    {
        _partnerTyping = true;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(1800);
        _partnerTyping = false;
        await InvokeAsync(StateHasChanged);
    }

    private void GoBack() => Nav.NavigateTo("/chats");

    private sealed record Payload(string Id, string PartnerName, string Subject,
        string? PartnerId, string? ListingId, List<MessageDto> Messages);
    private sealed record MessageDto(string Id, string From, string Text, DateTime SentAt,
        string? Attachment = null);
}
