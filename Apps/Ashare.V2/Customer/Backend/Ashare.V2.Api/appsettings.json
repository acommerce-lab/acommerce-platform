{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "HostSettings": {
    "BaseUrl": "https://api.ashare.sa",
    "WebBaseUrl": "https://ashare.app"
  },

  "JWT": {
    "Issuer": "https://ashare.app",
    "Audience": "ashare-api",
    "AccessTokenLifetime": "30.00:00:00"
  },

  "Authentication": {
    "TwoFactor": {
      "Nafath": {
        "BaseUrl": "https://api.authentica.sa/api/v2/",
        "Mode": "Live",
        "SessionExpirationMinutes": 5
      }
    }
  },

  "Payments": {
    "Noon": {
      "ApplicationIdentifier": "newAshier",
      "BusinessIdentifier": "ashier",
      "Region": "SA",
      "TimeoutSeconds": 60
    }
  },

  "Files": {
    "Storage": {
      "AliyunOSS": {
        "Endpoint": "oss-me-central-1.aliyuncs.com",
        "Region": "me-central-1",
        "BucketName": "ashare-media",
        "UseHttps": true,
        "UseV4Signature": true,
        "UseDirectoryStructure": true,
        "DirectoryFormat": "yyyy/MM/dd"
      },
      "Local": {
        "BasePath": "wwwroot/uploads",
        "BaseUrl": "/uploads"
      }
    }
  },

  "Notifications": {
    "Firebase": {
      "ProjectId": "ashir-f4bfd",
      "DefaultChannelId": "ashare_notifications",
      "DefaultSound": "default",
      "DefaultPriority": "High",
      "EnableBadge": true
    }
  },

  "Cors": {
    "AllowedOrigins": [
      "https://ashare.app",
      "https://www.ashare.app"
    ]
  }
}
