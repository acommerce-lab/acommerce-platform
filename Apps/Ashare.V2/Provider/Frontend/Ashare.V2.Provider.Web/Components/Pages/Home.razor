@page "/"
@rendermode InteractiveServer
@inject AppStore Store
@inject ApiReader Api
@inject NavigationManager Nav
@inject L L
@implements IDisposable

<PageTitle>@L.T("لوحة التحكم","Dashboard") — @L.T("عشير V2 للمُلاّك", "Ashare V2 for Owners")</PageTitle>

@if (!Store.Auth.IsAuthenticated)
{
    <AcAuthGuard IsAuthenticated="false" LoginHref="/login" />
}
else
{
    <AcOwnerDashboard Stats="@_stats"
                      RecentBookings="@_recentBookings"
                      LoadingBookings="@_loading"
                      Title="@($"{L.T("مرحباً","Welcome")} {Store.Auth.FullName ?? ""}")"
                      BookingsTitle="@L.T("آخر الحجوزات","Recent bookings")"
                      OnBookingClick="@(_ => Nav.NavigateTo("/owner-bookings"))">
        <QuickActions>
            <a href="/my-listings" style="display:block;margin-top:8px">
                <AcButton Variant="primary" Block="true" Text="@L.T("عرض إعلاناتي", "Show my listings")" />
            </a>
        </QuickActions>
    </AcOwnerDashboard>
}

@code {
    private bool _loading = true;
    private List<OwnerStatDto> _stats = new();
    private List<BookingRowDto> _recentBookings = new();
    private List<ListingApiRow>? _rawListings;
    private List<BookingApiRow>? _rawBookings;

    protected override void OnInitialized() => Store.OnChanged += Refresh;
    private void Refresh() { Rebuild(); InvokeAsync(StateHasChanged); }
    public void Dispose() => Store.OnChanged -= Refresh;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !Store.Auth.IsAuthenticated) { _loading = false; StateHasChanged(); return; }

        var listingsEnv = await Api.GetAsync<List<ListingApiRow>>("/my-listings");
        _rawListings = listingsEnv.Data ?? new();

        var bookingsEnv = await Api.GetAsync<List<BookingApiRow>>("/bookings");
        _rawBookings = bookingsEnv.Data ?? new();

        Rebuild();
        _loading = false;
        StateHasChanged();
    }

    private void Rebuild()
    {
        if (_rawListings is null || _rawBookings is null) return;

        _stats = new List<OwnerStatDto>
        {
            new() { Label = L.T("إعلاناتي", "My listings"),   Value = _rawListings.Count.ToString(),                                IconName = "home"   },
            new() { Label = L.T("حجوزات معلقة", "Pending bookings"), Value = _rawBookings.Count(b => b.Status == 0).ToString(),     IconName = "clock"  },
            new() { Label = L.T("منشورة", "Published"),       Value = _rawListings.Count(l => l.IsActive).ToString(),               IconName = "check"  },
            new() { Label = L.T("مشاهدات", "Views"),          Value = _rawListings.Sum(l => l.ViewCount).ToString(),                IconName = "search" },
        };

        _recentBookings = _rawBookings
            .OrderByDescending(b => b.StartDate)
            .Take(5)
            .Select(b => new BookingRowDto
            {
                Id         = b.Id,
                TotalPrice = b.TotalPrice,
                Currency   = b.Currency,
                StartDate  = b.StartDate,
                EndDate    = b.EndDate,
                Status     = b.Status,
            })
            .ToList();
    }

    private record ListingApiRow(string Id, bool IsActive, int ViewCount, decimal Price);
    private record BookingApiRow(string Id, decimal TotalPrice, string Currency,
                                  DateTime StartDate, DateTime EndDate, int Status);
}
