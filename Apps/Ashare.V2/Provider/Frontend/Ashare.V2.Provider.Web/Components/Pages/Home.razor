@page "/"
@rendermode InteractiveServer
@inject AppStore Store
@inject ApiReader Api
@inject NavigationManager Nav

<PageTitle>@Store.Ui.Tr("لوحة التحكم","Dashboard") — عشير V2 للمُلاّك</PageTitle>

@if (!Store.Auth.IsAuthenticated)
{
    <AcAuthGuard IsAuthenticated="false" LoginHref="/login" />
}
else
{
    <AcOwnerDashboard Stats="@_stats"
                      RecentBookings="@_recentBookings"
                      LoadingBookings="@_loading"
                      Title="@($"مرحباً {Store.Auth.FullName ?? ""}")"
                      BookingsTitle="@Store.Ui.Tr("آخر الحجوزات","Recent Bookings")"
                      OnBookingClick="@(_ => Nav.NavigateTo("/owner-bookings"))">
        <QuickActions>
            <a href="/my-listings" style="display:block;margin-top:8px">
                <AcButton Variant="primary" Block="true" Text="عرض إعلاناتي" />
            </a>
        </QuickActions>
    </AcOwnerDashboard>
}

@code {
    private bool _loading = true;
    private List<OwnerStatDto> _stats = new();
    private List<BookingRowDto> _recentBookings = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !Store.Auth.IsAuthenticated) { _loading = false; StateHasChanged(); return; }

        var listingsEnv = await Api.GetAsync<List<ListingApiRow>>("/my-listings");
        var listings    = listingsEnv.Data ?? new();

        var bookingsEnv = await Api.GetAsync<List<BookingApiRow>>("/bookings");
        var bookings    = bookingsEnv.Data ?? new();

        _stats = new List<OwnerStatDto>
        {
            new() { Label = "إعلاناتي",    Value = listings.Count.ToString(),                     IconName = "home"   },
            new() { Label = "حجوزات معلقة", Value = bookings.Count(b => b.Status == 0).ToString(), IconName = "clock"  },
            new() { Label = "منشورة",       Value = listings.Count(l => l.IsActive).ToString(),    IconName = "check"  },
            new() { Label = "مشاهدات",      Value = listings.Sum(l => l.ViewCount).ToString(),     IconName = "search" },
        };

        _recentBookings = bookings
            .OrderByDescending(b => b.StartDate)
            .Take(5)
            .Select(b => new BookingRowDto
            {
                Id         = b.Id,
                TotalPrice = b.TotalPrice,
                Currency   = b.Currency,
                StartDate  = b.StartDate,
                EndDate    = b.EndDate,
                Status     = b.Status,
            })
            .ToList();

        _loading = false;
        StateHasChanged();
    }

    private record ListingApiRow(string Id, bool IsActive, int ViewCount, decimal Price);
    private record BookingApiRow(string Id, decimal TotalPrice, string Currency,
                                  DateTime StartDate, DateTime EndDate, int Status);
}
