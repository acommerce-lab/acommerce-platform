@inherits LayoutComponentBase
@inject AppStore Store
@inject AppStateApplier Applier
@inject AuthStateService AuthState
@implements IAsyncDisposable

<AcShell Brand="🏠 عشير V2 للمُلاّك" FooterText="عشير V2 — بوابة ملاك العقارات">
    <Links>
        @if (Store.Auth.IsAuthenticated)
        {
            <a class="act-navbar-link" href="/">@Store.Ui.Tr("لوحة التحكم", "Dashboard")</a>
            <a class="act-navbar-link" href="/my-listings">@Store.Ui.Tr("إعلاناتي", "My Listings")</a>
            <a class="act-navbar-link" href="/owner-bookings">@Store.Ui.Tr("الحجوزات", "Bookings")</a>
            <a class="act-navbar-link" href="/plans">@Store.Ui.Tr("الباقات", "Plans")</a>
        }
    </Links>
    <RightActions>
        @if (Store.Auth.IsAuthenticated)
        {
            <span class="ac-text-muted">@Store.Auth.FullName</span>
            <AcButton Variant="ghost" Size="sm"
                      Text="@Store.Ui.Tr("خروج","Sign out")"
                      OnClick="SignOutAsync" />
        }
        else
        {
            <a href="/login"><AcButton Variant="primary" Size="sm" Text="@Store.Ui.Tr("دخول","Sign in")" /></a>
        }
    </RightActions>
    <ChildContent>
        @Body
    </ChildContent>
</AcShell>

@code {
    protected override void OnInitialized() => Store.OnChanged += OnChange;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await AuthState.EnsureRestoredAsync();
        StateHasChanged();
    }

    private void OnChange() => InvokeAsync(StateHasChanged);

    private async Task SignOutAsync()
    {
        await Applier.ApplyLocalAsync(ProviderV2Ops.SignOut());
        await AuthState.ClearAsync();
    }

    public async ValueTask DisposeAsync()
    {
        Store.OnChanged -= OnChange;
        await Task.CompletedTask;
    }
}
