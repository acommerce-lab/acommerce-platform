@inherits LayoutComponentBase
@inject AuthStateService Auth
@implements IDisposable

@* استخدام AcShell من مكتبة templates - الهوية تأتي من app.css :root *@
<AcShell Brand="🏠 عشير" FooterText="عشير - مبني على ACommerce OperationEngine">
    <Links>
        <a class="act-navbar-link" href="/">العروض</a>
        <a class="act-navbar-link" href="/plans">الباقات</a>
        @if (Auth.IsAuthenticated)
        {
            <a class="act-navbar-link" href="/create-listing">+ عرض جديد</a>
            <a class="act-navbar-link" href="/my-bookings">حجوزاتي</a>
            <a class="act-navbar-link" href="/messages">الرسائل</a>
            <a class="act-navbar-link" href="/notifications">🔔 إشعارات</a>
            <a class="act-navbar-link" href="/my-subscription">اشتراكي</a>
        }
    </Links>
    <RightActions>
        @if (Auth.IsAuthenticated)
        {
            <span class="ac-text-muted">@Auth.PhoneNumber</span>
            <AcButton Variant="ghost" Size="sm" Text="خروج" OnClick="SignOut" />
        }
        else
        {
            <a href="/login"><AcButton Variant="primary" Size="sm" Text="دخول" /></a>
        }
    </RightActions>
    <ChildContent>
        @Body
    </ChildContent>
</AcShell>

@code {
    protected override void OnInitialized()
    {
        Auth.OnAuthStateChanged += OnChange;
    }

    private void OnChange() => InvokeAsync(StateHasChanged);

    private void SignOut()
    {
        Auth.SignOut();
    }

    public void Dispose()
    {
        Auth.OnAuthStateChanged -= OnChange;
    }
}
