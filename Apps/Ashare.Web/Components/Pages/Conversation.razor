@page "/conversation/{id:guid}"
@rendermode InteractiveServer
@inject AshareApiClient Api
@inject AuthStateService Auth

<PageTitle>محادثة - عشير</PageTitle>

<AcChatPage Messages="@Mapped"
            MySenderId="@(Auth.UserId?.ToString() ?? "")"
            Loading="@(messages is null)"
            Sending="@sending"
            Draft="@newMessage"
            DraftChanged="@(v => newMessage = v)"
            OnSend="Send"
            Title="محادثة"
            LoadingMessage="جاري التحميل..."
            EmptyMessage="لا رسائل بعد"
            InputPlaceholder="اكتب رسالة..."
            SendLabel="إرسال" />

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger mt-2">@error</div>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private List<MessageDto>? messages;
    private string newMessage = "";
    private bool sending;
    private string error = "";

    private IReadOnlyList<ChatMessageDto> Mapped =>
        messages is null ? Array.Empty<ChatMessageDto>() :
        messages.Select(m => new ChatMessageDto
        {
            Id = m.Id.ToString(),
            Content = m.Content,
            SenderId = m.SenderId.ToString(),
            CreatedAt = m.CreatedAt
        }).ToList();

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        var resp = await Api.GetAsync<List<MessageDto>>($"/api/messages/conversations/{Id}/messages");
        messages = resp.Data ?? new();
    }

    private async Task Send()
    {
        if (string.IsNullOrEmpty(newMessage) || !Auth.UserId.HasValue) return;
        sending = true;
        error = "";
        try
        {
            var resp = await Api.PostAsync<object>("/api/messages", new
            {
                conversationId = Id,
                senderId = Auth.UserId.Value,
                content = newMessage,
                messageType = "text"
            });

            if (resp.Operation.Status != "Success")
            {
                error = resp.Operation.ErrorMessage ?? "فشل الإرسال";
                return;
            }

            newMessage = "";
            await Load();
        }
        finally { sending = false; }
    }

    public class MessageDto
    {
        public Guid Id { get; set; }
        public Guid SenderId { get; set; }
        public string Content { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }
}
