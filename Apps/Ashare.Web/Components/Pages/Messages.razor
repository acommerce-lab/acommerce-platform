@page "/messages"
@rendermode InteractiveServer
@inject AshareApiClient Api
@inject AuthStateService Auth
@inject NavigationManager Nav

<PageTitle>الرسائل</PageTitle>

<AcMessagesListPage Conversations="@Mapped"
                    Loading="@(convs is null)"
                    Title="محادثاتي"
                    LoadingMessage="جاري التحميل..."
                    EmptyTitle="لا محادثات بعد"
                    EmptyMessage="ابدأ من صفحة عرض عبر زر «راسل المالك»"
                    OnSelectConversation="@(c => Nav.NavigateTo($"/conversation/{c.Id}"))" />

@code {
    private List<ConvDto>? convs;

    private IReadOnlyList<ConversationRowDto> Mapped =>
        convs is null ? Array.Empty<ConversationRowDto>() :
        convs.Select(c => new ConversationRowDto
        {
            Id = c.Id.ToString(),
            Title = $"محادثة {c.Id.ToString("N")[..8]}",
            LastMessageSnippet = c.LastMessageSnippet ?? "لا رسائل بعد",
            LastMessageAt = c.LastMessageAt,
            Unread = 0
        }).ToList();

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.UserId.HasValue) { convs = new(); return; }
        var resp = await Api.GetAsync<List<ConvDto>>($"/api/messages/conversations/by-user/{Auth.UserId}");
        convs = resp.Data ?? new();
    }

    public class ConvDto
    {
        public Guid Id { get; set; }
        public string? LastMessageSnippet { get; set; }
        public DateTime? LastMessageAt { get; set; }
    }
}
