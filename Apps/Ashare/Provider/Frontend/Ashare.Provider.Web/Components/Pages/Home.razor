@page "/"
@rendermode InteractiveServer
@inject AppStore Store
@inject ApiReader Reader
@inject ClientOpEngine Engine
@inject NavigationManager Nav

<PageTitle>@Store.Ui.Tr("لوحة التحكم", "Dashboard") - عشير للمُلاّك</PageTitle>

@if (!Store.Auth.IsAuthenticated)
{
    <AcAuthGuard IsAuthenticated="false" LoginHref="/login" />
}
else
{
    <AcOwnerDashboard Stats="@_stats"
                      RecentBookings="@_recentBookings"
                      LoadingBookings="@_loading"
                      Title="@(Store.Ui.Tr("مرحباً", "Welcome") + " " + (Store.Auth.DisplayName ?? ""))"
                      BookingsTitle="@Store.Ui.Tr("آخر الحجوزات", "Recent Bookings")"
                      OnBookingClick="@(b => Nav.NavigateTo($"/owner-bookings"))">
        <AboveStats></AboveStats>
        <QuickActions>
            <a href="/create-listing" style="margin-top:8px;display:block;">
                <AcButton Variant="primary" Block="true"
                          Text="@($"+ {Store.Ui.Tr("إعلان جديد", "New listing")}")" />
            </a>
        </QuickActions>
    </AcOwnerDashboard>
}

@code {
    private List<OwnerStatDto> _stats = new();
    private List<BookingRowDto> _recentBookings = new();
    private bool _loading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!Store.Auth.IsAuthenticated || !Store.Auth.UserId.HasValue)
        {
            _loading = false;
            StateHasChanged();
            return;
        }

        var listingsEnv = await Reader.GetAsync<List<ListingApiRow>>($"/api/listings/by-owner/{Store.Auth.UserId}");
        var listings = listingsEnv.Data ?? new();

        var bookingsEnv = await Reader.GetAsync<List<BookingApiRow>>($"/api/bookings/by-owner/{Store.Auth.UserId}");
        var bookings = bookingsEnv.Data ?? new();

        _stats = new List<OwnerStatDto>
        {
            new() { Label = Store.Ui.Tr("إعلاناتي", "My Listings"),   Value = listings.Count.ToString(),                          IconName = "home"   },
            new() { Label = Store.Ui.Tr("حجوزات معلقة", "Pending"),   Value = bookings.Count(b => b.Status == 0).ToString(),      IconName = "clock"  },
            new() { Label = Store.Ui.Tr("منشورة", "Published"),       Value = listings.Count(l => l.Status == 1).ToString(),      IconName = "check"  },
            new() { Label = Store.Ui.Tr("مشاهدة", "Views"),           Value = listings.Sum(l => l.ViewCount).ToString(),          IconName = "search" },
        };

        _recentBookings = bookings
            .OrderByDescending(b => b.StartDate)
            .Take(5)
            .Select(b => new BookingRowDto
            {
                Id         = b.Id,
                TotalPrice = b.TotalPrice,
                Currency   = b.Currency,
                StartDate  = b.StartDate,
                EndDate    = b.EndDate,
                Status     = b.Status,
                Notes      = b.Notes,
            })
            .ToList();

        _loading = false;
        StateHasChanged();
    }

    private class ListingApiRow
    {
        public int Status    { get; set; }
        public int ViewCount { get; set; }
    }

    private class BookingApiRow
    {
        public string   Id         { get; set; } = "";
        public decimal  TotalPrice { get; set; }
        public string   Currency   { get; set; } = "SAR";
        public DateTime StartDate  { get; set; }
        public DateTime EndDate    { get; set; }
        public int      Status     { get; set; }
        public string?  Notes      { get; set; }
    }
}
