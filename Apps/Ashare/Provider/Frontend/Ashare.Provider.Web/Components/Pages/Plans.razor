@page "/plans"
@rendermode InteractiveServer
@inject ApiReader Reader
@inject AppStore Store
@inject ClientOpEngine Engine

<PageTitle>@Store.Ui.Tr("الباقات", "Plans") - عشير للمُلاّك</PageTitle>

<div style="padding:16px;">
    <h1 class="acs-page-title" style="margin-bottom:20px;">@Store.Ui.Tr("باقات الاشتراك", "Subscription Plans")</h1>

    @if (Loading)
    {
        <AcLoadingState Message="@Store.Ui.Tr("جاري التحميل...", "Loading…")" />
    }
    else if (PlanRows.Count == 0)
    {
        <AcEmptyState IconName="package" Title="@Store.Ui.Tr("لا باقات متاحة", "No plans available")" />
    }
    else
    {
        @foreach (var p in PlanRows)
        {
            <div class="s-card" style="margin-bottom:12px;">
                <div style="font-weight:700;font-size:1.1rem;">@p.Name</div>
                <div style="font-size:0.82rem;color:var(--ac-text-muted);margin:4px 0 10px;">@p.Description</div>
                <div style="font-size:1.5rem;font-weight:700;color:var(--ac-primary);">
                    @p.MonthlyPrice.ToString("0.##") SAR
                    <span style="font-size:0.8rem;font-weight:400;color:var(--ac-text-muted);">@Store.Ui.Tr("/ شهرياً", "/ month")</span>
                </div>
                @if (Store.Auth.IsAuthenticated)
                {
                    <button class="btn btn-primary btn-sm" style="margin-top:10px;"
                            @onclick="() => Subscribe(p.Id)">
                        @Store.Ui.Tr("اشترك الآن", "Subscribe now")
                    </button>
                }
                else
                {
                    <a href="/login" class="btn btn-outline-primary btn-sm" style="margin-top:10px;">
                        @Store.Ui.Tr("سجّل دخولك للاشتراك", "Sign in to subscribe")
                    </a>
                }
            </div>
        }
    }
</div>

@code {
    private bool Loading = true;
    private List<PlanRow> PlanRows = new();
    private string? Message;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var env = await Reader.GetAsync<List<PlanRow>>("/api/plans");
        PlanRows = env.Data ?? new();
        Loading = false;
        StateHasChanged();
    }

    private async Task Subscribe(Guid planId)
    {
        if (!Store.Auth.UserId.HasValue) return;
        var result = await Engine.ExecuteAsync<object>(
            ClientOps.Subscribe(Store.Auth.UserId.Value, planId),
            new { UserId = Store.Auth.UserId.Value, PlanId = planId, BillingCycle = "monthly" });
        Message = result.Operation.Status == "Success"
            ? Store.Ui.Tr("تم الاشتراك بنجاح!", "Subscribed successfully!")
            : result.Operation.ErrorMessage;
        StateHasChanged();
    }

    public class PlanRow
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public decimal MonthlyPrice { get; set; }
        public string Slug { get; set; } = "";
    }
}
