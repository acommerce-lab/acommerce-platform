@page "/plans"
@rendermode InteractiveServer
@inject ApiReader Reader
@inject AppStore Store
@inject ClientOpEngine Engine

<PageTitle>@Store.Ui.Tr("الباقات", "Plans") - عشير للمُلاّك</PageTitle>

@if (Loading)
{
    <AcLoadingState Message="@Store.Ui.Tr("جاري التحميل...", "Loading…")" />
}
else if (PlanRows.Count == 0)
{
    <AcEmptyState IconName="package" Title="@Store.Ui.Tr("لا باقات متاحة", "No plans available")" />
}
else
{
    <div class="ac-grid ac-grid-cols-3">
        @foreach (var p in PlanRows)
        {
            <AcPlanCard Name="@p.Name"
                        Description="@p.Description"
                        Price="@p.MonthlyPrice.ToString("0.##")"
                        Period="@Store.Ui.Tr("شهرياً", "month")">
                <Action>
                    @if (Store.Auth.IsAuthenticated)
                    {
                        <button class="btn btn-primary btn-sm btn-block"
                                @onclick="() => Subscribe(p.Id)">
                            @Store.Ui.Tr("اشترك الآن", "Subscribe now")
                        </button>
                    }
                    else
                    {
                        <a href="/login" class="btn btn-outline-primary btn-sm btn-block">
                            @Store.Ui.Tr("سجّل دخولك للاشتراك", "Sign in to subscribe")
                        </a>
                    }
                </Action>
            </AcPlanCard>
        }
    </div>
}

@if (!string.IsNullOrEmpty(Message))
{
    <div class="ac-mt-lg">
        <AcAlert Variant="info" Message="@Message" />
    </div>
}

@code {
    private bool Loading = true;
    private List<PlanRow> PlanRows = new();
    private string? Message;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var env = await Reader.GetAsync<List<PlanRow>>("/api/plans");
        PlanRows = env.Data ?? new();
        Loading = false;
        StateHasChanged();
    }

    private async Task Subscribe(Guid planId)
    {
        if (!Store.Auth.UserId.HasValue) return;
        var userId = Store.Auth.UserId.Value;
        var result = await Engine.ExecuteAsync<object>(
            ClientOps.Subscribe(userId, planId),
            new { userId, planId, billingCycle = "monthly" });
        Message = result.Operation.Status == "Success"
            ? Store.Ui.Tr("تم الاشتراك بنجاح!", "Subscribed successfully!")
            : result.Operation.ErrorMessage;
        StateHasChanged();
    }

    public class PlanRow
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public decimal MonthlyPrice { get; set; }
        public string Slug { get; set; } = "";
    }
}
