@page "/owner-bookings"
@rendermode InteractiveServer
@inject ApiReader Reader
@inject AppStore Store
@inject ClientOpEngine Engine

<PageTitle>@Store.Ui.Tr("طلبات الحجز", "Booking Requests") - عشير للمُلاّك</PageTitle>

@if (!Store.Auth.IsAuthenticated)
{
    <div class="alert alert-warning" style="margin:16px;">
        <a href="/login">@Store.Ui.Tr("سجّل دخولك", "Sign in")</a>
    </div>
}
else
{
    <AcBookingsPage Bookings="@_bookings"
                    Loading="@_loading"
                    IsOwnerView="true"
                    ActiveFilter="@_filter"
                    OnFilterChange="@(f => { _filter = f; StateHasChanged(); })"
                    OnConfirm="@Confirm"
                    OnReject="@Reject"
                    Title="@Store.Ui.Tr("طلبات الحجز", "Booking Requests")" />
}

@code {
    private List<BookingRowDto> _bookings = new();
    private bool _loading = true;
    private string _filter = "all";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!Store.Auth.IsAuthenticated || !Store.Auth.UserId.HasValue)
        {
            _loading = false;
            StateHasChanged();
            return;
        }

        var env = await Reader.GetAsync<List<BookingApiRow>>($"/api/bookings/by-owner/{Store.Auth.UserId}");
        _bookings = (env.Data ?? new()).Select(r => new BookingRowDto
        {
            Id         = r.Id.ToString(),
            TotalPrice = r.TotalPrice,
            Currency   = r.Currency,
            StartDate  = r.StartDate,
            EndDate    = r.EndDate,
            Status     = r.Status,
            Notes      = r.Notes,
        }).ToList();

        _loading = false;
        StateHasChanged();
    }

    private async Task Confirm(BookingRowDto b)
    {
        b.Acting = true;
        StateHasChanged();
        var result = await Engine.ExecuteAsync<object>(ClientOps.ConfirmBooking(Guid.Parse(b.Id)), new { });
        if (result.Operation.Status == "Success")
        {
            var idx = _bookings.FindIndex(x => x.Id == b.Id);
            if (idx >= 0) _bookings[idx] = _bookings[idx] with { Status = 1 };
        }
        b.Acting = false;
        StateHasChanged();
    }

    private async Task Reject(BookingRowDto b)
    {
        b.Acting = true;
        StateHasChanged();
        var result = await Engine.ExecuteAsync<object>(ClientOps.RejectBooking(Guid.Parse(b.Id)), new { });
        if (result.Operation.Status == "Success")
        {
            var idx = _bookings.FindIndex(x => x.Id == b.Id);
            if (idx >= 0) _bookings[idx] = _bookings[idx] with { Status = 4 };
        }
        b.Acting = false;
        StateHasChanged();
    }

    private class BookingApiRow
    {
        public Guid     Id         { get; set; }
        public decimal  TotalPrice { get; set; }
        public string   Currency   { get; set; } = "SAR";
        public DateTime StartDate  { get; set; }
        public DateTime EndDate    { get; set; }
        public int      Status     { get; set; }
        public string?  Notes      { get; set; }
    }
}
