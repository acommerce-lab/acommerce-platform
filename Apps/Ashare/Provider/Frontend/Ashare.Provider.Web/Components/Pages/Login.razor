@page "/login"
@rendermode InteractiveServer
@inject ClientOpEngine Engine
@inject AppStore Store
@inject NavigationManager Nav

<PageTitle>دخول - عشير للمُلاّك</PageTitle>

<AcLoginPage Mode="TemplateOperationMode.Operation"
             Engine="Engine"
             BuildRequestOtpOp="@(phone => ClientOps.RequestOtp(phone))"
             BuildVerifyOtpOp="@((uid, cid, code) => ClientOps.VerifyOtp(uid, cid, code))"
             PhonePayload="@(phone => new { phoneNumber = phone })"
             VerifyPayload="@((uid, cid, code) => new { userId = uid, challengeId = cid, code })"
             RedirectUrl="/"
             BrandName="عشير للمُلاّك"
             BrandTagline="بوابة مُلاّك العقارات"
             PhoneStepTitle="دخول بالهاتف"
             PhoneStepSubtitle="سنرسل لك رمز تحقق عبر SMS"
             PhoneLabel="رقم الهاتف"
             PhonePlaceholder="+966500000001"
             RequestOtpLabel="إرسال رمز التحقق"
             SendingLabel="جاري الإرسال..."
             OtpStepTitle="رمز التحقق"
             OtpStepSubtitle="أدخل الرمز المرسل إلى"
             OtpLabel="رمز التحقق (6 أرقام)"
             VerifyOtpLabel="تحقق ودخول"
             VerifyingLabel="جاري التحقق..."
             BackLabel="تغيير الرقم" />
