        "ClientSecret": "",
        "ApplicationName": "AshareAdmin",
        "ApiKey": ""
      }
    }
  },
  "Payments": {
    "Noon": {
      "BusinessIdentifier": "ashier",
      "ApplicationIdentifier": "newAshier",
      "ApiKey": "",
      "Mode": "Test",
      "DefaultCurrency": "SAR",
      "Channel": "Web"
    }
  },
  "Notifications": {
    "Firebase": {
      "ProjectId": "ashir-f4bfd",
