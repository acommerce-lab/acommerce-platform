        "DirectoryFormat": "yyyy/MM/dd"
      },
      "AliyunOSS": {
        "AccessKeyId": "",
        "AccessKeySecret": "",
        "Endpoint": "oss-me-central-1.aliyuncs.com",
        "Region": "me-central-1",
        "BucketName": "ashare-media",
        "UseHttps": true,
        "UseV4Signature": true,
        "UseDirectoryStructure": true,
        "DirectoryFormat": "yyyy/MM/dd"
      }
    }
  },
  "Authentication": {
