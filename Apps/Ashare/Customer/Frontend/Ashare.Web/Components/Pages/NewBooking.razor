@page "/booking/new/{listingId:guid}"
@rendermode InteractiveServer
@inject ApiReader Reader
@inject ClientOpEngine Engine
@inject AppStore Store
@inject NavigationManager Nav

<PageTitle>حجز جديد - عشير</PageTitle>

<AcAuthGuard IsAuthenticated="Store.Auth.IsAuthenticated" IsArabic="true" LoginHref="/login">
    <div style="max-width:800px;margin:0 auto;padding: 24px 16px">
        <AcPageHeader Title="حجز جديد" Subtitle="أكمل بيانات الحجز" />

        @if (listing == null)
        {
            <AcLoadingState Message="جاري التحميل..." />
        }
        else
        {
            <div style="display:grid;grid-template-columns:3fr 2fr;gap: 24px;align-items:start">
                <AcCard>
                    <Header>
                        <strong>تفاصيل الحجز</strong>
                    </Header>
                    <ChildContent>
                        <AcField Label="من تاريخ" Class="ac-mb-md">
                            <input type="date" class="ac-input" @bind="startDate" />
                        </AcField>
                        <AcField Label="إلى تاريخ" Class="ac-mb-md">
                            <input type="date" class="ac-input" @bind="endDate" />
                        </AcField>
                        <AcField Label="ملاحظات" Class="ac-mb-md">
                            <textarea class="ac-input" style="min-height:100px;resize:vertical" @bind="notes"></textarea>
                        </AcField>
                        <AcButton Text="@(saving ? "جاري الحجز..." : "تأكيد الحجز")"
                                  Variant="primary" Block="true" Disabled="@saving"
                                  Loading="@saving" OnClick="CreateBooking" />
                    </ChildContent>
                </AcCard>

                <AcCard>
                    <ChildContent>
                        <div style="text-align:center;padding: 8px 0">
                            <div style="font-size:1.5rem;margin-bottom: 8px">🏠</div>
                            <div style="font-weight:600;margin-bottom: 4px">@listing.Title</div>
                            <div class="ac-text-muted" style="font-size:0.875rem;margin-bottom: 8px">@listing.City</div>
                            <div style="font-weight:700;color:var(--ac-primary);font-size:1.125rem">
                                @listing.Price @listing.Currency
                            </div>
                        </div>
                    </ChildContent>
                </AcCard>
            </div>

            @if (!string.IsNullOrEmpty(error))
            {
                <AcAlert Variant="danger" Message="@error" Class="ac-mt-md" />
            }
        }
    </div>
</AcAuthGuard>

@code {
    [Parameter] public Guid ListingId { get; set; }
    private ListingDto? listing;
    private DateTime startDate = DateTime.Today;
    private DateTime endDate = DateTime.Today.AddMonths(1);
    private string notes = "";
    private bool saving;
    private string error = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var resp = await Reader.GetAsync<ListingDto>($"/api/listings/{ListingId}");
            listing = resp.Data;
        }
        catch { }
        StateHasChanged();
    }

    private async Task CreateBooking()
    {
        if (!Store.Auth.UserId.HasValue) return;
        error = "";
        saving = true;
        try
        {
            var customerId = Store.Auth.UserId.Value;
            var resp = await Engine.ExecuteAsync<BookingDto>(
                ClientOps.CreateBooking(customerId, ListingId),
                new { listingId = ListingId, customerId, startDate, endDate, notes });

            if (resp.Operation.Status != "Success" || resp.Data == null)
            {
                error = resp.Operation.ErrorMessage ?? "فشل الحجز";
                return;
            }
            Nav.NavigateTo($"/booking/{resp.Data.Id}");
        }
        catch (Exception ex) { error = ex.Message; }
        finally { saving = false; StateHasChanged(); }
    }

    public class ListingDto
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = "";
        public string City { get; set; } = "";
        public decimal Price { get; set; }
        public string Currency { get; set; } = "";
    }

    public class BookingDto { public Guid Id { get; set; } }
}
