@page "/my-bookings"
@rendermode InteractiveServer
@inject ApiReader Reader
@inject AppStore Store
@inject NavigationManager Nav

<PageTitle>حجوزاتي - عشير</PageTitle>

<AcAuthGuard IsAuthenticated="Store.Auth.IsAuthenticated" IsArabic="true" LoginHref="/login">
    <div style="max-width:900px;margin:0 auto;padding: 24px 16px">
        <AcPageHeader Title="حجوزاتي" Subtitle="جميع حجوزاتك العقارية" />

        @if (bookings == null)
        {
            <AcLoadingState Message="جاري التحميل..." />
        }
        else if (bookings.Count == 0)
        {
            <AcEmptyState IconName="calendar"
                          Title="لا حجوزات حتى الآن"
                          Message="ابحث عن عقار واحجزه"
                          ActionLabel="تصفح العروض"
                          ActionHref="/" />
        }
        else
        {
            @foreach (var b in bookings)
            {
                <div @onclick="@(() => Nav.NavigateTo($"/booking/{b.Id}"))"
                     style="cursor:pointer">
                    <AcCard Hover Class="ac-mb-sm">
                        <ChildContent>
                            <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap: 8px">
                                <div>
                                    <div style="font-weight:600">حجز #@b.Id.ToString("N")[..8]</div>
                                    <div class="ac-text-muted" style="font-size:0.875rem">
                                        @b.StartDate.ToString("yyyy-MM-dd") → @b.EndDate.ToString("yyyy-MM-dd")
                                    </div>
                                </div>
                                <div style="text-align:end">
                                    <div style="font-weight:700;color:var(--ac-primary)">@b.TotalPrice @b.Currency</div>
                                    <span style="padding: 4px 8px;border-radius:var(--ac-radius-pill);font-size:0.875rem;font-weight:600;@StatusStyle(b.Status)">
                                        @StatusText(b.Status)
                                    </span>
                                </div>
                            </div>
                        </ChildContent>
                    </AcCard>
                </div>
            }
        }
    </div>
</AcAuthGuard>

@code {
    private List<BookingDto>? bookings;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!Store.Auth.UserId.HasValue) { bookings = new(); StateHasChanged(); return; }
        try
        {
            var resp = await Reader.GetAsync<List<BookingDto>>($"/api/bookings/by-customer/{Store.Auth.UserId}");
            bookings = resp.Data ?? new();
        }
        catch { bookings = new(); }
        StateHasChanged();
    }

    private string StatusText(int s) => s switch
    {
        0 => "معلّق", 1 => "مؤكد", 2 => "ينتظر الدفع",
        3 => "مدفوع", 4 => "مُلغى", 5 => "مكتمل", _ => "?"
    };

    private string StatusStyle(int s) => s switch
    {
        0 or 1 => "background:color-mix(in srgb, var(--ac-warning) 15%, transparent);color:var(--ac-warning);",
        2 => "background:color-mix(in srgb, var(--ac-info) 15%, transparent);color:var(--ac-info);",
        3 or 5 => "background:color-mix(in srgb, var(--ac-success) 15%, transparent);color:var(--ac-success);",
        4 => "background:color-mix(in srgb, var(--ac-danger) 15%, transparent);color:var(--ac-danger);",
        _ => ""
    };

    public class BookingDto
    {
        public Guid Id { get; set; }
        public decimal TotalPrice { get; set; }
        public string Currency { get; set; } = "";
        public DateTime StartDate { get; set; }
        public DateTime EndDate { get; set; }
        public int Status { get; set; }
    }
}
