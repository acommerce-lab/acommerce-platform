@page "/profile"
@rendermode InteractiveServer
@inject ApiReader Reader
@inject AppStore Store
@inject AppStateApplier Applier
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>@Store.Ui.Tr("ملفي الشخصي", "My Profile") - عشير</PageTitle>

<AcAuthGuard IsAuthenticated="Store.Auth.IsAuthenticated"
             IsArabic="Store.Ui.IsArabic"
             LoginHref="/login">
    @if (Loading)
    {
        <AcLoadingState Message="@Store.Ui.Tr("جاري التحميل...", "Loading…")" />
    }
    else
    {
        <AcProfilePage User="@UserDto"
                       Stats="@StatsList"
                       MenuSections="@MenuSectionsList"
                       SignOutLabel="@Store.Ui.Tr("تسجيل الخروج", "Sign out")"
                       OnSignOut="SignOut" />
    }
</AcAuthGuard>

@code {
    private bool Loading = true;

    // Profile data loaded from API
    private string? _avatarUrl;
    private string? _fullName;

    private ProfileUserDto UserDto => new()
    {
        Id          = Store.Auth.UserId?.ToString() ?? "",
        FullName    = _fullName ?? Store.Auth.FullName ?? Store.Ui.Tr("مستخدم عشير", "Ashare user"),
        PhoneNumber = Store.Auth.PhoneNumber,
        AvatarUrl   = _avatarUrl,
        Initial     = (_fullName ?? Store.Auth.FullName)?.Length > 0
                        ? (_fullName ?? Store.Auth.FullName)![..1]
                        : null,
    };

    private IReadOnlyList<ProfileStatDto> StatsList => Array.Empty<ProfileStatDto>();

    private IReadOnlyList<MenuSectionDto> MenuSectionsList => new[]
    {
        new MenuSectionDto
        {
            Title = Store.Ui.Tr("نشاطي", "My activity"),
            Items = new[]
            {
                new MenuItemDto { Label = Store.Ui.Tr("إعلاناتي", "My listings"),    IconName = "home",     Href = "/my-listings" },
                new MenuItemDto { Label = Store.Ui.Tr("حجوزاتي", "My bookings"),     IconName = "calendar", Href = "/my-bookings" },
                new MenuItemDto { Label = Store.Ui.Tr("المفضلة", "Favorites"),       IconName = "heart",    Href = "/favorites" },
                new MenuItemDto { Label = Store.Ui.Tr("محادثاتي", "Messages"),       IconName = "message",  Href = "/messages" },
            }
        },
        new MenuSectionDto
        {
            Title = Store.Ui.Tr("الحساب", "Account"),
            Items = new[]
            {
                new MenuItemDto { Label = Store.Ui.Tr("اشتراكي", "My subscription"), IconName = "star",     Href = "/my-subscription" },
                new MenuItemDto { Label = Store.Ui.Tr("الإعدادات", "Settings"),      IconName = "settings", Href = "/settings" },
            }
        }
    };

    protected override void OnInitialized() => Store.OnChanged += OnStoreChanged;
    private void OnStoreChanged() => InvokeAsync(StateHasChanged);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!Store.Auth.IsAuthenticated || !Store.Auth.UserId.HasValue)
        {
            Loading = false;
            StateHasChanged();
            return;
        }

        var env = await Reader.GetAsync<ProfileDto>($"/api/profiles/user/{Store.Auth.UserId}");
        if (env.Data != null)
        {
            _fullName  = string.Join(" ", new[] { env.Data.FirstName, env.Data.LastName }
                             .Where(s => !string.IsNullOrWhiteSpace(s)));
            _avatarUrl = env.Data.AvatarUrl;
        }

        Loading = false;
        StateHasChanged();
    }

    private async Task SignOut()
    {
        await Applier.ApplyLocalAsync(ClientOps.SignOut());
        Nav.NavigateTo("/", forceLoad: false);
    }

    public void Dispose() => Store.OnChanged -= OnStoreChanged;

    // ── Local DTO matching API response ────────────────────────────────────
    public class ProfileDto
    {
        public Guid    Id         { get; set; }
        public string? FirstName  { get; set; }
        public string? LastName   { get; set; }
        public string? Bio        { get; set; }
        public string? City       { get; set; }
        public string? AvatarUrl  { get; set; }
    }
}
