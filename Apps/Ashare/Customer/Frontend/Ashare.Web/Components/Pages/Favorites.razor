@page "/favorites"
@rendermode InteractiveServer
@inject ApiReader Reader
@inject AppStore Store
@inject ClientOpEngine Engine

<PageTitle>@Store.Ui.Tr("المفضلة", "Favorites") - عشير</PageTitle>

<AcAuthGuard IsAuthenticated="Store.Auth.IsAuthenticated"
             IsArabic="Store.Ui.IsArabic"
             LoginHref="/login">
    @if (Loading)
    {
        <AcLoadingState Message="@Store.Ui.Tr("جاري التحميل...", "Loading…")" />
    }
    else
    {
        <AcPageHeader Title="@Store.Ui.Tr("المفضلة", "Favorites")" />

        @if (Items.Count == 0)
        {
            <AcEmptyState IconName="heart"
                          Title="@Store.Ui.Tr("لا توجد عناصر في المفضلة", "No favorites yet")"
                          Message="@Store.Ui.Tr("أضف إعلانات إلى مفضلتك لتجدها هنا", "Add listings to your favorites to find them here")"
                          ActionLabel="@Store.Ui.Tr("تصفح الإعلانات", "Browse listings")"
                          ActionHref="/" />
        }
        else
        {
            @foreach (var f in Items)
            {
                <AcCard Class="ac-mb-sm">
                    <div class="ac-row-between ac-align-center">
                        <div>
                            <a href="/listing/@f.EntityId" class="ac-text-strong ac-link-plain">
                                @(f.Note ?? f.EntityId.ToString("N")[..8])
                            </a>
                            <p class="ac-text-muted ac-text-sm">@f.EntityType</p>
                        </div>
                        <AcButton Variant="outline-danger"
                                  Size="sm"
                                  Text="@Store.Ui.Tr("إزالة", "Remove")"
                                  OnClick="@(() => Remove(f))" />
                    </div>
                </AcCard>
            }
        }
    }
</AcAuthGuard>

@code {
    private bool Loading = true;
    private List<FavoriteRow> Items = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!Store.Auth.UserId.HasValue)
        {
            Loading = false;
            StateHasChanged();
            return;
        }

        var env = await Reader.GetAsync<List<FavoriteRow>>(
            $"/api/favorites/user/{Store.Auth.UserId}?entityType=listing");
        Items = env.Data ?? new();
        Loading = false;
        StateHasChanged();
    }

    private async Task Remove(FavoriteRow f)
    {
        if (!Store.Auth.UserId.HasValue) return;
        var result = await Engine.ExecuteAsync<object>(
            ClientOps.RemoveFavorite(Store.Auth.UserId.Value, f.EntityId, f.EntityType), new { });
        if (result.Operation.Status == "Success")
        {
            Items.Remove(f);
            StateHasChanged();
        }
    }

    public class FavoriteRow
    {
        public Guid Id { get; set; }
        public Guid EntityId { get; set; }
        public string EntityType { get; set; } = "";
        public string? Note { get; set; }
        public DateTime CreatedAt { get; set; }
    }
}
