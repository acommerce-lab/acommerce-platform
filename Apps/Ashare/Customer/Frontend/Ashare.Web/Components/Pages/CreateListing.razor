@page "/create-listing"
@rendermode InteractiveServer
@inject ApiReader Reader
@inject ClientOpEngine Engine
@inject AppStore Store
@inject NavigationManager Nav

<PageTitle>عرض جديد - عشير</PageTitle>

@if (!Store.Auth.IsAuthenticated)
{
    <div class="alert alert-warning">يجب تسجيل الدخول أولاً <a href="/login">دخول</a></div>
}
else
{
    <h1>إضافة عرض جديد</h1>
    <p class="text-muted">ينشأ القيد المحاسبي → معترض الاشتراكات يفحص الحصة → الحفظ</p>

    <EditForm Model="form" OnValidSubmit="Submit" FormName="CreateListing">
        <div class="row g-3">
            <div class="col-md-8">
                <label class="form-label">الفئة</label>
                <select class="form-select" @bind="form.CategoryId">
                    <option value="">-- اختر --</option>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat.Id">@cat.NameAr</option>
                    }
                </select>
            </div>
            <div class="col-md-12">
                <label class="form-label">العنوان</label>
                <input class="form-control" @bind="form.Title" />
            </div>
            <div class="col-md-12">
                <label class="form-label">الوصف</label>
                <textarea class="form-control" rows="4" @bind="form.Description"></textarea>
            </div>
            <div class="col-md-4">
                <label class="form-label">السعر</label>
                <input type="number" class="form-control" @bind="form.Price" />
            </div>
            <div class="col-md-4">
                <label class="form-label">المدة</label>
                <input type="number" class="form-control" @bind="form.Duration" />
            </div>
            <div class="col-md-4">
                <label class="form-label">الوحدة</label>
                <select class="form-select" @bind="form.TimeUnit">
                    <option value="month">شهر</option>
                    <option value="week">أسبوع</option>
                    <option value="day">يوم</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">المدينة</label>
                <input class="form-control" @bind="form.City" />
            </div>
            <div class="col-md-6">
                <label class="form-label">الحي</label>
                <input class="form-control" @bind="form.District" />
            </div>
            <div class="col-md-3">
                <label class="form-label">عدد الغرف</label>
                <input type="number" class="form-control" @bind="form.Rooms" />
            </div>
            <div class="col-md-3">
                <label class="form-label">عدد الحمامات</label>
                <input type="number" class="form-control" @bind="form.Bathrooms" />
            </div>
            <div class="col-md-3">
                <label class="form-label">المساحة (م²)</label>
                <input type="number" class="form-control" @bind="form.Area" />
            </div>
            <div class="col-md-3">
                <label class="form-label">الطابق</label>
                <input type="number" class="form-control" @bind="form.Floor" />
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-primary" disabled="@saving">
                    @(saving ? "جاري الحفظ..." : "نشر العرض")
                </button>
            </div>
        </div>
    </EditForm>

    @if (!string.IsNullOrEmpty(error))
    {
        <div class="alert alert-danger mt-3">
            <strong>فشل إنشاء العرض:</strong> @error
            <br/><small>السبب غالباً: اشتراكك الحالي لا يسمح بهذه الفئة أو تجاوزت الحصة. راجع <a href="/plans">الباقات</a>.</small>
        </div>
    }
    @if (!string.IsNullOrEmpty(success))
    {
        <div class="alert alert-success mt-3">@success</div>
    }
}

@code {
    private CreateForm form = new();
    private List<CategoryDto> categories = new();
    private bool saving;
    private string error = "";
    private string success = "";

    protected override async Task OnInitializedAsync()
    {
        var resp = await Reader.GetAsync<List<CategoryDto>>("/api/categories");
        categories = resp.Data ?? new();
    }

    private async Task Submit()
    {
        if (!Store.Auth.UserId.HasValue) return;
        error = ""; success = "";
        saving = true;
        try
        {
            var ownerId = Store.Auth.UserId.Value;
            var payload = new
            {
                ownerId,
                categoryId = form.CategoryId,
                title = form.Title,
                description = form.Description,
                price = form.Price,
                duration = form.Duration,
                timeUnit = form.TimeUnit,
                city = form.City,
                district = form.District,
                propertyType = (string?)null,
                floor = form.Floor,
                area = form.Area,
                rooms = form.Rooms,
                bathrooms = form.Bathrooms,
                furnished = (bool?)null,
                licenseNumber = (string?)null
            };

            var resp = await Engine.ExecuteAsync<ListingDto>(
                ClientOps.CreateListing(ownerId, form.Title),
                payload);

            if (resp.Operation.Status != "Success" || resp.Data == null)
            {
                error = resp.Operation.ErrorMessage ?? resp.Error?.Message ?? "فشل";
                return;
            }

            success = $"تم إنشاء العرض #{resp.Data.Id.ToString().Substring(0, 8)}. جاري التوجيه...";
            await Task.Delay(1000);
            Nav.NavigateTo($"/listing/{resp.Data.Id}");
        }
        finally { saving = false; }
    }

    public class CreateForm
    {
        public Guid CategoryId { get; set; }
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Price { get; set; } = 1000;
        public int Duration { get; set; } = 1;
        public string TimeUnit { get; set; } = "month";
        public string City { get; set; } = "الرياض";
        public string? District { get; set; }
        public int? Rooms { get; set; }
        public int? Bathrooms { get; set; }
        public double? Area { get; set; }
        public int? Floor { get; set; }
    }

    public class CategoryDto
    {
        public Guid Id { get; set; }
        public string NameAr { get; set; } = "";
    }

    public class ListingDto
    {
        public Guid Id { get; set; }
    }
}
