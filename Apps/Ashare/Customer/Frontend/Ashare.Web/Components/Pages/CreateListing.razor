@page "/create-listing"
@rendermode InteractiveServer
@inject ApiReader Reader
@inject ClientOpEngine Engine
@inject AppStore Store
@inject NavigationManager Nav

<PageTitle>عرض جديد - عشير</PageTitle>

<AcAuthGuard IsAuthenticated="Store.Auth.IsAuthenticated" IsArabic="true" LoginHref="/login">
    <div style="max-width:800px;margin:0 auto;padding: 24px 16px">
        <AcPageHeader Title="إضافة عرض جديد"
                      Subtitle="أدخل بيانات العقار ليظهر في سوق عشير" />

        <AcCard Class="ac-mb-lg">
            <Header><strong>بيانات العرض الأساسية</strong></Header>
            <ChildContent>
                <AcField Label="الفئة" Class="ac-mb-md">
                    <select class="ac-input" @bind="form.CategoryId">
                        <option value="">-- اختر الفئة --</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.Id">@cat.NameAr</option>
                        }
                    </select>
                </AcField>

                <AcField Label="العنوان" Class="ac-mb-md">
                    <AcInput Value="@form.Title" ValueChanged="@(v => form.Title = v ?? "")"
                             Placeholder="مثال: شقة فاخرة في حي الياسمين" />
                </AcField>

                <AcField Label="الوصف" Class="ac-mb-md">
                    <textarea class="ac-input" style="min-height:100px;resize:vertical"
                              @bind="form.Description"></textarea>
                </AcField>

                <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap: 12px" class="ac-mb-md">
                    <AcField Label="السعر">
                        <AcInput Type="number" Value="@form.Price.ToString()"
                                 ValueChanged="@(v => { if (decimal.TryParse(v, out var n)) form.Price = n; })" />
                    </AcField>
                    <AcField Label="المدة">
                        <AcInput Type="number" Value="@form.Duration.ToString()"
                                 ValueChanged="@(v => { if (int.TryParse(v, out var n)) form.Duration = n; })" />
                    </AcField>
                    <AcField Label="الوحدة">
                        <select class="ac-input" @bind="form.TimeUnit">
                            <option value="month">شهر</option>
                            <option value="week">أسبوع</option>
                            <option value="day">يوم</option>
                        </select>
                    </AcField>
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap: 12px">
                    <AcField Label="المدينة">
                        <AcInput Value="@form.City" ValueChanged="@(v => form.City = v ?? "")" />
                    </AcField>
                    <AcField Label="الحي">
                        <AcInput Value="@form.District" ValueChanged="@(v => form.District = v)"
                                 Placeholder="اختياري" />
                    </AcField>
                </div>
            </ChildContent>
        </AcCard>

        <AcCard Class="ac-mb-lg">
            <Header><strong>مواصفات العقار</strong></Header>
            <ChildContent>
                <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap: 12px">
                    <AcField Label="الغرف">
                        <AcInput Type="number" Value="@(form.Rooms?.ToString() ?? "")"
                                 ValueChanged="@(v => form.Rooms = int.TryParse(v, out var n) ? n : null)"
                                 Placeholder="0" />
                    </AcField>
                    <AcField Label="الحمامات">
                        <AcInput Type="number" Value="@(form.Bathrooms?.ToString() ?? "")"
                                 ValueChanged="@(v => form.Bathrooms = int.TryParse(v, out var n) ? n : null)"
                                 Placeholder="0" />
                    </AcField>
                    <AcField Label="المساحة م²">
                        <AcInput Type="number" Value="@(form.Area?.ToString() ?? "")"
                                 ValueChanged="@(v => form.Area = double.TryParse(v, out var n) ? n : null)"
                                 Placeholder="0" />
                    </AcField>
                    <AcField Label="الطابق">
                        <AcInput Type="number" Value="@(form.Floor?.ToString() ?? "")"
                                 ValueChanged="@(v => form.Floor = int.TryParse(v, out var n) ? n : null)"
                                 Placeholder="0" />
                    </AcField>
                </div>
            </ChildContent>
        </AcCard>

        @if (!string.IsNullOrEmpty(error))
        {
            <AcAlert Variant="danger" Message="@error" Class="ac-mb-md" />
        }
        @if (!string.IsNullOrEmpty(success))
        {
            <AcAlert Variant="success" Message="@success" Class="ac-mb-md" />
        }

        <AcButton Text="@(saving ? "جاري الحفظ..." : "نشر العرض")"
                  Variant="primary" Block="true" Disabled="@saving"
                  Loading="@saving" OnClick="Submit" />
    </div>
</AcAuthGuard>

@code {
    private CreateForm form = new();
    private List<CategoryDto> categories = new();
    private bool saving;
    private string error = "";
    private string success = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var resp = await Reader.GetAsync<List<CategoryDto>>("/api/categories");
            categories = resp.Data ?? new();
        }
        catch { }
        StateHasChanged();
    }

    private async Task Submit()
    {
        if (!Store.Auth.UserId.HasValue) return;
        error = ""; success = "";
        saving = true;
        try
        {
            var ownerId = Store.Auth.UserId.Value;
            var payload = new
            {
                ownerId, categoryId = form.CategoryId, title = form.Title,
                description = form.Description, price = form.Price,
                duration = form.Duration, timeUnit = form.TimeUnit,
                city = form.City, district = form.District,
                propertyType = (string?)null, floor = form.Floor,
                area = form.Area, rooms = form.Rooms, bathrooms = form.Bathrooms,
                furnished = (bool?)null, licenseNumber = (string?)null
            };

            var resp = await Engine.ExecuteAsync<ListingDto>(
                ClientOps.CreateListing(ownerId, form.Title), payload);

            if (resp.Operation.Status != "Success" || resp.Data == null)
            {
                error = resp.Operation.ErrorMessage ?? resp.Error?.Message ?? "فشل إنشاء العرض";
                return;
            }

            success = $"تم إنشاء العرض بنجاح!";
            StateHasChanged();
            await Task.Delay(800);
            Nav.NavigateTo($"/listing/{resp.Data.Id}");
        }
        catch (Exception ex) { error = ex.Message; }
        finally { saving = false; StateHasChanged(); }
    }

    public class CreateForm
    {
        public Guid CategoryId { get; set; }
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Price { get; set; } = 1000;
        public int Duration { get; set; } = 1;
        public string TimeUnit { get; set; } = "month";
        public string City { get; set; } = "الرياض";
        public string? District { get; set; }
        public int? Rooms { get; set; }
        public int? Bathrooms { get; set; }
        public double? Area { get; set; }
        public int? Floor { get; set; }
    }

    public class CategoryDto { public Guid Id { get; set; } public string NameAr { get; set; } = ""; }
    public class ListingDto { public Guid Id { get; set; } }
}
