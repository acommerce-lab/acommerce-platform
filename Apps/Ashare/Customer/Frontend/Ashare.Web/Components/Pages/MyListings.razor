@page "/my-listings"
@rendermode InteractiveServer
@inject AppStore Store
@inject ApiReader Reader
@inject ClientOpEngine Engine
@inject NavigationManager Nav

<PageTitle>@Store.Ui.Tr("إعلاناتي", "My Listings") - عشير</PageTitle>

@if (!Store.Auth.IsAuthenticated)
{
    <div class="alert alert-warning">
        <a href="/login">@Store.Ui.Tr("سجّل دخولك لرؤية إعلاناتك", "Sign in to view your listings")</a>
    </div>
}
else
{
    <AcListingsPage
        Title="@Store.Ui.Tr("إعلاناتي", "My Listings")"
        Loading="@_loading"
        Listings="@_listings"
        EmptyMessage="@Store.Ui.Tr("لا إعلانات بعد", "No listings yet")">
        <AboveList>
            <div style="display:flex;justify-content:flex-end;margin-bottom:8px;">
                <a href="/create-listing" class="btn btn-primary btn-sm">+ @Store.Ui.Tr("جديد", "New")</a>
            </div>
        </AboveList>
        <CardActions Context="listing">
            <div style="display:flex;flex-direction:column;gap:4px;min-width:90px;">
                <button class="btn btn-sm btn-outline-secondary"
                        @onclick="() => ToggleFeature(listing)">
                    @(listing.IsFeatured ? Store.Ui.Tr("إلغاء التمييز","Unfeature") : Store.Ui.Tr("تمييز","Feature"))
                </button>
                <button class="btn btn-sm btn-outline-danger"
                        @onclick="() => Delete(listing.Id)">
                    @Store.Ui.Tr("حذف", "Delete")
                </button>
            </div>
        </CardActions>
    </AcListingsPage>
}

@code {
    private List<ListingRowDto> _listings = new();
    private bool _loading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!Store.Auth.IsAuthenticated || !Store.Auth.UserId.HasValue)
        {
            _loading = false;
            StateHasChanged();
            return;
        }
        var env = await Reader.GetAsync<List<ApiListingItem>>($"/api/listings/by-owner/{Store.Auth.UserId}");
        _listings = (env.Data ?? new()).Select(x => new ListingRowDto
        {
            Id          = x.Id.ToString(),
            Title       = x.Title,
            Price       = x.Price,
            TimeUnit    = x.TimeUnit,
            City        = x.City,
            District    = x.District,
            Status      = x.Status,
            IsFeatured  = x.IsFeatured,
            ViewCount   = x.ViewCount
        }).ToList();
        _loading = false;
        StateHasChanged();
    }

    private async Task ToggleFeature(ListingRowDto l)
    {
        if (!Store.Auth.UserId.HasValue) return;
        await Engine.ExecuteAsync<object>(ClientOps.FeatureListing(Store.Auth.UserId.Value, Guid.Parse(l.Id)), new { });
        var idx = _listings.FindIndex(x => x.Id == l.Id);
        if (idx >= 0) _listings[idx] = _listings[idx] with { IsFeatured = !_listings[idx].IsFeatured };
        StateHasChanged();
    }

    private async Task Delete(string id)
    {
        if (!Store.Auth.UserId.HasValue) return;
        var result = await Engine.ExecuteAsync<object>(ClientOps.DeleteListing(Store.Auth.UserId.Value, Guid.Parse(id)), new { });
        if (result.Operation.Status == "Success")
        {
            _listings.RemoveAll(l => l.Id == id);
            StateHasChanged();
        }
    }

    // Local API response shape
    private class ApiListingItem
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = "";
        public decimal Price { get; set; }
        public string? TimeUnit { get; set; }
        public string City { get; set; } = "";
        public string? District { get; set; }
        public int Status { get; set; }
        public bool IsFeatured { get; set; }
        public int ViewCount { get; set; }
    }
}
