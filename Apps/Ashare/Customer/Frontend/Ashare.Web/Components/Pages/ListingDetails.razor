@page "/listing/{id:guid}"
@rendermode InteractiveServer
@inject ApiReader Reader
@inject ClientOpEngine Engine
@inject AppStore Store
@inject NavigationManager Nav

<PageTitle>تفاصيل العرض - عشير</PageTitle>

<div style="max-width:1000px;margin:0 auto;padding:24px 16px;">
    @if (loading)
    {
        <AcLoadingState Message="جاري التحميل..." />
    }
    else if (listing == null)
    {
        <AcEmptyState IconName="alert-circle" Title="العرض غير موجود"
                      ActionLabel="العودة للعروض" ActionHref="/" />
    }
    else
    {
        <div style="display:grid;grid-template-columns:1fr 340px;gap:24px;align-items:start;">
            @* Main content *@
            <div>
                <AcPageHeader Title="@listing.Title"
                              Subtitle="@($"{listing.City}{(listing.District != null ? $" • {listing.District}" : "")}")" />

                <AcCard Class="ac-mb-lg">
                    <ChildContent>
                        <p style="line-height:1.8;margin:0;">@listing.Description</p>
                    </ChildContent>
                </AcCard>

                @if (listing.Rooms.HasValue || listing.Bathrooms.HasValue || listing.Area.HasValue || listing.Floor.HasValue)
                {
                    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:12px;margin-bottom:20px;">
                        @if (listing.Rooms.HasValue)
                        {
                            <AcCard>
                                <ChildContent>
                                    <div style="text-align:center;padding:8px 0;">
                                        <div style="font-size:1.5rem;">🛏️</div>
                                        <div style="font-weight:600;">@listing.Rooms غرف</div>
                                    </div>
                                </ChildContent>
                            </AcCard>
                        }
                        @if (listing.Bathrooms.HasValue)
                        {
                            <AcCard>
                                <ChildContent>
                                    <div style="text-align:center;padding:8px 0;">
                                        <div style="font-size:1.5rem;">🚿</div>
                                        <div style="font-weight:600;">@listing.Bathrooms حمام</div>
                                    </div>
                                </ChildContent>
                            </AcCard>
                        }
                        @if (listing.Area.HasValue)
                        {
                            <AcCard>
                                <ChildContent>
                                    <div style="text-align:center;padding:8px 0;">
                                        <div style="font-size:1.5rem;">📐</div>
                                        <div style="font-weight:600;">@listing.Area م²</div>
                                    </div>
                                </ChildContent>
                            </AcCard>
                        }
                        @if (listing.Floor.HasValue)
                        {
                            <AcCard>
                                <ChildContent>
                                    <div style="text-align:center;padding:8px 0;">
                                        <div style="font-size:1.5rem;">🏢</div>
                                        <div style="font-weight:600;">الطابق @listing.Floor</div>
                                    </div>
                                </ChildContent>
                            </AcCard>
                        }
                    </div>
                }
            </div>

            @* Sidebar *@
            <div style="position:sticky;top:72px;">
                <AcCard>
                    <ChildContent>
                        <div style="text-align:center;padding:8px 0;">
                            <div style="font-size:1.8rem;font-weight:700;color:var(--ac-primary);margin-bottom:4px;">
                                @listing.Price.ToString("N0") @listing.Currency
                            </div>
                            <div class="ac-text-muted" style="font-size:0.88rem;margin-bottom:20px;">
                                / @listing.TimeUnit
                            </div>

                            @if (Store.Auth.IsAuthenticated)
                            {
                                <div style="display:flex;flex-direction:column;gap:10px;">
                                    <AcButton Text="احجز الآن" Variant="primary" Block="true" OnClick="StartBooking" />
                                    <AcButton Text="راسل المالك" Variant="outline-primary" Block="true" OnClick="StartChat" />
                                </div>
                            }
                            else
                            {
                                <a href="/login" style="display:block;">
                                    <AcButton Text="دخول للحجز" Variant="primary" Block="true" />
                                </a>
                            }

                            <div class="ac-text-muted" style="font-size:0.78rem;margin-top:16px;padding-top:12px;border-top:1px solid var(--ac-border);">
                                رقم العرض: @listing.Id.ToString("N")[..8]
                            </div>
                        </div>
                    </ChildContent>
                </AcCard>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }
    private ListingDto? listing;
    private bool loading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var resp = await Reader.GetAsync<ListingDto>($"/api/listings/{Id}");
            listing = resp.Data;
        }
        catch { }
        loading = false;
        StateHasChanged();
    }

    private void StartBooking() => Nav.NavigateTo($"/booking/new/{Id}");

    private async Task StartChat()
    {
        try
        {
            var resp = await Engine.ExecuteAsync<ConversationDto>(
                ClientOps.StartConversation(Id, Store.Auth.UserId),
                new { listingId = Id, customerId = Store.Auth.UserId });
            if (resp.Data != null)
                Nav.NavigateTo($"/conversation/{resp.Data.Id}");
        }
        catch { }
    }

    public class ListingDto
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Price { get; set; }
        public string Currency { get; set; } = "";
        public string City { get; set; } = "";
        public string? District { get; set; }
        public string TimeUnit { get; set; } = "";
        public int? Rooms { get; set; }
        public int? Bathrooms { get; set; }
        public double? Area { get; set; }
        public int? Floor { get; set; }
    }

    public class ConversationDto { public Guid Id { get; set; } }
}
