@page "/my-subscription"
@rendermode InteractiveServer
@inject ApiReader Reader
@inject AppStore Store

<PageTitle>اشتراكي - عشير</PageTitle>

<AcAuthGuard IsAuthenticated="Store.Auth.IsAuthenticated" IsArabic="true" LoginHref="/login">
    <div class="acs-page" style="max-width:800px;margin:0 auto;padding: 24px 16px">
        <AcPageHeader Title="اشتراكي الحالي" Subtitle="تفاصيل باقتك والاستخدام" />

        @if (loading)
        {
            <AcLoadingState Message="جاري التحميل..." />
        }
        else if (active == null)
        {
            <AcEmptyState IconName="credit-card"
                          Title="لا يوجد اشتراك نشط"
                          Message="اختر باقة مناسبة لبدء نشر عروضك"
                          ActionLabel="اختر باقة"
                          ActionHref="/plans" />
        }
        else
        {
            <AcCard Class="ac-mb-lg">
                <Header>
                    <strong>@active.Plan.Name</strong>
                </Header>
                <ChildContent>
                    <p class="ac-text-muted" style="margin-bottom: 16px">@active.Plan.Description</p>

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap: 16px">
                        <div>
                            <div class="ac-text-muted" style="font-size:0.875rem;margin-bottom: 4px">الحالة</div>
                            <div style="font-weight:600">
                                @(active.Subscription.Status == 2 ? "✅ نشط" : "⏳ معلّق")
                            </div>
                        </div>
                        <div>
                            <div class="ac-text-muted" style="font-size:0.875rem;margin-bottom: 4px">الفترة</div>
                            <div style="font-weight:600">
                                @active.Subscription.StartDate.ToString("yyyy-MM-dd") — @active.Subscription.EndDate.ToString("yyyy-MM-dd")
                            </div>
                        </div>
                    </div>
                </ChildContent>
            </AcCard>

            <AcCard>
                <Header>
                    <strong>الاستخدام</strong>
                </Header>
                <ChildContent>
                    <div style="margin-bottom: 8px;display:flex;justify-content:space-between">
                        <span>العروض المنشورة</span>
                        <strong>@active.Subscription.UsedListingsCount / @(active.Plan.MaxListings == -1 ? "∞" : active.Plan.MaxListings.ToString())</strong>
                    </div>
                    <div style="height:8px;background:var(--ac-bg-alt);border-radius:var(--ac-radius-pill);overflow:hidden">
                        <div style="height:100%;width:@(Percent(active.Subscription.UsedListingsCount, active.Plan.MaxListings))%;background:var(--ac-primary);border-radius:var(--ac-radius-pill);transition:width 300ms"></div>
                    </div>
                </ChildContent>
            </AcCard>
        }
    </div>
</AcAuthGuard>

@code {
    private ActiveDto? active;
    private bool loading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!Store.Auth.IsAuthenticated) { loading = false; StateHasChanged(); return; }

        try
        {
            var resp = await Reader.GetAsync<ActiveDto>($"/api/subscriptions/user/{Store.Auth.UserId}/active");
            active = resp.Data;
        }
        catch { }

        loading = false;
        StateHasChanged();
    }

    private int Percent(int used, int max)
    {
        if (max == -1) return 10;
        if (max == 0) return 0;
        return Math.Min(100, used * 100 / max);
    }

    public class ActiveDto
    {
        public SubDto Subscription { get; set; } = new();
        public PlanDto Plan { get; set; } = new();
    }

    public class SubDto
    {
        public int Status { get; set; }
        public DateTime StartDate { get; set; }
        public DateTime EndDate { get; set; }
        public int UsedListingsCount { get; set; }
    }

    public class PlanDto
    {
        public string Name { get; set; } = "";
        public string Description { get; set; } = "";
        public int MaxListings { get; set; }
    }
}
