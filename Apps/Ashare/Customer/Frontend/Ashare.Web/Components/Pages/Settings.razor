@page "/settings"
@rendermode InteractiveServer
@inject AppStore Store
@inject AppStateApplier Applier
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>@Store.Ui.Tr("الإعدادات", "Settings") - عشير</PageTitle>

<AcSettingsPage Snapshot="@Snapshot"
                Title="@Store.Ui.Tr("الإعدادات", "Settings")"
                ThemeLabel="@Store.Ui.Tr("المظهر", "Appearance")"
                LanguageLabel="@Store.Ui.Tr("اللغة", "Language")"
                AboutLabel="@Store.Ui.Tr("حول التطبيق", "About")"
                VersionLabel="@Store.Ui.Tr("الإصدار", "Version")"
                LightLabel="@Store.Ui.Tr("فاتح", "Light")"
                DarkLabel="@Store.Ui.Tr("داكن", "Dark")"
                OnThemeChange="@OnThemeChange"
                OnLanguageChange="@OnLanguageChange">
    <ExtraSections>
        @if (Store.Auth.IsAuthenticated)
        {
            <AcCard>
                <div class="acs-menu-section-title">@Store.Ui.Tr("الحساب", "Account")</div>
                <div class="acs-settings-info-row">
                    <span>@Store.Ui.Tr("رقم الهاتف", "Phone")</span>
                    <strong dir="ltr">@(Store.Auth.PhoneNumber ?? "-")</strong>
                </div>
                <div style="display:flex;flex-direction:column;gap: 8px;margin-top: 8px">
                    <a href="/profile"><AcButton Variant="outline-primary" Size="sm" Block="true" Text="@Store.Ui.Tr("تعديل الملف الشخصي", "Edit profile")" /></a>
                    <a href="/my-subscription"><AcButton Variant="ghost" Size="sm" Block="true" Text="@Store.Ui.Tr("إدارة الاشتراك", "Manage subscription")" /></a>
                    <a href="/my-bookings"><AcButton Variant="ghost" Size="sm" Block="true" Text="@Store.Ui.Tr("حجوزاتي", "My bookings")" /></a>
                </div>
            </AcCard>
        }
    </ExtraSections>
</AcSettingsPage>

@code {
    private SettingsSnapshot Snapshot => new()
    {
        Theme    = Store.Ui.Theme,
        Language = Store.Ui.Language,
    };

    protected override void OnInitialized() => Store.OnChanged += OnStoreChanged;
    private void OnStoreChanged() => InvokeAsync(StateHasChanged);

    private async Task OnThemeChange(string t) =>
        await Applier.ApplyLocalAsync(ClientOps.SetTheme(t));

    private async Task OnLanguageChange(string l) =>
        await Applier.ApplyLocalAsync(ClientOps.SetLanguage(l));

    public void Dispose() => Store.OnChanged -= OnStoreChanged;
}
