@page "/settings"
@rendermode InteractiveServer
@inject AppStore Store
@inject ClientOpEngine Engine

<PageTitle>@Store.Ui.Tr("الإعدادات", "Settings") - عشير</PageTitle>

<div style="padding:16px;max-width:400px;">
    <h1 class="acs-page-title" style="margin-bottom:20px;">
        @Store.Ui.Tr("الإعدادات", "Settings")
    </h1>

    <div class="s-card">
        <div class="acc-section-label">@Store.Ui.Tr("المظهر", "Appearance")</div>

        <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;">
            <span>@Store.Ui.Tr("الوضع الليلي", "Dark mode")</span>
            <button class="btn btn-sm @(Store.Ui.IsDark ? "btn-dark" : "btn-outline-secondary")"
                    @onclick="ToggleTheme">
                @(Store.Ui.IsDark ? Store.Ui.Tr("تفعيل", "On") : Store.Ui.Tr("إيقاف", "Off"))
            </button>
        </div>

        <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;">
            <span>@Store.Ui.Tr("اللغة", "Language")</span>
            <div class="acs-seg">
                <button class="acs-seg-btn @(Store.Ui.IsArabic ? "active" : "")"
                        @onclick='() => SetLanguage("ar")'>عربي</button>
                <button class="acs-seg-btn @(!Store.Ui.IsArabic ? "active" : "")"
                        @onclick='() => SetLanguage("en")'>English</button>
            </div>
        </div>
    </div>

    @if (Store.Auth.IsAuthenticated)
    {
        <div class="s-card" style="margin-top:12px;">
            <div class="acc-section-label">@Store.Ui.Tr("الحساب", "Account")</div>
            <div style="padding:4px 0;font-size:0.85rem;color:var(--ac-text-muted);">
                @Store.Ui.Tr("رقم الهاتف", "Phone"): @(Store.Auth.PhoneNumber ?? "-")
            </div>
            <a href="/profile" class="btn btn-outline-primary btn-sm btn-block" style="margin-top:8px;">
                @Store.Ui.Tr("تعديل الملف الشخصي", "Edit profile")
            </a>
        </div>

        <div class="s-card" style="margin-top:12px;">
            <div class="acc-section-label">@Store.Ui.Tr("الاشتراك", "Subscription")</div>
            <a href="/my-subscription" class="btn btn-outline-secondary btn-sm btn-block">
                @Store.Ui.Tr("إدارة الاشتراك", "Manage subscription")
            </a>
        </div>
    }
</div>

@code {
    private async Task ToggleTheme()
    {
        var newTheme = Store.Ui.IsDark ? "light" : "dark";
        await Engine.ExecuteAsync<object>(ClientOps.SetTheme(newTheme), new { });
    }

    private async Task SetLanguage(string lang)
    {
        await Engine.ExecuteAsync<object>(ClientOps.SetLanguage(lang), new { });
    }
}
