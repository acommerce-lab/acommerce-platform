{
  "_comment": "إعدادات افتراضية - تستخدم في Development. للإنتاج راجع appsettings.Production.json",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "AllowedHosts": "*",
  "Urls": "http://localhost:5500",
  "Database": {
    "Provider": "SQLite"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5600",
      "http://localhost:5601",
      "http://localhost:3000"
    ]
  },
  "Files": {
    "Storage": {
      "Provider": "Local",
      "Local": {
        "RootPath": "uploads",
        "BaseUrl": "http://localhost:5500/files",
        "UseDirectoryStructure": true,
        "DirectoryFormat": "yyyy/MM/dd"
      },
      "AliyunOSS": {
        "AccessKeyId": "",
        "AccessKeySecret": "",
        "Endpoint": "oss-me-central-1.aliyuncs.com",
        "Region": "me-central-1",
        "BucketName": "ashare-media",
        "UseHttps": true,
        "UseV4Signature": true,
        "UseDirectoryStructure": true,
        "DirectoryFormat": "yyyy/MM/dd"
      }
    }
  },
  "Authentication": {
    "TwoFactor": {
      "Nafath": {
        "Mode": "Sandbox",
        "BaseUrl": "https://api.authentica.sa/api/v2",
        "ClientId": "",
        "ClientSecret": "",
        "ApplicationName": "Ashare",
        "ApiKey": ""
      }
    }
  },
  "Payments": {
    "Noon": {
      "BusinessIdentifier": "ashier",
      "ApplicationIdentifier": "newAshier",
      "ApiKey": "",
      "Mode": "Test",
      "DefaultCurrency": "SAR",
      "Channel": "Web"
    }
  },
  "Notifications": {
    "Firebase": {
      "ProjectId": "ashir-f4bfd",
      "CredentialsJson": "",
      "CredentialsFilePath": "",
      "DefaultSound": "default"
    }
  }
}