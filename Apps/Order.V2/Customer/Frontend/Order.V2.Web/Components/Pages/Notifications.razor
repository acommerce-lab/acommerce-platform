@page "/notifications"
@inject AppStore Store
@inject ClientOpEngine Engine
@inject ApiReader Api
@inject L L

<PageTitle>@(L["notifications.title"]) — @(L["app.name"])</PageTitle>

@if (!Store.Auth.IsAuthenticated)
{
    <AcEmptyState IconName="bell"
                  Title="@(L["notifications.signin_required"])"
                  ActionLabel="@(L["auth.login.title"])"
                  ActionHref="/login" />
}
else
{
    <AcNotificationsPage Mode="TemplateOperationMode.Operation"
                         Engine="Engine"
                         BuildMarkReadOp="@(id => ClientOps.MarkNotificationRead(Guid.Parse(id)))"
                         BuildMarkAllReadOp="@(() => ClientOps.MarkAllNotificationsRead(Store.Auth.UserId))"
                         Notifications="@Mapped"
                         Loading="@Loading"
                         Title="@(L["notifications.title"])"
                         LoadingMessage="@(L["common.loading"])"
                         EmptyTitle="@(L["notifications.empty_title"])"
                         EmptyMessage="@(L["notifications.empty_message"])"
                         MarkAllReadLabel="@(L["notifications.mark_all_read"])" />
}

@code {
    private List<NotiApi> Items = new();
    private bool Loading = true;

    private IReadOnlyList<NotificationRowDto> Mapped =>
        Items.Select(n => new NotificationRowDto
        {
            Id = n.Id.ToString(),
            Title = n.Title,
            Body = n.Body,
            Type = n.Type,
            IsRead = n.IsRead,
            CreatedAt = n.CreatedAt
        }).ToList();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (Store.Auth.IsAuthenticated)
        {
            var env = await Api.GetAsync<List<NotiApi>>($"/api/notifications/user/{Store.Auth.UserId}");
            Items = env.Data ?? new();
        }
        Loading = false;
        StateHasChanged();
    }

    public class NotiApi
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = "";
        public string Body { get; set; } = "";
        public string Type { get; set; } = "general";
        public bool IsRead { get; set; }
        public DateTime CreatedAt { get; set; }
    }
}
