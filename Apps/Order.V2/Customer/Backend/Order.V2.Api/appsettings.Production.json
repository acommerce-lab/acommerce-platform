{
  "_comment": "إعدادات الإنتاج — الأسرار تأتي من متغيرات البيئة فقط",

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },

  "Database": {
    "Provider": "SqlServer"
  },

  "JWT": {
    "Issuer": "https://api.order.app",
    "Audience": "order-api"
  },

  "Cors": {
    "AllowedOrigins": [
      "https://order.app",
      "https://www.order.app"
    ]
  },

  "Security": {
    "EnableHttps": true,
    "HstsMaxAge": 31536000,
    "EnableRateLimiting": true
  }
}
