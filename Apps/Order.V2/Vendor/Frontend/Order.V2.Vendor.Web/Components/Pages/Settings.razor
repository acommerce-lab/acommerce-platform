@page "/settings"
@rendermode InteractiveServer
@inject AppStore Store
@inject AppStateApplier Applier
@inject L L
@implements IDisposable

<PageTitle>@L["page.settings.title"]</PageTitle>

<AcAuthGuard IsAuthenticated="@Store.Auth.IsAuthenticated" LoginHref="/login">
    <AcSettingsPage Snapshot="@(new SettingsSnapshot { Theme = Store.Ui.Theme, Language = Store.Ui.Language })"
                    Title="@L["settings.heading"]"
                    ThemeLabel="@L["settings.theme"]" LanguageLabel="@L["settings.language"]"
                    LightLabel="@L["settings.theme_light"]" DarkLabel="@L["settings.theme_dark"]"
                    OnThemeChange="@(t => Applier.ApplyLocalAsync(VendorV2Ops.SetTheme(t)))"
                    OnLanguageChange="@(l => Applier.ApplyLocalAsync(VendorV2Ops.SetLanguage(l)))" />
</AcAuthGuard>

@code {
    protected override void OnInitialized() => Store.OnChanged += Refresh;
    private void Refresh() => InvokeAsync(StateHasChanged);
    public void Dispose() => Store.OnChanged -= Refresh;
}
