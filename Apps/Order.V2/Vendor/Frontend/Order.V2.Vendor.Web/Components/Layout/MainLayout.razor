@namespace Order.V2.Vendor.Web.Components.Layout
@inherits LayoutComponentBase
@inject AppStore Store
@inject AppStateApplier Applier
@inject AuthStateService AuthService
@inject L L
@implements IDisposable

<div class="vndr-shell">
    <nav class="vndr-navbar">
        <a href="/" class="vndr-navbar-brand">
            @if (!string.IsNullOrEmpty(Store.Auth.VendorName))
            { @Store.Auth.VendorName }
            else
            { <span>@L.T("اوردر V2 — لوحة المتجر", "Order V2 — Vendor Panel")</span> }
        </a>
        @if (Store.Auth.IsAuthenticated)
        {
            <div class="vndr-navbar-actions">
                <a class="vndr-navbar-link" href="/">@L.T("لوحة التحكم", "Dashboard")</a>
                <a class="vndr-navbar-link" href="/orders">@L.T("الطلبات", "Orders")</a>
                <a class="vndr-navbar-link" href="/offers">@L.T("العروض", "Offers")</a>
                <a class="vndr-navbar-link" href="/profile">@L.T("الملف", "Profile")</a>
                <a class="vndr-navbar-link" href="/settings">@L.T("الإعدادات", "Settings")</a>
                <AcButton Variant="ghost" Size="sm" Text="@L.T("خروج", "Sign out")" OnClick="SignOut" />
            </div>
        }
        else
        {
            <div class="vndr-navbar-actions">
                <a href="/login"><AcButton Variant="primary" Size="sm" Text="@L.T("دخول", "Sign in")" /></a>
            </div>
        }
    </nav>
    <main class="vndr-main">
        @if (_authChecked) { @Body }
    </main>
</div>

@code {
    private bool _authChecked;
    private Guid? _lastPersistedUserId;

    protected override void OnInitialized() => Store.OnChanged += OnChange;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthService.EnsureRestoredAsync();
            if (AuthService.IsAuthenticated)
            {
                Store.Auth.UserId      = AuthService.UserId;
                Store.Auth.VendorId    = AuthService.VendorId;
                Store.Auth.VendorName  = AuthService.VendorName;
                Store.Auth.FullName    = AuthService.FullName;
                Store.Auth.PhoneNumber = AuthService.PhoneNumber;
                Store.Auth.AccessToken = AuthService.AccessToken;
                _lastPersistedUserId   = AuthService.UserId;
            }
            _authChecked = true;
            Store.NotifyChanged();
        }
        await SyncAuthAsync();
    }

    private async Task SyncAuthAsync()
    {
        if (Store.Auth.IsAuthenticated && Store.Auth.UserId != _lastPersistedUserId)
        {
            _lastPersistedUserId = Store.Auth.UserId;
            try
            {
                await AuthService.SignInAsync(
                    Store.Auth.UserId!.Value, Store.Auth.VendorId!.Value,
                    Store.Auth.VendorName, Store.Auth.FullName,
                    Store.Auth.PhoneNumber, Store.Auth.AccessToken!);
            }
            catch { }
        }
        else if (!Store.Auth.IsAuthenticated && _lastPersistedUserId.HasValue)
        {
            _lastPersistedUserId = null;
            try { await AuthService.SignOutAsync(); } catch { }
        }
    }

    private async Task SignOut() => await Applier.ApplyLocalAsync(VendorV2Ops.SignOut());
    private void OnChange() => InvokeAsync(StateHasChanged);
    public void Dispose() => Store.OnChanged -= OnChange;
}
