@page "/"
@rendermode InteractiveServer
@inject AppStore Store
@inject ApiReader Api
@inject NavigationManager Nav
@inject L L
@implements IDisposable

<PageTitle>@L["page.dashboard.title"]</PageTitle>

@if (!Store.Auth.IsAuthenticated)
{
    <AcAuthGuard IsAuthenticated="false" LoginHref="/login" />
}
else
{
    <AcAdminMetricsPage Metrics="@_metrics" Loading="@_loading" Title="@L["dashboard.heading"]" />
}

@code {
    private bool _loading = true;
    private List<PlatformMetricDto> _metrics = new();

    protected override void OnInitialized() => Store.OnChanged += Refresh;
    private void Refresh() { Rebuild(); InvokeAsync(StateHasChanged); }
    public void Dispose() => Store.OnChanged -= Refresh;

    private DashboardRow? _last;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !Store.Auth.IsAuthenticated) { _loading = false; StateHasChanged(); return; }

        var env = await Api.GetAsync<DashboardRow>("/api/admin/dashboard");
        _last = env.Data;
        Rebuild();
        _loading = false;
        StateHasChanged();
    }

    private void Rebuild()
    {
        if (_last is null) return;
        _metrics = new List<PlatformMetricDto>
        {
            new() { Label = L["metric.users"],          Value = _last.TotalUsers.ToString(),              IconName = "users"   },
            new() { Label = L["metric.active_users"],   Value = _last.ActiveUsers.ToString(),             IconName = "check"   },
            new() { Label = L["metric.vendors"],        Value = _last.TotalVendors.ToString(),            IconName = "store"   },
            new() { Label = L["metric.orders"],         Value = _last.TotalOrders.ToString(),             IconName = "receipt" },
            new() { Label = L["metric.pending"],        Value = _last.PendingOrders.ToString(),           IconName = "clock"   },
            new() { Label = L["metric.active_offers"],  Value = _last.ActiveOffers.ToString(),            IconName = "tag"     },
            new() { Label = L["metric.revenue"],        Value = $"{_last.TotalRevenue:0.##} {L["common.currency_sar"]}", IconName = "dollar" },
        };
    }

    private record DashboardRow(int TotalUsers, int ActiveUsers, int TotalVendors,
                                int TotalOrders, int PendingOrders, int TotalOffers,
                                int ActiveOffers, decimal TotalRevenue);
}
