@page "/"
@rendermode InteractiveServer
@inject AppStore Store
@inject ApiReader Api
@inject NavigationManager Nav
@inject L L
@implements IDisposable

<PageTitle>@L.T("لوحة التحكم — اوردر V2", "Dashboard — Order V2")</PageTitle>

@if (!Store.Auth.IsAuthenticated)
{
    <AcAuthGuard IsAuthenticated="false" LoginHref="/login" />
}
else
{
    <AcAdminMetricsPage Metrics="@_metrics" Loading="@_loading" Title="@L.T("لوحة تحكم اوردر V2", "Order V2 Dashboard")" />
}

@code {
    private bool _loading = true;
    private List<PlatformMetricDto> _metrics = new();

    protected override void OnInitialized() => Store.OnChanged += Refresh;
    private void Refresh() { Rebuild(); InvokeAsync(StateHasChanged); }
    public void Dispose() => Store.OnChanged -= Refresh;

    private DashboardRow? _last;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !Store.Auth.IsAuthenticated) { _loading = false; StateHasChanged(); return; }

        var env = await Api.GetAsync<DashboardRow>("/api/admin/dashboard");
        _last = env.Data;
        Rebuild();
        _loading = false;
        StateHasChanged();
    }

    private void Rebuild()
    {
        if (_last is null) return;
        _metrics = new List<PlatformMetricDto>
        {
            new() { Label = L.T("المستخدمون", "Users"),       Value = _last.TotalUsers.ToString(),              IconName = "users"   },
            new() { Label = L.T("نشطون", "Active"),           Value = _last.ActiveUsers.ToString(),             IconName = "check"   },
            new() { Label = L.T("المتاجر", "Vendors"),        Value = _last.TotalVendors.ToString(),            IconName = "store"   },
            new() { Label = L.T("الطلبات", "Orders"),         Value = _last.TotalOrders.ToString(),             IconName = "receipt" },
            new() { Label = L.T("طلبات معلقة", "Pending"),    Value = _last.PendingOrders.ToString(),           IconName = "clock"   },
            new() { Label = L.T("العروض النشطة", "Active Offers"), Value = _last.ActiveOffers.ToString(),      IconName = "tag"     },
            new() { Label = L.T("الإيرادات", "Revenue"),      Value = $"{_last.TotalRevenue:0.##} {L.T("ر.س", "SAR")}", IconName = "dollar" },
        };
    }

    private record DashboardRow(int TotalUsers, int ActiveUsers, int TotalVendors,
                                int TotalOrders, int PendingOrders, int TotalOffers,
                                int ActiveOffers, decimal TotalRevenue);
}
