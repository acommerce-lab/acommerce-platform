@page "/categories"
@rendermode InteractiveServer
@inject AppStore Store
@inject ApiReader Api
@inject ClientOpEngine Engine
@inject L L

<PageTitle>@L.T("التصنيفات — اوردر V2", "Categories — Order V2")</PageTitle>

<AcAuthGuard IsAuthenticated="@Store.Auth.IsAuthenticated" LoginHref="/login">
    <h2 class="page-title">@L.T("التصنيفات", "Categories")</h2>

    <div class="create-form card mb-4">
        <h4>@L.T("إضافة تصنيف جديد", "Add new category")</h4>
        <div class="form-row">
            <div class="ac-field">
                <label class="ac-label">@L.T("الاسم بالعربية", "Arabic name")</label>
                <input class="ac-input" placeholder="@L.T("مثال: مشاوي", "e.g. Grills")" @bind="_nameAr" />
            </div>
            <div class="ac-field">
                <label class="ac-label">@L.T("الاسم بالإنجليزية", "English name")</label>
                <input class="ac-input" placeholder="e.g. Grills" @bind="_nameEn" />
            </div>
            <div class="ac-field">
                <label class="ac-label">@L.T("الرابط (slug)", "Slug")</label>
                <input class="ac-input" placeholder="grills" @bind="_slug" />
            </div>
            <div class="ac-field">
                <label class="ac-label">@L.T("الأيقونة (emoji)", "Icon (emoji)")</label>
                <input class="ac-input" placeholder="🍖" @bind="_icon" />
            </div>
        </div>
        <AcButton Variant="primary" Text="@L.T("إضافة", "Add")" OnClick="Create" />
        @if (!string.IsNullOrEmpty(_createError))
        {
            <p class="error-msg">@_createError</p>
        }
    </div>

    @if (_loading)
    {
        <AcSpinner />
    }
    else
    {
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>@L.T("الأيقونة", "Icon")</th>
                        <th>@L.T("الاسم العربي", "Arabic name")</th>
                        <th>@L.T("الاسم الإنجليزي", "English name")</th>
                        <th>@L.T("الرابط", "Slug")</th>
                        <th>@L.T("إجراء", "Action")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in _categories)
                    {
                        <tr>
                            <td>@c.Icon</td>
                            <td>@c.NameAr</td>
                            <td>@c.NameEn</td>
                            <td>@c.Slug</td>
                            <td>
                                <AcButton Variant="danger" Size="sm" Text="@L.T("حذف", "Delete")"
                                          OnClick="@(() => Delete(c))" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</AcAuthGuard>

@code {
    private bool _loading = true;
    private List<CatRow> _categories = new();
    private string _nameAr = "", _nameEn = "", _slug = "", _icon = "🍽️";
    private string _createError = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !Store.Auth.IsAuthenticated) { _loading = false; StateHasChanged(); return; }
        await Reload();
    }

    private async Task Reload()
    {
        var env = await Api.GetAsync<List<CatRow>>("/api/admin/categories");
        _categories = env.Data ?? new();
        _loading = false; StateHasChanged();
    }

    private async Task Create()
    {
        _createError = "";
        if (string.IsNullOrWhiteSpace(_nameAr) || string.IsNullOrWhiteSpace(_slug))
        {
            _createError = L.T("الاسم العربي والرابط مطلوبان", "Arabic name and slug are required");
            StateHasChanged(); return;
        }
        var res = await Api.PostAsync<object>("/api/admin/categories",
            new { nameAr = _nameAr, nameEn = _nameEn, slug = _slug, icon = _icon });
        if (res.Operation?.Status == "Success")
        {
            _nameAr = ""; _nameEn = ""; _slug = ""; _icon = "🍽️";
            await Reload();
        }
        else { _createError = res.Operation?.ErrorMessage ?? L.T("فشل الإنشاء", "Create failed"); StateHasChanged(); }
    }

    private async Task Delete(CatRow c)
    {
        await Api.DeleteAsync($"/api/admin/categories/{c.Id}");
        _categories.RemoveAll(x => x.Id == c.Id);
        StateHasChanged();
    }

    private record CatRow(Guid Id, string NameAr, string NameEn, string? Icon, string Slug);
}
