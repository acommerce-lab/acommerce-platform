@page "/login"
@rendermode InteractiveServer
@inject ClientOpEngine Engine
@inject AppStore Store
@inject NavigationManager Nav
@inject L L

<PageTitle>@L["page.login.title"]</PageTitle>

<AcLoginPage Mode="TemplateOperationMode.Operation"
             Engine="Engine"
             BuildRequestOtpOp="@(phone => AdminV2Ops.RequestOtp(phone))"
             BuildVerifyOtpOp="@((uid, cid, code) => AdminV2Ops.VerifyOtp(uid, cid, code))"
             PhonePayload="@(phone => new { phoneNumber = phone })"
             VerifyPayload="@((uid, cid, code) => new { userId = uid, challengeId = cid, code })"
             RedirectUrl="/"
             BrandName="@L["brand.name"]"
             BrandTagline="@L["brand.tagline"]"
             PhoneStepTitle="@L["auth.phone_step.title"]"
             PhoneStepSubtitle="@L["auth.phone_step.subtitle"]"
             PhoneLabel="@L["auth.phone_label"]"
             PhonePlaceholder="+966599999901"
             RequestOtpLabel="@L["auth.request_otp"]"
             SendingLabel="@L["auth.sending"]"
             OtpStepTitle="@L["auth.otp_step.title"]"
             OtpStepSubtitle="@L["auth.otp_step.subtitle"]"
             OtpLabel="@L["auth.otp_label"]"
             VerifyOtpLabel="@L["auth.verify_otp"]"
             VerifyingLabel="@L["auth.verifying"]"
             BackLabel="@L["auth.change_phone"]" />
