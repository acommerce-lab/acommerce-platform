@page "/login"
@rendermode InteractiveServer
@inject ClientOpEngine Engine
@inject AppStore Store
@inject NavigationManager Nav
@inject L L

<PageTitle>@L.T("دخول — اوردر V2 الإدارة", "Sign in — Order V2 Admin")</PageTitle>

<AcLoginPage Mode="TemplateOperationMode.Operation"
             Engine="Engine"
             BuildRequestOtpOp="@(phone => AdminV2Ops.RequestOtp(phone))"
             BuildVerifyOtpOp="@((uid, cid, code) => AdminV2Ops.VerifyOtp(uid, cid, code))"
             PhonePayload="@(phone => new { phoneNumber = phone })"
             VerifyPayload="@((uid, cid, code) => new { userId = uid, challengeId = cid, code })"
             RedirectUrl="/"
             BrandName="@L.T("اوردر V2 — لوحة الإدارة", "Order V2 — Admin Panel")"
             BrandTagline="@L.T("بوابة المسؤولين والمشرفين", "Supervisors and admins portal")"
             PhoneStepTitle="@L.T("دخول بالهاتف", "Sign in by phone")"
             PhoneStepSubtitle="@L.T("سنرسل لك رمز تحقق عبر SMS", "We will send you an SMS verification code")"
             PhoneLabel="@L.T("رقم الهاتف", "Phone number")"
             PhonePlaceholder="+966599999901"
             RequestOtpLabel="@L.T("إرسال رمز التحقق", "Send verification code")"
             SendingLabel="@L.T("جاري الإرسال...", "Sending...")"
             OtpStepTitle="@L.T("رمز التحقق", "Verification code")"
             OtpStepSubtitle="@L.T("أدخل الرمز المرسل إلى", "Enter the code sent to")"
             OtpLabel="@L.T("رمز التحقق (6 أرقام)", "Verification code (6 digits)")"
             VerifyOtpLabel="@L.T("تحقق ودخول", "Verify and sign in")"
             VerifyingLabel="@L.T("جاري التحقق...", "Verifying...")"
             BackLabel="@L.T("تغيير الرقم", "Change number")" />
