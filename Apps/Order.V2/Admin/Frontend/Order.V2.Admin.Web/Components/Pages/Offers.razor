@page "/offers"
@rendermode InteractiveServer
@inject AppStore Store
@inject ApiReader Api
@inject ClientOpEngine Engine
@inject L L

<PageTitle>@L["page.offers.title"]</PageTitle>

<AcAuthGuard IsAuthenticated="@Store.Auth.IsAuthenticated" LoginHref="/login">
    <h2 class="page-title">@L["offers.heading"]</h2>
    @if (_loading)
    {
        <AcSpinner />
    }
    else
    {
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>@L["table.title"]</th>
                        <th>@L["table.vendor"]</th>
                        <th>@L["table.price"]</th>
                        <th>@L["table.original_price"]</th>
                        <th>@L["table.discount_pct"]</th>
                        <th>@L["table.currency"]</th>
                        <th>@L["table.active"]</th>
                        <th>@L["table.featured"]</th>
                        <th>@L["table.date"]</th>
                        <th>@L["table.action"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in _offers)
                    {
                        <tr>
                            <td>@o.Title</td>
                            <td class="id-cell">@o.VendorId.ToString()[..8]…</td>
                            <td>@o.Price.ToString("0.##")</td>
                            <td>@o.OriginalPrice.ToString("0.##")</td>
                            <td>@o.DiscountPercent%</td>
                            <td>@o.Currency</td>
                            <td>@(o.IsActive ? "✓" : "✗")</td>
                            <td>@(o.IsFeatured ? "✓" : "✗")</td>
                            <td>@o.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td>
                                @if (o.IsActive)
                                {
                                    <AcButton Variant="danger" Size="sm" Text="@L["common.disable"]"
                                              OnClick="@(() => Deactivate(o))" />
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</AcAuthGuard>

@code {
    private bool _loading = true;
    private List<OfferRow> _offers = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !Store.Auth.IsAuthenticated) { _loading = false; StateHasChanged(); return; }
        var env = await Api.GetAsync<List<OfferRow>>("/api/admin/offers");
        _offers = env.Data ?? new();
        _loading = false; StateHasChanged();
    }

    private async Task Deactivate(OfferRow o)
    {
        var res = await Engine.ExecuteAsync<object>(AdminV2Ops.DeactivateOffer(o.Id), new { });
        if (res.Operation.Status == "Success")
        {
            var i = _offers.FindIndex(x => x.Id == o.Id);
            if (i >= 0) _offers[i] = _offers[i] with { IsActive = false };
            StateHasChanged();
        }
    }

    private record OfferRow(Guid Id, string Title, Guid VendorId, Guid? CategoryId,
                             decimal Price, decimal OriginalPrice, string Currency,
                             bool IsActive, bool IsFeatured, decimal DiscountPercent, DateTime CreatedAt);
}
