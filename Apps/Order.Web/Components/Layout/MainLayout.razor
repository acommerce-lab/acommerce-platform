@inherits LayoutComponentBase
@inject AuthStateService Auth
@inject CartService Cart
@inject UiPreferences Ui
@inject IJSRuntime JS
@implements IDisposable

<div class="ord-shell">
    <main class="ord-main">
        @Body
    </main>

    <nav class="ord-bottom-nav">
        <NavLink href="/" Match="NavLinkMatch.All" class="ord-nav-item">
            <AcIcon Name="home" Size="22" />
            <span>@(Ui.IsArabic ? "الرئيسية" : "Home")</span>
        </NavLink>
        <NavLink href="/search" class="ord-nav-item">
            <AcIcon Name="search" Size="22" />
            <span>@(Ui.IsArabic ? "بحث" : "Search")</span>
        </NavLink>
        <NavLink href="/cart" class="ord-nav-item ord-nav-cart">
            <div class="ord-nav-cart-btn">
                <AcIcon Name="bag" Size="22" />
                @if (Cart.Count > 0)
                {
                    <span class="ord-cart-badge">@Cart.Count</span>
                }
            </div>
            <span>@(Ui.IsArabic ? "السلة" : "Cart")</span>
        </NavLink>
        <NavLink href="/orders" class="ord-nav-item">
            <AcIcon Name="receipt" Size="22" />
            <span>@(Ui.IsArabic ? "طلباتي" : "Orders")</span>
        </NavLink>
        <NavLink href="@(Auth.IsAuthenticated ? "/profile" : "/login")" class="ord-nav-item">
            <AcIcon Name="user" Size="22" />
            <span>@(Ui.IsArabic ? "حسابي" : "Profile")</span>
        </NavLink>
    </nav>
</div>

@code {
    protected override void OnInitialized()
    {
        Auth.OnChanged += OnChange;
        Cart.OnChanged += OnChange;
        Ui.OnChanged   += OnChange;
    }

    private string _lastAppliedTheme = "";
    private string _lastAppliedLang  = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Auth.EnsureRestoredAsync();
            _lastAppliedTheme = Ui.Theme;
            _lastAppliedLang  = Ui.Language;
        }
        // The root <html> element lives outside the interactive Blazor
        // tree, so Blazor can't flip its attributes directly — we push
        // the new values via JS interop whenever Ui notifies a change.
        if (_lastAppliedTheme != Ui.Theme)
        {
            _lastAppliedTheme = Ui.Theme;
            try { await JS.InvokeVoidAsync("acTheme.set", Ui.Theme); } catch { }
        }
        if (_lastAppliedLang != Ui.Language)
        {
            _lastAppliedLang = Ui.Language;
            try { await JS.InvokeVoidAsync("acLang.set", Ui.Language); } catch { }
        }
    }

    private void OnChange() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Auth.OnChanged -= OnChange;
        Cart.OnChanged -= OnChange;
        Ui.OnChanged   -= OnChange;
    }
}
