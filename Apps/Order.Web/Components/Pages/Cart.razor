@page "/cart"
@inject AppStore Store
@inject AppStateApplier Applier
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>السلة - اوردر</PageTitle>

<AcCartPage Cart="@Snapshot"
            Title="@(Store.Ui.IsArabic ? "سلة الطلبات" : "Your cart")"
            EmptyTitle="@(Store.Ui.IsArabic ? "السلة فارغة" : "Cart is empty")"
            EmptyMessage="@(Store.Ui.IsArabic ? "تصفّح العروض وأضف أصنافك المفضلة" : "Browse offers and add your favorites")"
            BrowseLabel="@(Store.Ui.IsArabic ? "تصفّح العروض" : "Browse offers")"
            BrowseHref="/"
            PickupHint="@(Store.Ui.IsArabic ? "الاستلام من المتجر أو من السيارة" : "In-store or curbside pickup")"
            SubtotalLabel="@(Store.Ui.IsArabic ? "المجموع الفرعي" : "Subtotal")"
            TotalLabel="@(Store.Ui.IsArabic ? "الإجمالي" : "Total")"
            CheckoutLabel="@(Store.Ui.IsArabic ? "متابعة للطلب" : "Continue to checkout")"
            ClearLabel="@(Store.Ui.IsArabic ? "إفراغ السلة" : "Clear cart")"
            OnQuantityChange="HandleQtyChange"
            OnClear="@(async () => { await Applier.ApplyLocalAsync(ClientOps.CartClear()); })"
            OnCheckout="GoCheckout" />

@code {
    private CartSnapshot Snapshot => new()
    {
        Items = Store.Cart.Items.Select(i => new CartLineDto
        {
            OfferId = i.OfferId.ToString(),
            Title = i.Title,
            Emoji = i.Emoji,
            UnitPrice = i.UnitPrice,
            Quantity = i.Quantity
        }).ToList(),
        Vendor = Store.Cart.VendorId.HasValue ? new VendorMiniDto
        {
            Id = Store.Cart.VendorId.Value.ToString(),
            Name = Store.Cart.VendorName ?? "",
            LogoEmoji = Store.Cart.VendorEmoji
        } : null,
        Subtotal = Store.Cart.Subtotal,
        Currency = "SAR"
    };

    protected override void OnInitialized() => Store.OnChanged += OnChanged;
    private void OnChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Store.OnChanged -= OnChanged;

    private async Task HandleQtyChange((string OfferId, int NewQty) args)
    {
        await Applier.ApplyLocalAsync(ClientOps.CartSetQuantity(Guid.Parse(args.OfferId), args.NewQty));
    }

    private void GoCheckout()
    {
        if (!Store.Auth.IsAuthenticated)
        {
            Nav.NavigateTo("/login?return=/checkout");
            return;
        }
        Nav.NavigateTo("/checkout");
    }
}
