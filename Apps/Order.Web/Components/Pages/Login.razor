@page "/login"
@inject AppStore Store
@inject ClientOpEngine Engine
@inject NavigationManager Nav

<PageTitle>تسجيل الدخول - اوردر</PageTitle>

<AcLoginPage Step="Step"
             Phone="@Phone"
             PhoneChanged="@(v => Phone = v)"
             Code="@Code"
             CodeChanged="@(v => Code = v)"
             Error="@Error"
             Busy="@Busy"
             BrandIcon="🍔"
             BrandName="اوردر"
             BrandTagline="@(Store.Ui.IsArabic ? "عروض الكافيهات والمطاعم" : "Cafe & restaurant deals")"
             PhoneStepTitle="@(Store.Ui.IsArabic ? "مرحباً بك" : "Welcome")"
             PhoneStepSubtitle="@(Store.Ui.IsArabic ? "أدخل رقم جوالك للمتابعة" : "Enter your phone number to continue")"
             PhoneLabel="@(Store.Ui.IsArabic ? "رقم الجوال" : "Phone number")"
             RequestOtpLabel="@(Store.Ui.IsArabic ? "إرسال رمز التحقق" : "Send verification code")"
             SendingLabel="@(Store.Ui.IsArabic ? "جاري الإرسال..." : "Sending...")"
             OtpStepTitle="@(Store.Ui.IsArabic ? "رمز التحقق" : "Verification code")"
             OtpStepSubtitle="@(Store.Ui.IsArabic ? "أدخل الرمز المرسل إلى" : "Enter the code sent to")"
             OtpLabel="@(Store.Ui.IsArabic ? "رمز التحقق (6 أرقام)" : "Verification code (6 digits)")"
             VerifyOtpLabel="@(Store.Ui.IsArabic ? "تحقق ودخول" : "Verify & sign in")"
             VerifyingLabel="@(Store.Ui.IsArabic ? "جاري التحقق..." : "Verifying...")"
             BackLabel="@(Store.Ui.IsArabic ? "تغيير رقم الجوال" : "Change phone")"
             OnRequestOtp="RequestOtp"
             OnVerifyOtp="VerifyOtp"
             OnBack="GoBack">
    <HintSlot>
        <strong>@(Store.Ui.IsArabic ? "وضع تجريبي:" : "Demo mode:")</strong>
        @(Store.Ui.IsArabic
            ? "أي رقم +9665xxxxxxxx يفتح حساباً جديداً. الرمز يطبع في سجل الـ API."
            : "Any +9665xxxxxxxx number creates a new account. The code is printed in the API log.")
        <br />
        <span style="font-size:0.78rem;">@(Store.Ui.IsArabic ? "حسابات تجريبية: " : "Demo accounts: ")</span>
        <code dir="ltr">+966500000001</code> (سارة)
    </HintSlot>
</AcLoginPage>

@code {
    [SupplyParameterFromQuery(Name = "return")] public string? ReturnUrl { get; set; }

    private int Step = 1;
    private string Phone = "+966500000001";
    private string Code = "";
    private string Error = "";
    private bool Busy;
    private Guid? UserId;
    private string? ChallengeId;

    private async Task RequestOtp()
    {
        Error = "";
        if (string.IsNullOrWhiteSpace(Phone)) { Error = Store.Ui.IsArabic ? "أدخل رقم الجوال" : "Enter phone"; return; }
        Busy = true;
        try
        {
            var result = await Engine.ExecuteAsync<OtpRequestDto>(ClientOps.RequestOtp(Phone), new { phoneNumber = Phone });
            if (result.Operation.Status != "Success" || result.Data == null)
            {
                Error = result.Operation.ErrorMessage ?? result.Error?.Message ?? (Store.Ui.IsArabic ? "فشل الإرسال" : "Send failed");
                return;
            }
            UserId = result.Data.UserId;
            ChallengeId = result.Data.ChallengeId;
            Step = 2;
        }
        catch (Exception ex) { Error = ex.Message; }
        finally { Busy = false; }
    }

    private async Task VerifyOtp()
    {
        Error = "";
        if (string.IsNullOrWhiteSpace(Code) || !UserId.HasValue) return;
        Busy = true;
        try
        {
            var result = await Engine.ExecuteAsync<VerifyDto>(ClientOps.VerifyOtp(UserId.Value, ChallengeId, Code), new
            {
                userId = UserId.Value,
                challengeId = ChallengeId,
                code = Code
            });
            if (result.Operation.Status != "Success" || result.Data == null || string.IsNullOrEmpty(result.Data.AccessToken))
            {
                Error = result.Operation.ErrorMessage ?? result.Error?.Message ?? (Store.Ui.IsArabic ? "كود غير صحيح" : "Wrong code");
                return;
            }
            Nav.NavigateTo(string.IsNullOrEmpty(ReturnUrl) ? "/" : ReturnUrl, forceLoad: false);
        }
        catch (Exception ex) { Error = ex.Message; }
        finally { Busy = false; }
    }

    private void GoBack()
    {
        Step = 1;
        Code = "";
        Error = "";
    }

    public class OtpRequestDto
    {
        public string ChallengeId { get; set; } = "";
        public Guid UserId { get; set; }
        public string PhoneNumber { get; set; } = "";
    }
    public class VerifyDto
    {
        public Guid UserId { get; set; }
        public string? PhoneNumber { get; set; }
        public string? FullName { get; set; }
        public string AccessToken { get; set; } = "";
    }
}
