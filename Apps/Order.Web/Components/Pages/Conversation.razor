@page "/chat/{Id:guid}"
@inject AppStore Store
@inject ClientOpEngine Engine
@inject ApiReader Api
@inject NavigationManager Nav

<PageTitle>محادثة - اوردر</PageTitle>

@if (!Store.Auth.IsAuthenticated)
{
    <AcEmptyState IconName="log-in"
                  Title="@(Store.Ui.IsArabic ? "سجل دخولك" : "Sign in")"
                  ActionLabel="@(Store.Ui.IsArabic ? "دخول" : "Sign in")"
                  ActionHref="/login" />
}
else
{
    <AcChatPage Messages="@Mapped"
                MySenderId="@(Store.Auth.UserId?.ToString() ?? "")"
                Loading="@Loading"
                Sending="@Sending"
                Draft="@Draft"
                DraftChanged="@(v => Draft = v)"
                OnSend="Send"
                Title="@(Store.Ui.IsArabic ? "محادثة" : "Chat")"
                LoadingMessage="@(Store.Ui.IsArabic ? "جاري التحميل..." : "Loading…")"
                EmptyMessage="@(Store.Ui.IsArabic ? "لا رسائل بعد" : "No messages yet")"
                InputPlaceholder="@(Store.Ui.IsArabic ? "اكتب رسالة..." : "Type a message...")"
                SendLabel="@(Store.Ui.IsArabic ? "إرسال" : "Send")" />
}

@code {
    [Parameter] public Guid Id { get; set; }
    private List<MsgApi> Messages = new();
    private bool Loading = true;
    private bool Sending;
    private string Draft = "";

    private IReadOnlyList<ChatMessageDto> Mapped =>
        Messages.Select(m => new ChatMessageDto
        {
            Id = m.Id.ToString(),
            Content = m.Content,
            SenderId = m.SenderId.ToString(),
            CreatedAt = m.CreatedAt
        }).ToList();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Reload();
        StateHasChanged();
    }

    private async Task Reload()
    {
        Loading = true;
        var env = await Api.GetAsync<List<MsgApi>>($"/api/messages/conversations/{Id}/messages");
        Messages = env.Data ?? new();
        Loading = false;
        // Reset unread count for this user when opening the conversation
        if (Store.Auth.UserId.HasValue)
            await Engine.ExecuteAsync<object>(ClientOps.MarkConversationRead(Id, Store.Auth.UserId.Value),
                new { readerId = Store.Auth.UserId.Value });
    }

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(Draft) || Sending) return;
        Sending = true;
        try
        {
            var result = await Engine.ExecuteAsync<MsgApi>(ClientOps.SendMessage(Id, Store.Auth.UserId, Draft),
                new { conversationId = Id, senderId = Store.Auth.UserId, content = Draft });
            if (result.Data != null)
            {
                Messages.Add(result.Data);
                Draft = "";
            }
        }
        finally { Sending = false; }
    }

    public class MsgApi
    {
        public Guid Id { get; set; }
        public Guid ConversationId { get; set; }
        public Guid SenderId { get; set; }
        public string Content { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }
}
