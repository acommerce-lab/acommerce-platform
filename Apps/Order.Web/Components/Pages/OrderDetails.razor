@page "/order/{Id:guid}"
@inject AppStore Store
@inject ClientOpEngine Engine
@inject ApiReader Api
@inject NavigationManager Nav

<PageTitle>تفاصيل الطلب - اوردر</PageTitle>

@if (JustCreated && Mapped != null)
{
    <AcOrderSuccessPage Order="@Mapped"
                        Title="@(Store.Ui.IsArabic ? "تم استلام طلبك" : "Order received")"
                        Subtitle="@(Store.Ui.IsArabic ? "سيؤكد المتجر طلبك قريباً جداً" : "The store will confirm shortly")"
                        TotalLabel="@(Store.Ui.IsArabic ? "الإجمالي" : "Total")"
                        ViewOrderLabel="@(Store.Ui.IsArabic ? "تفاصيل الطلب" : "View order")"
                        ContinueLabel="@(Store.Ui.IsArabic ? "متابعة التسوق" : "Continue shopping")" />
}
else
{
    <AcOrderDetailsPage Order="@Mapped"
                        Loading="@Loading"
                        BackHref="/orders"
                        LoadingMessage="@(Store.Ui.IsArabic ? "جاري التحميل..." : "Loading…")"
                        NotFoundTitle="@(Store.Ui.IsArabic ? "الطلب غير موجود" : "Order not found")"
                        BackLabel="@(Store.Ui.IsArabic ? "كل الطلبات" : "All orders")"
                        ItemsLabel="@(Store.Ui.IsArabic ? "العناصر" : "Items")"
                        TotalLabel="@(Store.Ui.IsArabic ? "الإجمالي" : "Total")"
                        VendorLabel="@(Store.Ui.IsArabic ? "المتجر" : "Store")"
                        PickupLabel="@(Store.Ui.IsArabic ? "الاستلام" : "Pickup")"
                        PaymentLabel="@(Store.Ui.IsArabic ? "الدفع (في المتجر)" : "Payment (at pickup)")"
                        CashTenderedLabel="@(Store.Ui.IsArabic ? "المبلغ المتوقع" : "Cash tendered")"
                        ExpectedChangeLabel="@(Store.Ui.IsArabic ? "الباقي المتوقع" : "Expected change")"
                        NotesLabel="@(Store.Ui.IsArabic ? "ملاحظاتك" : "Notes")"
                        CancelLabel="@(Store.Ui.IsArabic ? "إلغاء الطلب" : "Cancel order")"
                        OnCancel="Cancel" />
}

@code {
    [Parameter] public Guid Id { get; set; }
    [SupplyParameterFromQuery(Name = "just")] public string? Just { get; set; }
    private OrderApi? OrderData;
    private bool Loading = true;
    private bool JustCreated => Just == "1";

    private OrderDetailsDto? Mapped => OrderData is null ? null : new OrderDetailsDto
    {
        Id = OrderData.Id.ToString(),
        OrderNumber = OrderData.OrderNumber,
        Total = OrderData.Total,
        Currency = OrderData.Currency,
        Status = StatusKey(OrderData.Status),
        StatusLabel = OrderData.StatusAr,
        CreatedAt = OrderData.CreatedAt,
        Vendor = OrderData.Vendor is null ? null : new VendorMiniDto
        {
            Id = OrderData.Vendor.Id.ToString(),
            Name = OrderData.Vendor.Name,
            LogoEmoji = OrderData.Vendor.LogoEmoji,
            Phone = OrderData.Vendor.Phone
        },
        Items = OrderData.Items.Select(i => new CartLineDto
        {
            OfferId = i.Id.ToString(),
            Title = i.OfferTitle,
            Emoji = i.Emoji,
            UnitPrice = i.UnitPrice,
            Quantity = i.Quantity
        }).ToList(),
        PickupType = OrderData.PickupType == 1 ? "Curbside" : "InStore",
        PickupLabel = OrderData.PickupType == 1
            ? (Store.Ui.IsArabic ? "من السيارة" : "Curbside")
            : (Store.Ui.IsArabic ? "من المتجر" : "In-store"),
        PaymentMethod = OrderData.PreferredPayment == 1 ? "Card" : "Cash",
        PaymentLabel = OrderData.PreferredPayment == 1
            ? (Store.Ui.IsArabic ? "بطاقة" : "Card")
            : (Store.Ui.IsArabic ? "نقدي" : "Cash"),
        CashTendered = OrderData.CashTendered,
        ExpectedChange = OrderData.ExpectedChange,
        CustomerNotes = OrderData.CustomerNotes,
        CarModel = OrderData.CarModel,
        CarColor = OrderData.CarColor,
        CarPlate = OrderData.CarPlate,
        CanCancel = OrderData.Status == 0 || OrderData.Status == 1
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var env = await Api.GetAsync<OrderApi>($"/api/orders/{Id}");
        OrderData = env.Data;
        Loading = false;
        StateHasChanged();
    }

    private async Task Cancel()
    {
        var result = await Engine.ExecuteAsync<object>(ClientOps.CancelOrder(Id), new { });
        if (result.Operation.Status == "Success")
        {
            var refresh = await Api.GetAsync<OrderApi>($"/api/orders/{Id}");
            OrderData = refresh.Data;
        }
    }

    private static string StatusKey(int s) => s switch
    {
        0 => "pending",
        1 => "accepted",
        2 => "ready",
        3 => "delivered",
        4 => "cancelled",
        _ => "pending"
    };

    public class OrderApi
    {
        public Guid Id { get; set; }
        public string OrderNumber { get; set; } = "";
        public decimal Total { get; set; }
        public decimal Subtotal { get; set; }
        public string Currency { get; set; } = "SAR";
        public int Status { get; set; }
        public string StatusAr { get; set; } = "";
        public int PickupType { get; set; }
        public int PreferredPayment { get; set; }
        public decimal? CashTendered { get; set; }
        public decimal? ExpectedChange { get; set; }
        public string? CarModel { get; set; }
        public string? CarColor { get; set; }
        public string? CarPlate { get; set; }
        public string? CustomerNotes { get; set; }
        public DateTime CreatedAt { get; set; }
        public VendorApi? Vendor { get; set; }
        public List<ItemApi> Items { get; set; } = new();
    }

    public class VendorApi
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public string Phone { get; set; } = "";
        public string LogoEmoji { get; set; } = "🏪";
    }

    public class ItemApi
    {
        public Guid Id { get; set; }
        public string OfferTitle { get; set; } = "";
        public string Emoji { get; set; } = "🍽️";
        public int Quantity { get; set; }
        public decimal UnitPrice { get; set; }
        public decimal LineTotal { get; set; }
    }
}
