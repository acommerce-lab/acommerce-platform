@page "/messages"
@inject OrderApiClient Api
@inject AuthStateService Auth
@inject UiPreferences Ui
@inject NavigationManager Nav

<PageTitle>المحادثات - اوردر</PageTitle>

@if (!Auth.IsAuthenticated)
{
    <AcEmptyState IconName="message"
                  Title="@(Ui.IsArabic ? "سجّل دخولك لرؤية المحادثات" : "Sign in to chat")"
                  ActionLabel="@(Ui.IsArabic ? "تسجيل الدخول" : "Sign in")"
                  ActionHref="/login" />
}
else
{
    <AcMessagesListPage Conversations="@Mapped"
                        Loading="@Loading"
                        Title="@(Ui.IsArabic ? "محادثاتي" : "Messages")"
                        LoadingMessage="@(Ui.IsArabic ? "جاري التحميل..." : "Loading…")"
                        EmptyTitle="@(Ui.IsArabic ? "لا محادثات بعد" : "No conversations")"
                        EmptyMessage="@(Ui.IsArabic ? "ابدأ من صفحة العرض بزر «محادثة المتجر»" : "Tap \"Chat with store\" on any offer")"
                        OnSelectConversation="@SelectConversation" />
}

@code {
    private List<ConvApi> Conversations = new();
    private bool Loading = true;

    private IReadOnlyList<ConversationRowDto> Mapped =>
        Conversations
            .Where(c => c.LastMessageAt.HasValue) // hide conversations with no messages sent yet
            .Select(c => new ConversationRowDto
            {
                Id = c.Id.ToString(),
                Title = c.Title,
                Emoji = c.Emoji,
                LastMessageSnippet = c.LastMessageSnippet,
                LastMessageAt = c.LastMessageAt,
                Unread = c.Unread
            }).ToList();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Auth.EnsureRestoredAsync();
        if (Auth.IsAuthenticated)
        {
            var env = await Api.GetAsync<List<ConvApi>>($"/api/messages/conversations/by-user/{Auth.UserId}");
            Conversations = env.Data ?? new();
        }
        Loading = false;
        StateHasChanged();
    }

    private void SelectConversation(ConversationRowDto c)
    {
        Nav.NavigateTo($"/chat/{c.Id}");
    }

    public class ConvApi
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = "";
        public string Emoji { get; set; } = "💬";
        public string? LastMessageSnippet { get; set; }
        public DateTime? LastMessageAt { get; set; }
        public int Unread { get; set; }
    }
}
