@page "/search"
@inject OrderApiClient Api
@inject UiPreferences Ui
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>البحث - اوردر</PageTitle>

<AcMapSearchPage Title="@(Ui.IsArabic ? "اكتشف" : "Discover")"
                 Pins="@Pins"
                 Loading="@Loading"
                 SearchQuery="@Query"
                 SearchQueryChanged="@(q => { Query = q; StateHasChanged(); })"
                 SearchPlaceholder="@(Ui.IsArabic ? "متجر، منتج، حي..." : "Store, product, district...")"
                 Categories="@MappedCategories"
                 SelectedCategoryId="@SelectedCategoryId"
                 OnSelectCategory="HandleCategory"
                 AllLabel="@(Ui.IsArabic ? "الكل" : "All")"
                 View="@View"
                 ViewChanged="@(v => { View = v; StateHasChanged(); })"
                 MapViewLabel="@(Ui.IsArabic ? "خريطة" : "Map")"
                 ListViewLabel="@(Ui.IsArabic ? "قائمة" : "List")"
                 SelectedPinId="@SelectedPinId"
                 OnSelectPin="HandleSelect"
                 LoadingMessage="@(Ui.IsArabic ? "جاري التحميل..." : "Loading…")"
                 EmptyTitle="@(Ui.IsArabic ? "لا توجد نتائج" : "No results")"
                 EmptyMessage="@(Ui.IsArabic ? "جرّب فلتراً آخر أو ابحث باسم آخر" : "Try a different filter or search")">
    <FilterExtras>
        @* Mode toggle *@
        <div class="acs-seg" style="margin-bottom:10px;">
            <button type="button"
                    class="acs-seg-btn @(Mode == "vendors" ? "active" : "")"
                    @onclick="@(() => SetMode("vendors"))">
                <AcIcon Name="store" Size="14" />
                @(Ui.IsArabic ? "المتاجر" : "Stores")
            </button>
            <button type="button"
                    class="acs-seg-btn @(Mode == "offers" ? "active" : "")"
                    @onclick="@(() => SetMode("offers"))">
                <AcIcon Name="tag" Size="14" />
                @(Ui.IsArabic ? "العروض" : "Offers")
            </button>
        </div>

        @* Advanced filters — collapsible *@
        <div class="acc-filter-panel @(ShowFilters ? "open" : "")">
            <button type="button" class="acc-filter-toggle" @onclick="@(() => ShowFilters = !ShowFilters)">
                <AcIcon Name="settings" Size="16" />
                <span>@(Ui.IsArabic ? "فلاتر متقدمة" : "Advanced filters")</span>
                <AcIcon Name="@(ShowFilters ? "chevron-down" : "chevron-right")" Size="14" />
            </button>

            @if (ShowFilters)
            {
                <div class="acc-filter-body">
                    @if (Mode == "offers")
                    {
                        @* Has discount *@
                        <label class="acc-filter-check">
                            <input type="checkbox" @bind="OnlyDiscounted" />
                            <span>@(Ui.IsArabic ? "مع خصم فقط" : "Discounted only")</span>
                        </label>

                        @* Price range *@
                        <div class="acc-filter-row">
                            <div class="acc-filter-field">
                                <label class="form-label">@(Ui.IsArabic ? "السعر من" : "Min price")</label>
                                <input type="number" class="form-input" placeholder="0"
                                       value="@MinPrice" @oninput="@(e => { MinPrice = ParseDecimal(e); })" />
                            </div>
                            <div class="acc-filter-field">
                                <label class="form-label">@(Ui.IsArabic ? "إلى" : "Max price")</label>
                                <input type="number" class="form-input" placeholder="∞"
                                       value="@MaxPrice" @oninput="@(e => { MaxPrice = ParseDecimal(e); })" />
                            </div>
                        </div>
                    }

                    @if (Mode == "vendors")
                    {
                        @* Minimum rating *@
                        <div class="acc-filter-field">
                            <label class="form-label">@(Ui.IsArabic ? "الحد الأدنى للتقييم" : "Min rating")</label>
                            <div class="acs-seg">
                                @foreach (var r in new[] { 0, 3.0, 4.0, 4.5 })
                                {
                                    <button type="button"
                                            class="acs-seg-btn @(MinRating == r ? "active" : "")"
                                            @onclick="@(() => MinRating = r)">
                                        @(r == 0 ? (Ui.IsArabic ? "الكل" : "All") : $"★ {r:0.#}+")
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        @* Active filter chips *@
        @if (HasActiveFilters)
        {
            <div class="acc-filter-chips">
                @if (OnlyDiscounted)
                {
                    <button class="acc-filter-chip" @onclick="@(() => OnlyDiscounted = false)">
                        @(Ui.IsArabic ? "خصم" : "Discount") ✕
                    </button>
                }
                @if (MinPrice.HasValue)
                {
                    <button class="acc-filter-chip" @onclick="@(() => MinPrice = null)">
                        ≥ @MinPrice ✕
                    </button>
                }
                @if (MaxPrice.HasValue)
                {
                    <button class="acc-filter-chip" @onclick="@(() => MaxPrice = null)">
                        ≤ @MaxPrice ✕
                    </button>
                }
                @if (MinRating > 0)
                {
                    <button class="acc-filter-chip" @onclick="@(() => MinRating = 0)">
                        ★ @MinRating.ToString("0.#")+ ✕
                    </button>
                }
                <button class="acc-filter-chip acc-filter-chip-clear" @onclick="ClearFilters">
                    @(Ui.IsArabic ? "مسح الكل" : "Clear all")
                </button>
            </div>
        }
    </FilterExtras>
    <DetailsSlot Context="pin">
        @{
            var href = pin.Href;
        }
        <div class="acc-map-sheet-head">
            <div class="acc-map-sheet-emoji">@(pin.Emoji ?? "📍")</div>
            <div class="acc-map-sheet-body">
                <div class="acc-map-sheet-title">@pin.Title</div>
                @if (!string.IsNullOrEmpty(pin.Subtitle))
                {
                    <div class="acc-map-sheet-sub">@pin.Subtitle</div>
                }
            </div>
            @if (!string.IsNullOrEmpty(pin.Badge))
            {
                <span class="acc-search-list-badge">@pin.Badge</span>
            }
        </div>
        @if (!string.IsNullOrEmpty(href))
        {
            <a class="btn btn-primary btn-block" href="@href" style="margin-top:12px;">
                @(Mode == "vendors"
                    ? (Ui.IsArabic ? "عرض قائمة المتجر" : "View store menu")
                    : (Ui.IsArabic ? "عرض التفاصيل" : "View details"))
            </a>
        }
    </DetailsSlot>
</AcMapSearchPage>

@code {
    private List<VendorApi> Vendors = new();
    private List<OfferApi> Offers = new();
    private List<CatApi> Categories = new();
    private bool Loading = true;

    private string Mode = "vendors";
    private string View = "map";
    private string Query = "";
    private Guid? SelectedCategoryGuid;
    private string? SelectedCategoryId => SelectedCategoryGuid?.ToString();
    private string? SelectedPinId;

    // Advanced filters
    private bool ShowFilters;
    private bool OnlyDiscounted;
    private decimal? MinPrice;
    private decimal? MaxPrice;
    private double MinRating;

    private bool HasActiveFilters => OnlyDiscounted || MinPrice.HasValue || MaxPrice.HasValue || MinRating > 0;

    private IReadOnlyList<CategoryDto> MappedCategories =>
        Categories.Select(c => new CategoryDto
        {
            Id = c.Id.ToString(),
            Label = Ui.IsArabic ? c.NameAr : c.NameEn,
            Icon = c.Icon
        }).ToList();

    private IReadOnlyList<MapPinDto> Pins
    {
        get
        {
            var q = (Query ?? "").Trim();
            if (Mode == "vendors")
            {
                return Vendors
                    .Where(v => v.Latitude.HasValue && v.Longitude.HasValue)
                    .Where(v => !SelectedCategoryGuid.HasValue || v.CategoryId == SelectedCategoryGuid.Value)
                    .Where(v => MinRating <= 0 || v.Rating >= MinRating)
                    .Where(v => string.IsNullOrEmpty(q)
                             || v.Name.Contains(q, StringComparison.OrdinalIgnoreCase)
                             || (v.District ?? "").Contains(q, StringComparison.OrdinalIgnoreCase)
                             || (v.City ?? "").Contains(q, StringComparison.OrdinalIgnoreCase))
                    .Select(v => new MapPinDto
                    {
                        Id = v.Id.ToString(),
                        Latitude = v.Latitude!.Value,
                        Longitude = v.Longitude!.Value,
                        Title = v.Name,
                        Subtitle = string.IsNullOrEmpty(v.District) ? v.City : $"{v.City} • {v.District}",
                        Emoji = v.LogoEmoji,
                        Badge = v.Rating > 0 ? $"★ {v.Rating:0.0}" : null,
                        Href = $"/vendor/{v.Id}"
                    }).ToList();
            }
            else
            {
                return Offers
                    .Where(o => o.Vendor != null && o.Vendor.Latitude.HasValue && o.Vendor.Longitude.HasValue)
                    .Where(o => !SelectedCategoryGuid.HasValue || o.CategoryId == SelectedCategoryGuid.Value)
                    .Where(o => !OnlyDiscounted || o.DiscountPercent > 0)
                    .Where(o => !MinPrice.HasValue || o.Price >= MinPrice.Value)
                    .Where(o => !MaxPrice.HasValue || o.Price <= MaxPrice.Value)
                    .Where(o => string.IsNullOrEmpty(q)
                             || o.Title.Contains(q, StringComparison.OrdinalIgnoreCase)
                             || (o.Vendor?.Name ?? "").Contains(q, StringComparison.OrdinalIgnoreCase))
                    .Select(o => new MapPinDto
                    {
                        Id = o.Id.ToString(),
                        Latitude = o.Vendor!.Latitude!.Value,
                        Longitude = o.Vendor!.Longitude!.Value,
                        Title = o.Title,
                        Subtitle = $"{o.Vendor.Name} • {o.Price:0.##} {o.Currency}",
                        Emoji = o.Emoji,
                        Badge = o.DiscountPercent > 0 ? $"-{o.DiscountPercent}%" : null,
                        Href = $"/offer/{o.Id}"
                    }).ToList();
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        Ui.OnChanged += OnUiChange;
        var catEnv = await Api.GetAsync<List<CatApi>>("/api/categories");
        if (catEnv.Data != null) Categories = catEnv.Data;
        var vEnv = await Api.GetAsync<List<VendorApi>>("/api/vendors");
        if (vEnv.Data != null) Vendors = vEnv.Data;
        var oEnv = await Api.GetAsync<List<OfferApi>>("/api/offers");
        if (oEnv.Data != null) Offers = oEnv.Data;
        Loading = false;
    }

    private void OnUiChange() => InvokeAsync(StateHasChanged);

    private void SetMode(string m) { Mode = m; SelectedPinId = null; }

    private void HandleCategory(string? id)
    {
        SelectedCategoryGuid = string.IsNullOrEmpty(id) ? null : Guid.Parse(id);
        SelectedPinId = null;
    }

    private void HandleSelect(MapPinDto pin) => SelectedPinId = pin.Id;

    private void ClearFilters()
    {
        OnlyDiscounted = false;
        MinPrice = null;
        MaxPrice = null;
        MinRating = 0;
    }

    private static decimal? ParseDecimal(ChangeEventArgs e)
        => decimal.TryParse(e.Value?.ToString(), out var d) ? d : null;

    public void Dispose() => Ui.OnChanged -= OnUiChange;

    // ── API shapes ──────────────────────────────────────────────────
    public class CatApi
    {
        public Guid Id { get; set; }
        public string NameAr { get; set; } = "";
        public string NameEn { get; set; } = "";
        public string Icon { get; set; } = "🍔";
    }

    public class VendorApi
    {
        public Guid Id { get; set; }
        public Guid CategoryId { get; set; }
        public string Name { get; set; } = "";
        public string LogoEmoji { get; set; } = "🏪";
        public string City { get; set; } = "";
        public string? District { get; set; }
        public double? Latitude { get; set; }
        public double? Longitude { get; set; }
        public double Rating { get; set; }
    }

    public class OfferApi
    {
        public Guid Id { get; set; }
        public Guid CategoryId { get; set; }
        public string Title { get; set; } = "";
        public decimal Price { get; set; }
        public string Currency { get; set; } = "SAR";
        public string Emoji { get; set; } = "🍽️";
        public int DiscountPercent { get; set; }
        public VendorApiInner? Vendor { get; set; }
    }

    public class VendorApiInner
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public double? Latitude { get; set; }
        public double? Longitude { get; set; }
    }
}
