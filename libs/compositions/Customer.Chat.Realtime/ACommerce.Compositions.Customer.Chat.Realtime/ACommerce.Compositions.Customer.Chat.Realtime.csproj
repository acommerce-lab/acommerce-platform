<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>ACommerce.Compositions.Customer.Chat.Realtime</PackageId>
    <Description>
      composition تَدمج Chat client (OAM-shaped) مَع Realtime hub. تَحقن
      OAM interceptor عَلى تَنفيذ <c>chat.message.send</c> فتَبُثّ الرَسالَة
      للأَطراف الأُخرى. تَستَقبل رَسائل واردة مِن الـ hub وتَدفَعها لِـ
      <see cref="DefaultChatStore.IngestRealtimeMessage"/> فتُحَدِّث الحالة
      المَحَلّيّة فَوراً.
    </Description>
  </PropertyGroup>
  <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\core\OperationEngine\ACommerce.OperationEngine\ACommerce.OperationEngine.csproj" />
    <ProjectReference Include="..\..\..\core\OperationEngine\ACommerce.OperationEngine.Interceptors\ACommerce.OperationEngine.Interceptors.csproj" />
    <ProjectReference Include="..\..\..\kits\Chat\ACommerce.Chat.Operations\ACommerce.Chat.Operations.csproj" />
    <ProjectReference Include="..\..\..\kits\Chat\Frontend\Customer\ACommerce.Kits.Chat.Frontend.Customer.csproj" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.7" />
  </ItemGroup>
</Project>
