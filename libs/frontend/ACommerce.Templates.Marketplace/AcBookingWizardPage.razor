@namespace ACommerce.Templates.Marketplace

@*
    AcBookingWizardPage — مُعالج حجز بسيط.
    بنية 3 خطوات: تواريخ + سعة → مُلخّص → تأكيد.
    Operation-aware:
      - booking.validate_dates (محلّي)
      - booking.hold_room (محلّي)
      - booking.create (العمليّة الأم — تُرسَل للخادم)
*@

<div class="acs-page acm-wizard">
    @if (Listing is null)
    {
        <AcLoadingState />
    }
    else
    {
        <h1 class="acm-wizard-title">حجز: @Listing.Title</h1>

        @if (_step == 1)
        {
            <AcField Label="تاريخ البداية" Required="true">
                <AcInput Type="date" Value="@_startDate" ValueChanged="@(v => _startDate = v ?? string.Empty)" />
            </AcField>
            <AcField Label="عدد الليالي" Required="true">
                <AcInput Type="number" Value="@(_nights.ToString())"
                         ValueChanged="v => _nights = int.TryParse(v, out var n) ? n : 1" />
            </AcField>
            <AcField Label="عدد الأشخاص" Required="true">
                <AcInput Type="number" Value="@(_guests.ToString())"
                         ValueChanged="v => _guests = int.TryParse(v, out var n) ? n : 1" />
            </AcField>
            <AcButton Variant="primary" Size="lg" Text="التالي" OnClick="@(() => _step = 2)" Class="ac-btn-block" />
        }
        else if (_step == 2)
        {
            <AcCard>
                <ChildContent>
                    <h3 style="margin-top:0;">ملخّص الحجز</h3>
                    <p>العرض: <strong>@Listing.Title</strong></p>
                    <p>التاريخ: <strong>@_startDate</strong> — <strong>@_nights</strong> ليلة</p>
                    <p>الأشخاص: <strong>@_guests</strong></p>
                    <p>المجموع: <strong>@(Listing.Price * _nights) @Listing.Currency</strong></p>
                </ChildContent>
            </AcCard>
            <div style="display:flex; gap:8px;">
                <AcButton Variant="ghost" Text="رجوع" OnClick="@(() => _step = 1)" />
                <AcButton Variant="primary" Size="lg" Text="تأكيد الحجز"
                          OnClick="Confirm" Disabled="@_submitting" Class="ac-btn-block" />
            </div>
        }
        else
        {
            <AcCard>
                <ChildContent>
                    <div style="text-align:center; padding:24px;">
                        <AcIcon Name="check-circle" Filled="true" Size="48" />
                        <h2>تمّ تأكيد الحجز</h2>
                        <p>سيتواصل معك المالك قريبًا.</p>
                    </div>
                </ChildContent>
            </AcCard>
        }
    }
</div>

@code {
    [Parameter] public BookingListingDto? Listing { get; set; }
    [Parameter] public ITemplateEngine? Engine { get; set; }
    [Parameter] public ITemplateStore? Store { get; set; }
    [Parameter] public EventCallback<BookingResultDto> OnConfirmed { get; set; }

    private int _step = 1;
    private string _startDate = DateTime.UtcNow.AddDays(7).ToString("yyyy-MM-dd");
    private int _nights = 1;
    private int _guests = 1;
    private bool _submitting;

    private async Task Confirm()
    {
        if (Listing is null) return;
        _submitting = true;
        if (Engine is not null)
        {
            var op = Entry.Create("booking.create")
                .From($"User:{Store?.UserId?.ToString() ?? "anon"}", 1, ("role", "booker"))
                .To($"Listing:{Listing.Id}", 1, ("role", "target"))
                .Tag("nights", _nights.ToString())
                .Tag("guests", _guests.ToString())
                .Tag("start_date", _startDate)
                .Build();
            try
            {
                await Engine.ExecuteAsync<object>(op, new
                {
                    ListingId = Listing.Id,
                    StartDate = _startDate,
                    Nights = _nights,
                    Guests = _guests
                });
            }
            catch { /* fallback to local confirmation */ }
        }
        _submitting = false;
        _step = 3;
        await OnConfirmed.InvokeAsync(new BookingResultDto(
            Listing.Id, _startDate, _nights, _guests, Listing.Price * _nights, Listing.Currency));
    }

    public sealed record BookingListingDto(string Id, string Title, decimal Price, string Currency);
    public sealed record BookingResultDto(string ListingId, string StartDate, int Nights, int Guests, decimal Total, string Currency);
}
