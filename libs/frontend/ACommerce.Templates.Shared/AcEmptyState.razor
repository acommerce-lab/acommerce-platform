@namespace ACommerce.Templates.Shared

@*
    Empty-state template. Consumers inject branding via Icon/Title/Message
    and can add extra rows/buttons via the flex slots.

    Flex slots: ExtraContent (below message), BelowAction (below primary button)
*@

<div class="acs-empty @(ExtraClass ?? "")">
    @if (!string.IsNullOrEmpty(Icon))
    {
        <div class="acs-empty-icon">@((MarkupString)Icon)</div>
    }
    @if (!string.IsNullOrEmpty(Title))
    {
        <h3 class="acs-empty-title">@Title</h3>
    }
    @if (!string.IsNullOrEmpty(Message))
    {
        <p class="acs-empty-message">@Message</p>
    }
    @if (ExtraContent != null)
    {
        <div class="acs-empty-extra">@ExtraContent</div>
    }
    @if (!string.IsNullOrEmpty(ActionLabel))
    {
        @if (!string.IsNullOrEmpty(ActionHref))
        {
            <a class="btn btn-primary" href="@ActionHref">@ActionLabel</a>
        }
        else if (OnAction.HasDelegate)
        {
            <button class="btn btn-primary" @onclick="OnAction">@ActionLabel</button>
        }
    }
    @if (BelowAction != null)
    {
        <div class="acs-empty-below">@BelowAction</div>
    }
</div>

@code {
    [Parameter] public string? Icon { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Message { get; set; }
    [Parameter] public string? ActionLabel { get; set; }
    [Parameter] public string? ActionHref { get; set; }
    [Parameter] public EventCallback OnAction { get; set; }
    [Parameter] public string? ExtraClass { get; set; }
    // Flex slots
    [Parameter] public RenderFragment? ExtraContent { get; set; }
    [Parameter] public RenderFragment? BelowAction { get; set; }
}
