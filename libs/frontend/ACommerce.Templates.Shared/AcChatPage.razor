@namespace ACommerce.Templates.Shared

@*
    Chat bubble stream + input row.

    Callback mode (افتراضي): الصفحة تُمرر Draft وتعالج OnSend.
    Operation mode: القالب يُدير الـ draft ويُرسل العملية مباشرة.
      مطلوب: Engine + BuildSendOp + SenderId.

    Flex slots:
      HeaderSlot        — replaces the default title
      AboveStream       — rendered above the message stream
      AboveInput        — rendered above the text input row
      ExtraInputActions — inside the input row, before send button
*@

<div class="acs-chat-page">
    @if (HeaderSlot != null)
    {
        @HeaderSlot
    }
    else if (!string.IsNullOrEmpty(Title))
    {
        <h1 class="acs-page-title">@Title</h1>
    }

    @AboveStream

    <div class="acs-msg-stream s-card">
        @if (Loading)
        {
            <AcLoadingState Message="@LoadingMessage" />
        }
        else if (Messages.Count == 0)
        {
            <AcEmptyState IconName="message" Message="@(EmptyMessage ?? "ابدأ المحادثة")" />
        }
        else
        {
            @foreach (var m in Messages)
            {
                var mine = m.SenderId == MySenderId;
                <div class="acs-bubble-wrap @(mine ? "mine" : "")">
                    <div class="acs-bubble @(mine ? "acs-bubble-mine" : "acs-bubble-other")">
                        <div class="acs-bubble-content">@m.Content</div>
                        <div class="acs-bubble-time">@m.CreatedAt.ToLocalTime().ToString("HH:mm")</div>
                    </div>
                </div>
            }
        }
    </div>

    @AboveInput

    <div class="acs-msg-input">
        <input type="text"
               class="form-input"
               placeholder="@(InputPlaceholder ?? "اكتب رسالة...")"
               value="@CurrentDraft"
               @oninput="HandleDraftInput"
               @onkeydown="HandleKey"
               disabled="@CurrentSending" />
        @ExtraInputActions
        <button class="btn btn-primary"
                @onclick="HandleSend"
                disabled="@(CurrentSending || string.IsNullOrWhiteSpace(CurrentDraft))">
            @(SendLabel ?? "إرسال")
        </button>
    </div>
</div>

@code {
    // ── وضع التشغيل ────────────────���──────────────────────────────────────
    [Parameter] public TemplateOperationMode Mode { get; set; } = TemplateOperationMode.Callback;

    // ── البيانات ─────────────────────��────────────────────────────────────
    [Parameter] public IReadOnlyList<ChatMessageDto> Messages { get; set; } = Array.Empty<ChatMessageDto>();
    [Parameter] public required string MySenderId { get; set; }
    [Parameter] public bool Loading { get; set; }

    // ── Callback mode ──────────────────────────────────────────────────────
    [Parameter] public bool Sending { get; set; }
    [Parameter] public string Draft { get; set; } = "";
    [Parameter] public EventCallback<string> DraftChanged { get; set; }
    [Parameter] public EventCallback OnSend { get; set; }

    // ── Operation mode ──────────────────────────���──────────────────────────
    [Parameter] public ITemplateEngine? Engine { get; set; }
    [Parameter] public Func<string, Operation>? BuildSendOp { get; set; }
    [Parameter] public Func<string, object>? SendPayload { get; set; }
    [Parameter] public EventCallback<ChatMessageDto> OnMessageSent { get; set; }

    // ── Labels ─────────────────────────────────────────────────────────────
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? LoadingMessage { get; set; }
    [Parameter] public string? EmptyMessage { get; set; }
    [Parameter] public string? InputPlaceholder { get; set; }
    [Parameter] public string? SendLabel { get; set; }

    // ── Flex slots ───────────────��─────────────────────────────────────────
    [Parameter] public RenderFragment? HeaderSlot { get; set; }
    [Parameter] public RenderFragment? AboveStream { get; set; }
    [Parameter] public RenderFragment? AboveInput { get; set; }
    [Parameter] public RenderFragment? ExtraInputActions { get; set; }

    // ── حالة داخلية (Operation mode) ─────────────────��────────────────────
    private string _opDraft = "";
    private bool _opSending;

    private string CurrentDraft => Mode == TemplateOperationMode.Operation ? _opDraft : Draft;
    private bool CurrentSending => Mode == TemplateOperationMode.Operation ? _opSending : Sending;

    private async Task HandleDraftInput(ChangeEventArgs e)
    {
        var v = e.Value?.ToString() ?? "";
        if (Mode == TemplateOperationMode.Operation)
            _opDraft = v;
        else
        {
            Draft = v;
            if (DraftChanged.HasDelegate) await DraftChanged.InvokeAsync(Draft);
        }
    }

    private async Task HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(CurrentDraft) && !CurrentSending)
            await HandleSend();
    }

    private async Task HandleSend()
    {
        if (Mode == TemplateOperationMode.Operation)
            await OpSend();
        else if (OnSend.HasDelegate)
            await OnSend.InvokeAsync();
    }

    private async Task OpSend()
    {
        if (Engine == null || BuildSendOp == null || string.IsNullOrWhiteSpace(_opDraft)) return;
        _opSending = true;
        var text = _opDraft;
        _opDraft = "";
        try
        {
            var payload = SendPayload != null ? SendPayload(text) : (object)new { content = text };
            var op = BuildSendOp(text);
            var result = await Engine.ExecuteAsync<ChatMessageDto>(op, payload);
            if (result.Data != null && OnMessageSent.HasDelegate)
                await OnMessageSent.InvokeAsync(result.Data);
        }
        finally { _opSending = false; }
    }
}
