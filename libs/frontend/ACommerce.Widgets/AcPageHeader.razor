@namespace ACommerce.Widgets

<div class="ac-row-between ac-mb-lg @(Class ?? "")">
    <div>
        @if (!string.IsNullOrEmpty(Title)) { <h1 class="ac-text-xl">@Title</h1> }
        @if (!string.IsNullOrEmpty(Subtitle)) { <p class="ac-text-muted">@Subtitle</p> }
    </div>
    @if (Actions != null) { <div class="ac-row">@Actions</div> }
</div>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
    [Parameter] public string? Class { get; set; }
}
