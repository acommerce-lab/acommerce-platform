@namespace ACommerce.Widgets

@*
    AcIcon — monochrome line icons with currentColor.

    Every icon is a self-contained 24x24 inline SVG. Stroke uses currentColor
    so the icon inherits the text color of the parent element. Set color on
    any ancestor (or via var(--ac-primary)) to rebrand instantly.

    Usage:
        <AcIcon Name="home" />
        <AcIcon Name="cart" Size="20" />
        <AcIcon Name="heart" Filled="true" />
        <AcIcon Name="bell" ExtraClass="my-icon" />

    If Name is not a known icon, a circle placeholder is rendered so a missing
    mapping is visually obvious during development.

    The glyph library is intentionally small (~25 icons) — just the structural
    chrome needed by the shared + commerce templates. Data-driven emojis
    (vendor.logoEmoji, offer.emoji) stay as-is because they are content, not
    chrome.
*@

<svg class="ac-icon @(ExtraClass ?? "")"
     width="@Size"
     height="@Size"
     viewBox="0 0 24 24"
     fill="@(Filled ? "currentColor" : "none")"
     stroke="currentColor"
     stroke-width="@StrokeWidth.ToString(System.Globalization.CultureInfo.InvariantCulture)"
     stroke-linecap="round"
     stroke-linejoin="round"
     aria-hidden="true"
     focusable="false">
    @((MarkupString)GetPath(Name))
</svg>

@code {
    [Parameter, EditorRequired] public string Name { get; set; } = "";
    [Parameter] public int Size { get; set; } = 24;
    [Parameter] public double StrokeWidth { get; set; } = 1.75;
    /// <summary>When true, the icon's path is filled with currentColor (e.g. filled heart).</summary>
    [Parameter] public bool Filled { get; set; }
    [Parameter] public string? ExtraClass { get; set; }

