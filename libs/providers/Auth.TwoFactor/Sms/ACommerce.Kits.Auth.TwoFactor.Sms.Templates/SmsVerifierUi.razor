@*
  SMS-specific verifier. Two-step UI: enter phone → request OTP → enter
  6-digit code → verify. Calls /auth/otp/request and /auth/otp/verify on the
  backend (which the Auth Kit's AuthController already exposes).

  This component lives in the SMS provider's templates package — Nafath's,
  Email's, or any future provider's UI is its own component. The Auth shell
  (AcLoginPage) doesn't know which one is in use.
*@

@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components
@inject HttpClient Http
@inject NavigationManager Nav

<div class="ac-sms-verifier">
    @if (_step == Step.Phone)
    {
        <label class="ac-label">@(PhoneLabel ?? "رقم الجوّال")</label>
        <input class="ac-input" type="tel" inputmode="tel"
               @bind="_phone" placeholder="@(PhonePlaceholder ?? "+9665XXXXXXXX")" />
        <button class="ac-btn ac-btn-primary"
                disabled="@(_busy || string.IsNullOrWhiteSpace(_phone))"
                @onclick="@RequestOtp">
            @(SendLabel ?? "إرسال الرمز")
        </button>
    }
    else if (_step == Step.Code)
    {
        <p class="ac-sms-hint">@(CodeHint ?? $"أدخل الرمز المُرسَل إلى {_maskedPhone}")</p>
        <input class="ac-input" type="text" inputmode="numeric" maxlength="6"
               @bind="_code" placeholder="6 أرقام" />
        <button class="ac-btn ac-btn-primary"
                disabled="@(_busy || _code.Length != 6)"
                @onclick="@VerifyOtp">
            @(VerifyLabel ?? "تحقّق")
        </button>
        <button class="ac-btn ac-btn-ghost" @onclick="@(() => _step = Step.Phone)">
            @(ChangeLabel ?? "تغيير الرقم")
        </button>
    }

    @if (!string.IsNullOrEmpty(_error))
    {
        <p class="ac-error">@_error</p>
    }
</div>

@code {
    [Parameter] public string? PhoneLabel       { get; set; }
    [Parameter] public string? PhonePlaceholder { get; set; }
    [Parameter] public string? SendLabel        { get; set; }
    [Parameter] public string? VerifyLabel      { get; set; }
    [Parameter] public string? ChangeLabel      { get; set; }
    [Parameter] public string? CodeHint         { get; set; }

    /// <summary>Where to navigate on successful verify. Default: "/".</summary>
    [Parameter] public string  RedirectUrl { get; set; } = "/";

    /// <summary>Optional callback invoked with the verify response so the host
    /// app can persist token + user details into its AppStore.</summary>
    [Parameter] public EventCallback<AuthVerifyResponse> OnVerified { get; set; }

    private Step    _step = Step.Phone;
    private string  _phone = "";
    private string  _code  = "";
    private string  _maskedPhone = "";
    private string? _error;
    private bool    _busy;

    private enum Step { Phone, Code }

    private async Task RequestOtp()
    {
        _busy = true; _error = null;
        try
        {
            var resp = await Http.PostAsJsonAsync("/auth/otp/request", new { phone = _phone });
            if (!resp.IsSuccessStatusCode) { _error = "تعذّر إرسال الرمز"; return; }
            _maskedPhone = _phone[^4..].PadLeft(_phone.Length, '*');
            _step = Step.Code;
        }
        finally { _busy = false; }
    }

    private async Task VerifyOtp()
    {
        _busy = true; _error = null;
        try
        {
            var resp = await Http.PostAsJsonAsync("/auth/otp/verify",
                new { phone = _phone, code = _code });
            if (!resp.IsSuccessStatusCode) { _error = "رمز غير صحيح"; return; }
            var data = await resp.Content.ReadFromJsonAsync<AuthVerifyResponse>();
            if (data is not null && OnVerified.HasDelegate) await OnVerified.InvokeAsync(data);
            Nav.NavigateTo(RedirectUrl);
        }
        finally { _busy = false; }
    }

    public sealed record AuthVerifyResponse(string Token, string UserId, string Name, string Phone, string Role);
}
