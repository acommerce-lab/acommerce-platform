<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>ACommerce.Kits.Notifications</PackageId>
    <Version>1.0.0</Version>
    <Description>
      Meta-package: Notifications stack — push delivery (InApp + Firebase) + inbox API.
        - ACommerce.Notification.Operations               (Notifier + INotificationChannel)
        - ACommerce.Notification.Providers.InApp          (push via realtime hub)
        - ACommerce.Notification.Providers.Firebase       (FCM, opt-in)
        - ACommerce.Kits.Notifications.Backend            (inbox controller + INotificationStore)
      Apps wire it as:
          builder.Services.AddInAppNotificationChannel(o => o.MethodName = "ReceiveNotification");
          builder.Services.AddFirebaseNotificationChannel(cfg);  // optional
          builder.Services.AddNotificationsKit&lt;MyNotifStore&gt;();
    </Description>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\backend\messaging\ACommerce.Notification.Operations\ACommerce.Notification.Operations.csproj" />
    <ProjectReference Include="..\..\..\backend\messaging\ACommerce.Notification.Providers.InApp\ACommerce.Notification.Providers.InApp.csproj" />
    <ProjectReference Include="..\..\..\backend\messaging\ACommerce.Notification.Providers.Firebase\ACommerce.Notification.Providers.Firebase.csproj" />
    <ProjectReference Include="..\ACommerce.Kits.Notifications.Backend\ACommerce.Kits.Notifications.Backend.csproj" />
  </ItemGroup>
</Project>
