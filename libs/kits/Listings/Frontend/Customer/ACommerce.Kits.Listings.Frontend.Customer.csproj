<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>ACommerce.Kits.Listings.Frontend.Customer</PackageId>
    <Version>1.0.0</Version>
    <Description>Customer-facing UI for the Listings kit: widgets, IListingsApiClient (knows /listings wire shape) + default HttpListingsApiClient impl, IListingsStore reactive store. The app injects HttpClient and the kit peels OperationEnvelope itself — no shape knowledge in app bindings.</Description>
    <RazorLangVersion>latest</RazorLangVersion>
  </PropertyGroup>
  <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\ACommerce.Kits.Listings.Operations\ACommerce.Kits.Listings.Operations.csproj" />
    <ProjectReference Include="..\..\..\..\host-client\ACommerce.ClientHost\ACommerce.ClientHost.csproj" />
    <ProjectReference Include="..\..\..\..\core\OperationEngine\ACommerce.OperationEngine.Wire\ACommerce.OperationEngine.Wire.csproj" />
    <ProjectReference Include="..\..\..\..\templates\OAM\ACommerce.Templates.OAM\ACommerce.Templates.OAM.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Http" Version="10.0.7" />
  </ItemGroup>
</Project>
