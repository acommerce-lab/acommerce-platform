@namespace ACommerce.Templates.Shared
@using ACommerce.Client.Operations
@using ACommerce.OperationEngine.Core
@inject NavigationManager Nav

@*
    Phone-OTP login template — يعمل في وضعين:

    ┌─ Callback (الوضع الافتراضي) ──────────────────────────────────────────┐
    │  الصفحة تتحكم في Step / Phone / Code وتعالج OnRequestOtp / OnVerifyOtp │
    │  متوافق مع الكود القديم — لا تغيير مطلوب على الصفحات الموجودة.        │
    └───────────────────────────────────────────────────────────────────────┘

    ┌─ Operation (الوضع الجديد) ────────────────────────────────────────────┐
    │  القالب يُدير حالته الداخلية بالكامل.                                 │
    │  الصفحة تُمرر فقط:                                                    │
    │    Engine="@Engine"                                                    │
    │    BuildRequestOtpOp="@(p => ClientOps.RequestOtp(p))"                │
    │    BuildVerifyOtpOp="@((uid,cid,code) => ClientOps.VerifyOtp(...))"   │
    │    RedirectUrl="/"                                                     │
    │  اختياري: PhonePayload / VerifyPayload لتمرير بيانات إضافية.          │
    └───────────────────────────────────────────────────────────────────────┘

    Flex slots (في كلا الوضعين):
      HeroExtra     — أسفل العلامة التجارية
      HintSlot      — أسفل الاستمارة
      FooterExtra   — أسفل البطاقة
*@

<div class="acs-auth-page">
    <div class="acs-auth-hero">
        @if (!string.IsNullOrEmpty(BrandIcon))
        {
            <div class="acs-auth-icon">@((MarkupString)BrandIcon)</div>
        }
        @if (!string.IsNullOrEmpty(BrandName))
        {
            <h1 class="acs-auth-brand">@BrandName</h1>
        }
        @if (!string.IsNullOrEmpty(BrandTagline))
        {
            <p class="acs-auth-tag">@BrandTagline</p>
        }
        @HeroExtra
    </div>

    <div class="acs-auth-card">
        @if (CurrentStep == 1)
        {
            <h2 class="acs-auth-title">@(PhoneStepTitle ?? "مرحباً بك")</h2>
            <p class="acs-auth-subtitle">@(PhoneStepSubtitle ?? "أدخل رقم جوالك للمتابعة")</p>

            <label class="form-label">@(PhoneLabel ?? "رقم الجوال")</label>
            <input class="form-input" type="tel" inputmode="numeric"
                   placeholder="@(PhonePlaceholder ?? "+966500000001")"
                   value="@CurrentPhone"
                   @oninput="HandlePhoneInput" />

            @if (!string.IsNullOrEmpty(CurrentError))
            {
                <div class="alert alert-danger" style="margin-top: 12px">@CurrentError</div>
            }

            <button class="btn btn-primary btn-block" style="margin-top: 16px"
                    @onclick="HandleRequestOtp" disabled="@CurrentBusy">
                @if (CurrentBusy)
                {
                    <span>@(SendingLabel ?? "جاري الإرسال...")</span>
                }
                else
                {
                    <span>@(RequestOtpLabel ?? "إرسال رمز التحقق")</span>
                }
            </button>
        }
        else
        {
            <h2 class="acs-auth-title">@(OtpStepTitle ?? "رمز التحقق")</h2>
            <p class="acs-auth-subtitle">
                @(OtpStepSubtitle ?? "أدخل الرمز المرسل إلى")<br />
                <strong dir="ltr">@CurrentPhone</strong>
            </p>

            <label class="form-label">@(OtpLabel ?? "رمز التحقق (6 أرقام)")</label>
            <input class="form-input acs-otp-input" type="text" inputmode="numeric"
                   maxlength="6" placeholder="000000"
                   value="@CurrentCode"
                   @oninput="HandleCodeInput" />

            @if (!string.IsNullOrEmpty(CurrentError))
            {
                <div class="alert alert-danger" style="margin-top: 12px">@CurrentError</div>
            }

            <button class="btn btn-primary btn-block" style="margin-top: 16px"
                    @onclick="HandleVerifyOtp" disabled="@CurrentBusy">
                @if (CurrentBusy)
                {
                    <span>@(VerifyingLabel ?? "جاري التحقق...")</span>
                }
                else
                {
                    <span>@(VerifyOtpLabel ?? "تحقق ودخول")</span>
                }
            </button>
            <button class="btn btn-ghost btn-block" style="margin-top: 8px" @onclick="HandleBack">
                @(BackLabel ?? "تغيير رقم الجوال")
            </button>
        }

        @if (HintSlot != null)
        {
            <div class="acs-auth-hint">@HintSlot</div>
        }
    </div>

    @FooterExtra
</div>

@code {
    // ── وضع التشغيل ───────────────────────────────────────────────────────
    [Parameter] public TemplateOperationMode Mode { get; set; } = TemplateOperationMode.Callback;

    // ── Callback mode — الصفحة تتحكم ─────────────────────────────────────
    [Parameter] public int Step { get; set; } = 1;
    [Parameter] public string Phone { get; set; } = "";
    [Parameter] public EventCallback<string> PhoneChanged { get; set; }
    [Parameter] public string Code { get; set; } = "";
    [Parameter] public EventCallback<string> CodeChanged { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public bool Busy { get; set; }
    [Parameter] public EventCallback OnRequestOtp { get; set; }
    [Parameter] public EventCallback OnVerifyOtp { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }

    // ── Operation mode — القالب يتحكم ─────────────────────────────────────
    [Parameter] public ITemplateEngine? Engine { get; set; }
    [Parameter] public Func<string, Operation>? BuildRequestOtpOp { get; set; }
    [Parameter] public Func<Guid, string, string, Operation>? BuildVerifyOtpOp { get; set; }
    [Parameter] public Func<string, object>? PhonePayload { get; set; }
    [Parameter] public Func<Guid, string, string, object>? VerifyPayload { get; set; }
    [Parameter] public string RedirectUrl { get; set; } = "/";

    // ── Brand ──────────────────────────────────────────────────────────────
    [Parameter] public string? BrandIcon { get; set; }
    [Parameter] public string? BrandName { get; set; }
    [Parameter] public string? BrandTagline { get; set; }

    // ── Labels ─────────────────────────────────────────────────────────────
    [Parameter] public string? PhoneStepTitle { get; set; }
    [Parameter] public string? PhoneStepSubtitle { get; set; }
    [Parameter] public string? PhoneLabel { get; set; }
    [Parameter] public string? PhonePlaceholder { get; set; }
    [Parameter] public string? RequestOtpLabel { get; set; }
    [Parameter] public string? SendingLabel { get; set; }
    [Parameter] public string? OtpStepTitle { get; set; }
    [Parameter] public string? OtpStepSubtitle { get; set; }
    [Parameter] public string? OtpLabel { get; set; }
    [Parameter] public string? VerifyOtpLabel { get; set; }
    [Parameter] public string? VerifyingLabel { get; set; }
    [Parameter] public string? BackLabel { get; set; }

    // ── Flex slots ─────────────────────────────────────────────────────────
    [Parameter] public RenderFragment? HeroExtra { get; set; }
    [Parameter] public RenderFragment? HintSlot { get; set; }
    [Parameter] public RenderFragment? FooterExtra { get; set; }

    // ── حالة داخلية (Operation mode) ──────────────────────────────────────
    private int _opStep = 1;
    private string _opPhone = "";
    private string _opCode = "";
    private string _opError = "";
    private bool _opBusy;
    private string _challengeId = "";
    private Guid _pendingUserId;

    // ── بوابات موحّدة — تقرأ من المصدر الصحيح حسب الوضع ──────────────────
    private int CurrentStep => Mode == TemplateOperationMode.Operation ? _opStep : Step;
    private string CurrentPhone => Mode == TemplateOperationMode.Operation ? _opPhone : Phone;
    private string CurrentCode => Mode == TemplateOperationMode.Operation ? _opCode : Code;
    private string? CurrentError => Mode == TemplateOperationMode.Operation ? _opError : Error;
    private bool CurrentBusy => Mode == TemplateOperationMode.Operation ? _opBusy : Busy;

    private async Task HandlePhoneInput(ChangeEventArgs e)
    {
        var v = e.Value?.ToString() ?? "";
        if (Mode == TemplateOperationMode.Operation)
            _opPhone = v;
        else
        {
            Phone = v;
            if (PhoneChanged.HasDelegate) await PhoneChanged.InvokeAsync(Phone);
        }
    }

    private async Task HandleCodeInput(ChangeEventArgs e)
    {
        var v = e.Value?.ToString() ?? "";
        if (Mode == TemplateOperationMode.Operation)
            _opCode = v;
        else
        {
            Code = v;
            if (CodeChanged.HasDelegate) await CodeChanged.InvokeAsync(Code);
        }
    }

    private async Task HandleRequestOtp()
    {
        if (Mode == TemplateOperationMode.Operation)
            await OpRequestOtp();
        else if (OnRequestOtp.HasDelegate)
            await OnRequestOtp.InvokeAsync();
    }

    private async Task HandleVerifyOtp()
    {
        if (Mode == TemplateOperationMode.Operation)
            await OpVerifyOtp();
        else if (OnVerifyOtp.HasDelegate)
            await OnVerifyOtp.InvokeAsync();
    }

    private async Task HandleBack()
    {
        if (Mode == TemplateOperationMode.Operation)
        {
            _opStep = 1;
            _opError = "";
        }
        else if (OnBack.HasDelegate)
            await OnBack.InvokeAsync();
    }

    // ── Operation mode — منطق داخلي ───────────────────────────────────────

    private async Task OpRequestOtp()
    {
        if (Engine == null || BuildRequestOtpOp == null) return;
        _opError = "";
        if (string.IsNullOrWhiteSpace(_opPhone)) { _opError = "أدخل رقم الهاتف"; return; }
        _opBusy = true;
        try
        {
            var payload = PhonePayload != null ? PhonePayload(_opPhone) : (object)new { phoneNumber = _opPhone };
            var op = BuildRequestOtpOp(_opPhone);
            var result = await Engine.ExecuteAsync<OtpRequestResult>(op, payload);
            if (result.Operation.Status != "Success" || result.Data == null)
            {
                _opError = result.Operation.ErrorMessage ?? result.Error?.Message ?? "فشل طلب الرمز";
                return;
            }
            _challengeId = result.Data.ChallengeId;
            _pendingUserId = result.Data.UserId;
            _opStep = 2;
        }
        catch (Exception ex) { _opError = ex.Message; }
        finally { _opBusy = false; }
    }

    private async Task OpVerifyOtp()
    {
        if (Engine == null || BuildVerifyOtpOp == null) return;
        _opError = "";
        if (string.IsNullOrWhiteSpace(_opCode)) return;
        _opBusy = true;
        try
        {
            var payload = VerifyPayload != null
                ? VerifyPayload(_pendingUserId, _challengeId, _opCode)
                : (object)new { userId = _pendingUserId, challengeId = _challengeId, code = _opCode };
            var op = BuildVerifyOtpOp(_pendingUserId, _challengeId, _opCode);
            var result = await Engine.ExecuteAsync<VerifyResult>(op, payload);
            if (result.Operation.Status != "Success" || result.Data == null)
            {
                _opError = result.Operation.ErrorMessage ?? result.Error?.Message ?? "كود غير صحيح";
                return;
            }
            // StateBridge تطبّق تلقائياً داخل Engine — ننتقل للصفحة المستهدفة
            Nav.NavigateTo(RedirectUrl);
        }
        catch (Exception ex) { _opError = ex.Message; }
        finally { _opBusy = false; }
    }

    // DTOs داخلية لقراءة ردود OTP في Operation mode
    private class OtpRequestResult
    {
        public string ChallengeId { get; set; } = "";
        public Guid UserId { get; set; }
    }

    private class VerifyResult
    {
        public Guid UserId { get; set; }
        public string? PhoneNumber { get; set; }
        public string AccessToken { get; set; } = "";
    }
}
