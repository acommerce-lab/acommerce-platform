<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>ACommerce.Kits.Subscriptions.Backend</PackageId>
    <Version>1.0.0</Version>
    <Description>Drop-in subscriptions kit: SubscriptionsController + PlansController + InvoicesController over a small store contract. Trial.OpenAccess flag short-circuits to a synthetic active subscription so apps can launch with no payments wired.</Description>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\ACommerce.Subscriptions.Operations\ACommerce.Subscriptions.Operations.csproj" />
    <ProjectReference Include="..\..\..\core\OperationEngine\ACommerce.OperationEngine\ACommerce.OperationEngine.csproj" />
    <ProjectReference Include="..\..\..\core\OperationEngine\ACommerce.OperationEngine.Wire\ACommerce.OperationEngine.Wire.csproj" />
    <ProjectReference Include="..\..\..\core\OperationEngine\ACommerce.OperationEngine.AspNetCore\ACommerce.OperationEngine.AspNetCore.csproj" />
  </ItemGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
</Project>
