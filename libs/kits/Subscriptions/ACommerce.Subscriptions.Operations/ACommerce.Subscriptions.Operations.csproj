<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>ACommerce.Subscriptions.Operations</PackageId>
    <Version>1.0.0</Version>
    <Authors>ACommerce</Authors>
    <Description>General-purpose subscriptions/plans library on top of OperationEngine.Interceptors. Defines IPlan + ISubscription interfaces (no concrete entities), and provides QuotaInterceptor + QuotaConsumptionInterceptor that auto-inject into ANY operation marked with a quota_check tag - regardless of which library built that operation.</Description>
  </PropertyGroup>
  <ItemGroup>
    <!-- Microsoft.Extensions.* are needed for ILogger<T> + IServiceCollection
         (used by QuotaInterceptor + SubscriptionGateInterceptor). FrameworkReference
         Microsoft.AspNetCore.App is NOT needed — neither interceptor touches HttpContext
         (SubscriptionGate resolves user from operation tags/parties). Adding it would
         propagate into WASM via Subscriptions.Templates → Customer.UI → WebAssembly. -->
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.7" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\core\OperationEngine\ACommerce.OperationEngine\ACommerce.OperationEngine.csproj" />
    <ProjectReference Include="..\..\..\core\OperationEngine\ACommerce.OperationEngine.Interceptors\ACommerce.OperationEngine.Interceptors.csproj" />
    <ProjectReference Include="..\..\..\core\SharedKernel\ACommerce.SharedKernel.Domain\ACommerce.SharedKernel.Domain.csproj" />
    <ProjectReference Include="..\..\..\core\SharedKernel\ACommerce.SharedKernel.Repositories\ACommerce.SharedKernel.Repositories.csproj" />
  </ItemGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Release' AND '$(ACOMMERCE_BUILD_MODE)' != 'CLOUD'">
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
  </PropertyGroup>
</Project>

