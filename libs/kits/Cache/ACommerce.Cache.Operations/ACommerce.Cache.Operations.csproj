<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>ACommerce.Cache.Operations</PackageId>
    <Version>1.0.0</Version>
    <Description>Cache abstraction. Defines ICache (Get/Set/Increment/SetIfNotExists/GetOrSet/AcquireLock) and CacheEntryOptions (TTL + sliding expiration). Apps depend on this; concrete providers (InMemory, Redis) are DI-injected in Program.cs only.</Description>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.7" />
  </ItemGroup>
</Project>
