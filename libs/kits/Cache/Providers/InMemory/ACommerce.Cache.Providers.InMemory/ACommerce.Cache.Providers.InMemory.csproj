<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>ACommerce.Cache.Providers.InMemory</PackageId>
    <Version>1.0.0</Version>
    <Description>In-process implementation of ICache. Suited for development, single-instance deployments, and tests. NOT for multi-instance production — state is per-process.</Description>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\ACommerce.Cache.Operations\ACommerce.Cache.Operations.csproj" />
    <PackageReference Include="Microsoft.Extensions.Caching.Memory" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.0" />
  </ItemGroup>
</Project>
