<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>ACommerce.Cache.Providers.Redis</PackageId>
    <Version>1.0.0</Version>
    <Description>Redis implementation of ICache. Built on StackExchange.Redis. Multi-instance safe; suitable for production. Re-exports IConnectionMultiplexer so other libs (e.g. SignalR backplane) can share the same connection pool.</Description>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\ACommerce.Cache.Operations\ACommerce.Cache.Operations.csproj" />
    <PackageReference Include="StackExchange.Redis" Version="2.12.14" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.7" />
  </ItemGroup>
</Project>
