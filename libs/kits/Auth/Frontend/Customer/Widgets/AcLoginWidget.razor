@inject IAuthStore Auth
@inject NavigationManager Nav
@implements IDisposable

@*
    AcLoginWidget — تَدَفّق OTP بدون OamAnalyzerStrip.
    التَحقّق بسيط ومَرن: ٨ أرقام أو أكثر. السيرفر يَفرض الصيغة النهائيّة.
*@

<section class="ejar-login">
    <div class="ejar-login-card">
        <header class="ejar-login-head">
            <span class="ejar-login-glyph" aria-hidden="true">▣</span>
            <h1>@(_step == Step.Phone ? "تَسجيل الدخول" : "أَدخِل الرمز")</h1>
            <p class="ejar-login-sub">
                @(_step == Step.Phone
                    ? "أَدخِل رقم جوالك لاستلام رمز التَفعيل."
                    : "أَدخل الرمز الذي وَصلك.")
            </p>
        </header>

        @if (_step == Step.Phone)
        {
            <label class="ejar-field">
                <span>رقم الجوال</span>
                <input class="ac-input oam-mono" type="tel" inputmode="tel"
                       placeholder="مثال: 771234567"
                       value="@_phone"
                       @oninput="OnPhoneInput" />
            </label>

            @if (_phoneAttempted && !_phoneValid)
            {
                <p class="ac-hint">⚠ أَدخل رقماً صالحاً (٨ أرقام أو أكثر).</p>
            }

            <button class="oam-btn ejar-login-btn"
                    disabled="@(!_phoneValid || Auth.IsBusy)"
                    @onclick="RequestOtp">
                @(Auth.IsBusy ? "جاري الإرسال…" : "إرسال الرمز")
            </button>
        }
        else
        {
            <label class="ejar-field">
                <span>الرمز</span>
                <input class="ac-input oam-mono ejar-otp-input" type="text" inputmode="numeric"
                       maxlength="6" placeholder="●●●●●●"
                       value="@_code"
                       @oninput="OnCodeInput" />
            </label>

            <button class="oam-btn ejar-login-btn"
                    disabled="@(!_codeValid || Auth.IsBusy)"
                    @onclick="VerifyOtp">
                @(Auth.IsBusy ? "جاري التحقّق…" : "تَأكيد الرمز")
            </button>

            <button class="oam-btn-ghost ejar-login-back" type="button"
                    @onclick="BackToPhone">
                ← تَغيير الرقم
            </button>
        }

        @if (!string.IsNullOrEmpty(Auth.LastError))
        {
            <p class="ac-err">⚠ @Auth.LastError</p>
        }
    </div>
</section>

@code {
    private enum Step { Phone, Code }
    private Step _step = Step.Phone;
    private string _phone = "";
    private string _code  = "";
    private bool _phoneValid;
    private bool _codeValid;
    private bool _phoneAttempted;

    protected override void OnInitialized()
    {
        Auth.Changed += OnChanged;
    }

    private void OnPhoneInput(ChangeEventArgs e)
    {
        _phone = e.Value?.ToString() ?? "";
        var digits = NormalizeDigits(_phone).Count(char.IsDigit);
        _phoneValid = digits >= 8;
        if (!_phoneAttempted && digits > 0) _phoneAttempted = true;
        StateHasChanged();
    }

    private void OnCodeInput(ChangeEventArgs e)
    {
        _code = e.Value?.ToString() ?? "";
        var digits = NormalizeDigits(_code);
        _codeValid = digits.Length is >= 4 and <= 6 && digits.All(char.IsDigit);
        StateHasChanged();
    }

    /// <summary>يُحَوِّل أرقام ٠١٢٣٤٥٦٧٨٩ + ۰۱۲۳۴۵۶۷۸۹ إلى ASCII.</summary>
    private static string NormalizeDigits(string s)
    {
        var sb = new System.Text.StringBuilder(s.Length);
        foreach (var c in s)
        {
            sb.Append(c switch
            {
                >= '٠' and <= '٩' => (char)('0' + (c - '٠')),
                >= '۰' and <= '۹' => (char)('0' + (c - '۰')),
                _ => c,
            });
        }
        return sb.ToString();
    }

    /// <summary>
    /// يُحَوِّل أيّ صيغة مُدخَلة إلى E.164 يَمنيّ <c>+9677XXXXXXXX</c>.
    /// يَستوعب: <c>7XXXXXXXX</c>، <c>07XXXXXXXX</c>، <c>9677XXXXXXXX</c>،
    /// <c>+9677XXXXXXXX</c>، <c>00 9677XXXXXXXX</c>.
    /// </summary>
    private static string ToE164Yemen(string raw)
    {
        var digits = new string(NormalizeDigits(raw).Where(char.IsDigit).ToArray());
        // يَبدأ بـ 00 → دوليّ
        if (digits.StartsWith("00")) digits = digits[2..];
        // 967XXXXXXXXX → +967XXXXXXXXX
        if (digits.StartsWith("967")) return "+" + digits;
        // 0XXXXXXXXX → اقطع 0 ثمّ +967
        if (digits.StartsWith("0"))   return "+967" + digits.TrimStart('0');
        // YXXXXXXXX (محلّيّ بدون 0) → +967YXXXXXXXX
        return "+967" + digits;
    }

    private async Task RequestOtp()
    {
        await Auth.RequestOtpAsync(ToE164Yemen(_phone));
        if (string.IsNullOrEmpty(Auth.LastError)) _step = Step.Code;
    }

    private async Task VerifyOtp()
    {
        await Auth.VerifyOtpAsync(ToE164Yemen(_phone), NormalizeDigits(_code));
        if (Auth.IsAuthenticated)
        {
            var uri = new Uri(Nav.Uri);
            var q = System.Web.HttpUtility.ParseQueryString(uri.Query);
            var returnTo = q["return"];
            Nav.NavigateTo(string.IsNullOrEmpty(returnTo) ? "/" : returnTo);
        }
    }

    private void BackToPhone()
    {
        _step = Step.Phone;
        _code = "";
        _codeValid = false;
        StateHasChanged();
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Auth.Changed -= OnChanged;
}
