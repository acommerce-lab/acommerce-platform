@inject IAuthStore Auth
@inject NavigationManager Nav
@implements IDisposable

@*
    AcLoginWidget — تَدَفّق OTP بـ analyzer-strip:
      - الخطوة ١: phone (هاتف) — analyzer يَفحص الصيغة قبل تَفعيل الزرّ
      - الخطوة ٢: code (٤-٦ خانات) — analyzer يَفحص الطول
    صيغة الهاتف يَمنيّة: 7XXXXXXXX محلّيّ أو +9677XXXXXXXX دوليّ.
*@

<section class="ejar-login">
    <div class="ejar-login-card">
        <header class="ejar-login-head">
            <span class="ejar-login-glyph" aria-hidden="true">▣</span>
            <h1>@(_step == Step.Phone ? "تَسجيل الدخول" : "أَدخِل الرمز")</h1>
            <p class="ejar-login-sub">
                @(_step == Step.Phone
                    ? "أَدخِل رقم الجوال لاستلام رمز التَفعيل."
                    : "أَدخلنا الرمز إلى رقمك.")
            </p>
        </header>

        @if (_step == Step.Phone)
        {
            <label class="ejar-field">
                <span>رقم الجوال</span>
                <input class="ac-input oam-mono" type="tel" inputmode="tel"
                       placeholder="7XXXXXXXX"
                       @bind="_phone"
                       @bind:event="oninput"
                       @bind:after="RefreshAnalyzers" />
            </label>

            <OamAnalyzerStrip OperationType="auth.otp.request"
                              Analyzers="@_phoneAnalyzers">
                <Action>
                    <button class="oam-btn ejar-login-btn"
                            disabled="@(!_phoneValid || Auth.IsBusy)"
                            @onclick="RequestOtp">
                        @(Auth.IsBusy ? "جاري الإرسال…" : "إرسال الرمز")
                    </button>
                </Action>
            </OamAnalyzerStrip>
        }
        else
        {
            <label class="ejar-field">
                <span>الرمز</span>
                <input class="ac-input oam-mono ejar-otp-input" type="text" inputmode="numeric"
                       maxlength="6" placeholder="●●●●●●"
                       @bind="_code"
                       @bind:event="oninput"
                       @bind:after="RefreshAnalyzers" />
            </label>

            <OamAnalyzerStrip OperationType="auth.otp.verify"
                              Analyzers="@_codeAnalyzers">
                <Action>
                    <button class="oam-btn ejar-login-btn"
                            disabled="@(!_codeValid || Auth.IsBusy)"
                            @onclick="VerifyOtp">
                        @(Auth.IsBusy ? "جاري التحقّق…" : "تَأكيد الرمز")
                    </button>
                </Action>
            </OamAnalyzerStrip>

            <button class="oam-btn-ghost ejar-login-back" type="button"
                    @onclick="BackToPhone">
                ← تَغيير الرقم
            </button>
        }

        @if (!string.IsNullOrEmpty(Auth.LastError))
        {
            <p class="ac-err">⚠ @Auth.LastError</p>
        }
    </div>
</section>

@code {
    private enum Step { Phone, Code }
    private Step _step = Step.Phone;
    private string _phone = "";
    private string _code  = "";

    private OamAnalyzer[] _phoneAnalyzers = Array.Empty<OamAnalyzer>();
    private OamAnalyzer[] _codeAnalyzers  = Array.Empty<OamAnalyzer>();
    private bool _phoneValid;
    private bool _codeValid;

    protected override void OnInitialized()
    {
        Auth.Changed += OnChanged;
        RefreshAnalyzers();
    }

    /// <summary>
    /// يَتَحَقّق من صيغة الهاتف اليَمنيّة. يَقبل: <c>7XXXXXXXX</c> (٩ أرقام
    /// محلّيّ يَبدأ بـ 7)، أو <c>9677XXXXXXXX</c> (١٢ رقم دوليّ)، أو
    /// <c>+9677XXXXXXXX</c>. يُطَبِّع أرقام ٠-٩ العربيّة + ۰-۹ الفارسيّة.
    /// </summary>
    private void RefreshAnalyzers()
    {
        var phone = NormalizeDigits(_phone).Trim();
        var digitsOnly = new string(phone.Where(char.IsDigit).ToArray());

        // محلّيّ يَمنيّ: ٩ أرقام يَبدأ بـ 7. دوليّ: 967 + 7XXXXXXXX = ١٢ رقم.
        var localOk = digitsOnly.Length == 9 && digitsOnly.StartsWith("7");
        var intlOk  = (digitsOnly.Length == 12 && digitsOnly.StartsWith("9677"))
                   || (phone.StartsWith("+") && digitsOnly.Length == 12 && digitsOnly.StartsWith("9677"));
        _phoneValid = localOk || intlOk;

        _phoneAnalyzers = new[]
        {
            new OamAnalyzer("رقم يَمنيّ",
                _phoneValid     ? OamAnalyzerState.Pass
                : digitsOnly.Length == 0 ? OamAnalyzerState.Idle
                : OamAnalyzerState.Fail),
            new OamAnalyzer("صيغة 7XXXXXXXX أو +9677XXXXXXXX",
                _phoneValid     ? OamAnalyzerState.Pass
                : digitsOnly.Length == 0 ? OamAnalyzerState.Idle
                : OamAnalyzerState.Fail),
        };

        var code = NormalizeDigits(_code);
        _codeValid = code.Length is >= 4 and <= 6 && code.All(char.IsDigit);
        _codeAnalyzers = new[]
        {
            new OamAnalyzer("الرمز ٤-٦ أرقام",
                _codeValid                 ? OamAnalyzerState.Pass
                : code.Length == 0         ? OamAnalyzerState.Idle
                : OamAnalyzerState.Fail),
        };
    }

    /// <summary>يُحَوِّل أرقام ٠١٢٣٤٥٦٧٨٩ + ۰۱۲۳۴۵۶۷۸۹ إلى ASCII.</summary>
    private static string NormalizeDigits(string s)
    {
        var sb = new System.Text.StringBuilder(s.Length);
        foreach (var c in s)
        {
            sb.Append(c switch
            {
                >= '٠' and <= '٩' => (char)('0' + (c - '٠')),
                >= '۰' and <= '۹' => (char)('0' + (c - '۰')),
                _ => c,
            });
        }
        return sb.ToString();
    }

    /// <summary>يُحَوِّل أيّ صيغة مُدخَلة إلى E.164 يَمنيّ <c>+9677XXXXXXXX</c>.</summary>
    private static string ToE164Yemen(string raw)
    {
        var digits = new string(NormalizeDigits(raw).Where(char.IsDigit).ToArray());
        if (digits.Length == 9 && digits.StartsWith("7"))   return "+967" + digits;
        if (digits.Length == 12 && digits.StartsWith("9677")) return "+" + digits;
        if (digits.StartsWith("0"))                          return "+967" + digits.TrimStart('0');
        return "+" + digits;
    }

    private async Task RequestOtp()
    {
        await Auth.RequestOtpAsync(ToE164Yemen(_phone));
        if (string.IsNullOrEmpty(Auth.LastError)) _step = Step.Code;
    }

    private async Task VerifyOtp()
    {
        await Auth.VerifyOtpAsync(ToE164Yemen(_phone), NormalizeDigits(_code));
        if (Auth.IsAuthenticated)
        {
            var uri = new Uri(Nav.Uri);
            var q = System.Web.HttpUtility.ParseQueryString(uri.Query);
            var returnTo = q["return"];
            Nav.NavigateTo(string.IsNullOrEmpty(returnTo) ? "/" : returnTo);
        }
    }

    private void BackToPhone()
    {
        _step = Step.Phone;
        _code = "";
        RefreshAnalyzers();
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Auth.Changed -= OnChanged;
}
