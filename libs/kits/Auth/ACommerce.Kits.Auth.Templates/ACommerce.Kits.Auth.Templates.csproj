<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>ACommerce.Kits.Auth.Templates</PackageId>
    <Version>1.0.0</Version>
    <Description>
      General login shell. The shell handles layout + branding + flow state;
      the *verifier* (the actual phone/email/Nafath input form) is injected
      as a RenderFragment so each 2FA provider supplies its own
      provider-specific UI without forking the shell.
    </Description>
  </PropertyGroup>
  <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>
  <ItemGroup>
    <!-- Razor templates only use Components/Components.Authorization (Blazor side).
         No server-side ASP.NET Core types touched here, so NO FrameworkReference
         Microsoft.AspNetCore.App — that would cascade into WASM and trigger NETSDK1082. -->
    <ProjectReference Include="..\..\Widgets\ACommerce.Widgets\ACommerce.Widgets.csproj" />
    <PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="10.0.7" />
    <PackageReference Include="Microsoft.AspNetCore.Components.Authorization" Version="10.0.7" />
  </ItemGroup>
</Project>
