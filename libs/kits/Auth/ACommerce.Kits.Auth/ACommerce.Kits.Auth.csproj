<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>ACommerce.Kits.Auth</PackageId>
    <Version>1.0.0</Version>
    <Description>
      Auth feature meta-package — the SHELL only:
        - ACommerce.Kits.Auth.Operations  (IAuthFlow + IAuthUserStore + JwtConfig)
        - ACommerce.Kits.Auth.Backend     (AuthController driving an IAuthFlow)
        - ACommerce.Kits.Auth.Templates   (AcLoginPage Razor + Verifier slot)

      Auth has NO knowledge of 2FA. Apps wire an IAuthFlow themselves:
        - Most common: install ACommerce.Kits.Auth.TwoFactor + a 2FA provider
          (e.g. ACommerce.Kits.Auth.TwoFactor.Sms) + ACommerce.Kits.Auth.TwoFactor.AsAuth
          which provides an IAuthFlow that drives the 2FA channel.
        - Or install a custom IAuthFlow (email magic-link, WebAuthn).
    </Description>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\ACommerce.Kits.Auth.Operations\ACommerce.Kits.Auth.Operations.csproj" />
    <ProjectReference Include="..\ACommerce.Kits.Auth.Backend\ACommerce.Kits.Auth.Backend.csproj" />
    <ProjectReference Include="..\ACommerce.Kits.Auth.Templates\ACommerce.Kits.Auth.Templates.csproj" />
  </ItemGroup>
</Project>
