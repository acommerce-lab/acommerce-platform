<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>ACommerce.Kits.Auth</PackageId>
    <Version>1.0.0</Version>
    <Description>
      Auth feature — top-level meta package: Auth.Server + Auth.Client.
      Use this only for hybrid hosts that legitimately need BOTH the server controllers
      AND the Razor templates (rare). For everything else pick the side-specific meta:
        - Backend services (Ejar.Api, Order.Api …)  → ACommerce.Kits.Auth.Server
        - Frontend hosts   (Ejar.Web, Ejar.WebAssembly, Ejar.Maui …) → ACommerce.Kits.Auth.Client

      Auth has NO knowledge of 2FA. Apps wire an IAuthFlow themselves:
        - Most common: install ACommerce.Kits.Auth.TwoFactor + a 2FA provider
          (e.g. ACommerce.Kits.Auth.TwoFactor.Sms) + ACommerce.Kits.Auth.TwoFactor.AsAuth
          which provides an IAuthFlow that drives the 2FA channel.
        - Or install a custom IAuthFlow (email magic-link, WebAuthn).
    </Description>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\ACommerce.Kits.Auth.Server\ACommerce.Kits.Auth.Server.csproj" />
    <ProjectReference Include="..\ACommerce.Kits.Auth.Client\ACommerce.Kits.Auth.Client.csproj" />
  </ItemGroup>
</Project>
