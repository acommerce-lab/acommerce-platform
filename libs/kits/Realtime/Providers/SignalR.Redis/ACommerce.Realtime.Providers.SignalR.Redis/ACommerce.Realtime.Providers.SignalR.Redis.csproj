<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>ACommerce.Realtime.Providers.SignalR.Redis</PackageId>
    <Version>1.0.0</Version>
    <Description>Production wiring for SignalR + ICache so the realtime stack is multi-instance ready: SignalR Redis backplane (cross-host SendToGroup / SendToUser) + RedisConnectionTracker (cross-host userId→connectionId lookup) implementing IConnectionTracker on top of ICache.</Description>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\ACommerce.Realtime.Operations\ACommerce.Realtime.Operations.csproj" />
    <ProjectReference Include="..\..\SignalR\ACommerce.Realtime.Providers.SignalR\ACommerce.Realtime.Providers.SignalR.csproj" />
    <ProjectReference Include="..\..\..\..\Cache\ACommerce.Cache.Operations\ACommerce.Cache.Operations.csproj" />
    <PackageReference Include="Microsoft.AspNetCore.SignalR.StackExchangeRedis" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.0" />
  </ItemGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
</Project>
