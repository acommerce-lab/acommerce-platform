<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>ACommerce.Kits.Versions</PackageId>
    <Version>1.0.0</Version>
    <Description>
      Versions feature — top-level meta package: Versions.Server + Versions.Client.
      For hybrid hosts that need both. Use the side-specific meta otherwise:
        - Backend services → ACommerce.Kits.Versions.Server
        - Frontend hosts   → ACommerce.Kits.Versions.Client
    </Description>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\ACommerce.Kits.Versions.Server\ACommerce.Kits.Versions.Server.csproj" />
    <ProjectReference Include="..\ACommerce.Kits.Versions.Client\ACommerce.Kits.Versions.Client.csproj" />
  </ItemGroup>
</Project>
