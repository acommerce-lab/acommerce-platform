<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>ACommerce.Kits.Auth.TwoFactor</PackageId>
    <Version>1.0.0</Version>
    <Description>
      Two-factor authentication feature meta-package — the abstraction.
      Re-exposes ITwoFactorChannel + TwoFactorService from the existing
      backend lib so consumers add ONE reference instead of three. Does
      NOT include any specific provider (SMS/Nafath/Email). Pick a provider
      kit separately:
        - ACommerce.Kits.Auth.TwoFactor.Sms
        - ACommerce.Kits.Auth.TwoFactor.Nafath  (planned)
        - ACommerce.Kits.Auth.TwoFactor.Email   (planned)

      A 2FA channel can power Auth (login) via the AsAuth bridge package, OR
      be used post-login to secure individual operations (add/remove channels,
      step-up auth on sensitive actions). Both use cases see the same
      ITwoFactorChannel — Auth.TwoFactor doesn't care how it's used.
    </Description>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\ACommerce.Authentication.TwoFactor.Operations\ACommerce.Authentication.TwoFactor.Operations.csproj" />
  </ItemGroup>
</Project>
