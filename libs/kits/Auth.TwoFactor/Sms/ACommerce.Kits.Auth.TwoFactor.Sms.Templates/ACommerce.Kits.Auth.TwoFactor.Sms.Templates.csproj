<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>ACommerce.Kits.Auth.TwoFactor.Sms.Templates</PackageId>
    <Version>1.0.0</Version>
    <Description>
      SMS-specific verifier UI: phone-number input, OTP request button, then
      6-digit code input + verify button. Slots into AcLoginPage's
      &lt;Verifier&gt; render fragment.

      Each 2FA provider ships its own Templates package — Nafath has its own
      "scan QR + wait for app confirmation" UX, Email has its own "magic link
      sent, click to continue", etc. The shell (Auth.Templates) doesn't know
      about any of them.
    </Description>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\Widgets\ACommerce.Widgets\ACommerce.Widgets.csproj" />
  </ItemGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
</Project>
