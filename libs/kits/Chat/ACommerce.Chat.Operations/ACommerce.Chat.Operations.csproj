<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>ACommerce.Chat.Operations</PackageId>
    <Version>1.0.0</Version>
    <Description>Chat abstraction. Defines IChatMessage / IChatConversation interfaces (the app's domain entities implement them) and IChatService that broadcasts new messages on both `chat:conv:{id}` and `notif:conv:{id}` channels — letting the realtime channel manager decide reachability per recipient.</Description>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Realtime\ACommerce.Realtime.Operations\ACommerce.Realtime.Operations.csproj" />
    <ProjectReference Include="..\..\..\core\OperationEngine\ACommerce.OperationEngine.DataInterceptors\ACommerce.OperationEngine.DataInterceptors.csproj" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.7" />
  </ItemGroup>
</Project>
