@inject IChatStore Store
@inject IRichTextSanitizer Sanitizer
@implements IDisposable

@*
    AcChatRoomWidget — يَعرض رسائل المحادثة المفتوحة + composer.
    يَتركّب من AcChatComposerWidget — نفس الـ composer قابل للاستعمال
    بشكل مستقلّ في side-drawer مثلاً.
*@

<section class="ac-chat-room">
    <ul class="ac-messages">
        @foreach (var m in Store.CurrentMessages)
        {
            <li>
                <span class="ac-from">@m.SenderPartyId</span>
                <p>@Sanitizer.Sanitize(m.Body)</p>
            </li>
        }
    </ul>
    <AcChatComposerWidget OnSend="@HandleSend" />
</section>

@code {
    [Parameter] public string? Id { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        Store.Changed += OnChanged;
        if (!string.IsNullOrEmpty(Id))
            await Store.OpenConversationAsync(Id);
    }

    private Task HandleSend(string body) => Store.SendAsync(body);
    private void OnChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Store.Changed -= OnChanged;
}
