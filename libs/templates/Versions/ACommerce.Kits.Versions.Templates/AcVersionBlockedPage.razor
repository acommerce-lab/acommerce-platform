@*
  Full-screen panel shown when the version is Unsupported. Replaces the entire
  app content. Provides the latest version, sunset date if any, notes, and a
  download link if the backend supplied one.

  All visible labels exposed as parameters with English defaults — apps pass
  localized strings (no hardcoded Arabic in the template).
*@

@using ACommerce.Kits.Versions.Operations

<div class="ac-version-block-page" role="alert" aria-live="assertive">
    <div class="ac-version-block-card">
        <div class="ac-version-block-icon">⚠️</div>
        <h1 class="ac-version-block-title">@(Title ?? "Update required")</h1>
        <p class="ac-version-block-msg">
            @(Message ?? "Your current version is no longer supported. Please update the app to continue.")
        </p>

        <dl class="ac-version-block-meta">
            <div><dt>@(YourVersionLabel ?? "Your version")</dt><dd>@Result.Version</dd></div>
            @if (!string.IsNullOrEmpty(Result.Latest))
            {
                <div><dt>@(LatestLabel ?? "Latest")</dt><dd>@Result.Latest</dd></div>
            }
            @if (Result.SunsetAt is { } s)
            {
                <div><dt>@(SunsetLabel ?? "Sunset date")</dt><dd>@s.ToString("yyyy-MM-dd")</dd></div>
            }
        </dl>

        @if (!string.IsNullOrEmpty(Result.Notes))
        {
            <p class="ac-version-block-notes">@Result.Notes</p>
        }

        @if (!string.IsNullOrEmpty(Result.DownloadUrl))
        {
            <a class="ac-version-block-cta" href="@Result.DownloadUrl" target="_blank" rel="noopener">
                @(DownloadLabel ?? "Update now")
            </a>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public VersionCheckResult Result { get; set; } = default!;
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Message { get; set; }
    [Parameter] public string? DownloadLabel { get; set; }
    [Parameter] public string? YourVersionLabel { get; set; }
    [Parameter] public string? LatestLabel { get; set; }
    [Parameter] public string? SunsetLabel { get; set; }
}
