@inject ISupportStore Store
@inject NavigationManager Nav
@inject L L
@implements IDisposable

@*
    AcTicketsWidget — تَذاكر الدَعم بإيقاع OAM:
      - زرّ "تَذكرة جديدة" أعلى الصفحة
      - قائمة بَطاقات: subject (bold) + OamStamp يَعكس الحالة
        (open=Pending، waiting=Executing، resolved=Executed، closed=Rejected)
      - عَدّاد الردود غير المَقروءة كَـ red dot
*@

<section class="ac-tickets">
    <header class="ejar-section-head">
        <h2 class="ejar-section-title">@(L[LedgerStrings.TicketsTitle])</h2>
        <a href="/support/new" class="oam-btn ejar-add-btn">@(L[LedgerStrings.TicketsNewButton])</a>
    </header>

    @if (Store.IsLoading)
    {
        <p class="ejar-loading">@(L[LedgerStrings.CommonLoading])</p>
    }
    else if (Store.Tickets.Count == 0)
    {
        <div class="ejar-empty">
            <span class="ejar-empty-glyph" aria-hidden="true">?</span>
            <h3>@(L[LedgerStrings.TicketsEmptyTitle])</h3>
            <p>@(L[LedgerStrings.TicketsEmptyBody])</p>
        </div>
    }
    else
    {
        <ul class="ejar-tickets">
            @foreach (var t in Store.Tickets)
            {
                var tid = t.Id;
                <li class="ejar-ticket-row" @onclick="@(() => Nav.NavigateTo($"/support/{tid}"))"
                    role="button" tabindex="0">
                    <div class="ejar-ticket-body">
                        <div class="ejar-ticket-top">
                            <span class="ejar-ticket-subject">@t.Subject</span>
                            <OamStamp State="@MapStatus(t.Status)" Compact="true" />
                        </div>
                        <div class="ejar-ticket-meta oam-mono">
                            <span>@FormatTime(t.UpdatedAt)</span>
                            <span class="ejar-ticket-id"># @ShortId(t.Id)</span>
                        </div>
                    </div>
                    @if (t.UnreadReplies > 0)
                    {
                        <span class="ejar-ticket-unread"
                              aria-label="@(string.Format(L[LedgerStrings.TicketsUnreadRepliesFormat], t.UnreadReplies))">
                            @t.UnreadReplies
                        </span>
                    }
                </li>
            }
        </ul>
    }
</section>

@code {
    protected override async Task OnInitializedAsync()
    {
        Store.Changed += OnChanged;
        await Store.LoadAsync();
    }

    private static OamState MapStatus(string status) => status switch
    {
        "open"     or "new"      => OamState.Pending,
        "waiting"  or "pending"  => OamState.Executing,
        "resolved" or "closed"   => OamState.Executed,
        "rejected" or "cancelled"=> OamState.Rejected,
        _                        => OamState.Pending,
    };

    // ‹L› مَحقون → غَير static
    private string FormatTime(DateTime utc)
    {
        var local = utc.ToLocalTime();
        var diff  = DateTime.Now - local;
        if (diff.TotalMinutes < 60) return string.Format(L[LedgerStrings.TimeMinutesAgoFormat], (int)diff.TotalMinutes);
        if (diff.TotalHours   < 24) return string.Format(L[LedgerStrings.TimeHoursAgoFormat], (int)diff.TotalHours);
        if (diff.TotalDays    < 7)  return string.Format(L[LedgerStrings.TimeDaysAgoFormat], (int)diff.TotalDays);
        return local.ToString("yyyy-MM-dd");
    }

    private static string ShortId(string id)
        => id.Length > 8 ? id[..8] : id;

    private void OnChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Store.Changed -= OnChanged;
}
