@inject IProfileStore Store
@inject NavigationManager Nav
@inject L L
@implements IDisposable

@*
    AcProfileWidget — صفحة "حسابي" بأنماط OAM:
      - بَطاقة هويّة: AcAvatar + الاسم + هاتف/بريد بصيغة tags
      - OamStamp بجانب كلّ هويّة (مُوثَّقة / تَنتظر التحقّق)
      - actions: تعديل المَلفّ، تَسجيل الخروج
*@

<section class="ac-profile">
    @if (Store.IsLoading)
    {
        <p class="ejar-loading">@(L[LedgerStrings.CommonLoading])</p>
    }
    else if (Store.Current is null)
    {
        <div class="ejar-empty">
            <span class="ejar-empty-glyph" aria-hidden="true">◉</span>
            <h3>@(L[LedgerStrings.ProfileLoadFailedTitle])</h3>
            <p>@(L[LedgerStrings.ProfileLoadFailedBody])</p>
        </div>
    }
    else
    {
        var p = Store.Current;
        <header class="ejar-section-head">
            <h2 class="ejar-section-title">@(L[LedgerStrings.ProfileTitle])</h2>
            <span class="ejar-section-meta oam-mono">/ profile</span>
        </header>

        <div class="ejar-profile-card">
            <AcAvatar Name="@p.FullName" ImageUrl="@p.AvatarUrl" Size="72" />
            <div class="ejar-profile-card-body">
                <h1 class="ejar-profile-name">@p.FullName</h1>
                @if (p.MemberSince != default)
                {
                    <p class="ejar-profile-since oam-mono">
                        @(string.Format(L[LedgerStrings.ProfileMemberSinceFormat], p.MemberSince.ToString("yyyy-MM-dd")))
                    </p>
                }
            </div>
        </div>

        <header class="ejar-section-head">
            <h2 class="ejar-section-title">@(L[LedgerStrings.ProfileIdentityTitle])</h2>
            <span class="ejar-section-meta oam-mono">/ identities</span>
        </header>

        <ul class="ejar-identity-list">
            <li class="ejar-identity-row">
                <span class="ejar-identity-label">@(L[LedgerStrings.ProfilePhoneLabel])</span>
                <span class="ejar-identity-value oam-mono">@p.Phone</span>
                <OamStamp State="@(p.PhoneVerified ? OamState.Executed : OamState.Pending)"
                          Compact="true" />
            </li>
            @if (!string.IsNullOrEmpty(p.Email))
            {
                <li class="ejar-identity-row">
                    <span class="ejar-identity-label">@(L[LedgerStrings.ProfileEmailLabel])</span>
                    <span class="ejar-identity-value oam-mono">@p.Email</span>
                    <OamStamp State="@(p.EmailVerified ? OamState.Executed : OamState.Pending)"
                              Compact="true" />
                </li>
            }
            @if (!string.IsNullOrEmpty(p.City))
            {
                <li class="ejar-identity-row">
                    <span class="ejar-identity-label">@(L[LedgerStrings.ProfileCityLabel])</span>
                    <span class="ejar-identity-value">@p.City</span>
                </li>
            }
        </ul>

        <div class="ejar-profile-actions">
            <a href="/me/edit" class="oam-btn">@(L[LedgerStrings.ProfileEdit])</a>
            <a href="/me/settings" class="oam-btn oam-btn-ghost">@(L[LedgerStrings.ProfileSettings])</a>
        </div>
    }
</section>

@code {
    protected override async Task OnInitializedAsync()
    {
        Store.Changed += OnChanged;
        await Store.LoadAsync();
    }
    private void OnChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Store.Changed -= OnChanged;
}
