@page "/settings"
@attribute [Authorize]
@inject AppStore Store
@inject AppStateApplier Applier
@inject NavigationManager Nav
@inject L L

<PageTitle>@(L["settings.title"]) — @(L["app.name"])</PageTitle>

<div class="acs-page acs-settings-page">
    <h1 class="acm-wizard-title">@(L["settings.title"])</h1>

    <AcCard>
        <ChildContent>
            <div class="acm-checkout-line">
                <span>@(L["settings.theme"])</span>
                <div style="display:inline-flex; gap:8px;">
                    <AcFilterChip Label="@(L["settings.theme.light"])"
                                  Active="@(Store.Ui.Theme == "light")"
                                  OnClick="@SetLight" />
                    <AcFilterChip Label="@(L["settings.theme.dark"])"
                                  Active="@(Store.Ui.Theme == "dark")"
                                  OnClick="@SetDark" />
                </div>
            </div>
            <div class="acm-checkout-line">
                <span>@(L["settings.language"])</span>
                <div style="display:inline-flex; gap:8px;">
                    <AcFilterChip Label="العربيّة" Active="@(Store.Ui.Language == "ar")" OnClick="@SetAr" />
                    <AcFilterChip Label="English"  Active="@(Store.Ui.Language == "en")" OnClick="@SetEn" />
                </div>
            </div>
        </ChildContent>
    </AcCard>

    <AcCard>
        <ChildContent>
            <h3 style="margin-top:0;">المستندات القانونيّة</h3>
            <AcButton Variant="ghost" Class="ac-btn-block" Text="@(L["legal.privacy"])" OnClick="@GoPrivacy" />
            <AcButton Variant="ghost" Class="ac-btn-block" Text="@(L["legal.terms"])"   OnClick="@GoTerms" />
            <AcButton Variant="ghost" Class="ac-btn-block" Text="@(L["legal.return"])"  OnClick="@GoRefund" />
        </ChildContent>
    </AcCard>
</div>

@code {
    private Task SetLight() => Applier.ApplyLocalAsync(EjarOps.SetTheme("light"));
    private Task SetDark()  => Applier.ApplyLocalAsync(EjarOps.SetTheme("dark"));
    private Task SetAr()    => Applier.ApplyLocalAsync(EjarOps.SetLanguage("ar"));
    private Task SetEn()    => Applier.ApplyLocalAsync(EjarOps.SetLanguage("en"));
    private void GoPrivacy() => Nav.NavigateTo("/legal/privacy");
    private void GoTerms()   => Nav.NavigateTo("/legal/terms");
    private void GoRefund()  => Nav.NavigateTo("/legal/refund");
}
