@page "/plans"
@attribute [Authorize]
@inject ITemplateEngine Engine
@inject NavigationManager Nav
@inject L L

<PageTitle>@(L[TemplateStrings.PlansTitle]) — @(L[TemplateStrings.AppName])</PageTitle>

<div class="acs-page acs-plans-page">
    <h1 class="acm-wizard-title">@(L[TemplateStrings.PlansTitle])</h1>
    <p style="color:var(--ac-text-muted);">@(L[TemplateStrings.PlansIntro])</p>

    @if (_loading) { <AcLoadingState /> }
    else
    {
        <div class="acm-home-grid acs-plans-grid">
            @foreach (var p in _plans)
            {
                var plan = p;
                <AcCard Hover="true">
                    <ChildContent>
                        <div style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                            <h3 style="margin:0;">@plan.Name</h3>
                            @if (plan.Popular) { <AcBadge Variant="secondary" Text="@(L[TemplateStrings.PlansPopularBadge])" /> }
                        </div>
                        <p style="color:var(--ac-text-muted); font-size:13px;">@plan.Description</p>

                        <div style="font-size:24px; font-weight:700; margin:8px 0;">
                            @if (plan.Price == 0) { <span>@(L[TemplateStrings.PlansFree])</span> }
                            else { <span>@plan.Price @(L[TemplateStrings.CommonCurrencyShort])</span><small style="font-size:13px; color:var(--ac-text-muted);"> / @plan.Unit</small> }
                        </div>

                        <ul style="list-style:none; padding:0; margin:8px 0 12px;">
                            @foreach (var f in plan.Features)
                            {
                                <li style="display:flex; gap:8px; padding:4px 0; align-items:center;">
                                    <AcIcon Name="check-circle" Size="14" />
                                    <span>@f</span>
                                </li>
                            }
                        </ul>

                        <AcButton Variant="@(plan.Popular ? "primary" : "outline-primary")"
                                  Class="ac-btn-block"
                                  Text="@(plan.Price == 0 ? L[TemplateStrings.PlansStartFree] : L[TemplateStrings.PlansSubscribe])"
                                  OnClick="@(() => Subscribe(plan))" />
                    </ChildContent>
                </AcCard>
            }
        </div>

        <h3 style="margin-top:16px;">@(L[TemplateStrings.PlansCompareHeading])</h3>
        <AcCard>
            <ChildContent>
                <table class="acs-plans-compare">
                    <thead>
                        <tr>
                            <th>@(L[TemplateStrings.PlansFeatureCol])</th>
                            @foreach (var p in _plans) { <th>@p.Name</th> }
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>@(L[TemplateStrings.PlansFeatureActiveListings])</td>
                            @foreach (var p in _plans) { <td>@(p.ListingQuota == 99 ? "∞" : p.ListingQuota.ToString())</td> }
                        </tr>
                        <tr>
                            <td>@(L[TemplateStrings.PlansFeatureFeaturedListings])</td>
                            @foreach (var p in _plans) { <td>@p.FeaturedQuota</td> }
                        </tr>
                        <tr>
                            <td>@(L[TemplateStrings.PlansFeatureImagesPerListing])</td>
                            @foreach (var p in _plans) { <td>@p.ImagesPerListing</td> }
                        </tr>
                        <tr>
                            <td>@(L[TemplateStrings.PlansFeatureSupport])</td>
                            @foreach (var p in _plans) { <td>@SupportLevel(p.Id)</td> }
                        </tr>
                    </tbody>
                </table>
            </ChildContent>
        </AcCard>
    }
</div>

@code {
    private List<PlanDto> _plans = new();
    private bool _loading = true;

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (!first) return;
        // OAM-pure: نَدفَع نَفس op الـ kit (subscriptions.plans.list) عَبر
        // ITemplateEngine ⇒ نَفس الـ route / interceptors. الـ DTO المَحَلّيّ
        // يَلتَقِط الشَكل الكامِل (Description/Features/Quotas) الذي يَفقِده
        // ISubscriptionsStore.Plans (الذي يَلتَقِط Id/Slug/Name فَقَط).
        var env = await Engine.ExecuteAsync<List<PlanDto>>(SubscriptionsOps.ListPlans());
        _plans = env.Data ?? new();
        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    // ToString(InvariantCulture) ضروريّ — فاصل العربيّة "٫" يكسر
    // [SupplyParameterFromQuery] decimal في الصفحة الهدف، ينتج crash كامل.
    private void Subscribe(PlanDto p) => Nav.NavigateTo(
        $"/subscribe?type=plan&id={p.Id}&amount={p.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)}");

    private string SupportLevel(string id) => id switch
    {
        "plan-basic"   => L[TemplateStrings.PlansSupportEmail],
        "plan-pro"     => L[TemplateStrings.PlansSupportPriority],
        "plan-premium" => L[TemplateStrings.PlansSupportAccountManager],
        _              => "—"
    };

    private sealed record PlanDto(string Id, string Name, string Description,
        decimal Price, string Unit, int ListingQuota, int FeaturedQuota,
        int ImagesPerListing, bool Popular, List<string> Features);
}
