@page "/payment/callback"
@attribute [Authorize]
@inject ITemplateEngine Engine
@inject NavigationManager Nav
@inject L L

<PageTitle>@($"{L[TemplateStrings.PaymentResultTitle]} — {L[TemplateStrings.AppName]}")</PageTitle>

<div class="acs-page acs-payment-callback" style="text-align:center; padding:32px 16px;">
    @if (Status == "success")
    {
        <div style="color:var(--ac-success);"><AcIcon Name="check-circle" Filled="true" Size="48" /></div>
        <h1 class="acm-wizard-title">@(L[TemplateStrings.PaymentSuccess])</h1>
        <p>@(L[TemplateStrings.PaymentSuccessBody])</p>

        <AcCard>
            <ChildContent>
                <div class="acm-checkout-line"><span>@(L[TemplateStrings.PaymentTransactionLabel])</span><strong>@_txnId</strong></div>
                @if (!string.IsNullOrEmpty(Id))
                {
                    <div class="acm-checkout-line"><span>@(Type == "booking" ? L[TemplateStrings.PaymentNoteBookingId] : L[TemplateStrings.PaymentNotePlanId])</span><strong>@Id</strong></div>
                }
                @if (Amount > 0)
                {
                    <div class="acm-checkout-line"><span>@(L[TemplateStrings.PaymentAmountLabel])</span><strong>@Amount @(L[TemplateStrings.CommonCurrencyShort])</strong></div>
                }
                <div class="acm-checkout-line"><span>@(L[TemplateStrings.PaymentDateLabel])</span><strong>@DateTime.Now.ToString("yyyy-MM-dd HH:mm")</strong></div>
            </ChildContent>
        </AcCard>

        <div style="display:flex; gap:8px; margin-top:16px; justify-content:center;">
            <AcButton Variant="primary" Text="@(L[TemplateStrings.MeStatsSubscription])" OnClick="@GoMySub" />
            <AcButton Variant="ghost"   Text="@(L[TemplateStrings.NavHomeAlt])" OnClick="@GoHome" />
        </div>
    }
    else
    {
        <div style="color:var(--ac-danger);"><AcIcon Name="x-circle" Filled="true" Size="48" /></div>
        <h1 class="acm-wizard-title">@(L[TemplateStrings.PaymentFailed])</h1>
        <p>@(L[TemplateStrings.PaymentFailedBody])</p>
        <div style="display:flex; gap:8px; margin-top:16px; justify-content:center;">
            <AcButton Variant="primary" Text="@(L[TemplateStrings.PaymentRetry])" OnClick="@Retry" />
            <AcButton Variant="ghost"   Text="@(L[TemplateStrings.NavHomeAlt])" OnClick="@GoHome" />
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery] public string? Status { get; set; }
    [SupplyParameterFromQuery] public string? Type { get; set; }
    [SupplyParameterFromQuery] public string? Id { get; set; }
    [SupplyParameterFromQuery] public decimal Amount { get; set; }

    private string _txnId = "";

    protected override async Task OnInitializedAsync()
    {
        _txnId = $"TXN-{Random.Shared.Next(100000, 999999)}";
        // فعّل الاشتراك فعلاً على الخادم — قبل هذا التغيير كانت الصفحة تكتفي
        // بعرض "تمّ الدفع" دون كتابة أيّ شيء في DB، فـ /me/subscription يرجع
        // فارغاً حتى للذي "اشترى". الآن نَدفَع subscription.activate op
        // لإنشاء SubscriptionEntity + InvoiceEntity فعليّاً.
        if (Status == "success" && Type == "plan" && !string.IsNullOrEmpty(Id))
        {
            await Engine.ExecuteAsync<object>(
                SubscriptionsOps.Activate(Id), payload: new { planId = Id });
        }
    }

    private void GoMySub() => Nav.NavigateTo("/my-subscription");
    private void GoHome()  => Nav.NavigateTo("/");
    private void Retry()   => Nav.NavigateTo("/plans");
}
