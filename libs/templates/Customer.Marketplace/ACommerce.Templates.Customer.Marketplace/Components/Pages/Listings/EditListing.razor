@page "/listings/{Id}/edit"
@attribute [Authorize]
@using System.Net.Http.Json
@using ACommerce.OperationEngine.Wire
@using ACommerce.SharedKernel.Domain.DynamicAttributes
@inject IListingsStore Listings
@inject IDiscoveryStore Discovery
@inject NavigationManager Nav
@inject IHttpClientFactory HttpFactory
@inject L L
@inject INumeralNormalizer Numerals

@*
    صَفحَة تَعديل إعلان. تَفترض أَنّ الإعلان مَوجود في
    <c>IListingsStore.Mine</c> (مَن MyListings.razor) أَو نَجلِبه عَبر
    GetByIdAsync. لا تَوجَد صَفحَة "wizard" — تَعديل واحِد بِسيط لِأَنّ
    الصُّوَر + الموقِع نادِراً ما تَتَغَيَّر في التَّعديل.

    الـ payload يُبنى مَن قِيَم النَموذَج المَحَلِّي + يُرسَل عَبر
    <c>IListingsStore.UpdateAsync</c> الَّذي يَستَخدِم PATCH /my-listings/{id}.
*@

<PageTitle>@(L[TemplateStrings.CommonEdit]) — @(L[TemplateStrings.AppName])</PageTitle>

<div class="acs-page acs-edit-listing">
    <h1 class="acm-wizard-title">@(L[TemplateStrings.CommonEdit])</h1>

    @if (_loading)
    {
        <AcLoadingState />
    }
    else if (_listing is null)
    {
        <AcEmptyState IconName="alert-triangle" Message="@(L[TemplateStrings.ListingsEmpty])" />
        <AcButton Variant="ghost" Class="ac-btn-block" Text="@(L[TemplateStrings.CommonBack])"
                  OnClick="@(() => Nav.NavigateTo("/my-listings"))" />
    }
    else
    {
        <AcCard>
            <ChildContent>
                <AcField Label="@(L[TemplateStrings.ListingCreateFieldTitle])">
                    <AcInput Value="@_title" ValueChanged="@(v => _title = v)" />
                </AcField>

                <AcField Label="@(L[TemplateStrings.ListingCreateFieldDescription])">
                    <AcInput Multiline="true" Value="@_description" ValueChanged="@(v => _description = v)" />
                </AcField>

                <div class="acs-row">
                    <AcField Label="@(L[TemplateStrings.ListingCreateFieldPrice])">
                        <AcInput Type="number" Value="@_price.ToString()"
                                 ValueChanged="@(v => _price = decimal.TryParse(Numerals.ToLatin(v), out var n) ? n : 0)" />
                    </AcField>
                    <AcField Label="@(L[TemplateStrings.ListingCreateFieldTimeUnit])">
                        <select class="form-select" @bind="_timeUnit">
                            <option value="monthly">@(L[TemplateStrings.TimeUnitMonthly])</option>
                            <option value="yearly">@(L[TemplateStrings.TimeUnitYearly])</option>
                            <option value="daily">@(L[TemplateStrings.TimeUnitDaily])</option>
                            <option value="hourly">@(L[TemplateStrings.TimeUnitHourly])</option>
                        </select>
                    </AcField>
                </div>

                <div class="acs-row">
                    <AcField Label="@(L[TemplateStrings.ListingCreateFieldBedrooms])">
                        <AcInput Type="number" Value="@_bedrooms.ToString()"
                                 ValueChanged="@(v => _bedrooms = int.TryParse(Numerals.ToLatin(v), out var n) ? n : 0)" />
                    </AcField>
                    <AcField Label="@(L[TemplateStrings.ListingCreateFieldBathrooms])">
                        <AcInput Type="number" Value="@_bathrooms.ToString()"
                                 ValueChanged="@(v => _bathrooms = int.TryParse(Numerals.ToLatin(v), out var n) ? n : 0)" />
                    </AcField>
                    <AcField Label="@(L[TemplateStrings.ListingCreateFieldArea])">
                        <AcInput Type="number" Value="@_area.ToString()"
                                 ValueChanged="@(v => _area = int.TryParse(Numerals.ToLatin(v), out var n) ? n : 0)" />
                    </AcField>
                </div>

                @if (_attrTemplate is { Fields.Count: > 0 })
                {
                    <h4 class="acs-section-title">@(L[TemplateStrings.ListingAttributes])</h4>
                    <AcAttrEditor Template="_attrTemplate"
                                  Values="_attrValues"
                                  ValuesChanged="@(v => _attrValues = v)"
                                  IsArabic="true" />
                }

                <AcField Label="@(L[TemplateStrings.ListingAmenities])">
                    <div class="acs-amenity-chips">
                        @foreach (var a in Discovery.Amenities)
                        {
                            var am = a;
                            <AcFilterChip Label="@am.Label"
                                          Active="@_amenities.Contains(am.Key)"
                                          OnClick="@(() => ToggleAmenity(am.Key))" />
                        }
                    </div>
                </AcField>

                <AcField Label="@(L[TemplateStrings.ListingCreateFieldCity])">
                    <AcInput Value="@_city" ValueChanged="@(v => _city = v)" />
                </AcField>
                <AcField Label="@(L[TemplateStrings.ListingCreateFieldDistrict])">
                    <AcInput Value="@_district" ValueChanged="@(v => _district = v)" />
                </AcField>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="acs-error">@_error</div>
                }

                <div class="acs-actions">
                    <AcButton Variant="primary" Text="@(L[TemplateStrings.CommonSave])"
                              OnClick="@Save" Disabled="@_saving" />
                    <AcButton Variant="ghost" Text="@(L[TemplateStrings.CommonCancel])"
                              OnClick="@(() => Nav.NavigateTo($"/listings/{Id}"))" />
                </div>
            </ChildContent>
        </AcCard>
    }
</div>

@code {
    [Parameter] public string Id { get; set; } = "";

    private IListing? _listing;
    private bool _loading = true;
    private bool _saving;
    private string? _error;

    // قِيَم النَموذَج المَحَلّيّ — مُهَيَّأة مَن _listing عِندَ التَّحميل.
    private string  _title       = "";
    private string  _description = "";
    private decimal _price;
    private string  _timeUnit    = "monthly";
    private int     _bedrooms;
    private int     _bathrooms;
    private int     _area;
    private string  _city        = "";
    private string  _district    = "";
    private HashSet<string> _amenities = new(StringComparer.OrdinalIgnoreCase);

    private AttributeTemplate? _attrTemplate;
    private Dictionary<string, object?> _attrValues = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (!first) return;
        await LoadAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _listing = await Listings.GetByIdAsync(Id);
            if (_listing is null) return;

            _title       = _listing.Title;
            _description = _listing.Description;
            _price       = _listing.Price;
            _timeUnit    = _listing.TimeUnit;
            _bedrooms    = _listing.BedroomCount;
            _bathrooms   = _listing.BathroomCount;
            _area        = _listing.AreaSqm;
            _city        = _listing.City;
            _district    = _listing.District;
            _amenities   = new HashSet<string>(_listing.Amenities ?? Array.Empty<string>(),
                                               StringComparer.OrdinalIgnoreCase);

            await LoadAttrsAsync(_listing.PropertyType);
        }
        finally { _loading = false; }
    }

    /// <summary>
    /// يَجلِب قالَب السِمات لِفِئَة الإعلان + قِيَمها الحالِيَّة. القالَب
    /// مَن endpoint الكيت <c>/categories/{slug}/attribute-template</c>؛
    /// القِيَم تَأتي مَن snapshot الإعلان عَبر
    /// <c>/listings/{id}/attributes</c> (لَو مَوجود) أَو نَتَجاهَل ⇒
    /// الحُقول تَظهَر فارِغَة.
    /// </summary>
    private async Task LoadAttrsAsync(string categorySlug)
    {
        if (string.IsNullOrEmpty(categorySlug)) return;
        try
        {
            var http = HttpFactory.CreateClient("ejar");
            var env = await http.GetFromJsonAsync<OperationEnvelope<AttributeTemplate>>(
                $"categories/{Uri.EscapeDataString(categorySlug)}/attribute-template");
            _attrTemplate = env?.Data is { Fields.Count: > 0 } t ? t : null;

            // قِيَم الإعلان الحالِيَّة: ListingDetails endpoint يُعيد snapshot
            // كَ List<DynamicAttribute>. نُحَوِّل إلى Dict مُسَطَّح لِلتَحرير.
            var attrsEnv = await http.GetFromJsonAsync<OperationEnvelope<List<DynamicAttribute>>>(
                $"listings/{Id}/attributes");
            if (attrsEnv?.Data is not null)
            {
                foreach (var a in attrsEnv.Data)
                {
                    if (a.Value is not null) _attrValues[a.Key] = a.Value;
                }
            }
        }
        catch
        {
            // لا قالَب أَو لا endpoint قِيَم ⇒ نَتَجاهَل بِصَمت.
        }
    }

    private void ToggleAmenity(string key)
    {
        if (!_amenities.Add(key)) _amenities.Remove(key);
    }

    private async Task Save()
    {
        if (_listing is null) return;
        _saving = true; _error = null;
        try
        {
            var payload = new ListingDraftPayload(
                Title:         _title,
                Description:   _description,
                Price:         _price,
                TimeUnit:      _timeUnit,
                PropertyType:  _listing.PropertyType,
                City:          _city,
                District:      _district,
                Lat:           _listing.Lat,
                Lng:           _listing.Lng,
                BedroomCount:  _bedrooms,
                BathroomCount: _bathrooms,
                AreaSqm:       _area,
                Amenities:     _amenities.ToList(),
                Images:        _listing.Images.ToList(),
                Thumbnail:     _listing.ThumbnailUrl,
                Attributes:    _attrValues.Count > 0 ? _attrValues : null);

            var updated = await Listings.UpdateAsync(Id, payload);
            if (updated is null)
            {
                _error = L[TemplateStrings.CreateListingPublishFailed];
                return;
            }
            Nav.NavigateTo($"/listings/{Id}");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally { _saving = false; }
    }
}
