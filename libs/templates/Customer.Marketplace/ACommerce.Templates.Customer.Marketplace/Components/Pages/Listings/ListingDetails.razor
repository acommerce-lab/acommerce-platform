@page "/listings/{Id}"
@inject ITemplateEngine Engine
@inject IClientAuthState Auth
@inject IFavoritesStore Favorites
@inject IChatStore Chat
@inject IUiPreferences Prefs
@inject NavigationManager Nav
@inject L L
@implements IDisposable

<PageTitle>@(_listing?.Title ?? L[TemplateStrings.AppName])</PageTitle>

<div class="acs-page acs-space-details">
    @if (_loading) { <AcLoadingState /> }
    else if (_listing is null) { <AcEmptyState IconName="info" Message="@(L[TemplateStrings.ListingNotFound])" /> }
    else
    {
        <div class="acs-gallery-wrap">
            @if (_listing.Images is not null && _listing.Images.Count > 0)
            {
                <AcGallery Images="@(_listing.Images.ToList())" />
            }
            else
            {
                <div class="acs-gallery-ph"><AcIcon Name="image" Size="48" /></div>
            }
            <button type="button" class="acs-fav-btn @(_isFav ? "active" : "")" @onclick="ToggleFavorite">
                <AcIcon Name="heart" Filled="@_isFav" Size="20" />
            </button>
        </div>

        <h1 class="acm-wizard-title">@_listing.Title</h1>
        <div style="display:flex; flex-wrap:wrap; gap:8px; align-items:center; margin-bottom:8px;">
            @if (!string.IsNullOrEmpty(_listing.District))
            {
                <span><AcIcon Name="map-pin" Size="14" /> @_listing.District — @_listing.City</span>
            }
            @if (_listing.BedroomCount > 0)
            {
                <span><AcIcon Name="home" Size="14" /> @_listing.BedroomCount @(L[TemplateStrings.ListingBedrooms])</span>
            }
            @if (_listing.IsVerified)
            {
                <AcBadge Variant="success" Text="@(L[TemplateStrings.ListingVerified])" />
            }
        </div>

        <div class="acm-checkout-line">
            <strong style="font-size:20px;">@_listing.Price.ToString("N0") @(L[TemplateStrings.CommonCurrencyShort])</strong>
            <span>/ @_listing.TimeUnitLabel</span>
        </div>

        @if (!string.IsNullOrEmpty(_listing.Description))
        {
            <AcCard>
                <ChildContent>
                    <h3 style="margin-top:0;">@(L[TemplateStrings.ListingDescription])</h3>
                    <p>@_listing.Description</p>
                </ChildContent>
            </AcCard>
        }

        @if (_listing.Amenities is not null && _listing.Amenities.Count > 0)
        {
            <AcCard>
                <ChildContent>
                    <h3 style="margin-top:0;">@(L[TemplateStrings.ListingAmenities])</h3>
                    <div class="acs-amenity-chips">
                        @foreach (var a in _listing.Amenities)
                        {
                            <span class="acs-amenity-chip"><AcIcon Name="check" Size="14" /> @a.Label</span>
                        }
                    </div>
                </ChildContent>
            </AcCard>
        }

        @* الخَصائِص الديناميكِيَّة — snapshots كامِلَة مِن enricher التَطبيق
           (Template+Snapshot). الـ widgets مِن SharedKernel/widgets تَتَوَلّى
           الرَسم: AcAttrGrid لِلتَفاصيل (تَسمِيَة + قِيمَة + أَيقونَة + وَحدَة)،
           AcAttrChipRow لِلبِطاقات. لا labels مَحفورَة هُنا — كُلٌّ مُجَمَّد
           في الـ snapshot وَقت الإنشاء. *@
        @if (_listing.Attributes is not null && _listing.Attributes.Count > 0)
        {
            <AcCard>
                <ChildContent>
                    <h3 style="margin-top:0;">@(L[TemplateStrings.ListingAttributes])</h3>
                    <AcAttrGrid Attributes="@_listing.Attributes" IsArabic="@(Prefs.Language == "ar")" />
                </ChildContent>
            </AcCard>
        }

        <AcCard>
            <ChildContent>
                <h3 style="margin-top:0;">@(L[TemplateStrings.ListingLocation])</h3>
                <AcMapSim Pins="@MapPins" />
            </ChildContent>
        </AcCard>

        @if (_listing.Owner is not null && !IsMine)
        {
            <AcCard>
                <ChildContent>
                    <h3 style="margin-top:0;">@(L[TemplateStrings.ListingOwner])</h3>
                    <div class="acm-details-owner">
                        <span class="acm-details-owner-avatar"><AcIcon Name="user" Size="20" /></span>
                        <div class="acm-details-owner-info">
                            <strong>@_listing.Owner.Name</strong>
                            @if (!string.IsNullOrEmpty(_listing.Owner.MemberSince))
                            {
                                <span>@(L[TemplateStrings.CommonMemberSince]) @_listing.Owner.MemberSince</span>
                            }
                        </div>
                    </div>
                </ChildContent>
            </AcCard>
        }

        @if (!string.IsNullOrEmpty(_chatError))
        {
            <AcAlert Variant="danger" Message="@_chatError" />
        }

        @if (IsMine)
        {
            @* لا زرّ تعديل الآن — التحرير غير مدعوم في الـ backend بعد. نُظهر
               فقط ملصقاً يبيّن للمستخدم أنّ الإعلان له حتى لا يظنّ أنّ الزرّ
               مفقود. زرّ "إدارة" يصل إلى /my-listings للتحكّم العامّ. *@
            <AcCard>
                <ChildContent>
                    <div style="display:flex; align-items:center; gap:8px;">
                        <AcIcon Name="check-circle" Size="20" />
                        <strong>@(L[TemplateStrings.ListingIsYours])</strong>
                    </div>
                </ChildContent>
            </AcCard>
        }
        @* زرّ "إبلاغ عن الإعلان" — AcButton(ghost) widget. AcButton.Icon
           يرسم النصّ خام لذا نستخدم ChildContent مع AcIcon. *@
        @if (!IsMine && Auth.IsAuthenticated && _listing is not null)
        {
            <div class="acs-report-link-wrap">
                <AcButton Variant="ghost" Size="sm" OnClick="@OpenReport">
                    <ChildContent>
                        <AcIcon Name="flag" Size="16" />
                        <span style="margin-inline-start:6px;">@(L[TemplateStrings.ListingReportLink])</span>
                    </ChildContent>
                </AcButton>
            </div>
        }

        @if (_showReport)
        {
            <AcCard>
                <ChildContent>
                    <h3 style="margin-top:0;">@(L[TemplateStrings.ListingReportModalTitle])</h3>
                    <AcField Label="@(L[TemplateStrings.ReportFieldReason])" Required="true">
                        <select class="ac-input" @bind="_reportReason">
                            <option value="">@(L[TemplateStrings.ReportChooseReason])</option>
                            <option value="spam">@(L[TemplateStrings.ReportReasonSpam])</option>
                            <option value="scam">@(L[TemplateStrings.ReportReasonScam])</option>
                            <option value="inappropriate_images">@(L[TemplateStrings.ReportReasonImages])</option>
                            <option value="wrong_info">@(L[TemplateStrings.ReportReasonWrongInfo])</option>
                            <option value="duplicate">@(L[TemplateStrings.ReportReasonDuplicate])</option>
                            <option value="offensive">@(L[TemplateStrings.ReportReasonOffensive])</option>
                            <option value="other">@(L[TemplateStrings.ReportReasonOther])</option>
                        </select>
                    </AcField>
                    <AcField Label="@(L[TemplateStrings.ReportFieldDetails])">
                        <textarea class="ac-input" rows="3" @bind="_reportBody"
                                  @bind:event="oninput" placeholder="@(L[TemplateStrings.ReportDetailsPlaceholder])"></textarea>
                    </AcField>
                    @if (!string.IsNullOrEmpty(_reportAlert))
                    {
                        <AcAlert Variant="@_reportAlertVariant" Message="@_reportAlert" />
                    }
                    <div style="display:flex; gap:8px;">
                        <AcButton Variant="primary" Text="@(L[TemplateStrings.ReportSubmit])" OnClick="@SubmitReport"
                                  Disabled="@(string.IsNullOrEmpty(_reportReason) || _reportSending)" />
                        <AcButton Variant="ghost" Text="@(L[TemplateStrings.CommonCancel])" OnClick="@(() => _showReport = false)" />
                    </div>
                </ChildContent>
            </AcCard>
        }

        <AcStickyActionBar>
            <AcButton Variant="ghost" Text="@(L[TemplateStrings.CommonBack])" OnClick="@GoBack" />
            @if (IsMine)
            {
                <AcButton Variant="outline-primary" Class="ac-btn-block" Text="@(L[TemplateStrings.ListingManageMine])"
                          OnClick="@(() => Nav.NavigateTo("/my-listings"))" />
            }
            else if (Auth.IsAuthenticated)
            {
                <AcButton Variant="primary" Class="ac-btn-block" Text="@(L[TemplateStrings.ListingContact])"
                          OnClick="@StartChat" Disabled="@_startingChat" />
            }
            else
            {
                <AcButton Variant="primary" Class="ac-btn-block" Text="@(L[TemplateStrings.ListingSigninToContact])"
                          OnClick="@(() => Nav.NavigateTo("/login"))" />
            }
        </AcStickyActionBar>
    }
</div>

@code {
    [Parameter] public string Id { get; set; } = "";

    private ListingDetailDto? _listing;
    private bool _loading = true;
    private bool _startingChat;
    private string? _chatError;

    // Report state
    private bool   _showReport;
    private string _reportReason = "";
    private string _reportBody = "";
    private bool   _reportSending;
    private string? _reportAlert;
    private string  _reportAlertVariant = "success";

    private void OpenReport()
    {
        _showReport = true;
        _reportReason = "";
        _reportBody = "";
        _reportAlert = null;
    }

    private async Task SubmitReport()
    {
        if (string.IsNullOrEmpty(_reportReason) || _listing is null) return;
        _reportSending = true;
        _reportAlert = null;
        try
        {
            var env = await Engine.ExecuteAsync<object>(
                ReportsOps.Create(),
                payload: new
                {
                    EntityType = "listing",
                    EntityId   = _listing.Id,
                    Reason     = _reportReason,
                    Body       = string.IsNullOrWhiteSpace(_reportBody) ? null : _reportBody,
                });
            if (env.Operation.Status == "Success")
            {
                _reportAlert = L[TemplateStrings.ReportSuccess];
                _reportAlertVariant = "success";
                _reportReason = "";
                _reportBody = "";
                // أَغلِق النَموذَج بَعد ٣ ثَوانٍ.
                _ = Task.Delay(3000).ContinueWith(_ => InvokeAsync(() => { _showReport = false; StateHasChanged(); }));
            }
            else
            {
                _reportAlert = env.Error?.Message ?? env.Operation.ErrorMessage ?? L[TemplateStrings.ReportFailed];
                _reportAlertVariant = "danger";
            }
        }
        catch (Exception ex)
        {
            _reportAlert = L[TemplateStrings.ListingsReportNetworkErrorPrefix] + ex.Message;
            _reportAlertVariant = "danger";
        }
        finally { _reportSending = false; }
    }
    private bool _isFav => _listing is not null && Favorites.IsFavorited(_listing.Id);
    private bool IsMine => _listing is not null && Auth.IsAuthenticated
                           && _listing.OwnerId == Auth.UserId?.ToString();

    private IReadOnlyList<AcMapSim.MapPin> MapPins =>
        _listing is null ? Array.Empty<AcMapSim.MapPin>()
                         : new[] { new AcMapSim.MapPin("loc", _listing.Title, _listing.Lat, _listing.Lng) };

    protected override void OnInitialized()
    {
        Favorites.Changed += OnChange;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        // OAM-pure: نَدفَع listings.get op (kit-defined) عَبر engine بِـ DTO
        // مَحَلّيّ يَلتَقِط الشَكل الكامِل (Description/Owner/Amenities labels)
        // الذي يَفقِده IListing kit interface.
        var env = await Engine.ExecuteAsync<ListingDetailDto>(ListingsOps.GetById(Id));
        _listing = env.Data;
        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ToggleFavorite()
    {
        if (_listing is null) return;
        if (!Auth.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
        // IFavoritesStore.ToggleAsync = optimistic + OAM-pure (favorite.toggle op
        // مَع realtime_broadcast tag ⇒ composition Realtime تُعلِم الأَجهزة الأُخرى).
        await Favorites.ToggleAsync(_listing.Id);
    }

    private async Task StartChat()
    {
        if (_listing is null) return;
        if (!Auth.IsAuthenticated) { Nav.NavigateTo("/login?returnUrl=" + Uri.EscapeDataString($"/listings/{_listing.Id}")); return; }
        _startingChat = true; _chatError = null;
        try
        {
            // OAM-pure: kit-defined chat.conversation.start op. الـ store يَتَوَلّى
            // wire shape ({ListingId, Text}) داخِليّاً.
            var text = string.Format(L[TemplateStrings.ListingsContactMessageFormat], _listing.Title);
            var convId = await Chat.StartConversationAsync(_listing.Id, text);
            if (!string.IsNullOrEmpty(convId))
            {
                Nav.NavigateTo($"/chat/{convId}");
                return;
            }
            _chatError = L[TemplateStrings.ChatStartFailed];
        }
        finally { _startingChat = false; }
    }

    private void GoBack() => Nav.NavigateTo("/search");

    private void OnChange() => InvokeAsync(StateHasChanged);
    public void Dispose() => Favorites.Changed -= OnChange;

    private sealed record AmenityDto(string Key, string Label);
    private sealed record OwnerDto(string Name, string? MemberSince);
    private sealed record ListingDetailDto(
        string Id, string Title, string Description, decimal Price,
        string TimeUnit, string TimeUnitLabel, string PropertyType, string PropertyTypeLabel,
        string City, string District, double Lat, double Lng,
        List<AmenityDto> Amenities, string OwnerId, OwnerDto? Owner,
        int BedroomCount, int BathroomCount,
        double AreaSqm, bool IsVerified, int ViewsCount, int Status, bool IsFavorite,
        List<string>? Images,
        // Template+Snapshot: نَوع SharedKernel (Label/LabelAr/Icon/Unit/DisplayValue
        // مُجَمَّدَة). AcAttrGrid يَرسُمها مُباشَرَةً.
        List<ACommerce.SharedKernel.Domain.DynamicAttributes.DynamicAttribute>? Attributes);
}
