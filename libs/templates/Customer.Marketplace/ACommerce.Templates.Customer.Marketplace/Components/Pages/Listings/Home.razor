@page "/"
@inject ITemplateStore Store
@inject ITemplateEngine Engine
@inject IUiPreferences Prefs
@inject IMarketplaceHomeStore HomeStore
@inject IDiscoveryStore Discovery
@inject ITaxonomyStore Taxonomy
@inject IClientCultureController Culture
@inject IFavoritesStore Favs
@inject NavigationManager Nav
@inject L L
@implements IDisposable

<PageTitle>@(L[TemplateStrings.AppName])</PageTitle>

@* شَجَرَة الأَنواع عَلى رَأس الـ Home — drill-down هَرَمي قَبل عَرض الإعلانات.
   اختيار leaf يَأخُذ المُستَخدِم إلى /explore فَلتَراً بِالـ slug. الـ widget
   يُخفي نَفسه لَو الـ root غَير مَزروع. *@
@if (_taxonomyHasNodes)
{
    <AcCard Class="acs-home-taxonomy-card">
        <ChildContent>
            <h3 style="margin-top:0;">@(L[TemplateStrings.HomeCategoriesTitle])</h3>
            <AcTaxonomyTreeSelect RootCode="listing_categories"
                                  SelectedChanged="@OnTaxonomyPicked"
                                  IsArabic="true" />
        </ChildContent>
    </AcCard>
}

<AcMarketplaceHomePage Data="_data"
                       Engine="Engine"
                       Store="Store"
                       FavoriteIds="@FavSet"
                       IsArabicCulture="@(Prefs.Language == "ar")"
                       QuickActions="_quickActions"
                       Title="@(L[TemplateStrings.HomeTitle])"
                       Subtitle="@(L[TemplateStrings.HomeSubtitle])"
                       SearchPlaceholder="@(L[TemplateStrings.HomeSearchPlaceholder])"
                       CategoriesTitle="@(L[TemplateStrings.HomeCategoriesTitle])"
                       FeaturedTitle="@(L[TemplateStrings.HomeFeaturedTitle])"
                       NewTitle="@(L[TemplateStrings.HomeNewTitle])"
                       ViewAllLabel="@(L[TemplateStrings.HomeViewAll])"
                       CtaTitle="@(L[TemplateStrings.HomeCtaTitle])"
                       CtaSubtitle="@(L[TemplateStrings.HomeCtaSubtitle])"
                       OnSearch="OnSearch"
                       OnCategorySelected="OnCategorySelected"
                       OnListingOpen="OnListingOpen"
                       OnFavoriteToggled="OnFavoriteToggled"
                       OnCtaClick="OnCtaClick"
                       OnQuickAction="OnQuickAction"
                       OnViewAll="OnViewAll">
    <LogoContent>
        <div class="acm-brand">
            <span class="acm-brand-mark" aria-hidden="true">
                <AcIcon Name="home" Size="24" />
            </span>
            <span class="acm-brand-text">@(L[TemplateStrings.AppName])</span>
            <div class="acm-brand-city">
                <AcCityPicker Cities="@Discovery.Cities" Value="@Prefs.City" ValueChanged="OnCityChanged" />
            </div>
        </div>
    </LogoContent>
</AcMarketplaceHomePage>

@code {
    private MarketplaceHomeDto? _data;
    private bool _taxonomyHasNodes;

    // ‹L› مَحقون كَـ instance، فالحَقل لا يُمكِن أن يَكون static. استَبدَلناه
    // بِـ property بِـ getter لِيُعيد الحساب لُغَويّاً عَلى كُلّ render — رَخيص.
    private IReadOnlyList<QuickActionDto> _quickActions =>
    [
        new("find-place",  L[TemplateStrings.SearchFindPlace],   "search-heart", "primary"),
        new("my-listings", L[TemplateStrings.MyListingsHeading], "building",     "secondary")
    ];

    private ISet<string> FavSet => new HashSet<string>(Favs.Ids);

    protected override void OnInitialized()
    {
        Prefs.OnChanged    += OnChange;
        Discovery.Changed  += OnChange;
        HomeStore.Changed  += OnChange;
        Favs.Changed       += OnChange;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Discovery.LoadCitiesAsync();
            await LoadHome();
        }
    }

    private async Task LoadHome()
    {
        await HomeStore.LoadHomeAsync(string.IsNullOrEmpty(Prefs.City) ? null : Prefs.City);
        _data = MapHomeView(HomeStore.Home);

        // شَجَرَة Taxonomy — تَأتي مَن endpoint مُختَلِف، نُحَمِّلها بِالتَوازي
        // مَع Home view. فارِغَة ⇒ الـ section يَختَفي تِلقائيّاً.
        var tree = await Taxonomy.GetTreeAsync("listing_categories");
        _taxonomyHasNodes = tree.Count > 0;

        await InvokeAsync(StateHasChanged);
    }

    /// <summary>اختيار leaf مَن شَجَرَة الأَنواع عَلى Home ⇒ /explore فَلتَراً
    /// بِالـ slug. الـ tree widget يَنطَوي فَوق kinds بِشَكل افتِراضي + يَنبَسِط
    /// لِيُظهِر الـ leaves عِندَ النَّقر.</summary>
    private void OnTaxonomyPicked(string? slug)
    {
        if (string.IsNullOrEmpty(slug)) return;
        Nav.NavigateTo($"/explore?category={Uri.EscapeDataString(slug)}");
    }

    private static MarketplaceHomeDto MapHomeView(HomeView? v)
    {
        if (v is null) return new MarketplaceHomeDto
        {
            Categories = Array.Empty<CategoryTileDto>(),
            Featured   = Array.Empty<ListingRowDto>(),
            New        = Array.Empty<ListingRowDto>()
        };
        return new MarketplaceHomeDto
        {
            Categories = v.Categories.Select(c =>
                new CategoryTileDto { Id = c.Id, Label = c.Label, Icon = c.Icon ?? "" }).ToList(),
            Featured = v.Featured.Select(ToRow).ToList(),
            New      = v.New.Select(ToRow).ToList()
        };
    }

    // البحث المُمتلِك نصّاً → صفحة الاقتراحات (recent + popular). البحث
    // الفارغ يفتحها للتصفّح. الاقتراحات بدورها تنقل لـ /explore عند
    // اختيار قائمة (انظر Search.razor).
    private void OnSearch(string? q)
    {
        if (string.IsNullOrWhiteSpace(q)) { Nav.NavigateTo("/search"); return; }
        Nav.NavigateTo($"/search?q={Uri.EscapeDataString(q)}");
    }

    // اختيار فئة من Home → نتائج /explore فلتر بالفئة (لا /search لأنّها
    // اقتراحات لا نتائج). هذا أيضاً يضمن أنّ الفلاتر القديمة لا تتراكم.
    private void OnCategorySelected(CategoryTileDto c)
        => Nav.NavigateTo($"/explore?category={Uri.EscapeDataString(c.Id)}");

    private void OnListingOpen(ListingRowDto l)
        => Nav.NavigateTo($"/listings/{Uri.EscapeDataString(l.Id)}");

    private void OnCtaClick() => Nav.NavigateTo("/create-listing");

    private void OnQuickAction(QuickActionDto a) => Nav.NavigateTo(a.Id switch
    {
        "find-place"  => "/search",
        "my-listings" => "/my-listings",
        _             => "/"
    });

    // "مشاهدة الكل" من قسم المميَّزة/الجديدة على Home → /explore بفلاتر
    // نظيفة (طلب صاحب المصلحة).
    private void OnViewAll(string section) => Nav.NavigateTo("/explore?reset=1");

    private async Task OnCityChanged(string city)
    {
        await Culture.SetCityAsync(city);
        await LoadHome();
    }

    private async Task OnFavoriteToggled((ListingRowDto Listing, bool On) e)
        => await Favs.ToggleAsync(e.Listing.Id);

    private static ListingRowDto ToRow(HomeListingCard l) => new()
    {
        Id = l.Id, Title = l.Title,
        Price = l.Price, Currency = "YER", TimeUnit = l.TimeUnitLabel ?? l.TimeUnit ?? "",
        City = l.City ?? "", District = l.District ?? "", Status = 1, IsFeatured = l.IsVerified,
        ThumbnailUrl = l.FirstImage,
        Capacity = l.BedroomCount == 0 ? null : l.BedroomCount,
        Attributes = l.Attributes?.ToList()
    };

    private void OnChange() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Prefs.OnChanged    -= OnChange;
        Discovery.Changed  -= OnChange;
        HomeStore.Changed  -= OnChange;
        Favs.Changed       -= OnChange;
    }
}
