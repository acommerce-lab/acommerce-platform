@page "/create-listing"
@attribute [Authorize]
@using System.Net.Http.Json
@using ACommerce.OperationEngine.Wire
@using ACommerce.SharedKernel.Domain.DynamicAttributes
@using ACommerce.Kits.Taxonomy.Frontend.Customer.Stores
@inject ITemplateEngine Engine
@inject IUiPreferences Prefs
@inject IListingDraft Draft
@inject IListingsStore Listings
@inject IDiscoveryStore Discovery
@inject ITaxonomyStore Taxonomy
@inject IListingPublishGate PublishGate
@inject IListingCreatePrecheck Precheck
@inject NavigationManager Nav
@inject IHttpClientFactory HttpFactory
@inject IJSRuntime JS
@inject L L
@inject INumeralNormalizer Numerals

<PageTitle>@(L[TemplateStrings.ListingCreateTitle]) — @(L[TemplateStrings.AppName])</PageTitle>

<div class="acs-page acs-create-listing">
    <h1 class="acm-wizard-title">@(L[TemplateStrings.ListingCreateTitle])</h1>

    @if (_precheckLoading)
    {
        <AcLoadingState />
    }
    else if (_precheck is { Allowed: false })
    {
        @* الحَجب يَأتي مِن IListingCreatePrecheck. Default يُمَرِّر — تَطبيقات
           الاشتِراك تَعرِض شاشَة "لا اشتِراك" + رابِط /plans، تَطبيقات الدَفع
           لِلإعلان الواحِد لا تَحجِب هُنا (تَفحَص عِند publish عَبر Gate). *@
        <AcCard>
            <ChildContent>
                <div style="text-align:center; padding:16px 0;">
                    <AcIcon Name="package" Size="48" />
                    @if (!string.IsNullOrEmpty(_precheck.Title))
                    {
                        <h3 style="margin:12px 0 4px;">@_precheck.Title</h3>
                    }
                    @if (!string.IsNullOrEmpty(_precheck.Message))
                    {
                        <p style="color:var(--ac-text-muted); margin:0 0 16px;">@_precheck.Message</p>
                    }
                    @if (!string.IsNullOrEmpty(_precheck.ActionUrl))
                    {
                        <AcButton Variant="primary" Class="ac-btn-block"
                                  Text="@(_precheck.ActionLabel ?? L[TemplateStrings.PlansBrowseAction])"
                                  OnClick="@(() => Nav.NavigateTo(_precheck.ActionUrl!))" />
                    }
                    <AcButton Variant="ghost" Class="ac-btn-block" Text="@(L[TemplateStrings.CommonBack])"
                              OnClick="@(() => Nav.NavigateTo("/me"))" />
                </div>
            </ChildContent>
        </AcCard>
    }
    else
    {
    <div class="acs-step-indicator">
        <span class="@(_step >= 1 ? "active" : "")">@(L[TemplateStrings.CreatelistingStep1Category])</span>
        <span class="@(_step >= 2 ? "active" : "")">@(L[TemplateStrings.CreatelistingStep2Details])</span>
        <span class="@(_step >= 3 ? "active" : "")">@(L[TemplateStrings.CreatelistingStep3Images])</span>
        <span class="@(_step >= 4 ? "active" : "")">@(L[TemplateStrings.CreatelistingStep4Location])</span>
    </div>

    @if (_step == 1)
    {
        <AcCard>
            <ChildContent>
                <h3 style="margin-top:0;">@(L[TemplateStrings.CreateListingCategoryHeading])</h3>
                @* AcTaxonomyTreeSelect — شَجَرَة هَرَمِيَّة لِفِئات الإعلانات
                   (root="listing_categories"). الاختيار يَضَع slug في
                   Draft.CategoryId. لَو الـ taxonomy غَير مَزروع (تَطبيقات لَم
                   تَدعَم الكيت بَعد)، نَسقُط لِلشَبَكَة المُسَطَّحَة القَديمَة. *@
                @if (_taxonomyLoaded && _taxonomyHasNodes)
                {
                    <AcTaxonomyTreeSelect RootCode="listing_categories"
                                          Selected="@Draft.CategoryId"
                                          SelectedChanged="@OnCategorySelected"
                                          IsArabic="true" />
                }
                else
                {
                    <div class="acm-home-grid">
                        @foreach (var c in Discovery.Categories)
                        {
                            var cat = c;
                            <button type="button" class="acs-cat-pick @(Draft.CategoryId == cat.Id ? "active" : "")"
                                    @onclick="@(() => { Draft.CategoryId = cat.Id; Draft.NotifyChanged(); })">
                                <AcIcon Name="@cat.Icon" Size="24" />
                                <span>@cat.Label</span>
                            </button>
                        }
                    </div>
                }
                <div style="margin-top:24px;">
                    <AcButton Variant="primary" Class="ac-btn-block" Text="@(L[TemplateStrings.CommonNext])"
                              OnClick="@GoToStep2"
                              Disabled="@(string.IsNullOrEmpty(Draft.CategoryId))" />
                </div>
            </ChildContent>
        </AcCard>
    }
    else if (_step == 2)
    {
        <AcCard>
            <ChildContent>
                <h3 style="margin-top:0;">@(L[TemplateStrings.CreateListingDetailsHeading])</h3>
                <AcField Label="@(L[TemplateStrings.ListingCreateFieldTitle])" Required="true">
                    <AcInput Value="@Draft.Title"
                             ValueChanged="@(v => { Draft.Title = v ?? string.Empty; Draft.NotifyChanged(); })"
                             Placeholder="@(L[TemplateStrings.CreateListingTitlePlaceholder])" />
                </AcField>
                <AcField Label="@(L[TemplateStrings.ListingCreateFieldDescription])" Required="true">
                    <textarea class="ac-input" rows="4"
                              value="@Draft.Description"
                              @oninput="@(e => { Draft.Description = e.Value?.ToString() ?? string.Empty; Draft.NotifyChanged(); })"
                              placeholder="@(L[TemplateStrings.CreateListingBodyPlaceholder])"></textarea>
                </AcField>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                    <AcField Label="@(L[TemplateStrings.ListingCreateFieldPrice])" Required="true">
                        <AcInput Type="number" Value="@Draft.Price.ToString()"
                                 ValueChanged="@(v => { Draft.Price = decimal.TryParse(Numerals.ToLatin(v), out var p) ? p : 0; Draft.NotifyChanged(); })" />
                    </AcField>
                    <AcField Label="@(L[TemplateStrings.ListingCreateFieldTimeUnit])">
                        <select class="ac-input" value="@Draft.TimeUnit"
                                @onchange="@(e => { Draft.TimeUnit = e.Value?.ToString() ?? "monthly"; Draft.NotifyChanged(); })">
                            <option value="monthly">@(L[TemplateStrings.TimeUnitMonthly])</option>
                            <option value="yearly">@(L[TemplateStrings.TimeUnitYearly])</option>
                            <option value="daily">@(L[TemplateStrings.TimeUnitDaily])</option>
                            <option value="hourly">@(L[TemplateStrings.TimeUnitHourly])</option>
                        </select>
                    </AcField>
                </div>
                @* لا حُقول ثابِتَة لِـ Bedrooms/Bathrooms/Area — أَصبَحَت
                   سِمات ديناميكِيَّة per-kind: الـ Realty يُظهِرها، الـ
                   Vehicle يُظهِر Make/Model/Year بَدَلاً، إلخ. الـ wizard لا
                   يَفرِض حُقولاً عَقارِيَّة عَلى إعلانات الباصات. *@
                @if (_attrTemplate is { Fields.Count: > 0 })
                {
                    <AcAttrEditor Template="_attrTemplate"
                                  Values="_attrValues"
                                  ValuesChanged="@(v => _attrValues = v)"
                                  IsArabic="true" />
                }

                @* قِسم "المَرافِق والخَصائِص" الثابِت أُزيل: المَرافِق
                   الآن سَمَة ديناميكِيَّة تَأتي مَن قالَب الفِئَة (إن
                   عُرِّفَت). لا داعي لِقِسم مُكَرَّر فارِغ هُنا.

                   <c>margin-top:24px</c> لِفَصل أَزرار التَنَقُّل عَن
                   آخِر حَقل في النَموذَج (كانَت مُلتَصِقَة). *@
                <div style="display:flex; gap:8px; margin-top:24px;">
                    <AcButton Variant="ghost" Text="@(L[TemplateStrings.CommonBack])" OnClick="@(() => _step = 1)" />
                    <AcButton Variant="primary" Class="ac-btn-block" Text="@(L[TemplateStrings.CommonNext])"
                              OnClick="@(() => _step = 3)"
                              Disabled="@(string.IsNullOrWhiteSpace(Draft.Title) || Draft.Price <= 0)" />
                </div>
            </ChildContent>
        </AcCard>
    }
    else if (_step == 3)
    {
        <AcCard>
            <ChildContent>
                <h3 style="margin-top:0;">@(L[TemplateStrings.CreatelistingImagesHeading]) <small style="color:var(--ac-text-muted); font-weight:normal;">@(L[TemplateStrings.CommonOptionalParen])</small></h3>
                <p style="color:var(--ac-text-muted); font-size:13px;">
                    @(string.Format(L[TemplateStrings.CreatelistingImagesHelpFormat], _maxImages))
                </p>

                <label class="ac-btn ac-btn-outline-primary ac-btn-block"
                       style="cursor:pointer; display:inline-flex; align-items:center; gap:8px; justify-content:center;">
                    <AcIcon Name="camera" Size="16" />
                    <span>@(_compressing ? L[TemplateStrings.CreatelistingCompressing] : L[TemplateStrings.CreatelistingAddImages])</span>
                    <InputFile OnChange="OnImagesPicked" accept="image/*" multiple style="display:none;"
                               disabled="@_compressing" />
                </label>

                @if (_images.Count > 0)
                {
                    <div class="acs-images-grid">
                        @for (int i = 0; i < _images.Count; i++)
                        {
                            var idx = i;
                            var img = _images[idx];
                            <div class="acs-image-thumb @(idx == 0 ? "main" : "")">
                                <img src="@img.ThumbUrl" alt="img-@idx" />
                                @if (idx == 0) { <span class="acs-image-badge">@(L[TemplateStrings.CreateListingMainBadge])</span> }
                                <div class="acs-image-actions">
                                    @if (idx > 0)
                                    {
                                        <button type="button" title="@(L[TemplateStrings.CreateListingMakeMain])" @onclick="@(() => MakeMain(idx))">
                                            <AcIcon Name="star" Size="14" />
                                        </button>
                                    }
                                    <button type="button" title="@(L[TemplateStrings.CommonDelete])" @onclick="@(() => Remove(idx))">
                                        <AcIcon Name="x" Size="14" />
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                    <small style="color:var(--ac-text-muted);">@_images.Count / @_maxImages</small>
                }

                @if (!string.IsNullOrEmpty(_imgError))
                {
                    <AcAlert Variant="danger" Message="@_imgError" />
                }

                <div style="display:flex; gap:8px; margin-top:24px;">
                    <AcButton Variant="ghost" Text="@(L[TemplateStrings.CommonBack])" OnClick="@(() => _step = 2)" />
                    @* الصور أصبحت اختياريّة — زرّ L[TemplateStrings.CommonNext] مفتوح حتّى بصفر صور.
                       نُظهر "تخطّي الصور" عند صفر للوضوح. *@
                    <AcButton Variant="primary" Class="ac-btn-block"
                              Text="@(_images.Count == 0 ? L[TemplateStrings.CreatelistingContinueNoImages] : L[TemplateStrings.CommonNext])"
                              OnClick="@(() => _step = 4)" Disabled="@_compressing" />
                </div>
            </ChildContent>
        </AcCard>
    }
    else
    {
        <AcCard>
            <ChildContent>
                <h3 style="margin-top:0;">@(L[TemplateStrings.CreateListingLocationHeading])</h3>
                <AcField Label="@(L[TemplateStrings.ListingCreateFieldCity])" Required="true">
                    <select class="ac-input" value="@Draft.City"
                            @onchange="@(e => { Draft.City = e.Value?.ToString() ?? string.Empty; Draft.NotifyChanged(); })">
                        @foreach (var c in Discovery.Cities) { <option value="@c">@c</option> }
                    </select>
                </AcField>
                <AcField Label="@(L[TemplateStrings.ListingCreateFieldDistrict])" Required="true">
                    <AcInput Value="@Draft.District"
                             ValueChanged="@(v => { Draft.District = v ?? string.Empty; Draft.NotifyChanged(); })"
                             Placeholder="@(L[TemplateStrings.CreateListingDistrictPlaceholder])" />
                </AcField>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                    <AcField Label="@(L[TemplateStrings.CreateListingLatOptional])">
                        <AcInput Type="number" Value="@_lat.ToString("0.######")"
                                 ValueChanged="@(v => _lat = double.TryParse(Numerals.ToLatin(v), out var d) ? d : _lat)" />
                    </AcField>
                    <AcField Label="@(L[TemplateStrings.CreateListingLngOptional])">
                        <AcInput Type="number" Value="@_lng.ToString("0.######")"
                                 ValueChanged="@(v => _lng = double.TryParse(Numerals.ToLatin(v), out var d) ? d : _lng)" />
                    </AcField>
                </div>
                <AcMapSim Pins="@MapPins" />

                @if (!string.IsNullOrEmpty(_publishError))
                {
                    <AcAlert Variant="danger" Message="@_publishError" />
                }
                <div style="display:flex; gap:8px; margin-top:24px;">
                    <AcButton Variant="ghost" Text="@(L[TemplateStrings.CommonBack])" OnClick="@(() => _step = 3)" Disabled="@_publishing" />
                    <AcButton Variant="primary" Class="ac-btn-block"
                              Text="@(_publishing ? L[TemplateStrings.CreatelistingPublishing] : L[TemplateStrings.CreatelistingPublish])"
                              OnClick="@Publish"
                              Disabled="@(_publishing || string.IsNullOrWhiteSpace(Draft.City) || string.IsNullOrWhiteSpace(Draft.District))" />
                </div>
            </ChildContent>
        </AcCard>
    }
    } @* end: _precheck.Allowed *@
</div>

@code {
    private int _step = 1;
    private int _maxImages = 10;
    private bool _publishing;
    private bool _compressing;
    private bool _precheckLoading = true;
    private CreatePrecheckResult? _precheck;
    private string? _publishError;
    private string? _imgError;
    private List<PickedImage> _images = new();
    private double _lat = 24.7136;
    private double _lng = 46.6753;
    // قالَب سِمات ديناميكِيَّة + قِيَمها لِلفِئَة المُختارَة. يُعاد تَحميله
    // عِندَ تَغيير الفِئَة. الـ Key = اسم property/code في backend.
    private AttributeTemplate? _attrTemplate;
    private Dictionary<string, object?> _attrValues = new();
    private string? _attrLoadedForCategory;

    // Taxonomy state: شَجَرَة "listing_categories" تَحُلّ مَحَلّ Discovery.Categories
    // المُسَطَّحَة. لَو الـ root لَيس مَزروعاً في DB، نَسقُط لِلشَبَكَة الافتِراضِيَّة.
    private bool _taxonomyLoaded;
    private bool _taxonomyHasNodes;

    private IReadOnlyList<AcMapSim.MapPin> MapPins =>
        new[] { new AcMapSim.MapPin("loc", L[TemplateStrings.CreatelistingLocationPinLabel], _lat, _lng) };

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (!first) return;
        if (string.IsNullOrEmpty(Draft.City)) Draft.City = Prefs.City;

        // البَوّابَة الأَوَّلِيَّة — Default يُمَرِّر، تَطبيق الاشتِراك يُعيد
        // <c>Allowed=false</c> + رابِط /plans. V3 (دَفع لِكُلّ إعلان) يُمَرِّر
        // ⇒ الفورم يَفتَح، الدَفع يَجري عِند Publish عَبر IListingPublishGate.
        _precheck = await Precheck.CanCreateAsync();
        _precheckLoading = false;
        if (_precheck is not { Allowed: true })
        {
            await InvokeAsync(StateHasChanged);
            return;
        }
        // Discovery store يَجلب categories + amenities + cities بِالتَوازي.
        await Discovery.LoadAsync();

        // حَمِّل شَجَرَة Taxonomy إن كانَت مَزروعَة لِهذا التَطبيق.
        var tree = await Taxonomy.GetTreeAsync("listing_categories");
        _taxonomyHasNodes = tree.Count > 0;
        _taxonomyLoaded   = true;

        await InvokeAsync(StateHasChanged);
    }

    /// <summary>callback مَن AcTaxonomyTreeSelect عِندَ اختيار عُقدَة. الـ
    /// slug يُحفَظ في Draft.CategoryId — نَفس الحَقل الَّذي كانَت تَستَخدِمه
    /// الشَبَكَة القَديمَة ⇒ صِفر تَغيير في باقي الـ wizard / publish payload.</summary>
    private void OnCategorySelected(string? slug)
    {
        Draft.CategoryId = slug;
        Draft.NotifyChanged();
    }

    /// <summary>
    /// يَجلب قالَب السِمات لِلفِئَة المُختارَة. يُستَدعى مِن SetterOf
    /// step ⇒ step 2 (Next مِن خِطوَة الفِئَة) لِيَكون مَوجوداً قَبل عَرض
    /// القِسم. <c>_attrLoadedForCategory</c> يَمنَع إعادَة الجَلب لِنَفس
    /// الفِئَة. الفَشَل ⇒ القِسم يَختَفي بِلا أَخطاء.
    /// </summary>
    private async Task EnsureAttrTemplateAsync()
    {
        var slug = Draft.CategoryId;
        if (string.IsNullOrEmpty(slug) || slug == _attrLoadedForCategory) return;
        _attrLoadedForCategory = slug;
        _attrTemplate = null;
        _attrValues = new();
        try
        {
            var http = HttpFactory.CreateClient("ejar");
            var env = await http.GetFromJsonAsync<OperationEnvelope<AttributeTemplate>>(
                $"categories/{Uri.EscapeDataString(slug)}/attribute-template");
            _attrTemplate = env?.Data is { Fields.Count: > 0 } t ? t : null;
        }
        catch
        {
            _attrTemplate = null;
        }
    }

    private async Task GoToStep2()
    {
        await EnsureAttrTemplateAsync();
        _step = 2;
    }


    private async Task OnImagesPicked(InputFileChangeEventArgs e)
    {
        _imgError = null;
        _compressing = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            foreach (var f in e.GetMultipleFiles(_maxImages - _images.Count))
            {
                if (f.Size > 20 * 1024 * 1024)
                {
                    _imgError = string.Format(L[TemplateStrings.CreatelistingImageTooBigFormat], f.Name);
                    continue;
                }
                try
                {
                    using var s  = f.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024);
                    using var ms = new MemoryStream();
                    await s.CopyToAsync(ms);
                    var rawDataUrl = $"data:{f.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";

                    var bundle = await JS.InvokeAsync<CompressResult?>(
                        "ejarImg.compressDataUrl", rawDataUrl, 1600, 0.8, 400, 0.7);
                    if (bundle is null || string.IsNullOrEmpty(bundle.Full))
                    {
                        _imgError = string.Format(L[TemplateStrings.CreatelistingImageProcessingFailedFormat], f.Name);
                        continue;
                    }
                    _images.Add(new PickedImage(bundle.Full, bundle.Thumb ?? bundle.Full, f.Name));
                }
                catch (Exception ex)
                {
                    _imgError = string.Format(L[TemplateStrings.CreatelistingImageErrorFormat], f.Name, ex.Message);
                }
            }
        }
        finally { _compressing = false; await InvokeAsync(StateHasChanged); }
    }

    private void MakeMain(int idx)
    {
        if (idx <= 0 || idx >= _images.Count) return;
        var img = _images[idx];
        _images.RemoveAt(idx);
        _images.Insert(0, img);
    }

    private void Remove(int idx) => _images.RemoveAt(idx);

    // مِفتاح حِمايَة مَن التَّكرار — يُوَلَّد مَرَّة عِندَ أَوَّل ضَغطَة
    // Publish ويُعاد استِخدامه عَلى كُلّ retry لِنَفس الـ wizard. الـ
    // server-side <c>IdempotencyInterceptor</c> يَرفُض الإعلان الثاني
    // بِنَفس المِفتاح ⇒ لا تَكرار حَتّى لَو رَدّ الشَبَكَة ضاعَ.
    private Guid? _idempotencyKey;

    private async Task Publish()
    {
        _publishing = true; _publishError = null;
        _idempotencyKey ??= Guid.NewGuid();
        try
        {
            // ① البَوّابَة قَبل أَيّ بِناء payload. الـ default يُمَرِّر؛
            // تَطبيقات تَفرِض دَفع/اشتِراك تُسَجِّل impl يَرُدّ Scope يَحقُن
            // headers عَلى الـ HttpClient طَوال CreateAsync.
            var auth = await PublishGate.AuthorizeAsync();
            if (!auth.Allowed)
            {
                _publishError = auth.Error ?? L[TemplateStrings.CreateListingPublishFailed];
                return;
            }

            var payload = new ListingDraftPayload(
                Title:         Draft.Title ?? "",
                Description:   Draft.Description,
                Price:         Draft.Price,
                TimeUnit:      Draft.TimeUnit,
                PropertyType:  Draft.CategoryId,
                City:          Draft.City ?? "",
                District:      Draft.District,
                Lat:           _lat,
                Lng:           _lng,
                BedroomCount:  0,                    // attr.BedroomCount عَبر Attributes
                BathroomCount: 0,
                AreaSqm:       0,
                Amenities:     Draft.Amenities.ToList(),
                Images:        _images.Select(i => i.DataUrl).ToList(),
                Thumbnail:     _images.Count > 0 ? _images[0].ThumbUrl : null,
                Attributes:    _attrValues.Count > 0 ? _attrValues : null,
                IdempotencyKey: _idempotencyKey);

            using var _scope = auth.Scope;   // null-safe: لا scope ⇒ لا تَنظيف
            var created = await Listings.CreateAsync(payload);
            if (created is not null)
            {
                Draft.Clear();
                _images.Clear();
                _idempotencyKey = null;   // النَّجاح ⇒ لا حاجَة لِلمِفتاح
                Nav.NavigateTo("/my-listings");
                return;
            }

            _publishError = L[TemplateStrings.CreateListingPublishFailed];
        }
        catch (Exception ex) { _publishError = string.Format(L[TemplateStrings.CreatelistingPublishErrorFormat], ex.Message); }
        finally { _publishing = false; }
    }

    // SubDto / SubscriptionsOps استُبدِلَت بِـ IListingCreatePrecheck.
    // تَطبيق اشتِراك يُسَجِّل impl يَستَدعي subscription.get_active ويَفحَص
    // <c>ImagesPerListing</c> + يُعيد ActionUrl = "/plans" إذا لا اشتِراك.

    private sealed record PickedImage(string DataUrl, string ThumbUrl, string Name);
    private sealed record CompressResult(string Full, string? Thumb);
}
