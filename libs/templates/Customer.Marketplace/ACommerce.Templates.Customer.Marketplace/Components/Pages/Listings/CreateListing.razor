@page "/create-listing"
@attribute [Authorize]
@inject ITemplateEngine Engine
@inject IUiPreferences Prefs
@inject IListingDraft Draft
@inject IListingsStore Listings
@inject IDiscoveryStore Discovery
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject L L
@inject INumeralNormalizer Numerals

<PageTitle>@(L["listing.create.title"]) — @(L["app.name"])</PageTitle>

<div class="acs-page acs-create-listing">
    <h1 class="acm-wizard-title">@(L["listing.create.title"])</h1>

    @if (_subLoading)
    {
        <AcLoadingState />
    }
    else if (_subscription is null)
    {
        @* لا يوجد اشتراك نشط — أَوقِف عِند البَوّابَة بَدَل السَماح بِإكمال
           المُعالِج ثُمّ رَفض الخادم. *@
        <AcCard>
            <ChildContent>
                <div style="text-align:center; padding:16px 0;">
                    <AcIcon Name="package" Size="48" />
                    <h3 style="margin:12px 0 4px;">يلزمك اشتراك نشط لنشر الإعلانات</h3>
                    <p style="color:var(--ac-text-muted); margin:0 0 16px;">
                        اختر باقة تناسبك وابدأ بنشر إعلاناتك خلال دقائق.
                    </p>
                    <AcButton Variant="primary" Class="ac-btn-block" Text="تصفّح الباقات"
                              OnClick="@(() => Nav.NavigateTo("/plans"))" />
                    <AcButton Variant="ghost" Class="ac-btn-block" Text="رجوع"
                              OnClick="@(() => Nav.NavigateTo("/me"))" />
                </div>
            </ChildContent>
        </AcCard>
    }
    else
    {
    <div class="acs-step-indicator">
        <span class="@(_step >= 1 ? "active" : "")">١ الفئة</span>
        <span class="@(_step >= 2 ? "active" : "")">٢ التفاصيل</span>
        <span class="@(_step >= 3 ? "active" : "")">٣ الصور</span>
        <span class="@(_step >= 4 ? "active" : "")">٤ الموقع</span>
    </div>

    @if (_step == 1)
    {
        <AcCard>
            <ChildContent>
                <h3 style="margin-top:0;">اختر فئة الإعلان</h3>
                <div class="acm-home-grid">
                    @foreach (var c in Discovery.Categories)
                    {
                        var cat = c;
                        <button type="button" class="acs-cat-pick @(Draft.CategoryId == cat.Id ? "active" : "")"
                                @onclick="@(() => { Draft.CategoryId = cat.Id; Draft.NotifyChanged(); })">
                            <AcIcon Name="@cat.Icon" Size="24" />
                            <span>@cat.Label</span>
                        </button>
                    }
                </div>
                <AcButton Variant="primary" Class="ac-btn-block" Text="التالي"
                          OnClick="@(() => _step = 2)"
                          Disabled="@(string.IsNullOrEmpty(Draft.CategoryId))" />
            </ChildContent>
        </AcCard>
    }
    else if (_step == 2)
    {
        <AcCard>
            <ChildContent>
                <h3 style="margin-top:0;">تفاصيل الإعلان</h3>
                <AcField Label="@(L["listing.create.field.title"])" Required="true">
                    <AcInput Value="@Draft.Title"
                             ValueChanged="@(v => { Draft.Title = v ?? string.Empty; Draft.NotifyChanged(); })"
                             Placeholder="مثلاً: شقة مفروشة في حيّ السبل" />
                </AcField>
                <AcField Label="@(L["listing.create.field.description"])" Required="true">
                    <textarea class="ac-input" rows="4"
                              value="@Draft.Description"
                              @oninput="@(e => { Draft.Description = e.Value?.ToString() ?? string.Empty; Draft.NotifyChanged(); })"
                              placeholder="اذكر المساحة، الغرف، الميزات…"></textarea>
                </AcField>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                    <AcField Label="@(L["listing.create.field.price"])" Required="true">
                        <AcInput Type="number" Value="@Draft.Price.ToString()"
                                 ValueChanged="@(v => { Draft.Price = decimal.TryParse(Numerals.ToLatin(v), out var p) ? p : 0; Draft.NotifyChanged(); })" />
                    </AcField>
                    <AcField Label="@(L["listing.create.field.timeUnit"])">
                        <select class="ac-input" value="@Draft.TimeUnit"
                                @onchange="@(e => { Draft.TimeUnit = e.Value?.ToString() ?? "monthly"; Draft.NotifyChanged(); })">
                            <option value="monthly">شهري</option>
                            <option value="yearly">سنوي</option>
                            <option value="daily">يومي</option>
                            <option value="hourly">بالساعة</option>
                        </select>
                    </AcField>
                </div>
                <AcField Label="عدد الغرف (اختياريّ)">
                    <AcInput Type="number" Value="@Draft.BedroomCount.ToString()"
                             ValueChanged="@(v => { Draft.BedroomCount = int.TryParse(Numerals.ToLatin(v), out var n) ? n : 0; Draft.NotifyChanged(); })" />
                </AcField>

                <AcField Label="@(L["listing.amenities"])">
                    <div class="acs-amenity-chips">
                        @foreach (var a in Discovery.Amenities)
                        {
                            var am = a;
                            <AcFilterChip Label="@am.Label"
                                          Active="@Draft.Amenities.Contains(am.Key)"
                                          OnClick="@(() => ToggleAmenity(am.Key))" />
                        }
                    </div>
                </AcField>
                <div style="display:flex; gap:8px;">
                    <AcButton Variant="ghost" Text="رجوع" OnClick="@(() => _step = 1)" />
                    <AcButton Variant="primary" Class="ac-btn-block" Text="التالي"
                              OnClick="@(() => _step = 3)"
                              Disabled="@(string.IsNullOrWhiteSpace(Draft.Title) || Draft.Price <= 0)" />
                </div>
            </ChildContent>
        </AcCard>
    }
    else if (_step == 3)
    {
        <AcCard>
            <ChildContent>
                <h3 style="margin-top:0;">صور الإعلان <small style="color:var(--ac-text-muted); font-weight:normal;">(اختياريّ)</small></h3>
                <p style="color:var(--ac-text-muted); font-size:13px;">
                    حتّى @_maxImages صور • نضغط الصور تلقائياً قبل الرفع لتقليل الباندويث • الصورة الأولى هي الرئيسيّة.
                </p>

                <label class="ac-btn ac-btn-outline-primary ac-btn-block"
                       style="cursor:pointer; display:inline-flex; align-items:center; gap:8px; justify-content:center;">
                    <AcIcon Name="camera" Size="16" />
                    <span>@(_compressing ? "جارٍ الضغط…" : "إضافة صور")</span>
                    <InputFile OnChange="OnImagesPicked" accept="image/*" multiple style="display:none;"
                               disabled="@_compressing" />
                </label>

                @if (_images.Count > 0)
                {
                    <div class="acs-images-grid">
                        @for (int i = 0; i < _images.Count; i++)
                        {
                            var idx = i;
                            var img = _images[idx];
                            <div class="acs-image-thumb @(idx == 0 ? "main" : "")">
                                <img src="@img.ThumbUrl" alt="img-@idx" />
                                @if (idx == 0) { <span class="acs-image-badge">رئيسيّة</span> }
                                <div class="acs-image-actions">
                                    @if (idx > 0)
                                    {
                                        <button type="button" title="اجعلها رئيسيّة" @onclick="@(() => MakeMain(idx))">
                                            <AcIcon Name="star" Size="14" />
                                        </button>
                                    }
                                    <button type="button" title="حذف" @onclick="@(() => Remove(idx))">
                                        <AcIcon Name="x" Size="14" />
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                    <small style="color:var(--ac-text-muted);">@_images.Count / @_maxImages</small>
                }

                @if (!string.IsNullOrEmpty(_imgError))
                {
                    <AcAlert Variant="danger" Message="@_imgError" />
                }

                <div style="display:flex; gap:8px; margin-top:12px;">
                    <AcButton Variant="ghost" Text="رجوع" OnClick="@(() => _step = 2)" />
                    @* الصور أصبحت اختياريّة — زرّ "التالي" مفتوح حتّى بصفر صور.
                       نُظهر "تخطّي الصور" عند صفر للوضوح. *@
                    <AcButton Variant="primary" Class="ac-btn-block"
                              Text="@(_images.Count == 0 ? "متابعة بدون صور" : "التالي")"
                              OnClick="@(() => _step = 4)" Disabled="@_compressing" />
                </div>
            </ChildContent>
        </AcCard>
    }
    else
    {
        <AcCard>
            <ChildContent>
                <h3 style="margin-top:0;">موقع الإعلان</h3>
                <AcField Label="@(L["listing.create.field.city"])" Required="true">
                    <select class="ac-input" value="@Draft.City"
                            @onchange="@(e => { Draft.City = e.Value?.ToString() ?? string.Empty; Draft.NotifyChanged(); })">
                        @foreach (var c in Discovery.Cities) { <option value="@c">@c</option> }
                    </select>
                </AcField>
                <AcField Label="@(L["listing.create.field.district"])" Required="true">
                    <AcInput Value="@Draft.District"
                             ValueChanged="@(v => { Draft.District = v ?? string.Empty; Draft.NotifyChanged(); })"
                             Placeholder="مثلاً: السبل" />
                </AcField>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                    <AcField Label="خط العرض (اختياريّ)">
                        <AcInput Type="number" Value="@_lat.ToString("0.######")"
                                 ValueChanged="@(v => _lat = double.TryParse(Numerals.ToLatin(v), out var d) ? d : _lat)" />
                    </AcField>
                    <AcField Label="خط الطول (اختياريّ)">
                        <AcInput Type="number" Value="@_lng.ToString("0.######")"
                                 ValueChanged="@(v => _lng = double.TryParse(Numerals.ToLatin(v), out var d) ? d : _lng)" />
                    </AcField>
                </div>
                <AcMapSim Pins="@MapPins" />

                @if (!string.IsNullOrEmpty(_publishError))
                {
                    <AcAlert Variant="danger" Message="@_publishError" />
                }
                <div style="display:flex; gap:8px; margin-top:12px;">
                    <AcButton Variant="ghost" Text="رجوع" OnClick="@(() => _step = 3)" Disabled="@_publishing" />
                    <AcButton Variant="primary" Class="ac-btn-block"
                              Text="@(_publishing ? "جارٍ النشر…" : "نشر الإعلان")"
                              OnClick="@Publish"
                              Disabled="@(_publishing || string.IsNullOrWhiteSpace(Draft.City) || string.IsNullOrWhiteSpace(Draft.District))" />
                </div>
            </ChildContent>
        </AcCard>
    }
    } @* end: _subscription is not null *@
</div>

@code {
    private int _step = 1;
    private int _maxImages = 10;
    private bool _publishing;
    private bool _compressing;
    private bool _subLoading = true;
    private SubDto? _subscription;
    private string? _publishError;
    private string? _imgError;
    private List<PickedImage> _images = new();
    private double _lat = 24.7136;
    private double _lng = 46.6753;

    private IReadOnlyList<AcMapSim.MapPin> MapPins =>
        new[] { new AcMapSim.MapPin("loc", "الموقع", _lat, _lng) };

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (!first) return;
        if (string.IsNullOrEmpty(Draft.City)) Draft.City = Prefs.City;

        // افحَص الاشتِراك أَوَّلاً — نَدفَع subscription.get_active op كَ
        // OAM-pure (kit-defined). الـ DTO المَحَلّيّ يَلتَقِط الـ wire shape
        // الكامِل (PlanId/Status/ImagesPerListing) لأنّ ISubscriptionsStore.Active
        // يَكشِف ISubscription فَقَط (Guid Id فَقَط).
        var sub = await Engine.ExecuteAsync<SubDto>(SubscriptionsOps.GetActive());
        _subscription = sub.Data;
        _subLoading = false;
        if (_subscription is null)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }
        _maxImages = _subscription.ImagesPerListing > 0 ? _subscription.ImagesPerListing : 10;

        // Discovery store يَجلب categories + amenities + cities بِالتَوازي.
        await Discovery.LoadAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void ToggleAmenity(string key)
    {
        if (Draft.Amenities.Contains(key)) Draft.Amenities.Remove(key);
        else                                Draft.Amenities.Add(key);
        Draft.NotifyChanged();
    }

    private async Task OnImagesPicked(InputFileChangeEventArgs e)
    {
        _imgError = null;
        _compressing = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            foreach (var f in e.GetMultipleFiles(_maxImages - _images.Count))
            {
                if (f.Size > 20 * 1024 * 1024)
                {
                    _imgError = $"الصورة {f.Name} أكبر من 20MB — تُخطَّى.";
                    continue;
                }
                try
                {
                    using var s  = f.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024);
                    using var ms = new MemoryStream();
                    await s.CopyToAsync(ms);
                    var rawDataUrl = $"data:{f.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";

                    var bundle = await JS.InvokeAsync<CompressResult?>(
                        "ejarImg.compressDataUrl", rawDataUrl, 1600, 0.8, 400, 0.7);
                    if (bundle is null || string.IsNullOrEmpty(bundle.Full))
                    {
                        _imgError = $"تعذّر معالجة {f.Name} — تخطّيها.";
                        continue;
                    }
                    _images.Add(new PickedImage(bundle.Full, bundle.Thumb ?? bundle.Full, f.Name));
                }
                catch (Exception ex)
                {
                    _imgError = $"خطأ في معالجة {f.Name}: {ex.Message}";
                }
            }
        }
        finally { _compressing = false; await InvokeAsync(StateHasChanged); }
    }

    private void MakeMain(int idx)
    {
        if (idx <= 0 || idx >= _images.Count) return;
        var img = _images[idx];
        _images.RemoveAt(idx);
        _images.Insert(0, img);
    }

    private void Remove(int idx) => _images.RemoveAt(idx);

    private async Task Publish()
    {
        _publishing = true; _publishError = null;
        try
        {
            // OAM-pure: نَبني ListingDraftPayload (DTO الكِيت) ونَدفَع
            // listings.create op عَبر IListingsStore. الـ store يَتَوَلّى
            // بِناء payload + dispatch + تَحديث Mine list.
            var payload = new ListingDraftPayload(
                Title:         Draft.Title ?? "",
                Description:   Draft.Description,
                Price:         Draft.Price,
                TimeUnit:      Draft.TimeUnit,
                PropertyType:  Draft.CategoryId,
                City:          Draft.City ?? "",
                District:      Draft.District,
                Lat:           _lat,
                Lng:           _lng,
                BedroomCount:  Draft.BedroomCount,
                BathroomCount: 0,
                AreaSqm:       0,
                Amenities:     Draft.Amenities.ToList(),
                Images:        _images.Select(i => i.DataUrl).ToList(),
                Thumbnail:     _images.Count > 0 ? _images[0].ThumbUrl : null);

            var created = await Listings.CreateAsync(payload);
            if (created is not null)
            {
                Draft.Clear();
                _images.Clear();
                Nav.NavigateTo("/my-listings");
                return;
            }

            _publishError = "فشل نشر الإعلان — تحقّق من اشتراكك ثمّ حاول مجدّداً.";
        }
        catch (Exception ex) { _publishError = $"حدث خطأ أثناء النشر: {ex.Message}"; }
        finally { _publishing = false; }
    }

    private sealed record SubDto(string Id, string PlanId, string PlanName, string Status,
        DateTime StartDate, DateTime EndDate, int DaysRemaining,
        int ListingsUsed, int ListingsLimit, int FeaturedUsed, int FeaturedLimit, int ImagesPerListing);

    private sealed record PickedImage(string DataUrl, string ThumbUrl, string Name);
    private sealed record CompressResult(string Full, string? Thumb);
}
