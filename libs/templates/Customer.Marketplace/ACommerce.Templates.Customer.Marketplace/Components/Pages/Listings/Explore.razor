@page "/explore"
@inject ITemplateStore Store
@inject ITemplateEngine Engine
@inject IUiPreferences Prefs
@inject IClientAuthState Auth
@inject IMarketplaceHomeStore Home
@inject IDiscoveryStore Discovery
@inject IFavoritesStore Favs
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>استكشف</PageTitle>

@if (HasAnyFilter)
{
    <div class="acs-clear-filters-bar" style="display:flex; justify-content:flex-end; padding:8px 12px;">
        <AcButton Variant="ghost" Text="إلغاء كلّ الفلاتر" OnClick="@ClearAllFilters" />
    </div>
}

<AcListingExplorePage Title="استكشف"
                      Data="_listings"
                      MapListings="_mapListings"
                      Categories="_categories"
                      Cities="@Discovery.Cities"
                      SelectedCategoryId="@_categoryId"
                      Sort="@_sort"
                      View="@_view"
                      Filters="_filters"
                      FavoriteIds="@FavSet"
                      Engine="Engine"
                      Store="Store"
                      OnCategorySelected="OnCategorySelected"
                      OnSortChanged="OnSortChanged"
                      OnViewChanged="OnViewChanged"
                      OnListingOpen="OnListingOpen"
                      OnFavoriteToggled="OnFavoriteToggled"
                      OnFiltersApplied="OnFiltersApplied" />

@code {
    private IReadOnlyList<ListingRowDto>? _listings;
    private IReadOnlyList<AcListingMapPage.MapListingDto> _mapListings = Array.Empty<AcListingMapPage.MapListingDto>();
    private IReadOnlyList<CategoryTileDto> _categories = Array.Empty<CategoryTileDto>();
    private string? _categoryId;
    private string? _query;
    private string _sort = "newest";
    private string _view = "list";
    // يُهيَّأ في OnInitialized بمدينة الصفحة الرئيسيّة (طلب صاحب المصلحة).
    // C# لا يسمح لمُهيِّئ الحقل باستدعاء method instance، فنبدأ فاضياً.
    private AcListingExplorePage.ExploreFilters _filters = new(null, null, null, null, 0, 0);

    private ISet<string> FavSet => new HashSet<string>(Favs.Ids);

    /// <summary>
    /// قيم الفلتر الافتراضيّة: المدينة = اختيار المستخدم على الصفحة الرئيسيّة
    /// (Prefs.City) — طلب صاحب المصلحة. لو غيّرها المستخدم في الـ modal،
    /// تُحفَظ في _filters مباشرةً. زرّ "إلغاء كلّ الفلاتر" يعيدنا لهذه القيم.
    /// </summary>
    private AcListingExplorePage.ExploreFilters NewDefaultFilters() =>
        new(string.IsNullOrWhiteSpace(Prefs.City) ? null : Prefs.City,
            null, null, null, 0, 0);

    protected override void OnInitialized()
    {
        Prefs.OnChanged   += OnChange;
        Discovery.Changed += OnChange;
        Home.Changed      += OnChange;
        Favs.Changed      += OnChange;
        var qs = System.Web.HttpUtility.ParseQueryString(new Uri(Nav.Uri).Query);

        // ?reset=1 من Home.OnViewAll → حالة نظيفة. مدينة الصفحة الرئيسيّة
        // تبقى الافتراضيّة.
        if (qs.Get("reset") == "1")
        {
            _categoryId = null;
            _query      = null;
            _sort       = "newest";
            _filters    = NewDefaultFilters();
            Nav.NavigateTo("/explore", replace: true);
            return;
        }

        _categoryId = qs.Get("category");
        _query      = qs.Get("q");

        var urlCity     = qs.Get("city");
        var urlDistrict = qs.Get("district");
        var defaultCity = string.IsNullOrWhiteSpace(Prefs.City) ? null : Prefs.City;
        var initialCity = !string.IsNullOrEmpty(urlCity) ? urlCity : defaultCity;
        _filters = _filters with { City = initialCity, District = urlDistrict };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadCategoriesAsync();
            await LoadListingsAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadCategoriesAsync()
    {
        await System.Threading.Tasks.Task.WhenAll(
            Discovery.LoadCategoriesAsync(),
            Discovery.LoadCitiesAsync());
        _categories = Discovery.Categories.Select(c =>
            new CategoryTileDto { Id = c.Id, Label = c.Label, Icon = c.Icon ?? "" }).ToList();
    }

    private async Task LoadListingsAsync()
    {
        var filter = new ExploreFilter(
            City: _filters.City,
            PropertyType: _categoryId,
            Query: _query,
            MinBedrooms: _filters.Capacity > 0 ? _filters.Capacity : 0,
            MinPrice: _filters.MinPrice,
            MaxPrice: _filters.MaxPrice,
            Sort: _sort);
        await Home.ApplyExploreAsync(filter);
        _listings = Home.Explore.Select(ToRow).ToList();
        _mapListings = Home.Explore
            .Where(i => i.Lat is not null && i.Lng is not null && i.Lat != 0 && i.Lng != 0)
            .Select(i => new AcListingMapPage.MapListingDto(ToRow(i), i.Lat ?? 0, i.Lng ?? 0))
            .ToList();
    }

    private bool HasAnyFilter =>
        !string.IsNullOrEmpty(_categoryId)
        || !string.IsNullOrEmpty(_query)
        || !string.IsNullOrEmpty(_filters.District)
        || (!string.IsNullOrEmpty(_filters.City) && _filters.City != Prefs.City)
        || _filters.MinPrice.HasValue || _filters.MaxPrice.HasValue
        || _filters.Capacity > 0 || _filters.MinRating > 0
        || _sort != "newest";

    private async Task OnCategorySelected(string? id)
    {
        _categoryId = id;
        if (id is null)
        {
            _query   = null;
            _sort    = "newest";
            _filters = NewDefaultFilters();
        }
        await ApplyAndSyncAsync();
    }

    private async Task OnSortChanged    (string? sort)  { _sort = sort ?? "newest";  await ApplyAndSyncAsync(); }
    private void      OnViewChanged     (string? view)  { _view = view ?? "list";    StateHasChanged(); }
    private async Task OnFiltersApplied (AcListingExplorePage.ExploreFilters f) { _filters = f; await ApplyAndSyncAsync(); }

    private async Task ClearAllFilters()
    {
        _categoryId = null;
        _query      = null;
        _sort       = "newest";
        _filters    = NewDefaultFilters();
        await ApplyAndSyncAsync();
    }

    private async Task ApplyAndSyncAsync()
    {
        var qs = BuildQueryString();
        Nav.NavigateTo($"/explore{qs}", replace: true);
        await LoadListingsAsync();
        StateHasChanged();
    }

    private string BuildQueryString()
    {
        var parts = new List<string>();
        if (!string.IsNullOrEmpty(_categoryId))      parts.Add($"category={Uri.EscapeDataString(_categoryId)}");
        if (!string.IsNullOrEmpty(_query))           parts.Add($"q={Uri.EscapeDataString(_query)}");
        if (!string.IsNullOrEmpty(_filters.City))    parts.Add($"city={Uri.EscapeDataString(_filters.City)}");
        if (!string.IsNullOrEmpty(_filters.District)) parts.Add($"district={Uri.EscapeDataString(_filters.District)}");
        if (_filters.MinPrice.HasValue)              parts.Add($"priceMin={_filters.MinPrice}");
        if (_filters.MaxPrice.HasValue)              parts.Add($"priceMax={_filters.MaxPrice}");
        if (_filters.Capacity > 0)                   parts.Add($"capacity={_filters.Capacity}");
        if (_filters.MinRating > 0)                  parts.Add($"minRating={_filters.MinRating}");
        parts.Add($"sort={_sort}");
        return "?" + string.Join("&", parts);
    }

    private void OnListingOpen(ListingRowDto l) => Nav.NavigateTo($"/listings/{Uri.EscapeDataString(l.Id)}");

    private Task OnFavoriteToggled((ListingRowDto Listing, bool On) e)
    {
        if (!Auth.IsAuthenticated) { Nav.NavigateTo("/login"); return Task.CompletedTask; }
        return Favs.ToggleAsync(e.Listing.Id);
    }

    private static ListingRowDto ToRow(HomeListingCard l) => new()
    {
        Id = l.Id, Title = l.Title,
        Price = l.Price, Currency = "YER", TimeUnit = l.TimeUnitLabel ?? l.TimeUnit ?? "",
        City = l.City ?? "", District = l.District ?? "", Status = 1, IsFeatured = l.IsVerified,
        ThumbnailUrl = l.FirstImage,
        Capacity = l.BedroomCount == 0 ? null : l.BedroomCount
    };

    private void OnChange() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Prefs.OnChanged   -= OnChange;
        Discovery.Changed -= OnChange;
        Home.Changed      -= OnChange;
        Favs.Changed      -= OnChange;
    }
}
