@page "/login"
@inject IAuthLoginUi LoginUi
@inject L L

@*
    /login — dispatcher فَقَط. يَكتَشِف IAuthLoginUi مِن DI ويَرسُمه. الـ
    Template نَفسه يُسَجِّل PhoneOtpLoginContent كَافتِراضي (في
    EjarCustomerUiExtensions); تَطبيقات تُفَضِّل nafath أَو غَيره تُسَجِّل
    IAuthLoginUi مَخصوص قَبل أَن يُبنى الـ host.

    لا مَنطِق هُنا — كُلّ شَيء داخِل المُكَوِّن المُختار. ReturnUrl يُمَرَّر
    إلَيه عَبر [Parameter].
*@

<PageTitle>@(L[TemplateStrings.AuthLoginTitle]) — @(L[TemplateStrings.AppName])</PageTitle>

<div class="acs-page acs-auth-page">
    <DynamicComponent Type="@LoginUi.ComponentType" Parameters="@_params" />
</div>

@code {
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }

    private Dictionary<string, object?> _params = new();

    protected override void OnParametersSet()
    {
        _params = new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl };
    }
}
