@page "/login"
@using Ejar.Customer.UI.Services
@inject IAuthStore Auth
@inject IClientAuthState AuthState
@inject IUiPreferences Prefs
@inject IFavoritesStore Favorites
@inject FirebasePushService FirebasePush
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject L L
@inject INumeralNormalizer Numerals
@implements IDisposable

@code {
    /// <summary>
    /// مسار العودة بعد نجاح الدخول. يضعه RedirectToLogin عندما يحاول مستخدم
    /// غير مصادَق فتح صفحة محميّة، فيُعاد إلى تلك الصفحة بدل الرئيسيّة.
    /// </summary>
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }
}

<PageTitle>@(L[TemplateStrings.AuthLoginTitle]) — @(L[TemplateStrings.AppName])</PageTitle>

<div class="acs-page acs-auth-page">
    <div class="acs-nafath-head">
        <AcIcon Name="smartphone" Size="48" />
        <h1 class="acm-wizard-title">@(L[TemplateStrings.AppName])</h1>
    </div>

    <AcCard>
        <ChildContent>
            @if (!_otpSent)
            {
                @* @onkeydown على الـ wrapper يلتقط Enter من داخل أيّ <input>
                   وُلِد عبر AcInput ويُشغّل زرّ الإرسال — كان زرّ Enter لا يفعل
                   شيئاً، فيضطرّ المستخدم لرفع يده من المفاتيح والنقر بالماوس. *@
                <div @onkeydown="OnPhoneKey">
                    <AcField Label="@(L[TemplateStrings.AuthPhone])" Required="true">
                        <AcInput Type="tel" Value="@_phone" id="login-phone"
                                 ValueChanged="@(v => _phone = (Numerals.ToLatin(v) ?? string.Empty).Trim())"
                                 Placeholder="7XXXXXXXX" />
                    </AcField>

                    @if (_error is not null)
                    {
                        <div class="ac-alert ac-alert-danger mt-2">@_error</div>
                    }

                    <AcButton Variant="primary" Size="lg" Class="ac-btn-block mt-2"
                              Text="@(L[TemplateStrings.AuthSendOtp])"
                              OnClick="@RequestOtp"
                              Disabled="@(_phone.Length < 9 || Auth.IsBusy)" />
                </div>
            }
            else
            {
                <div @onkeydown="OnCodeKey">
                    <p class="acs-nafath-instruction">@(L[TemplateStrings.AuthOtpHint])</p>

                    <AcField Label="@(L[TemplateStrings.AuthOtp])" Required="true">
                        <AcInput Type="tel" Value="@_code" id="login-code"
                                 ValueChanged="@(v => _code = (Numerals.ToLatin(v) ?? string.Empty).Trim())"
                                 Placeholder="123456" />
                    </AcField>

                    <div class="acs-nafath-state acs-nafath-state--ok mt-2">
                        <AcIcon Name="check-circle" Size="16" />
                        <span>@(L[TemplateStrings.AuthOtpDemo])</span>
                    </div>

                    @if (_error is not null)
                    {
                        <div class="ac-alert ac-alert-danger mt-2">@_error</div>
                    }

                    <AcButton Variant="primary" Size="lg" Class="ac-btn-block mt-2"
                              Text="@(L[TemplateStrings.AuthVerify])"
                              OnClick="@VerifyOtp"
                              Disabled="@(_code.Length < 6 || Auth.IsBusy)" />
                    <AcButton Variant="ghost" Class="ac-btn-block"
                              Text="@(L[TemplateStrings.LoginChangePhone])" OnClick="@Reset" />
                </div>
            }
        </ChildContent>
    </AcCard>
</div>

@code {
    private string _phone = "";
    private string _code = "";
    private bool _otpSent;
    private string? _error;

    protected override void OnInitialized()
    {
        Auth.Changed += OnChange;
        Prefs.HideChrome = true;
        if (Auth.IsAuthenticated) Nav.NavigateTo("/");
    }

    private bool _wasOtpSent;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) Prefs.HideChrome = true;

        // ركّز على الحقل المفتوح: phone في الخطوة الأولى، code بعد إرسال OTP.
        // _wasOtpSent يضمن أن نُركّز على code فور الانتقال للخطوة الثانية مرّة
        // واحدة فقط (لا في كل re-render).
        var target = !_otpSent ? "#login-phone" : "#login-code";
        if (firstRender || _wasOtpSent != _otpSent)
        {
            _wasOtpSent = _otpSent;
            try { await JS.InvokeVoidAsync("ejarChatUi.focus", target); } catch { }
        }
    }

    private async Task RequestOtp()
    {
        _error = null;
        await Auth.RequestOtpAsync(_phone);
        if (Auth.LastError is null) _otpSent = true;
        else _error = Auth.LastError ?? L[TemplateStrings.LoginSendOtpFailed];
        await InvokeAsync(StateHasChanged);
    }

    private async Task VerifyOtp()
    {
        _error = null;
        await Auth.VerifyOtpAsync(_phone, _code);
        if (Auth.IsAuthenticated)
        {
            // IClientAuthState.Phone يَتَكَفَّل بِه DefaultAuthStore داخِل verify
            // — لا تَلمَسه يَدويّاً هُنا.
            Prefs.HideChrome = false;
            // اسحب المفضّلات من الخادم بعد تسجيل دخول جديد — حتّى تظهر مفضّلات
            // الجهاز الآخر فوراً دون الحاجة للذهاب إلى صفحة المفضّلة.
            try { await Favorites.LoadAsync(); } catch { /* غير قاتل */ }
            // سجِّل رمز الجهاز في FCM ليصلَ المستخدم إشعارات الدفع حتى وهو
            // خارج التبويب/التطبيق. آمن للاستدعاء حتى عند غياب الإعداد.
            try { await FirebasePush.TryRegisterAsync(); } catch { /* غير قاتل */ }
            // ارجع إلى المسار الذي حاول المستخدم زيارته قبل أن يُطلَب منه الدخول
            // (يضعه RedirectToLogin في returnUrl). الافتراضيّ: الرئيسيّة.
            var dest = !string.IsNullOrWhiteSpace(ReturnUrl) ? ReturnUrl! : "/";
            Nav.NavigateTo(dest);
        }
        else
        {
            _error = Auth.LastError ?? L[TemplateStrings.LoginInvalidOtp];
        }
        await InvokeAsync(StateHasChanged);
    }

    private void Reset() { _otpSent = false; _code = ""; _error = null; }

    private async Task OnPhoneKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !Auth.IsBusy && _phone.Length >= 9)
            await RequestOtp();
    }

    private async Task OnCodeKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !Auth.IsBusy && _code.Length >= 6)
            await VerifyOtp();
    }

    private void OnChange() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Auth.Changed -= OnChange;
        Prefs.HideChrome = false;
    }
}
