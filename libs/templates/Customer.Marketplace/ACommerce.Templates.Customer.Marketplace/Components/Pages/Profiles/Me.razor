@page "/me"
@attribute [Authorize]
@using ACommerce.Kits.Versions.Templates
@inject IClientAuthState AuthState
@inject IAuthStore Auth
@inject IProfileStore Profiles
@inject IListingsStore Listings
@inject ISupportStore Support
@inject IFavoritesStore Favorites
@inject MarketplaceUiOptions UiOptions
@inject NavigationManager Nav
@inject AppVersionInfo AppVersion
@inject L L

<PageTitle>@(L[TemplateStrings.NavProfile]) - @(L[TemplateStrings.AppName])</PageTitle>

<div class="acs-page acs-profile-page">
    <h1 class="acm-wizard-title">@(L[TemplateStrings.NavProfile])</h1>

    <AcCard>
        <ChildContent>
            <div class="acm-details-owner">
                <span class="acm-details-owner-avatar"><AcIcon Name="user" Size="24" /></span>
                <div class="acm-details-owner-info" style="flex:1;">
                    <h3 style="margin:0;">@(Profiles.Current?.FullName ?? AuthState.FullName ?? L[TemplateStrings.CommonGuest])</h3>
                    <span>@(Profiles.Current?.Phone ?? AuthState.Phone ?? "")</span>
                    @if (Profiles.Current is not null)
                    {
                        <small style="display:block; color:var(--ac-text-muted);">
                            @(L[TemplateStrings.CommonMemberSince]) @Profiles.Current.MemberSince.ToString("yyyy-MM-dd") • @Profiles.Current.City
                        </small>
                    }
                </div>
                <AcButton Variant="outline-primary" Text="@(L[TemplateStrings.CommonEdit])" OnClick="@GoEdit" />
            </div>
        </ChildContent>
    </AcCard>

    @if (_statsLoaded)
    {
        <div class="acm-home-grid" style="margin-top:12px;">
            <AcCard><ChildContent>
                <strong>@Listings.Mine.Count</strong>
                <div style="color:var(--ac-text-muted);">@(L[TemplateStrings.MyListingsHeading])</div>
            </ChildContent></AcCard>
            <AcCard><ChildContent>
                <strong>@Favorites.Ids.Count</strong>
                <div style="color:var(--ac-text-muted);">@(L[TemplateStrings.MeStatsFavorites])</div>
            </ChildContent></AcCard>
            <AcCard><ChildContent>
                <strong>@Support.Tickets.Count</strong>
                <div style="color:var(--ac-text-muted);">@(L[TemplateStrings.MeStatsComplaints])</div>
            </ChildContent></AcCard>
        </div>
    }

    @* سِمات البروفايل الإضافِيَّة (مَثَلاً NationalId, BusinessName, Address)
       لَيسَت ضِمن IUserProfile الكَيت. تَطبيقات تُريد عَرضها تُسَجِّل
       implementation لِـ <c>IProfileExtraFieldsProvider</c> (TBD) — حالِيّاً
       غَير مُفَعَّلَة في V3 بِانتِظار تَصميم القِراءَة مِن أَعمِدَة
       Profile الخاصَّة. *@

    <div class="acm-home-actions" style="margin-top:12px;">
        @* "الخطط" + "اشتراكي" يَظهَران فَقَط لِتَطبيقات تُسَجِّل
           Subscriptions kit. UiOptions يُتيح إخفاءهما لِـ V3 الَّذي يَستَخدِم
           الدَفع بِالإعلان الواحِد. *@
        @if (UiOptions.ShowSubscriptionsMenu)
        {
            <AcActionCard Label="@(L[TemplateStrings.PlansHeading])"        IconName="package"     Variant="primary" OnClick="@GoPlans" />
        }
        <AcActionCard Label="@(L[TemplateStrings.MyListingsHeading])"             IconName="building"    Variant="surface" OnClick="@GoMyListings" />
        <AcActionCard Label="@(L[TemplateStrings.NavFavorites])" IconName="heart"      Variant="surface" OnClick="@GoFavorites" />
        @if (UiOptions.ShowSubscriptionsMenu)
        {
            <AcActionCard Label="@(L[TemplateStrings.MeStatsSubscription])"              IconName="check-circle" Variant="surface" OnClick="@GoMySub" />
        }
        <AcActionCard Label="@(L[TemplateStrings.ComplaintTitle])" IconName="alert-circle" Variant="surface" OnClick="@GoComplaints" />
        <AcActionCard Label="@(L[TemplateStrings.NavMessages])"              IconName="message"     Variant="surface" OnClick="@GoChats" />
        <AcActionCard Label="@(L[TemplateStrings.SettingsTitle])" IconName="settings" Variant="surface" OnClick="@GoSettings" />
    </div>

    <div style="margin-top:12px; display:flex; gap:8px;">
        <AcButton Variant="ghost" Text="@(L[TemplateStrings.SettingsSignOut])" OnClick="@SignOut" />
    </div>

    @* رقم الإصدار في القاعدة — مفيد لتشخيص "هل وصل التحديث الجديد؟" *@
    <div style="margin-top:24px; text-align:center; color:var(--ac-text-muted); font-size:12px;">
        @(string.Format(L[TemplateStrings.MeAppVersionFormat], AppVersion.Version, AppVersion.Platform))
    </div>
</div>

@code {
    private bool _statsLoaded;

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (!first) return;
        await System.Threading.Tasks.Task.WhenAll(
            Profiles.LoadAsync(),
            Listings.LoadMineAsync(),
            Support.LoadAsync(),
            Favorites.LoadAsync());
        _statsLoaded = true;
        await InvokeAsync(StateHasChanged);
    }

    private void GoEdit()       => Nav.NavigateTo("/profile/edit");
    private void GoMyListings() => Nav.NavigateTo("/my-listings");
    private void GoFavorites()  => Nav.NavigateTo("/favorites");
    private void GoMySub()      => Nav.NavigateTo("/my-subscription");
    private void GoComplaints() => Nav.NavigateTo("/complaints");
    private void GoChats()      => Nav.NavigateTo("/chats");
    private void GoSettings()   => Nav.NavigateTo("/settings");
    private void GoPlans()      => Nav.NavigateTo("/plans");

    private async Task SignOut()
    {
        // SignOut عَبر IAuthStore.LogoutAsync — يَدفَع auth.sign_out op
        // ويَمسَح IClientAuthState (UserId/Token/...) داخِليّاً. أَيّ مَنطِق
        // إضافيّ (مَسح المُفَضَّلات المَحَلّيّة، …) يَنتَقِل لِـ post-interceptor
        // عَلى auth.sign_out في composition (لاحِقاً)؛ مُؤَقَّتاً نَحفَظ
        // السُلوك القَديم بِالتَنظيف هُنا.
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login");
    }
}
