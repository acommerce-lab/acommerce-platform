<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>ACommerce.Templates.Customer.Marketplace</PackageId>
    <Version>1.0.0</Version>
    <Description>
      قالَب Customer Marketplace — يَجمَع تَجربة "السوق" الكامِلة (browse +
      booking + checkout + listing details) لِنَكهة العميل. يَستهلِك
      libs/templates/Marketplace كَمَصدر لـ Pages مُرَكَّبة (AcListingExplorePage،
      AcListingDetailsPage، AcCreateListingPage…). تَطبيق إيجار V1 سَيَتَبَنّاه
      تَدريجيّاً مَكان @page-routing الحاليّ.

      هذا الـskeleton — سَيُكتَمل في جَلسة لاحقَة بـ AddTemplate_Customer_Marketplace
      كامِلاً بَعد أن يُحَدَّد كَيف تَصير صَفحات Marketplace قابِلة لِلتَّسجيل
      كـ Type references (تَحتاج إِزالة dependencies على V1 services).
    </Description>
    <RazorLangVersion>latest</RazorLangVersion>
  </PropertyGroup>
  <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\host-client\ACommerce.ClientHost\ACommerce.ClientHost.csproj" />
    <ProjectReference Include="..\..\Marketplace\ACommerce.Templates.Marketplace\ACommerce.Templates.Marketplace.csproj" />
    <ProjectReference Include="..\..\Shared\ACommerce.Templates.Shared\ACommerce.Templates.Shared.csproj" />
    <ProjectReference Include="..\..\..\kits\Auth\Frontend\Customer\ACommerce.Kits.Auth.Frontend.Customer.csproj" />
    <ProjectReference Include="..\..\..\kits\Listings\Frontend\Customer\ACommerce.Kits.Listings.Frontend.Customer.csproj" />
    <ProjectReference Include="..\..\..\kits\Chat\Frontend\Customer\ACommerce.Kits.Chat.Frontend.Customer.csproj" />
    <ProjectReference Include="..\..\..\kits\Notifications\Frontend\Customer\ACommerce.Kits.Notifications.Frontend.Customer.csproj" />
    <ProjectReference Include="..\..\..\kits\Profiles\Frontend\Customer\ACommerce.Kits.Profiles.Frontend.Customer.csproj" />
    <ProjectReference Include="..\..\..\kits\Subscriptions\Frontend\Customer\ACommerce.Kits.Subscriptions.Frontend.Customer.csproj" />
    <ProjectReference Include="..\..\..\kits\Support\Frontend\Customer\ACommerce.Kits.Support.Frontend.Customer.csproj" />
    <ProjectReference Include="..\..\..\kits\Favorites\Frontend\Customer\ACommerce.Kits.Favorites.Frontend.Customer.csproj" />
  </ItemGroup>
</Project>
