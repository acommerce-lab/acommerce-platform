<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>ACommerce.Templates.Customer.Marketplace</PackageId>
    <Version>1.0.0</Version>
    <Description>
      قالَب Customer Marketplace — يَرِث Customer.Ledger (نَفس صَفحات Login/
      Listings/Chat/Notifications/Profile/Plans/Support/Favorites) ويُعيد
      الطِلاء عَبر MarketplaceClasses + CSS فقط. هذا تَطبيق فِعليّ لِفِكرة
      "وراثَة القَوالِب": template جَديد يُعيد استِخدام كلّ Razor + Stores
      من template أَب، ويَتَخَصَّص بـ class names + ألوان فقط.
      عِندَما يُريد Marketplace صَفَحة structural مُختَلِفة (مَثلاً
      checkout-wizard يَختَلف عَن Ledger plans)، تُضاف هنا وتَطغى عَلى
      نَظيرَتِها في Ledger عَبر StoreOverrides أو ExtraPages.
    </Description>
  </PropertyGroup>
  <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>
  <ItemGroup>
    <!-- وراثَة من Customer.Ledger — يَنقُل ٢٥+ مَلَفّ Razor + 8 XxxWidgets transitively -->
    <ProjectReference Include="..\..\Customer.Ledger\ACommerce.Templates.Customer.Ledger\ACommerce.Templates.Customer.Ledger.csproj" />
  </ItemGroup>
</Project>
