@using Microsoft.AspNetCore.Components.Authorization
@inject KitPageRegistry Registry
@inject NavigationManager Nav
@inject AuthenticationStateProvider Auth

@*
    HostedApp — يَلفّ Blazor Router مع KitPageRegistry + auth gate +
    DefaultLayout. الـ slots (loading/404) parameters نصّيّة فقط — قابلة
    للـ serialize عبر rendermode boundary.
*@

<CascadingAuthenticationState>
    <Router AppAssembly="@(AppAssembly ?? typeof(HostedApp).Assembly)"
            AdditionalAssemblies="@Registry.PageAssemblies"
            OnNavigateAsync="@HandleNavigation">
        <Found Context="routeData">
            @if (_currentMatch is null)
            {
                <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@DefaultLayout">
                    <Authorizing>
                        <div class="ejar-loading" role="status" aria-busy="true">@LoadingMessage</div>
                    </Authorizing>
                    <NotAuthorized>
                        <_RedirectToLogin Login="@LoginRoute" Return="@_returnUrl" />
                    </NotAuthorized>
                </AuthorizeRouteView>
            }
            else if (_currentMatch.Page.RequiresAuth && !_isAuthenticated)
            {
                <_RedirectToLogin Login="@LoginRoute" Return="@_returnUrl" />
            }
            else
            {
                <LayoutView Layout="@DefaultLayout">
                    <DynamicComponent Type="@_currentMatch.Page.Component"
                                      Parameters="@BuildParameters(_currentMatch)" />
                </LayoutView>
            }
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <LayoutView Layout="@DefaultLayout">
                <div class="ejar-notfound">
                    <h1>@NotFoundTitle</h1>
                    <p>@NotFoundMessage <a href="/">الرئيسيّة</a>.</p>
                </div>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>

@code {
    [Parameter] public System.Reflection.Assembly? AppAssembly { get; set; }
    [Parameter] public Type? DefaultLayout { get; set; }
    [Parameter] public string LoginRoute     { get; set; } = "/login";
    [Parameter] public string LoadingMessage { get; set; } = "جاري التحميل…";
    [Parameter] public string NotFoundTitle  { get; set; } = "الصفحة غير موجودة";
    [Parameter] public string NotFoundMessage{ get; set; } = "تأكّد من الرابط أو عُد للرئيسيّة.";

    private PageMatch? _currentMatch;
    private bool _isAuthenticated;
    private string _returnUrl = "/";

    private async Task HandleNavigation(NavigationContext context)
    {
        var path = "/" + context.Path;
        _currentMatch = Registry.Resolve(path);
        _returnUrl = path;

        if (_currentMatch?.Page.RequiresAuth == true)
        {
            var state = await Auth.GetAuthenticationStateAsync();
            _isAuthenticated = state.User.Identity?.IsAuthenticated == true;
        }
    }

    private static IDictionary<string, object?> BuildParameters(PageMatch match)
    {
        var dict = new Dictionary<string, object?>(match.RouteParameters.Count);
        foreach (var kvp in match.RouteParameters)
            dict[kvp.Key] = kvp.Value;
        return dict;
    }
}
