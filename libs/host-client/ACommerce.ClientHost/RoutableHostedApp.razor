@page "/"
@page "/{*Path:nonfile}"

@*
    RoutableHostedApp — مكوّن جذر routable واحد بـ catch-all.

    حدود rendermode:
      App.razor (SSR) → RoutableHostedApp (Interactive) ← هنا boundary
      Parameters تَعبر الحدّ يَجب أن تَكون JSON-serializable.

    لذلك: لا <c>RenderFragment</c> parameters هنا. الـ slots (loading،
    404…) مُعرَّفة داخل HostedApp بـ defaults نَصّيّة. التطبيقات التي
    تَحتاج loader مخصّصاً تُغيّره عبر CSS أو تُعرّف كاسكاديّة DI.
*@

<HostedApp DefaultLayout="@DefaultLayout"
           LoginRoute="@LoginRoute"
           AppAssembly="@AppAssembly"
           LoadingMessage="@LoadingMessage"
           NotFoundTitle="@NotFoundTitle"
           NotFoundMessage="@NotFoundMessage" />

@code {
    [Parameter] public string? Path { get; set; }

    /// <summary>الـ layout الافتراضيّ — Type قابل للـ serialize عبر boundary.</summary>
    [Parameter] public Type? DefaultLayout { get; set; }

    [Parameter] public string LoginRoute     { get; set; } = "/login";
    [Parameter] public string LoadingMessage { get; set; } = "جاري التحميل…";
    [Parameter] public string NotFoundTitle  { get; set; } = "الصفحة غير موجودة";
    [Parameter] public string NotFoundMessage{ get; set; } = "تأكّد من الرابط أو عُد للرئيسيّة.";

    [Parameter] public System.Reflection.Assembly? AppAssembly { get; set; }
}
